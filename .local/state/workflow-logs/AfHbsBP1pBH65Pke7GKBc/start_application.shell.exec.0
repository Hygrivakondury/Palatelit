6:27:12 PM [express] GET /api/recipes 200 in 51ms :: [{"id":1,"title":"Palak Paneer","description":"Creamy cottage cheese cubes in a vibrant, spiced spinach gravy — the quintessential North Indian comfort food.","ingredients":["500g fresh spinach (palak), washed","250g paneer, cut into cubes","2 medium onions, finely chopped","2 tomatoes, pureed","1 tbsp ginger-garlic paste","2 green chillies, slit","1 tsp cumin seeds","1 tsp garam masala","1 tsp coriander powder","½ tsp turmeric powder","½ tsp red chilli powder","3 tbsp fresh cream","2 tbsp ghee or oil","Salt to taste"],"instructions":["Blanch spinach in boiling water for 2 minutes, then transfer immediately to ice cold water to retain its green colour.","Drain the spinach and blend into a smooth puree. Set aside.","Heat ghee in a kadhai over medium heat. Add cumin seeds and let them splutter.","Add onions and sauté until golden brown, about 8–10 minutes. Add ginger-garlic paste and cook 2 minutes more.","Add tomato puree and all dry spices. Cook until oil separates from the masala, about 8 minutes.","Pour in the spinach puree and mix well. Add ½ cup water and bring to a gentle simmer.","Slide in the paneer cubes and stir gently. Cook for 5 minutes so paneer absorbs the flavours.","Stir in fresh cream and taste for seasoning. Serve hot with roti or steamed rice."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free","Jain Friendly"],"category":"main","imageUrl":"/stock-images/recipe-palak-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Palak%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.654Z"},{"id":2,"title":"Masoor Dal Tadka","description":"Earthy red lentils simmered to silky perfection, finished with a smoky tempering of ghee, cumin and dried chillies.","ingredients":["1 cup masoor dal (red lentils), rinsed","1 medium onion, finely chopped","2 tomatoes, chopped","1 tbsp ginger-garlic paste","1 tsp turmeric powder","1 tsp red chilli powder","1 tsp cumin seeds","2 dry red chillies","1 tsp mustard seeds","8–10 curry leaves","2 tbsp ghee","Fresh coriander for garnish","Salt to taste","Lemon juice to taste"],"instructions":["Pressure cook lentils with turmeric, salt and 3 cups water for 3 whistles until completely soft. Mash lightly.","Heat 1 tbsp oil in a pan. Sauté onions until lightly golden, then add ginger-garlic paste and cook 2 minutes.","Add tomatoes and cook until they break down and oil separates, about 8 minutes.","Stir in red chilli powder and add the cooked lentils. Mix well and simmer 10 minutes adding water for desired consistency.","For tadka: heat ghee in a small pan until smoking. Add cumin seeds, mustard seeds, dry chillies and curry leaves.","Once seeds pop, pour the sizzling tadka over the dal immediately.","Finish with a squeeze of lemon juice and fresh coriander. Serve with rice or roti."],"prepTime":10,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-masoor-dal-tadka.png","youtubeUrl":"https://www.youtube.com/results?search_query=Masoor%20Dal%20Tadka%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.658Z"},{"id":3,"title":"Dosa with Coconut Chutney","description":"Crispy, lacy fermented rice and lentil crepes — South India's most beloved breakfast, served with fresh coconut chutney.","ingredients":["2 cups parboiled rice","½ cup urad dal (split black lentils)","1 tsp fenugreek seeds","Salt to taste","Oil for cooking","For Coconut Chutney:","1 cup fresh grated coconut","2 green chillies","1 small piece ginger","½ cup roasted chana dal","Salt to taste","For chutney tadka:","1 tsp mustard seeds","8 curry leaves","1 dry red chilli","1 tbsp oil"],"instructions":["Soak rice, urad dal and fenugreek seeds in water overnight or for 8 hours. Grind to a smooth batter adding water gradually.","Add salt and ferment the batter in a warm place for 8–12 hours until it rises and turns slightly sour.","For coconut chutney: blend coconut, green chillies, ginger, roasted chana dal and salt with water to a smooth consistency.","Prepare chutney tadka: heat oil, add mustard seeds, curry leaves and dry red chilli. Pour over chutney and mix.","Heat a flat non-stick tawa or iron griddle on medium-high. Rub with a cut onion to season.","Pour a ladleful of batter in the centre and spread in circular motion to a thin crepe.","Drizzle oil around the edges and cook until golden and crisp. Fold and serve hot with coconut chutney."],"prepTime":20,"cookTime":20,"servings":6,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dosa-with-coconut-chutney.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dosa%20with%20Coconut%20Chutney%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.661Z"},{"id":4,"title":"Gujarati Dhokla","description":"Soft, spongy steamed gram flour cakes — light, tangy and irresistibly topped with a sweet-spicy mustard seed tempering.","ingredients":["1 cup besan (gram flour)","¾ cup yogurt, whisked","1 tsp ginger-green chilli paste","1 tsp lemon juice","1 tsp sugar","1 tsp Eno fruit salt (or baking soda)","Salt to taste","For tadka:","2 tbsp oil","1 tsp mustard seeds","8–10 curry leaves","2 green chillies, slit","1 tbsp sugar dissolved in ¼ cup water","Fresh coriander and grated coconut for garnish"],"instructions":["Mix besan, yogurt, ginger-chilli paste, lemon juice, sugar and salt into a smooth batter. Add water if needed — should be of thick pouring consistency.","Grease a steaming thali or cake tin thoroughly with oil.","Add Eno fruit salt to the batter, mix quickly and pour immediately into the greased tin.","Steam on high heat for 15–18 minutes until a toothpick inserted comes out clean.","Allow to cool 5 minutes. Cut into diamond or square shapes.","For tadka: heat oil, add mustard seeds and let them pop. Add curry leaves and green chillies.","Pour the sugar water into the tadka (it will splutter) and then pour over the dhokla immediately.","Garnish with coriander and coconut. Serve with green chutney."],"prepTime":15,"cookTime":20,"servings":6,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-gujarati-dhokla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gujarati%20Dhokla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.665Z"},{"id":5,"title":"Rajma Masala","description":"Hearty kidney beans slow-cooked in a rich, deeply spiced tomato-onion gravy — Punjab's beloved soul food.","ingredients":["1½ cups rajma (kidney beans), soaked overnight","2 large onions, finely chopped","3 large tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","2 bay leaves","1 black cardamom","1 tsp coriander powder","1 tsp cumin powder","½ tsp turmeric","1 tsp red chilli powder","1 tsp garam masala","2 tbsp oil or ghee","Fresh coriander to garnish","Salt to taste"],"instructions":["Pressure cook soaked rajma with salt and 4 cups water for 5–6 whistles until completely tender. Reserve the cooking liquid.","Heat oil in a heavy pan. Add cumin seeds, bay leaves and black cardamom. Let them crackle.","Add onions and cook on medium heat, stirring often, until deep golden brown — about 15 minutes. Don't rush this step.","Add ginger-garlic paste and cook 3 minutes until raw smell disappears.","Add tomato puree and all dry spices except garam masala. Cook on medium heat stirring often until oil separates — about 12 minutes.","Add the boiled rajma along with the cooking liquid. Stir well and bring to a boil.","Simmer on low heat for 20–25 minutes, mashing some beans lightly to thicken the gravy.","Add garam masala and adjust seasoning. Garnish with coriander and serve with steamed basmati rice."],"prepTime":20,"cookTime":60,"servings":5,"cuisineType":"Punjabi","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-rajma-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rajma%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.668Z"},{"id":6,"title":"Aloo Gobi","description":"A rustic, dry-style curry of potatoes and cauliflower stir-fried with whole spices and fresh coriander — simple and deeply satisfying.","ingredients":["3 medium potatoes, cut into cubes","1 small cauliflower, cut into florets","1 large onion, thinly sliced","2 tomatoes, chopped","1 tsp cumin seeds","1 tsp ginger, grated","1 tsp coriander powder","½ tsp turmeric","½ tsp red chilli powder","½ tsp amchur (dry mango powder)","½ tsp garam masala","3 tbsp oil","Fresh coriander to garnish","Salt to taste"],"instructions":["Parboil the potato cubes in salted water for 5 minutes until slightly tender but not fully cooked. Drain and set aside.","Heat oil in a wide pan or kadhai on medium-high heat. Add cumin seeds and let them splutter.","Add onions and cook until lightly golden. Add grated ginger and cook 1 minute.","Add tomatoes and cook until soft. Add all dry spices except garam masala and amchur.","Add cauliflower florets and potatoes. Toss gently to coat with the masala.","Cover and cook on low heat for 15 minutes, stirring occasionally, until both vegetables are tender.","Remove lid, increase heat and cook 3–4 minutes to dry out any moisture.","Sprinkle amchur and garam masala. Toss and garnish generously with fresh coriander."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free","Jain Friendly"],"category":"main","imageUrl":"/stock-images/recipe-aloo-gobi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Gobi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.672Z"},{"id":7,"title":"Sambar","description":"A nourishing South Indian lentil broth packed with vegetables and the complex warmth of freshly ground sambar powder.","ingredients":["½ cup toor dal (split pigeon peas)","1 cup mixed vegetables (drumstick, brinjal, carrot, pumpkin)","1 tomato, quartered","1 small onion, quartered","1 tbsp tamarind paste","2 tbsp sambar powder","½ tsp turmeric","For tadka:","1 tbsp oil","1 tsp mustard seeds","½ tsp cumin seeds","10–12 curry leaves","2 dry red chillies","A pinch of asafoetida (hing)","Salt to taste","Fresh coriander to garnish"],"instructions":["Pressure cook toor dal with turmeric and 2 cups water for 4 whistles until completely mushy. Whisk until smooth.","In a pot, cook the vegetables in 2 cups water with turmeric and salt until just tender.","Add tamarind paste diluted in ½ cup water, sambar powder, tomato and onion to the vegetables. Boil 10 minutes.","Add the cooked dal to the vegetables and mix well. Add water to adjust consistency — sambar should be slightly thin.","Simmer together for 10 minutes until all flavours meld. Taste and adjust salt.","For tadka: heat oil until smoking. Add mustard seeds and wait for them to pop. Add cumin, dry chillies, curry leaves and hing.","Pour the tadka into the sambar immediately. Garnish with coriander and serve hot with idli or rice."],"prepTime":15,"cookTime":40,"servings":5,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sambar.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sambar%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.675Z"},{"id":8,"title":"Chana Masala","description":"Bold, tangy and deeply spiced chickpeas in a thick, complex masala — a Punjabi classic that pairs perfectly with bhature or rice.","ingredients":["1½ cups chickpeas (chana), soaked overnight","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","2 tsp chana masala powder","1 tsp coriander powder","½ tsp red chilli powder","½ tsp turmeric","1 tsp amchur (dry mango powder)","½ tsp garam masala","2 tbsp oil","Fresh coriander, onion rings and lemon wedges to serve","Salt to taste"],"instructions":["Pressure cook chickpeas with salt and a tea bag (for colour) in 3 cups water for 6–7 whistles until completely tender. Discard tea bag.","Heat oil in a heavy pan. Add cumin seeds and let them splutter.","Add onions and cook until deep golden brown — this is key to the flavour, takes about 12–15 minutes.","Add ginger-garlic paste and cook 2 minutes. Add tomato puree and cook until oil separates, about 10 minutes.","Add chana masala powder, coriander powder, red chilli powder and turmeric. Cook 3 minutes more.","Add the cooked chickpeas with some liquid. Mix well and bring to a boil.","Simmer 20 minutes, pressing some chickpeas against the pan to thicken the gravy naturally.","Finish with amchur and garam masala. Serve garnished with coriander, onion rings and a squeeze of lemon."],"prepTime":20,"cookTime":55,"servings":5,"cuisineType":"Punjabi","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-chana-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chana%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.679Z"},{"id":9,"title":"Baingan Bharta","description":"Smoky, fire-roasted aubergine mashed with spices and herbs — a rustic North Indian classic with complex charred depth.","ingredients":["2 large aubergines (baingan)","2 medium onions, finely chopped","2 tomatoes, finely chopped","4 garlic cloves, minced","1 tbsp ginger, grated","2 green chillies, finely chopped","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp red chilli powder","½ tsp garam masala","2 tbsp mustard oil (or any oil)","Fresh coriander to garnish","Salt to taste"],"instructions":["Apply oil all over the aubergines and roast directly on a gas flame, turning with tongs, until skin is completely charred and flesh is completely soft — about 15 minutes.","Place in a bowl covered with foil for 10 minutes. Peel off all charred skin under running water.","Mash the flesh roughly, keeping some texture. Set aside.","Heat oil in a pan. Add cumin seeds. Once they splutter, add onions and cook until golden.","Add garlic, ginger and green chillies. Cook 3 minutes. Add tomatoes and cook until completely broken down.","Add all dry spices and cook the masala 5 minutes more.","Add the mashed aubergine and mix thoroughly. Cook 10 minutes, stirring often.","Adjust salt and finish with garam masala. Garnish abundantly with fresh coriander."],"prepTime":15,"cookTime":40,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-baingan-bharta.png","youtubeUrl":"https://www.youtube.com/results?search_query=Baingan%20Bharta%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.681Z"},{"id":10,"title":"Rasam","description":"A thin, peppery, tamarind-tomato broth — South India's restorative soup that warms from within, served over rice or as a digestif.","ingredients":["2 tbsp toor dal, cooked and mashed","2 tomatoes, blended","1 tbsp tamarind paste","1 tsp black pepper, coarsely crushed","1 tsp cumin powder","1 tsp rasam powder","½ tsp turmeric","3 garlic cloves, crushed","For tadka:","1 tbsp ghee","1 tsp mustard seeds","A pinch of asafoetida","10 curry leaves","2 dry red chillies","Fresh coriander to garnish","Salt to taste"],"instructions":["Combine tomato puree, tamarind paste, turmeric, salt and 2 cups water in a pot. Bring to a boil.","Add crushed garlic, black pepper, cumin powder and rasam powder. Simmer 10 minutes.","Add the cooked, mashed dal and mix well. Thin with more water — rasam should be very watery.","Bring to a full rolling boil for 2 minutes. The top should be frothy. Remove from heat immediately — don't overcook.","For tadka: heat ghee until smoking. Add mustard seeds and wait for them to pop.","Add asafoetida, curry leaves and dry chillies. They will crisp up in seconds.","Pour tadka into the rasam. Garnish with coriander and serve immediately over rice or in small cups as a soup."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-rasam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rasam%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.685Z"},{"id":11,"title":"Paneer Butter Masala","description":"Silky, mildly spiced cottage cheese in a velvety tomato-cashew gravy with butter and cream — India's most celebrated restaurant curry.","ingredients":["300g paneer, cubed","2 onions, roughly chopped","4 tomatoes, roughly chopped","15 cashews, soaked 30 minutes","1 tbsp ginger-garlic paste","2 tsp kashmiri red chilli powder","1 tsp coriander powder","1 tsp sugar","½ tsp garam masala","3 tbsp butter","4 tbsp fresh cream","1 bay leaf","2 green cardamoms","Salt to taste","Dried fenugreek leaves (kasuri methi) to finish"],"instructions":["Heat 1 tbsp butter in a pan. Sauté onions until translucent. Add tomatoes and cashews and cook until tomatoes are soft.","Cool the mixture and blend into a completely smooth, silky puree. Strain through a sieve for extra smoothness.","In the same pan, heat remaining butter. Add bay leaf, cardamom and ginger-garlic paste. Cook 2 minutes.","Add the strained tomato-cashew puree. Add kashmiri chilli powder, coriander powder and sugar.","Cook the gravy on medium heat for 15 minutes until it thickens and butter begins to float on top.","Add paneer cubes and fold gently. Simmer 5 minutes.","Stir in fresh cream and adjust seasoning. Crush dried fenugreek leaves between palms and stir in.","Finish with a swirl of cream and serve with buttery naan or fragrant basmati rice."],"prepTime":20,"cookTime":40,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free","Jain Friendly"],"category":"main","imageUrl":"/stock-images/recipe-paneer-butter-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Butter%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.688Z"},{"id":12,"title":"Khichdi","description":"The ultimate Indian comfort food — a wholesome, golden one-pot of rice and lentils cooked with warming spices. Nourishing and healing.","ingredients":["½ cup basmati rice, rinsed","½ cup moong dal (yellow split lentils), rinsed","1 small onion, finely chopped","1 tomato, chopped","1 tsp ginger, grated","1 tsp cumin seeds","¼ tsp turmeric","¼ tsp asafoetida (hing)","1 tsp ghee","2 tbsp extra ghee to serve","Salt to taste","Fresh coriander to garnish"],"instructions":["Dry roast moong dal in a pan for 3–4 minutes until lightly golden and fragrant. Set aside.","Heat ghee in a pressure cooker. Add cumin seeds and asafoetida. When seeds crackle, add onions.","Sauté onions until translucent. Add ginger and cook 1 minute. Add tomatoes and cook 3 minutes.","Add turmeric and salt. Add the rice and roasted moong dal. Mix to coat with the ghee and spices.","Add 3 cups water. Pressure cook for 3 whistles, then simmer on low for 5 minutes.","Allow pressure to release naturally. Open and mash gently — khichdi should be creamy, not grainy.","Thin with hot water if needed. Serve in bowls, topped generously with ghee and fresh coriander."],"prepTime":10,"cookTime":25,"servings":3,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-khichdi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Khichdi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.691Z"},{"id":13,"title":"Dal Makhani","description":"Velvety whole black lentils and kidney beans slow-cooked overnight with butter and cream — the crown jewel of Punjabi cooking.","ingredients":["1 cup whole urad dal (black lentils)","¼ cup rajma (kidney beans)","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp red chilli powder","1 tsp cumin seeds","¼ tsp turmeric","3 tbsp butter","3 tbsp fresh cream","1 tsp kasuri methi (dried fenugreek leaves)","Salt to taste"],"instructions":["Soak urad dal and rajma overnight in plenty of water. Pressure cook with salt for 8–10 whistles until very soft.","Heat butter in a heavy pan. Add cumin seeds. When they crackle, add onions and cook until deep golden.","Add ginger-garlic paste and cook 3 minutes. Add tomato puree and all dry spices.","Cook the masala until butter separates — about 15 minutes.","Add the cooked lentils and beans with their cooking liquid. Stir well and bring to a boil.","Reduce heat to very low and simmer for at least 30 minutes, stirring occasionally, until thick and creamy.","Crush kasuri methi and add. Stir in cream. Serve with a final knob of butter and naan or rice."],"prepTime":20,"cookTime":90,"servings":6,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dal-makhani.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dal%20Makhani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.574Z"},{"id":14,"title":"Matar Paneer","description":"Fresh garden peas and golden fried paneer in a fragrant, mildly spiced tomato gravy — a wholesome North Indian everyday favourite.","ingredients":["200g paneer, cubed and lightly fried","1 cup fresh or frozen peas","2 onions, blended to paste","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp red chilli powder","½ tsp turmeric","½ tsp garam masala","2 tbsp oil","2 tbsp fresh cream (optional)","Fresh coriander to garnish","Salt to taste"],"instructions":["Lightly fry paneer cubes in oil until golden on all sides. Remove and soak in warm water for 10 minutes.","Heat oil in a pan. Add cumin seeds. When they splutter, add onion paste and cook until light brown.","Add ginger-garlic paste and cook 2 minutes. Add tomato puree and all dry spices except garam masala.","Cook masala until oil separates — about 10 minutes.","Add peas and ½ cup water. Cover and cook until peas are tender — about 8 minutes.","Add the fried paneer cubes. Stir gently and simmer 5 minutes.","Add garam masala and cream. Garnish with coriander and serve with chapati or rice."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-matar-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Matar%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.580Z"},{"id":15,"title":"Shahi Paneer","description":"Mughal-inspired cottage cheese in a rich, aromatic gravy of cashews, cream and whole spices — regal, indulgent and utterly sublime.","ingredients":["300g paneer, cut into cubes","2 onions, roughly chopped","20 cashews, soaked","4 tomatoes, pureed","1 tbsp ginger-garlic paste","2 green cardamoms","4 cloves","1 cinnamon stick","1 tsp kashmiri chilli powder","1 tsp coriander powder","4 tbsp fresh cream","2 tbsp ghee","1 tbsp rose water","Salt to taste"],"instructions":["Sauté onions in ghee until golden. Cool and blend with soaked cashews into a smooth paste.","In the same pan, add whole spices (cardamom, cloves, cinnamon) and ginger-garlic paste. Cook 2 minutes.","Add tomato puree and cook until oil separates, about 10 minutes.","Add the onion-cashew paste. Cook on medium heat, stirring, for 8 minutes until gravy is rich and thick.","Add kashmiri chilli powder, coriander powder and salt. Stir in cream.","Add paneer cubes and gently fold in. Simmer 5 minutes.","Add rose water in the end for a royal fragrance. Serve with naan or basmati pulao."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-shahi-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shahi%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.586Z"},{"id":16,"title":"Malai Kofta","description":"Melt-in-your-mouth fried paneer and potato balls served in a luscious, golden cream and cashew gravy — pure festive indulgence.","ingredients":["200g paneer, grated","2 medium potatoes, boiled and mashed","2 tbsp cornflour","Salt and spices for kofta","Oil for deep frying","2 onions, finely chopped","4 tomatoes, pureed","20 cashews, soaked and blended","1 tsp kashmiri chilli powder","1 tsp coriander powder","4 tbsp cream","2 tbsp butter","Salt to taste"],"instructions":["Mix grated paneer, mashed potato, cornflour, salt and a pinch of spices. Divide into smooth balls.","Deep fry koftas on medium heat until golden and crisp. Drain on paper towels.","Sauté onions in butter until translucent. Add tomato puree and cook until oil separates.","Add the blended cashew paste and stir well. Add kashmiri chilli powder and coriander powder.","Simmer the gravy for 10 minutes until thick and creamy. Stir in cream.","Just before serving, gently place koftas in the gravy. Do not boil or they will break.","Garnish with a drizzle of cream and serve immediately with naan or paratha."],"prepTime":30,"cookTime":40,"servings":5,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-malai-kofta.png","youtubeUrl":"https://www.youtube.com/results?search_query=Malai%20Kofta%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.591Z"},{"id":17,"title":"Kadhai Paneer","description":"Robust, semi-dry cottage cheese with capsicum and onions cooked in a freshly ground kadhai spice blend — bold, aromatic, restaurant-style.","ingredients":["300g paneer, cut into cubes","2 bell peppers (capsicum), cubed","2 onions, cut into chunks","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp coriander seeds, coarsely crushed","1 tsp cumin seeds","½ tsp black pepper, coarsely crushed","2 dry red chillies","1 tsp garam masala","2 tbsp oil","Fresh coriander and ginger julienne to garnish","Salt to taste"],"instructions":["Dry roast coriander seeds, cumin seeds and dry red chillies. Coarsely crush in a mortar.","Heat oil in a kadhai. Add the crushed spice mix and let it bloom for 30 seconds.","Add onion chunks and bell peppers. Stir-fry on high heat for 3–4 minutes keeping them slightly crunchy.","Remove the vegetables and set aside. In the same pan, add ginger-garlic paste and cook 2 minutes.","Add tomato puree and cook until oil separates, about 10 minutes.","Return the vegetables to the pan. Add paneer cubes and toss gently.","Cook 5–7 minutes. Sprinkle garam masala. Garnish with coriander and ginger julienne."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kadhai-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kadhai%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.596Z"},{"id":18,"title":"Aloo Paratha","description":"Golden, flaky whole wheat flatbreads stuffed with a spiced mashed potato filling — Punjab's beloved breakfast, served with white butter.","ingredients":["2 cups whole wheat flour (atta)","Water to knead dough","Salt to taste","4 medium potatoes, boiled and mashed","2 green chillies, finely chopped","1 tsp ginger, grated","1 tsp cumin seeds","1 tsp amchur (dry mango powder)","½ tsp red chilli powder","Fresh coriander, chopped","Ghee or butter for cooking"],"instructions":["Knead whole wheat flour with water and salt into a smooth, soft dough. Cover and rest 30 minutes.","Mix mashed potatoes with green chillies, ginger, cumin, amchur, red chilli powder, coriander and salt.","Divide dough into golf ball-sized portions. Roll one into a small disc.","Place a generous ball of potato filling in the centre. Bring edges together to seal and flatten into a ball.","Gently roll out into a thick paratha, about 20cm diameter, without letting the filling burst out.","Cook on a hot tawa, applying ghee, until both sides are golden with brown spots — about 3 minutes per side.","Serve hot with white butter, yogurt and pickles."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"Punjabi","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-aloo-paratha.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Paratha%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.600Z"},{"id":19,"title":"Chole Bhature","description":"Fiery, tangy Punjabi chickpea curry paired with deep-fried, puffed leavened bread — the iconic street food duo loved across North India.","ingredients":["1½ cups chickpeas, soaked overnight","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","2 tsp chana masala powder","1 tsp coriander powder","1 tsp red chilli powder","2 cups all-purpose flour (for bhature)","½ cup yogurt (for bhature)","1 tsp baking powder","Oil for deep frying","Salt to taste"],"instructions":["Pressure cook chickpeas with salt for 6–7 whistles until very tender.","Sauté onions in oil until deep golden. Add ginger-garlic paste, then tomato puree and all spices.","Add cooked chickpeas with liquid. Simmer 20 minutes until gravy is thick.","For bhature: mix flour, yogurt, baking powder, salt and oil. Knead to a smooth dough. Rest 1 hour.","Divide dough into portions and roll into oval shapes about 5mm thick.","Deep fry in hot oil until golden and puffed on both sides.","Serve chole with bhature, sliced onions and pickles."],"prepTime":30,"cookTime":50,"servings":5,"cuisineType":"Punjabi","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-chole-bhature.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chole%20Bhature%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.603Z"},{"id":20,"title":"Paneer Tikka","description":"Tandoor-kissed cubes of marinated cottage cheese with bell peppers and onions — smoky, spiced and irresistibly charred.","ingredients":["300g paneer, cut into thick cubes","1 red bell pepper, cut into cubes","1 green bell pepper, cut into cubes","1 large onion, cut into chunks","4 tbsp thick yogurt","1 tbsp ginger-garlic paste","1 tsp kashmiri chilli powder","1 tsp chaat masala","½ tsp cumin powder","½ tsp garam masala","2 tbsp oil","Lemon juice to taste","Salt to taste"],"instructions":["Mix yogurt, ginger-garlic paste, kashmiri chilli powder, cumin, garam masala, oil, lemon juice and salt.","Add paneer cubes, bell peppers and onions to the marinade. Toss gently. Marinate for at least 1 hour.","Thread paneer and vegetables alternately onto skewers.","Grill on a very hot grill pan or oven grill at 220°C for 15–20 minutes, turning once, until charred.","Brush with butter during the last 2 minutes for extra flavour.","Sprinkle with chaat masala and a squeeze of lemon.","Serve with mint-coriander chutney and sliced onion rings."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-tikka.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Tikka%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.607Z"},{"id":21,"title":"Jeera Aloo","description":"Simply perfect cumin-spiced potatoes — dry, fragrant and addictive, ready in minutes. A staple side dish for any Indian meal.","ingredients":["4 medium potatoes, boiled and cubed","2 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp amchur (dry mango powder)","½ tsp red chilli powder","2 tbsp oil","Fresh coriander to garnish","Salt to taste"],"instructions":["Boil potatoes until just tender but not mushy. Peel and cut into cubes.","Heat oil in a pan over medium-high heat. Add cumin seeds and let them splutter and brown.","Add the boiled potato cubes. Toss to coat in the cumin oil.","Add coriander powder, turmeric and red chilli powder. Toss well.","Cook on medium-high heat for 5–7 minutes, tossing occasionally, until potatoes get slightly crispy edges.","Sprinkle amchur powder and salt. Toss and taste.","Garnish generously with fresh coriander. Serve with dal and rice or as a side with any main."],"prepTime":5,"cookTime":15,"servings":3,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-jeera-aloo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Jeera%20Aloo%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.611Z"},{"id":22,"title":"Kadhi Pakora","description":"Tangy yogurt-based curry with golden gram flour fritters — a warming, soul-satisfying Punjabi dish best enjoyed with steamed rice.","ingredients":["1 cup yogurt, whisked","4 tbsp besan (gram flour), divided","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander powder","For pakoras: 1 medium onion, sliced","1 green chilli, chopped","Oil for deep frying","For tadka: 2 tbsp ghee","1 tsp cumin seeds","1 tsp mustard seeds","4–5 dry red chillies","A pinch of asafoetida","Salt to taste"],"instructions":["Whisk yogurt with 3 tbsp besan, turmeric, salt and 2 cups water to a smooth, lump-free mixture.","Mix remaining 1 tbsp besan with sliced onions, green chilli, salt and a splash of water to make pakora batter.","Deep fry spoonfuls of pakora batter until golden. Drain and set aside.","Pour the yogurt mixture into a pot. Bring to a boil, stirring constantly to prevent curdling.","Reduce heat and simmer the kadhi for 20–25 minutes, stirring occasionally, until it thickens slightly.","Add the fried pakoras. Simmer 5 more minutes.","For tadka: heat ghee, add cumin, mustard seeds, dry chillies and asafoetida. Pour over kadhi and serve."],"prepTime":20,"cookTime":40,"servings":5,"cuisineType":"Punjabi","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-kadhi-pakora.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kadhi%20Pakora%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.615Z"},{"id":23,"title":"Tawa Pulao","description":"Mumbai street-style smoky fried rice cooked on a flat tawa with pav bhaji masala — vibrant, spicy and irresistibly fragrant.","ingredients":["2 cups cooked basmati rice","1 onion, finely chopped","2 tomatoes, chopped","1 bell pepper, diced","½ cup peas","2 tbsp pav bhaji masala","1 tsp red chilli powder","½ tsp turmeric","2 tbsp butter","Fresh coriander to garnish","Lemon juice to serve","Salt to taste"],"instructions":["Cook rice until just done — each grain should be separate. Spread on a plate and cool.","Heat butter on a flat tawa or wide pan over high heat.","Add onions and sauté on high flame until lightly charred at the edges.","Add tomatoes and cook on high heat, mashing lightly. Add bell peppers and peas.","Add pav bhaji masala, red chilli powder and turmeric. Mix well and cook 2 minutes.","Add the cooked rice and toss everything together on high heat for 3–4 minutes.","Squeeze lemon juice, garnish with coriander and serve with lemon wedges."],"prepTime":10,"cookTime":20,"servings":3,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-tawa-pulao.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tawa%20Pulao%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.618Z"},{"id":24,"title":"Saag Aloo","description":"Tender potatoes in a richly spiced, wilted spinach and fenugreek leaf base — a rustic North Indian classic that's earthy and warming.","ingredients":["3 medium potatoes, cut into cubes","400g spinach (palak), blanched","1 cup fenugreek leaves (methi)","1 onion, finely chopped","2 tomatoes, chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp red chilli powder","2 tbsp oil","Salt to taste"],"instructions":["Blanch spinach and fenugreek leaves in boiling water for 2 minutes. Drain and blend coarsely.","Parboil potato cubes in salted water until slightly tender. Drain and set aside.","Heat oil in a pan. Add cumin seeds. When they splutter, add onions and cook until golden.","Add ginger-garlic paste and cook 2 minutes. Add tomatoes and cook until soft.","Add all dry spices and cook the masala 5 minutes.","Add the potatoes and toss to coat. Cook 5 minutes.","Add the blended greens and mix well. Cover and cook 10 minutes until everything is combined.","Adjust seasoning and serve with makki ki roti or paratha."],"prepTime":15,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-saag-aloo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Saag%20Aloo%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.622Z"},{"id":25,"title":"Paneer Bhurji","description":"Scrambled cottage cheese stir-fried with spiced onions, tomatoes and peppers — a quick, protein-packed Indian breakfast or snack.","ingredients":["300g paneer, crumbled","1 large onion, finely chopped","2 tomatoes, finely chopped","1 bell pepper, diced","2 green chillies, finely chopped","1 tsp ginger, grated","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","½ tsp garam masala","2 tbsp oil","Fresh coriander to garnish","Salt to taste"],"instructions":["Heat oil in a pan. Add cumin seeds and let them splutter.","Add green chillies and grated ginger. Cook 30 seconds.","Add onions and sauté until golden. Add bell peppers and cook 2 minutes.","Add tomatoes and cook until they completely break down, about 5 minutes.","Add turmeric, red chilli powder and salt. Mix well.","Add crumbled paneer and toss everything together on high heat.","Cook 3–4 minutes, stirring often. Sprinkle garam masala and fresh coriander.","Serve hot with buttered toast or paratha."],"prepTime":10,"cookTime":15,"servings":3,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-bhurji.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Bhurji%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.625Z"},{"id":26,"title":"Bharwa Bhindi","description":"Whole okra stuffed with a tangy masala of coriander, cumin and amchur — a delicate dry sabzi that pairs beautifully with dal and rice.","ingredients":["500g bhindi (okra), wiped clean","1 tsp coriander powder","1 tsp cumin powder","½ tsp amchur (dry mango powder)","½ tsp fennel powder","½ tsp red chilli powder","¼ tsp turmeric","Salt to taste","2 tbsp oil","1 tsp lemon juice"],"instructions":["Trim the top and bottom of each bhindi. Make a vertical slit lengthwise without cutting all the way through.","Mix all the dry spices with salt. Add lemon juice to make a slightly moist masala.","Using a spoon or finger, stuff each bhindi generously with the masala mixture.","Heat oil in a wide, heavy-bottomed pan over medium heat.","Arrange the stuffed bhindi in a single layer. Cover and cook 5 minutes.","Gently turn and cook the other side, covered, for another 5 minutes.","Remove lid and cook on medium-high for 3–4 more minutes until bhindi is tender and slightly crispy.","Serve with dal and rotis."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bharwa-bhindi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bharwa%20Bhindi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.628Z"},{"id":27,"title":"Makki Ki Roti with Sarson Ka Saag","description":"The great Punjabi winter duo — crispy yellow corn flatbread paired with slow-cooked mustard greens, finished with a generous knob of white butter.","ingredients":["2 cups makki ka atta (corn flour)","Hot water to knead","Salt to taste","Ghee for cooking","500g sarson (mustard greens), chopped","200g spinach, chopped","100g bathua (lamb's quarters) or more spinach","1 onion, finely chopped","2 green chillies","1 tbsp ginger, grated","2 tbsp ghee","1 tsp maize flour to thicken saag","White butter to serve"],"instructions":["Pressure cook sarson, spinach and bathua with a little water and salt for 4–5 whistles. Mash coarsely.","Heat ghee in a pan. Sauté onions until golden. Add ginger and green chillies.","Add the mashed greens. Mix in maize flour to thicken. Simmer 20 minutes on low heat.","For makki ki roti: mix corn flour, salt and enough hot water to make a soft dough.","Flatten each portion into a thick disc (about 5mm) by hand on a piece of plastic wrap.","Cook on a tawa with ghee over medium heat until golden on both sides — about 4 minutes per side.","Serve roti with saag and a generous knob of white butter on top."],"prepTime":25,"cookTime":45,"servings":4,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-makki-ki-roti-with-sarson-ka-saag.png","youtubeUrl":"https://www.youtube.com/results?search_query=Makki%20Ki%20Roti%20Sarson%20Ka%20Saag%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.631Z"},{"id":28,"title":"Mix Veg Curry","description":"A colourful medley of seasonal vegetables in a fragrant, mildly spiced tomato-onion gravy — versatile, nutritious and endlessly customisable.","ingredients":["2 carrots, diced","1 potato, diced","½ cup French beans, chopped","½ cup cauliflower florets","½ cup peas","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","2 tbsp oil","Salt to taste"],"instructions":["Parboil carrots and potatoes in salted water for 5 minutes. Set aside.","Heat oil in a pan. Add cumin seeds. When they splutter, add onions and cook until golden.","Add ginger-garlic paste and cook 2 minutes. Add tomato puree and all dry spices except garam masala.","Cook masala until oil separates — about 8 minutes.","Add all the vegetables including French beans, cauliflower and peas.","Add ½ cup water. Cover and cook 12–15 minutes until all vegetables are tender.","Sprinkle garam masala, stir and serve hot with roti or rice."],"prepTime":20,"cookTime":30,"servings":5,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mix-veg-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mix%20Veg%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.634Z"},{"id":29,"title":"Mushroom Do Pyaaza","description":"Button mushrooms cooked twice with onions in a rich, restaurant-style masala — earthy, fragrant and wonderfully indulgent.","ingredients":["400g button mushrooms, halved","3 large onions, 2 finely chopped, 1 cut into chunks","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp red chilli powder","½ tsp garam masala","2 tbsp oil","Fresh coriander and ginger julienne to garnish","Salt to taste"],"instructions":["Sauté mushrooms in 1 tbsp oil on high heat until lightly browned and all moisture evaporates. Set aside.","Heat remaining oil. Add cumin seeds. When they crackle, add finely chopped onions.","Cook onions until deep golden. Add ginger-garlic paste and cook 2 minutes.","Add tomato puree and all dry spices except garam masala. Cook until oil separates.","Add the browned mushrooms and the chunky onions. Stir well.","Cook on medium heat for 8–10 minutes until mushrooms are cooked through and masala clings.","Sprinkle garam masala. Garnish with coriander and ginger julienne. Serve with naan."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mushroom-do-pyaaza.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mushroom%20Do%20Pyaaza%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.637Z"},{"id":30,"title":"Lauki Chana Dal","description":"Bottle gourd and split chickpeas cooked together in a light, mildly spiced curry — digestible, comforting and beautifully simple.","ingredients":["1 medium lauki (bottle gourd), peeled and cubed","½ cup chana dal (split chickpeas), soaked 1 hour","1 onion, finely chopped","2 tomatoes, chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","½ tsp coriander powder","2 tbsp oil","Fresh coriander to garnish","Salt to taste"],"instructions":["Pressure cook chana dal with turmeric and 1 cup water for 2 whistles — it should be cooked but hold its shape.","Heat oil in a pressure cooker. Add cumin seeds. When they crackle, add onions and cook until golden.","Add ginger-garlic paste and cook 2 minutes. Add tomatoes and cook until soft.","Add all dry spices and salt. Cook the masala 3 minutes.","Add lauki cubes and the cooked chana dal. Mix well.","Add 1 cup water. Pressure cook for 2 whistles.","Open, adjust consistency and seasoning. Garnish with coriander and serve with roti."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-lauki-chana-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lauki%20Chana%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.641Z"},{"id":31,"title":"Idli with Sambar","description":"Pillowy-soft steamed rice and lentil cakes served with a hearty, vegetable-packed sambar — the quintessential South Indian breakfast.","ingredients":["2 cups idli rice (or parboiled rice)","½ cup urad dal","1 tsp fenugreek seeds","Salt to taste","½ cup toor dal (for sambar)","1 cup mixed vegetables","2 tbsp sambar powder","1 tbsp tamarind paste","1 tsp mustard seeds","10 curry leaves","2 dry red chillies","A pinch of asafoetida","1 tbsp oil"],"instructions":["Soak rice, urad dal and fenugreek seeds separately for 6 hours. Grind urad dal first until very fluffy.","Grind rice to a slightly coarse batter. Mix both batters with salt. Ferment overnight.","Grease idli moulds. Pour batter into moulds and steam for 10–12 minutes until cooked through.","For sambar: pressure cook toor dal until mushy. Cook vegetables in water with turmeric.","Add sambar powder, tamarind and cooked dal to vegetables. Simmer 15 minutes.","Prepare tadka with mustard seeds, curry leaves, dry chillies and asafoetida. Add to sambar.","Serve hot idlis with sambar and coconut chutney."],"prepTime":20,"cookTime":30,"servings":6,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-idli-with-sambar.png","youtubeUrl":"https://www.youtube.com/results?search_query=Idli%20with%20Sambar%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.643Z"},{"id":32,"title":"Uttapam","description":"Thick, pancake-style dosas topped with colourful diced vegetables — crispy at the edges, soft in the centre, utterly satisfying.","ingredients":["2 cups dosa batter (fermented)","1 onion, finely chopped","2 tomatoes, finely chopped","1 bell pepper, diced","2 green chillies, finely chopped","Fresh coriander, chopped","Oil for cooking","Salt to taste"],"instructions":["Prepare dosa batter by soaking and fermenting rice and urad dal (or use ready-made batter).","Mix the chopped vegetables together.","Heat a tawa on medium heat. Grease lightly with oil.","Pour a ladleful of batter and gently spread into a thick circle (don't make it too thin).","While the batter is still wet, scatter a generous amount of mixed vegetables on top. Press lightly.","Drizzle oil around the edges. Cook 3–4 minutes until the bottom is golden.","Flip carefully and cook the vegetable side for 2–3 minutes. Serve with sambar and chutney."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-uttapam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Uttapam%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.646Z"},{"id":33,"title":"Pongal","description":"Sacred comfort — a creamy, peppery porridge of rice and moong dal cooked with ghee, cashews and whole spices, served at sunrise.","ingredients":["1 cup raw rice","½ cup moong dal","2 tsp black pepper, coarsely crushed","1 tsp cumin seeds","10–12 cashews","10 curry leaves","1 tbsp ginger, grated","A pinch of asafoetida","3 tbsp ghee","Salt to taste"],"instructions":["Dry roast moong dal until lightly golden and fragrant.","Wash rice and roasted dal together. Pressure cook with 5 cups water and salt for 5 whistles until very soft.","Mash well until the rice and dal merge into a thick, creamy porridge. Add hot water if too thick.","Heat ghee in a small pan. Add cashews and fry until golden. Remove and set aside.","In the same ghee, add cumin seeds, black pepper, curry leaves and asafoetida.","When spices splutter, add grated ginger and cook 30 seconds.","Pour the entire tempering over the pongal. Add fried cashews. Mix and serve hot with sambar and chutney."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-pongal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pongal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.649Z"},{"id":34,"title":"Medu Vada","description":"Crispy, doughnut-shaped urad dal fritters with a crunchy exterior and fluffy interior — the indispensable sidekick to idli and sambar.","ingredients":["1 cup urad dal (split black lentils), soaked 4 hours","1 tsp ginger, finely grated","2 green chillies, finely chopped","10 curry leaves, chopped","½ tsp black pepper","A pinch of asafoetida","Salt to taste","Oil for deep frying"],"instructions":["Drain soaked urad dal and grind to a very thick, fluffy batter using minimal water. The batter should be stiff.","Add ginger, green chillies, curry leaves, black pepper, asafoetida and salt. Mix well.","Wet your hands. Take a small portion of batter and shape into a ball. Make a hole in the centre with your thumb.","Heat oil for deep frying. Slide the vada carefully into the hot oil.","Fry on medium heat for 3–4 minutes, turning once, until deep golden and crisp.","Drain on paper towels.","Serve immediately with sambar and coconut chutney."],"prepTime":20,"cookTime":25,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-medu-vada.png","youtubeUrl":"https://www.youtube.com/results?search_query=Medu%20Vada%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.652Z"},{"id":35,"title":"Masala Dosa","description":"A crispy, paper-thin crepe wrapped around a fragrant spiced potato filling — South India's most famous export, beloved worldwide.","ingredients":["2 cups fermented dosa batter","3 medium potatoes, boiled and coarsely mashed","1 onion, thinly sliced","2 green chillies, slit","1 tsp mustard seeds","10 curry leaves","½ tsp turmeric","2 tbsp oil","Fresh coriander for filling","Salt to taste","Oil for cooking dosa"],"instructions":["For the filling: heat oil, add mustard seeds. When they pop, add curry leaves and green chillies.","Add sliced onions and cook until translucent. Add turmeric and salt.","Add mashed potatoes and mix well. Fold in fresh coriander. Set aside.","Heat a tawa on medium-high. Grease lightly.","Pour a ladleful of batter and spread immediately into a very thin circle.","Drizzle oil around edges. Cook until the base is crisp and golden.","Place potato filling in the centre. Fold the dosa over and serve immediately with sambar and chutneys."],"prepTime":15,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-masala-dosa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Masala%20Dosa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.655Z"},{"id":36,"title":"Avial","description":"Kerala's treasured mixed vegetable stew in a thick, tangy coconut-yogurt gravy — a celebration of seasonal vegetables in temple-style cooking.","ingredients":["2 cups mixed vegetables (raw banana, drumstick, yam, carrot, beans, raw mango)","1 cup fresh grated coconut","2 green chillies","1 tsp cumin seeds","½ cup sour yogurt","½ tsp turmeric","1 tbsp coconut oil","10 curry leaves","Salt to taste"],"instructions":["Cook vegetables in salted water with turmeric until just tender but still holding their shape.","Grind coconut, green chillies and cumin seeds with a little water to a coarse paste.","Drain most of the cooking water from vegetables, leaving just a little.","Add the coconut paste to the vegetables and mix well. Cook on low heat for 5 minutes.","Remove from heat. Add whisked sour yogurt and stir gently — do not boil after adding yogurt.","Heat coconut oil and add curry leaves. When they splutter, pour over the avial.","Serve with rice or as a side for a South Indian feast."],"prepTime":20,"cookTime":25,"servings":5,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-avial.png","youtubeUrl":"https://www.youtube.com/results?search_query=Avial%20Kerala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.658Z"},{"id":37,"title":"Curd Rice","description":"Cooling, comforting rice mixed with yogurt and tempered with mustard and curry leaves — the definitive South Indian palate cleanser and meal ender.","ingredients":["2 cups cooked rice","1½ cups yogurt, whisked","¼ cup milk","1 tsp mustard seeds","1 tsp cumin seeds","10 curry leaves","2 dry red chillies","2 green chillies, finely chopped","1 tsp ginger, grated","A pinch of asafoetida","2 tbsp oil","Pomegranate seeds and coriander to garnish","Salt to taste"],"instructions":["Mash the cooked rice slightly. Allow it to cool completely.","Mix whisked yogurt and milk into the rice. Season with salt. The mixture should be creamy.","Heat oil in a small pan. Add mustard seeds and let them pop.","Add cumin seeds, dry red chillies, curry leaves and asafoetida.","Add grated ginger and green chillies. Cook 30 seconds.","Pour the tempering over the curd rice and mix well.","Garnish with pomegranate seeds and fresh coriander. Serve at room temperature or chilled."],"prepTime":10,"cookTime":10,"servings":3,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-curd-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Curd%20Rice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.661Z"},{"id":38,"title":"Lemon Rice","description":"Bright, sunshine-yellow turmeric and lemon-infused rice with a crunchy peanut and curry leaf tempering — tangy, vibrant and irresistible.","ingredients":["2 cups cooked rice","Juice of 1 lemon","½ tsp turmeric","2 tbsp oil","1 tsp mustard seeds","1 tsp chana dal","1 tsp urad dal","2–3 dry red chillies","10 curry leaves","¼ cup roasted peanuts","A pinch of asafoetida","Salt to taste"],"instructions":["Cook rice until just done. Spread on a plate to cool completely — each grain should be separate.","Heat oil in a large pan. Add mustard seeds and let them pop.","Add chana dal, urad dal and dry red chillies. Fry until dals turn golden.","Add curry leaves and asafoetida. Sauté 30 seconds.","Add turmeric and immediately add the cooled rice. Toss gently.","Add peanuts, lemon juice and salt. Toss everything together.","Taste and adjust lemon juice. Serve warm or at room temperature."],"prepTime":10,"cookTime":15,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-lemon-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lemon%20Rice%20South%20Indian%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.664Z"},{"id":39,"title":"Bisi Bele Bath","description":"Karnataka's legendary one-pot of rice, lentils and vegetables simmered with an aromatic masala — nourishing, complex and deeply satisfying.","ingredients":["1 cup rice","½ cup toor dal","1 cup mixed vegetables (carrots, beans, peas, potato)","2 tbsp bisi bele bath masala powder","1 tbsp tamarind paste","1 tsp jaggery","½ tsp turmeric","For tadka: 2 tbsp ghee","1 tsp mustard seeds","10 cashews","10 curry leaves","2 dry red chillies","A pinch of asafoetida","Salt to taste"],"instructions":["Pressure cook toor dal with turmeric and 2 cups water for 4 whistles. Mash completely.","Cook rice with vegetables in 3 cups water until tender.","Combine the cooked dal with the rice-vegetable mixture in a large pot.","Add tamarind paste, bisi bele bath masala, jaggery and salt. Mix well.","Cook on medium heat for 10–15 minutes, stirring, until everything comes together and thickens.","For tadka: heat ghee, fry cashews until golden. Add mustard seeds, curry leaves, chillies and asafoetida.","Pour the tadka over the bisi bele bath. Serve hot with raita and papad."],"prepTime":20,"cookTime":45,"servings":5,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bisi-bele-bath.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bisi%20Bele%20Bath%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.667Z"},{"id":40,"title":"Rava Upma","description":"A quick, savoury semolina porridge cooked with onions, mustard seeds and curry leaves — South India's beloved 15-minute morning staple.","ingredients":["1 cup rava (semolina), dry roasted","1 medium onion, finely chopped","2 green chillies, slit","1 tsp mustard seeds","1 tsp chana dal","1 tsp urad dal","10 curry leaves","A pinch of asafoetida","2 tbsp oil or ghee","2½ cups water, boiling","Salt to taste","Fresh coriander and grated coconut to garnish"],"instructions":["Dry roast rava on medium heat until lightly golden and fragrant. Set aside.","Heat oil in a pan. Add mustard seeds and let them pop.","Add chana dal and urad dal. Fry until lightly golden.","Add green chillies, curry leaves and asafoetida. Sauté 30 seconds.","Add onions and cook until translucent.","Add boiling water and salt. Bring to a rolling boil.","Add roasted rava in a steady stream, stirring continuously to prevent lumps.","Cover and cook 3–4 minutes until rava is cooked through. Garnish and serve."],"prepTime":5,"cookTime":15,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-rava-upma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rava%20Upma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.669Z"},{"id":41,"title":"Tamarind Rice","description":"Puliyodarai — tangy, peppery tamarind rice with a punchy tempering of peanuts and spices, a South Indian temple offering and travel staple.","ingredients":["2 cups cooked rice","2 tbsp thick tamarind paste","¼ cup roasted peanuts","2 tbsp sesame seeds, toasted","2 tbsp oil","1 tsp mustard seeds","1 tsp chana dal","1 tsp urad dal","3–4 dry red chillies","10 curry leaves","½ tsp turmeric","A pinch of asafoetida","1 tsp jaggery","Salt to taste"],"instructions":["Spread cooked rice on a plate and allow to cool — grains must be separate.","Mix tamarind paste with ½ cup water, turmeric, jaggery and salt.","Heat oil in a pan. Add mustard seeds and let them pop.","Add chana dal, urad dal and dry red chillies. Fry until golden.","Add curry leaves, asafoetida and peanuts. Toss 1 minute.","Add the tamarind mixture. Cook on medium heat for 5 minutes until it thickens slightly.","Add the cooked rice and toss gently to coat every grain. Add sesame seeds and serve."],"prepTime":10,"cookTime":15,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-tamarind-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tamarind%20Rice%20Puliyodarai%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.672Z"},{"id":42,"title":"Pesarattu","description":"Green moong dal crepes from Andhra Pradesh — protein-rich, crispy and flavoured with ginger and green chillies. Served with upma stuffing.","ingredients":["1 cup whole green moong dal, soaked 6 hours","2–3 green chillies","1 tbsp ginger, grated","A pinch of asafoetida","Salt to taste","Oil for cooking","Ginger, green chillies and onion to scatter on top"],"instructions":["Drain soaked moong dal. Grind with green chillies, ginger, asafoetida and salt to a smooth batter.","The batter should be like dosa batter — not too thick, not too thin.","Heat a tawa on medium-high. Grease lightly.","Pour a ladleful of batter and spread into a thin circle.","Scatter finely chopped ginger, green chillies and onion on top.","Drizzle oil around edges. Cook 3–4 minutes until crispy at the bottom.","Fold and serve with ginger chutney or upma stuffed inside."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-pesarattu.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pesarattu%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.674Z"},{"id":43,"title":"Rava Idli","description":"Instant semolina idlis that need no fermentation — fluffy, spongy and ready in under 30 minutes. A modern South Indian breakfast essential.","ingredients":["1 cup rava (semolina)","¾ cup yogurt","½ tsp baking soda","1 tsp mustard seeds","1 tsp chana dal","10 curry leaves","2 green chillies, chopped","1 tbsp oil","Fresh coriander, chopped","Cashews for topping","Salt to taste"],"instructions":["Dry roast rava until fragrant. Cool completely.","Heat oil. Add mustard seeds, chana dal, curry leaves and green chillies. Sauté 1 minute.","Mix roasted rava, yogurt, salt and the tempering together. Add water if needed to make a thick batter.","Rest the batter for 10 minutes.","Just before steaming, add baking soda and mix gently.","Grease idli moulds. Place a cashew in each mould. Pour batter.","Steam for 10–12 minutes until a toothpick comes out clean. Serve with sambar and chutney."],"prepTime":15,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-rava-idli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rava%20Idli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.678Z"},{"id":44,"title":"Kesari Bath","description":"Golden semolina halwa perfumed with saffron, fragrant with cardamom and studded with cashews and raisins — a South Indian festive sweet.","ingredients":["1 cup rava (semolina)","¾ cup sugar","2 cups water","A pinch of saffron, soaked in warm milk","½ tsp cardamom powder","3 tbsp ghee","10 cashews","2 tbsp raisins","A drop of orange or yellow food colour (optional)"],"instructions":["Dry roast rava in ghee on medium heat until golden and fragrant — about 5 minutes.","In a separate pan, boil water with sugar and saffron (with its milk) until sugar dissolves.","Pour the hot sugar syrup slowly into the roasted rava, stirring constantly to prevent lumps.","Cook on low heat, stirring, until the mixture thickens and leaves the sides of the pan.","In a small pan, fry cashews and raisins in ghee until golden.","Add cardamom powder and the fried nuts to the kesari. Mix well.","Serve warm, shaped into portions or directly from the pan."],"prepTime":5,"cookTime":20,"servings":5,"cuisineType":"South Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-kesari-bath.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kesari%20Bath%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.680Z"},{"id":45,"title":"Undhiyu","description":"Gujarati's crown jewel — a mixed winter vegetable and muthiya casserole slow-cooked with a fragrant coconut-herb masala. A labour of love.","ingredients":["500g mixed vegetables (surti papdi, raw banana, purple yam, brinjal, sweet potato)","For muthiyas: 1 cup methi leaves, chopped","1 cup besan (gram flour)","1 tsp ginger-chilli paste","For masala: 1 cup fresh grated coconut","1 cup fresh coriander","2 tbsp sesame seeds","1 tbsp sugar","1 tsp cumin seeds","4 garlic cloves","2 tbsp oil","Salt to taste"],"instructions":["For muthiyas: mix methi leaves, besan, ginger-chilli paste, salt and oil to a stiff dough. Shape into small cylinders. Deep fry until golden.","Grind coconut, coriander, sesame seeds, garlic, cumin, sugar and salt to a coarse masala.","Cut all vegetables into large chunks. Slit brinjals and stuff with the coconut masala.","Heat oil in a heavy pot. Layer vegetables, starting with hardest at the bottom.","Add muthiyas on top. Pour remaining masala over everything.","Add oil and a splash of water. Cover tightly and cook on very low heat for 30–40 minutes.","Gently stir once halfway through. Serve with puris."],"prepTime":45,"cookTime":50,"servings":6,"cuisineType":"Gujarati","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-undhiyu.png","youtubeUrl":"https://www.youtube.com/results?search_query=Undhiyu%20Gujarati%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.683Z"},{"id":46,"title":"Dal Dhokli","description":"Wholesome whole wheat flour dumplings simmered in a sweet-sour-spicy toor dal — Gujarat's ultimate one-pot comfort food.","ingredients":["1 cup toor dal","1 cup whole wheat flour","1 tbsp besan (gram flour)","1 tsp ginger-chilli paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander powder","1 tbsp tamarind paste","1 tbsp jaggery","1 tsp mustard seeds","10 curry leaves","2 tbsp ghee","Fresh coriander to garnish","Salt to taste"],"instructions":["Pressure cook toor dal with turmeric for 4 whistles. Mash and add tamarind, jaggery, salt and spices.","Simmer the dal for 10 minutes, adjusting consistency with water.","Mix whole wheat flour, besan, ginger-chilli paste, turmeric, salt and a little oil. Knead to stiff dough.","Roll the dough thin and cut into diamond shapes (dhoklis).","Drop dhoklis into the simmering dal. Cook 10–12 minutes until they are cooked through.","Prepare tadka with mustard seeds, curry leaves in ghee. Pour over the dal dhokli.","Garnish with coriander. Serve piping hot with ghee drizzled on top."],"prepTime":20,"cookTime":40,"servings":4,"cuisineType":"Gujarati","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-dal-dhokli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dal%20Dhokli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.686Z"},{"id":47,"title":"Khandvi","description":"Paper-thin, melt-in-your-mouth gram flour rolls in a tangy yogurt base — a Gujarati snack of extraordinary texture and elegance.","ingredients":["1 cup besan (gram flour)","1 cup yogurt","2 cups water","½ tsp turmeric","1 tsp ginger-chilli paste","Salt to taste","For tadka: 2 tbsp oil","1 tsp mustard seeds","1 tsp sesame seeds","10 curry leaves","2 dry red chillies","Fresh coriander and grated coconut to garnish"],"instructions":["Whisk besan, yogurt, water, turmeric, ginger-chilli paste and salt into a completely smooth, lump-free mixture.","Cook the mixture in a heavy pan on medium heat, stirring constantly without stopping for 10–12 minutes until very thick.","Immediately spread a thin layer on a greased surface or on the back of a steel plate.","Allow to cool for 5 minutes. Cut into 7cm wide strips.","Roll each strip tightly from one end to make a cylinder. Arrange on a serving plate.","Heat oil for tadka. Add mustard seeds, sesame seeds, curry leaves and dry chillies.","Pour tadka over khandvi. Garnish with coriander and coconut."],"prepTime":10,"cookTime":20,"servings":5,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-khandvi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Khandvi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.688Z"},{"id":48,"title":"Methi Thepla","description":"Soft, spiced flatbreads packed with fresh fenugreek leaves — Gujarat's ultimate travel food that stays fresh for days.","ingredients":["2 cups whole wheat flour","1 cup fresh methi (fenugreek) leaves, washed and chopped","½ cup yogurt","1 tsp ginger-chilli paste","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","½ tsp ajwain (carom seeds)","2 tbsp oil","Salt to taste","Oil for cooking"],"instructions":["Mix all dry ingredients — flour, cumin, turmeric, red chilli, ajwain and salt.","Add methi leaves, ginger-chilli paste, yogurt and oil. Mix well.","Knead to a soft, smooth dough using water if needed. Rest 15 minutes.","Divide into equal portions. Roll each into a thin circle.","Cook on a hot tawa over medium heat, applying oil on both sides.","Cook until golden spots appear on both sides — about 2 minutes per side.","Serve with yogurt, pickle or raw mango chutney."],"prepTime":20,"cookTime":20,"servings":5,"cuisineType":"Gujarati","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-methi-thepla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Methi%20Thepla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.691Z"},{"id":49,"title":"Sev Tameta Nu Shaak","description":"Juicy tomatoes cooked in a tangy sweet-spice Gujarati gravy, finished generously with crunchy sev — a quick, vibrant everyday sabzi.","ingredients":["4 large tomatoes, roughly chopped","1 onion, finely chopped","1 tsp ginger-chilli paste","1 tsp mustard seeds","½ tsp cumin seeds","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander-cumin powder","1 tsp sugar","2 tbsp oil","Fresh coriander","Salt to taste","1 cup sev (fried chickpea noodles) to top"],"instructions":["Heat oil. Add mustard seeds and cumin seeds. Let them splutter.","Add onions and cook until translucent. Add ginger-chilli paste and cook 1 minute.","Add chopped tomatoes. Cook on medium heat until tomatoes break down completely — about 8 minutes.","Add turmeric, red chilli powder, coriander-cumin powder, sugar and salt.","Cook 5 more minutes until the sabzi comes together and oil separates.","Add fresh coriander.","Serve immediately topped generously with sev. The contrast of hot gravy and crunchy sev is essential."],"prepTime":10,"cookTime":20,"servings":3,"cuisineType":"Gujarati","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sev-tameta-nu-shaak.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sev%20Tameta%20Nu%20Shaak%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.694Z"},{"id":50,"title":"Gujarati Kadhi","description":"A thin, sweet-sour yogurt and gram flour broth tempered with whole spices — lighter, more delicate and more complex than its Punjabi counterpart.","ingredients":["2 cups yogurt, whisked","3 tbsp besan (gram flour)","1 tsp ginger-chilli paste","1 tsp sugar","Salt to taste","2 tbsp ghee","1 tsp mustard seeds","½ tsp cumin seeds","4–5 cloves","2 cinnamon sticks","10–12 curry leaves","3 dry red chillies","A pinch of asafoetida"],"instructions":["Whisk yogurt, besan, ginger-chilli paste, sugar, salt and 2 cups water until completely smooth.","Pour into a pot and heat on medium, stirring constantly until it comes to a boil.","Reduce heat and simmer 15–20 minutes, stirring occasionally, until slightly thickened.","For tadka: heat ghee until hot. Add mustard seeds and let them pop.","Add cumin seeds, cloves, cinnamon, curry leaves, dry chillies and asafoetida.","Pour the sizzling tadka into the kadhi.","Adjust seasoning. Serve with khichdi or rice for a perfect Gujarati meal."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-gujarati-kadhi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gujarati%20Kadhi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.697Z"},{"id":51,"title":"Patra","description":"Colocasia leaves smeared with a tangy besan paste, rolled, steamed and then fried — a Gujarati snack of incredible textural genius.","ingredients":["6 large colocasia (arvi) leaves","2 cups besan (gram flour)","2 tbsp tamarind paste","2 tbsp jaggery","1 tsp ginger-chilli paste","1 tsp coriander-cumin powder","½ tsp turmeric","Salt to taste","Oil for frying","For tadka: mustard seeds, sesame seeds, curry leaves"],"instructions":["Mix besan with tamarind, jaggery, ginger-chilli paste, spices and enough water to make a smooth, spreadable paste.","Wash colocasia leaves and dry completely. Trim the central vein to make it pliable.","Apply a thin, even layer of the besan paste on one side of a leaf.","Stack 2–3 leaves on top of each other (paste side up) and roll tightly from the wider end.","Secure with a thread and steam for 20 minutes. Allow to cool.","Slice into rounds. Shallow-fry or pan-fry until crispy on both sides.","Prepare tadka and pour over. Garnish with coconut and coriander."],"prepTime":30,"cookTime":35,"servings":5,"cuisineType":"Gujarati","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-patra.png","youtubeUrl":"https://www.youtube.com/results?search_query=Patra%20Gujarati%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.700Z"},{"id":52,"title":"Dabeli","description":"Mumbai's famous street sandwich — a soft pav filled with a tangy spiced potato mixture, chutneys, pomegranate and crunchy sev. Pure joy.","ingredients":["4 pav buns","3 medium potatoes, boiled and mashed","1 tbsp dabeli masala","1 tbsp tamarind chutney","1 tbsp green chutney","1 tsp red garlic chutney","Butter for toasting","¼ cup pomegranate seeds","¼ cup roasted peanuts","½ cup sev","Fresh coriander","Salt to taste"],"instructions":["Mix mashed potatoes with dabeli masala, a spoonful of tamarind chutney and salt.","Divide potato mixture into portions, shaping each into a flat patty.","Slit pav buns without separating them completely.","Apply butter inside and toast on a hot tawa until golden.","Spread green chutney and garlic chutney inside the bun.","Place the potato patty inside. Top with tamarind chutney, pomegranate seeds, peanuts and sev.","Garnish with coriander. Press and serve immediately."],"prepTime":20,"cookTime":15,"servings":4,"cuisineType":"Gujarati","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-dabeli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dabeli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.702Z"},{"id":53,"title":"Batata Vada","description":"Golden, crunchy gram flour-coated fried potato balls — the heart of the beloved Vada Pav. Addictive, spicy and utterly perfect.","ingredients":["4 medium potatoes, boiled and mashed","1 tsp ginger-green chilli paste","1 tsp mustard seeds","10 curry leaves","½ tsp turmeric","1 tbsp fresh coriander, chopped","1 tsp lemon juice","For batter: 1 cup besan","½ tsp turmeric","A pinch of baking soda","Salt to taste","Oil for deep frying"],"instructions":["Heat 1 tsp oil. Add mustard seeds, curry leaves and ginger-chilli paste.","Add turmeric and the mashed potatoes. Mix well. Add lemon juice, coriander and salt.","Divide into equal portions and roll into smooth balls.","Make a thick batter with besan, turmeric, baking soda, salt and water.","Heat oil for deep frying. Dip each potato ball in the batter to coat completely.","Fry in hot oil until golden and crispy — about 3–4 minutes.","Serve hot with garlic chutney and green chutney."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-batata-vada.png","youtubeUrl":"https://www.youtube.com/results?search_query=Batata%20Vada%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.704Z"},{"id":54,"title":"Dal Baati Churma","description":"Rajasthan's iconic trio — hard, baked wheat balls served with five-lentil dal and crumbled sweet churma, all drowned in ghee.","ingredients":["For baati: 2 cups whole wheat flour","½ cup semolina","½ cup ghee","Salt to taste","For dal: ¼ cup each chana dal, toor dal, moong dal, urad dal, masoor dal","2 onions, 3 tomatoes","1 tbsp ginger-garlic paste","Whole spices and red chilli powder","2 tbsp ghee","For churma: baati, jaggery, cardamom, ghee"],"instructions":["For baati: mix flour, semolina, ghee and salt. Add water to make a stiff dough. Rest 20 minutes.","Shape into round balls. Bake in a preheated oven at 180°C for 25–30 minutes until hard and golden.","Break open and dip in ghee before serving.","For panchratan dal: pressure cook all dals together with turmeric. Prepare a masala with onions, tomatoes and spices.","Combine cooked dal with masala. Simmer 15 minutes. Add a final tadka of ghee and red chillies.","For churma: crumble leftover baked baati and mix with melted jaggery, ghee and cardamom.","Serve baati with dal poured over, alongside churma and extra ghee."],"prepTime":30,"cookTime":60,"servings":6,"cuisineType":"Rajasthani","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-dal-baati-churma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dal%20Baati%20Churma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.707Z"},{"id":55,"title":"Gatte Ki Sabzi","description":"Spiced gram flour dumplings in a tangy yogurt-based curry — Rajasthan's ingenious solution to cooking in a region with few fresh vegetables.","ingredients":["2 cups besan (gram flour)","½ tsp ajwain (carom seeds)","½ tsp red chilli powder","½ tsp turmeric","2 tbsp oil","For curry: 1 cup yogurt, whisked","1 onion, finely chopped","2 tomatoes, pureed","1 tsp coriander powder","1 tsp cumin seeds","Salt to taste"],"instructions":["Mix besan with ajwain, red chilli, turmeric, oil and salt. Add water to make a stiff dough.","Roll into long cylinders (1 cm thick). Boil in salted water for 8–10 minutes until cooked through.","Cool and cut into 2 cm pieces (gattas). Reserve the cooking water.","Heat oil. Add cumin seeds. Sauté onions until golden. Add tomato puree and spices. Cook until oil separates.","Add whisked yogurt gradually, stirring constantly on medium heat.","Cook the yogurt masala for 8–10 minutes until it thickens.","Add gattas and the reserved cooking water. Simmer 10 minutes. Serve with roti or rice."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"Rajasthani","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-gatte-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gatte%20Ki%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.710Z"},{"id":56,"title":"Ker Sangri","description":"The signature Rajasthani desert berry and dried beans dish — tangy, spicy and exotic, cooked with an aromatic blend of dry spices.","ingredients":["1 cup sangri (dried Rajasthani beans), soaked overnight","½ cup ker (dried desert berries), soaked 3 hours","2 tbsp oil","½ tsp asafoetida","1 tsp coriander powder","1 tsp red chilli powder","½ tsp amchur (dry mango powder)","½ tsp turmeric","1 tsp fennel powder","Dry red chillies","Salt to taste"],"instructions":["Wash soaked sangri and ker thoroughly several times to remove any bitterness.","Boil sangri and ker in separate pots until tender. Drain.","Heat oil in a pan. Add asafoetida and dry red chillies.","Add the cooked sangri and ker. Toss well.","Add all the dry spices — coriander, red chilli, amchur, turmeric and fennel powder.","Stir-fry on medium heat for 8–10 minutes until spices coat the beans and berries.","Adjust seasoning. Serve as a dry sabzi with bajra roti and dal."],"prepTime":20,"cookTime":25,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-ker-sangri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Ker%20Sangri%20Rajasthani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.712Z"},{"id":57,"title":"Pyaaz Kachori","description":"Flaky, golden-fried pastry puffs stuffed with a zesty spiced onion filling — Jodhpur's famous breakfast kachori, best eaten warm.","ingredients":["2 cups all-purpose flour","¼ cup oil (for dough)","Salt to taste","For filling: 3 large onions, finely chopped","1 tsp fennel seeds","½ tsp cumin seeds","1 tsp coriander powder","1 tsp red chilli powder","1 tsp amchur","2 tbsp besan, dry roasted","Oil for deep frying"],"instructions":["Knead flour with oil, salt and water to a firm dough. Cover and rest 30 minutes.","Heat 2 tbsp oil. Sauté onions until completely soft and dry — about 15 minutes.","Add all spices and roasted besan. Mix and cook 3 more minutes. Cool the filling.","Divide dough into equal portions. Roll into circles.","Place a tablespoon of filling in the centre. Bring edges up and seal tightly.","Flatten gently into a round disc.","Deep fry on medium-low heat for 8–10 minutes until very crispy and golden. Serve with tamarind chutney."],"prepTime":30,"cookTime":35,"servings":6,"cuisineType":"Rajasthani","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-pyaaz-kachori.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pyaaz%20Kachori%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.715Z"},{"id":58,"title":"Rajasthani Kadhi","description":"A sour, deeply flavoured yogurt curry unique to Rajasthan — thinner than Punjabi kadhi, studded with fried pakoras and rich with spices.","ingredients":["1½ cups yogurt","3 tbsp besan (gram flour)","1 tsp ginger-garlic paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander-cumin powder","2 tbsp ghee","1 tsp cumin seeds","4 dry red chillies","A pinch of asafoetida","Fresh coriander to garnish","Salt to taste"],"instructions":["Whisk yogurt, besan, turmeric, red chilli, ginger-garlic paste and salt with 3 cups water until smooth.","Pour into a pot. Bring to a boil on medium heat, stirring constantly.","Reduce heat and simmer 20–25 minutes, stirring often, until kadhi thickens slightly.","Heat ghee in a small pan. Add cumin seeds, dry chillies and asafoetida.","When spices splutter, add coriander-cumin powder. Cook 30 seconds.","Pour the tadka into the kadhi. Stir and taste for seasoning.","Garnish with coriander. Serve with basmati rice or bajre ki roti."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-rajasthani-kadhi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rajasthani%20Kadhi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.718Z"},{"id":59,"title":"Mirchi Vada","description":"Large green chillies stuffed with a tangy potato filling, dipped in besan batter and deep-fried — Jodhpur's fiery signature street snack.","ingredients":["8 large, mild green chillies (banana peppers)","3 medium potatoes, boiled and mashed","1 tsp amchur (dry mango powder)","1 tsp cumin powder","½ tsp red chilli powder","Fresh coriander","For batter: 1 cup besan","½ tsp turmeric","Salt","Oil for deep frying"],"instructions":["Make a lengthwise slit in each green chilli and remove the seeds.","Mix mashed potatoes with amchur, cumin, red chilli, coriander and salt.","Stuff each chilli generously with the potato mixture.","Make a thick batter with besan, turmeric, salt and water.","Heat oil for deep frying. Dip each stuffed chilli in batter to coat completely.","Fry in batches until golden and crispy all around.","Serve immediately with tamarind chutney and green chutney."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mirchi-vada.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mirchi%20Vada%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.720Z"},{"id":60,"title":"Aloo Posto","description":"Potatoes cooked in a velvety paste of poppy seeds — Bengali cuisine's most iconic vegetarian dish, simple yet deeply addictive.","ingredients":["4 medium potatoes, cut into cubes","4 tbsp posto (khus khus / white poppy seeds)","2–3 green chillies, slit","½ tsp turmeric","½ tsp red chilli powder","1 tbsp mustard oil","Salt to taste","A pinch of sugar"],"instructions":["Soak poppy seeds in warm water for 1 hour. Grind with green chillies and a little water to a smooth paste.","Heat mustard oil in a pan until it smokes slightly. Reduce to medium.","Add potatoes, turmeric and salt. Stir well. Cover and cook 10 minutes, stirring occasionally.","Add the poppy seed paste and red chilli powder. Mix gently.","Add ¼ cup water. Cover and cook 10 more minutes until potatoes are completely tender.","Add a pinch of sugar. Stir and check seasoning.","Serve with steamed white rice. The dish should be semi-dry."],"prepTime":15,"cookTime":25,"servings":3,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-posto.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Posto%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.724Z"},{"id":61,"title":"Cholar Dal","description":"Bengal gram cooked with fresh coconut and fragrant whole spices — a festive Bengali dal, aromatic with cardamom and sweet with raisins.","ingredients":["1 cup chana dal (Bengal gram), soaked 1 hour","¼ cup fresh coconut, cut into thin strips","2 tbsp raisins","2 bay leaves","2 dry red chillies","2 green cardamoms","1 cinnamon stick","½ tsp turmeric","1 tsp cumin seeds","1 tsp ginger, grated","1 tsp ghee","1 tsp sugar","Salt to taste"],"instructions":["Pressure cook chana dal with turmeric and 2 cups water for 3 whistles until cooked but holding shape.","Heat ghee. Fry coconut strips until lightly golden. Remove and set aside.","In the same ghee, add bay leaves, dry chillies, cardamom and cinnamon.","Add grated ginger and cumin seeds. Cook 30 seconds.","Add the cooked dal. Mix gently — the dal should not be mushy.","Add sugar, salt, fried coconut and raisins. Simmer 5 minutes.","Serve with luchi (puri) or rice."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-cholar-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Cholar%20Dal%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.726Z"},{"id":62,"title":"Shukto","description":"A bittersweet Bengali mixed vegetable stew made with bitter gourd and seasonal produce, tempered with mustard and a touch of milk.","ingredients":["1 bitter gourd (karela), sliced","1 raw banana, cubed","1 drumstick, cut into pieces","1 potato, cubed","½ cup red radish, sliced","1 tsp mustard paste","1 tsp ginger paste","1 tbsp poppy seed paste","½ cup milk","1 tsp panch phoron (Bengali five-spice)","1 tbsp mustard oil","Salt and a pinch of sugar"],"instructions":["Heat mustard oil. Add panch phoron and let it splutter.","Add bitter gourd and fry on medium heat until lightly golden.","Add all other vegetables and toss well.","Add ginger paste, mustard paste and poppy seed paste. Stir.","Add 1 cup water and salt. Cover and cook 15 minutes until vegetables are tender.","Pour in milk and add a pinch of sugar. Stir gently and simmer 3–4 more minutes.","Serve as the first dish of a Bengali meal with steamed rice."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-shukto.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shukto%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.729Z"},{"id":63,"title":"Begun Bhaja","description":"Crispy, golden fried aubergine rounds marinated with turmeric and chilli — a simple Bengali classic that outshines its humble ingredients.","ingredients":["1 large aubergine (brinjal), cut into thick round slices","1 tsp turmeric","1 tsp red chilli powder","1 tsp salt","Mustard oil for frying"],"instructions":["Cut aubergine into thick rounds (about 1 cm). Score one side lightly with a knife.","Mix turmeric, red chilli powder and salt together.","Apply the spice mix generously on both sides of each slice. Let marinate 15 minutes.","Heat generous mustard oil in a flat pan on medium heat.","Add the aubergine slices and fry on medium heat until golden and crispy on the bottom — about 5 minutes.","Flip and fry the other side until equally golden and crispy.","Serve as a starter or side with dal and rice."],"prepTime":15,"cookTime":15,"servings":3,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-begun-bhaja.png","youtubeUrl":"https://www.youtube.com/results?search_query=Begun%20Bhaja%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.732Z"},{"id":64,"title":"Mochar Ghonto","description":"A rich Bengali dry curry made from banana blossoms with grated coconut and whole spices — sophisticated vegetable cooking at its finest.","ingredients":["1 banana flower (mocha), cleaned and chopped","1 medium potato, diced","¼ cup fresh grated coconut","2 bay leaves","1 tsp panch phoron","1 tsp ginger, grated","½ tsp turmeric","1 tsp cumin-coriander powder","1 tsp sugar","2 tbsp mustard oil","Salt to taste"],"instructions":["Cleaning banana flower: remove outer petals, chop the inner florets, removing stamens. Soak in salted water 30 minutes.","Drain and squeeze out water completely. The flower should be as dry as possible.","Heat mustard oil. Add bay leaves and panch phoron. Let them splutter.","Add potato and cook until half done.","Add grated ginger and the banana flower. Stir well.","Add turmeric, cumin-coriander powder, sugar and salt. Toss and cook covered for 15 minutes.","Add grated coconut and mix. Cook uncovered for 5 more minutes until dry. Serve with rice."],"prepTime":40,"cookTime":30,"servings":4,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mochar-ghonto.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mochar%20Ghonto%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.735Z"},{"id":65,"title":"Niramish Alur Dom","description":"Bengali slow-cooked whole potatoes in a fragrant, spiced gravy without onion or garlic — a pure, temple-style offering of extraordinary flavour.","ingredients":["500g baby potatoes or small potatoes","2 tomatoes, pureed","1 tsp ginger, grated","½ tsp turmeric","1 tsp cumin-coriander powder","1 tsp red chilli powder","1 tsp Bengali garam masala","1 tsp sugar","1 tsp panch phoron","2 bay leaves","2 tbsp mustard oil","Fresh coriander","Salt to taste"],"instructions":["Parboil potatoes with skin on. Peel and prick all over with a fork.","Fry the potatoes in hot mustard oil until golden all around. Set aside.","In the same oil, add panch phoron and bay leaves.","Add grated ginger and tomato puree. Cook until oil separates.","Add all dry spices, sugar and salt. Cook 3 minutes.","Add the fried potatoes. Pour 1 cup water and stir gently.","Cover and simmer 15 minutes. Add Bengali garam masala and coriander. Serve with luchi."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-niramish-alur-dom.png","youtubeUrl":"https://www.youtube.com/results?search_query=Niramish%20Alur%20Dom%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.738Z"},{"id":66,"title":"Misal Pav","description":"Fiery sprouted moth bean curry topped with crunchy chivda, onion, tomatoes and lemon — Maharashtra's most satisfying street breakfast.","ingredients":["2 cups sprouted moth beans (matki)","1 onion, finely chopped","2 tomatoes, finely chopped","2 tbsp misal masala or goda masala","1 tsp red chilli powder","½ tsp turmeric","1 tbsp ginger-garlic paste","2 tbsp oil","4 pav buns","1 cup farsan / chivda (crunchy mix)","Lemon, coriander and onion to serve","Salt to taste"],"instructions":["Pressure cook sprouted moth beans with salt and turmeric for 2 whistles. They should be just cooked.","Heat oil. Add ginger-garlic paste and cook 1 minute. Add onions and sauté until golden.","Add tomatoes and cook until soft. Add misal masala, red chilli powder and salt.","Add the cooked sprouts with their cooking water. Bring to a boil.","Simmer 10 minutes until the curry (usal) is thick and spicy.","To serve: place usal in a bowl, top with farsan, chopped onions, tomatoes, coriander and a squeeze of lemon.","Serve with buttered pav on the side."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-misal-pav.png","youtubeUrl":"https://www.youtube.com/results?search_query=Misal%20Pav%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.741Z"},{"id":67,"title":"Vada Pav","description":"The original Indian veggie burger — a crispy spiced potato vada nestled in a soft pav with fiery chutneys. Mumbai's soul on a plate.","ingredients":["4 pav buns","4 batata vadas (see Batata Vada recipe)","Green chutney (coriander-mint-garlic)","Dry garlic chutney (dry red chilli, garlic, salt)","Tamarind chutney","Fresh coriander","Fried green chillies to serve"],"instructions":["Prepare batata vadas by mixing mashed potato with spices, rolling into balls and dipping in besan batter.","Deep fry the vadas until golden and crispy. Set aside.","Slit the pav buns without separating them completely.","Apply green chutney generously on one side inside the bun.","Apply dry garlic chutney on the other side.","Place a hot vada inside and press gently.","Serve with tamarind chutney and a fried green chilli on the side."],"prepTime":30,"cookTime":20,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-vada-pav.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vada%20Pav%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.744Z"},{"id":68,"title":"Puran Poli","description":"Sweet, fragrant flatbread stuffed with a golden jaggery and chana dal filling — Maharashtra's beloved festive bread served with ghee.","ingredients":["1 cup chana dal, soaked","¾ cup jaggery (gur)","½ tsp cardamom powder","¼ tsp nutmeg powder","2 cups whole wheat flour","½ cup all-purpose flour","Turmeric for colour","Oil to knead dough","Ghee to serve","Salt to taste"],"instructions":["Pressure cook chana dal for 4 whistles until completely soft. Drain excess water.","Cook dal with jaggery on medium heat, stirring until it forms a thick, dry mixture (puran).","Add cardamom and nutmeg. Cool and pass through a sieve for a smooth filling.","Knead a soft, pliable dough with both flours, turmeric, oil and water.","Take a dough ball, flatten and place a generous portion of puran filling in the centre. Seal edges.","Gently roll out into a thin circle — the filling should not tear through.","Cook on a hot tawa on medium heat, applying ghee generously, until golden on both sides."],"prepTime":30,"cookTime":40,"servings":8,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-puran-poli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Puran%20Poli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.747Z"},{"id":69,"title":"Bharli Vangi","description":"Tiny brinjals stuffed to bursting with a nutty, tangy coconut-peanut masala and slow-cooked in their own steam — Maharashtrian cooking at its finest.","ingredients":["8–10 small round brinjals","½ cup roasted peanuts, coarsely ground","¼ cup fresh grated coconut","1 onion, finely chopped and fried golden","2 tbsp sesame seeds, roasted","1 tbsp goda masala","1 tsp red chilli powder","1 tsp coriander-cumin powder","1 tsp tamarind paste","1 tsp jaggery","2 tbsp oil","Salt to taste"],"instructions":["Mix peanuts, coconut, fried onion, sesame seeds, goda masala, red chilli, coriander-cumin, tamarind, jaggery and salt.","Make two deep cross slits in each brinjal from the bottom end, keeping the stem intact.","Generously stuff each brinjal with the masala mixture.","Heat oil in a heavy-bottomed pan. Place stuffed brinjals in a single layer.","Add any remaining masala around the brinjals. Sprinkle a little water.","Cover and cook on low heat for 20–25 minutes, turning once very gently.","Serve with bhakri (jowar roti) or rice."],"prepTime":25,"cookTime":30,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bharli-vangi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bharli%20Vangi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.751Z"},{"id":70,"title":"Sabudana Khichdi","description":"Soft, non-sticky tapioca pearls cooked with roasted peanuts, ginger and curry leaves — Maharashtra's favourite fasting food and a textural joy.","ingredients":["1 cup sabudana (sago / tapioca pearls)","½ cup roasted peanuts, coarsely crushed","2 medium potatoes, boiled and cubed","2 green chillies, finely chopped","1 tsp ginger, grated","1 tsp cumin seeds","10 curry leaves","1 tsp lemon juice","1 tsp sugar","2 tbsp oil or ghee","Fresh coriander to garnish","Salt to taste"],"instructions":["Wash sabudana in several changes of water. Soak for 4 hours. Each pearl should be separate and soft but not mushy.","Drain and spread on a cloth to dry for 20 minutes. This prevents sticky clumping.","Heat oil or ghee. Add cumin seeds and curry leaves. When they crackle, add green chillies and ginger.","Add the boiled potato cubes and cook 3 minutes.","Add the soaked sabudana. Toss gently over medium heat.","Add crushed peanuts, sugar, salt and lemon juice. Toss everything together.","Cook 5 minutes, tossing gently, until sabudana is cooked through and translucent. Garnish and serve."],"prepTime":20,"cookTime":15,"servings":3,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sabudana-khichdi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sabudana%20Khichdi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.754Z"},{"id":71,"title":"Amti","description":"Maharashtra's everyday toor dal with goda masala and kokum — tangy, slightly sweet and spiced with this regional masala blend. A Maharashtrian staple.","ingredients":["1 cup toor dal, pressure cooked","1 tsp goda masala","½ tsp red chilli powder","½ tsp turmeric","2 pieces kokum (or 1 tsp tamarind paste)","1 tsp jaggery","1 tbsp oil","1 tsp mustard seeds","10 curry leaves","2 dry red chillies","A pinch of asafoetida","Fresh coriander to garnish","Salt to taste"],"instructions":["Cook toor dal until completely soft. Whisk until smooth.","Add goda masala, red chilli powder, turmeric, kokum, jaggery and salt. Mix well.","Add water to achieve a medium-thin consistency. Bring to a boil.","Simmer 10 minutes until flavours meld and dal takes on a slightly tangy-sweet note.","For tadka: heat oil. Add mustard seeds, dry red chillies, curry leaves and asafoetida.","Pour the tadka into the amti. Stir and taste.","Garnish with coriander and serve with steamed rice and papad."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-amti.png","youtubeUrl":"https://www.youtube.com/results?search_query=Amti%20Maharashtrian%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.757Z"},{"id":72,"title":"Vegetable Biryani","description":"Fragrant, long-grained basmati rice layered with spiced vegetables and slow-cooked by the dum method — a festive one-pot masterpiece.","ingredients":["2 cups basmati rice, soaked 30 minutes","2 cups mixed vegetables (carrots, beans, peas, cauliflower, potato)","2 onions, thinly sliced and fried crispy","3 tomatoes, pureed","1 tbsp ginger-garlic paste","¾ cup yogurt","Whole spices (cloves, cardamom, cinnamon, bay leaf, star anise)","2 tsp biryani masala","A pinch of saffron in warm milk","Fresh mint and coriander leaves","3 tbsp ghee","Salt to taste"],"instructions":["Parboil basmati rice until 70% cooked. Drain and set aside.","Cook a spiced vegetable masala: sauté whole spices, then onions, ginger-garlic paste, tomatoes and yogurt.","Add vegetables and biryani masala. Cook until vegetables are half done.","In a heavy pot, layer half the parboiled rice, then the vegetable masala, then remaining rice.","Top with saffron milk, fried onions, mint, coriander and dollops of ghee.","Seal the pot with foil and a tight lid. Cook on very low heat for 20 minutes (dum method).","Open at the table. Gently mix from the sides. Serve with raita and salan."],"prepTime":30,"cookTime":50,"servings":6,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-vegetable-biryani.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vegetable%20Biryani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.759Z"},{"id":73,"title":"Pav Bhaji","description":"Mumbai's favourite street food — a thick, spiced mash of mixed vegetables cooked on a tawa with a generous knob of butter, served with soft toasted pav.","ingredients":["4 medium potatoes, boiled and mashed","1 cup cauliflower florets","½ cup peas","2 carrots, boiled","2 onions, finely chopped","3 tomatoes, finely chopped","2 tbsp pav bhaji masala","1 tsp red chilli powder","1 tsp ginger-garlic paste","4 tbsp butter","8 pav buns","Lemon, coriander and onion to serve","Salt to taste"],"instructions":["Boil all vegetables and mash them completely — everything should be a smooth mash.","Heat butter on a tawa. Add ginger-garlic paste and onions. Cook on high heat until onions are golden.","Add tomatoes and cook on high heat, mashing them.","Add pav bhaji masala, red chilli powder and salt. Mix well.","Add the mashed vegetables. Mix everything together, adding a little water if needed.","Mash and cook on high heat for 10 minutes until bhaji is smooth, thick and shiny.","Slit and butter the pav buns. Toast on the tawa until golden. Serve with bhaji, lemon and coriander."],"prepTime":20,"cookTime":30,"servings":5,"cuisineType":"Maharashtrian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-pav-bhaji.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pav%20Bhaji%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.763Z"},{"id":74,"title":"Aloo Tikki","description":"Crispy shallow-fried potato patties seasoned with cumin and coriander — the ultimate Indian street food snack, served with three chutneys.","ingredients":["4 large potatoes, boiled and mashed","2 tbsp breadcrumbs or cornflour","1 tsp cumin seeds, roasted and crushed","1 tsp coriander powder","1 tsp amchur (dry mango powder)","½ tsp garam masala","2 green chillies, finely chopped","Fresh coriander, chopped","Salt to taste","Oil for shallow frying"],"instructions":["Mix mashed potatoes with breadcrumbs, cumin, coriander, amchur, garam masala, green chillies, coriander and salt.","Divide into equal portions and shape into flat, round patties about 1 cm thick.","Refrigerate for 15 minutes to firm up.","Heat a thin layer of oil in a flat pan on medium-high heat.","Place tikkis and cook without disturbing for 4–5 minutes until the bottom is deep golden and crispy.","Flip carefully and cook the other side for 4–5 minutes.","Serve hot with mint chutney, tamarind chutney and yogurt."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-aloo-tikki.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Tikki%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.766Z"},{"id":75,"title":"Bhel Puri","description":"The iconic Mumbai beach snack — puffed rice tossed with onions, tomatoes, sev and the essential trio of chutneys. Tangy, crunchy, addictive.","ingredients":["3 cups puffed rice (murmura)","1 cup sev","1 onion, finely chopped","2 tomatoes, finely chopped","1 potato, boiled and cubed","2 tbsp green chutney (coriander-mint)","2 tbsp tamarind chutney","1 tsp chaat masala","½ tsp cumin powder","Fresh coriander","Lemon juice to taste","Salt to taste"],"instructions":["This dish must be assembled and served immediately or the puffed rice will go soggy.","In a large bowl, combine puffed rice and sev.","Add onions, tomatoes and boiled potato cubes.","Add green chutney and tamarind chutney. Toss well.","Add chaat masala, cumin powder, salt and lemon juice.","Toss everything together very quickly.","Serve immediately in newspaper cones or small bowls topped with extra sev and coriander."],"prepTime":15,"cookTime":0,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-bhel-puri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bhel%20Puri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.769Z"},{"id":76,"title":"Dahi Vada","description":"Soft, fluffy lentil dumplings submerged in sweetened yogurt and topped with tamarind chutney, cumin and pomegranate — a cooling Indian classic.","ingredients":["1 cup urad dal, soaked 4 hours and ground to fluffy batter","2 cups thick yogurt, whisked smooth","2 tsp sugar","1 tsp cumin powder, roasted","1 tsp red chilli powder","Tamarind chutney","Green chutney","Chaat masala","Pomegranate seeds and coriander","Oil for deep frying","Salt to taste"],"instructions":["Grind soaked urad dal with minimal water to a very fluffy batter. Add salt.","Deep fry spoonfuls of batter on medium heat until golden. Drain.","Soak the fried vadas in warm water for 10 minutes to soften. Squeeze out excess water gently.","Whisk yogurt with sugar, salt and a pinch of cumin. Chill well.","Arrange soaked vadas in a serving dish. Pour chilled yogurt over them.","Drizzle tamarind chutney and green chutney generously.","Sprinkle cumin powder, red chilli, chaat masala, pomegranate and coriander. Serve immediately."],"prepTime":20,"cookTime":25,"servings":5,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dahi-vada.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dahi%20Vada%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.772Z"},{"id":77,"title":"Handvo","description":"A savoury Gujarati baked or pan-fried mixed dal and rice cake loaded with bottle gourd and sesame — crispy outside, moist and flavourful inside.","ingredients":["1 cup rice","½ cup chana dal","¼ cup toor dal","¼ cup urad dal","1 cup bottle gourd (lauki), grated","½ cup yogurt","1 tsp ginger-chilli paste","1 tsp Eno fruit salt","For tadka: 2 tbsp oil, 1 tsp mustard seeds, 1 tsp sesame seeds, 8 curry leaves, 2 dry red chillies","Salt to taste"],"instructions":["Soak rice and all dals together overnight. Grind to a coarse batter with yogurt.","Add grated lauki, ginger-chilli paste and salt. Ferment for 8 hours.","Just before cooking, add Eno fruit salt and mix gently.","Heat oil in a heavy-bottomed pan. Add mustard seeds, sesame seeds, curry leaves and dry red chillies.","Pour the batter into the pan. Cover and cook on low heat for 20 minutes.","Flip the handvo (as one large cake) and cook the other side 15 minutes until golden and crispy.","Slice and serve with green chutney."],"prepTime":20,"cookTime":40,"servings":6,"cuisineType":"Gujarati","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-handvo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Handvo%20Gujarati%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.776Z"},{"id":78,"title":"Gajar Ka Halwa","description":"Slow-cooked grated carrots in rich, saffron-kissed milk with sugar, cardamom, ghee and garnished with golden cashews — winter's greatest dessert.","ingredients":["1 kg red carrots, peeled and grated","1 litre full-fat milk","¾ cup sugar","3 tbsp ghee","½ tsp cardamom powder","A generous pinch of saffron in 2 tbsp warm milk","¼ cup cashews and raisins, fried in ghee","2 tbsp khoya (dried milk solids) (optional for richness)"],"instructions":["Heat ghee in a heavy, wide kadhai. Add grated carrots and sauté on medium heat for 10 minutes.","Add the milk and bring to a boil. Reduce heat to medium.","Cook, stirring every 5 minutes, until all the milk is absorbed — about 30–35 minutes.","Add sugar, saffron milk and khoya if using. Stir well.","Continue cooking until the halwa comes together, leaves the sides of the pan and is shiny — about 10 minutes.","Add cardamom powder and mix.","Top with fried cashews and raisins. Serve warm or at room temperature."],"prepTime":20,"cookTime":50,"servings":8,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-gajar-ka-halwa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gajar%20Ka%20Halwa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.779Z"},{"id":79,"title":"Gulab Jamun","description":"Soft, spongy milk-solid dumplings deep-fried until mahogany and soaked in a cardamom and rose-scented sugar syrup — India's most beloved mithai.","ingredients":["1 cup khoya (mawa), crumbled","¼ cup all-purpose flour (maida)","A pinch of baking soda","Milk to bind","Oil or ghee for deep frying","For syrup: 2 cups sugar","1½ cups water","½ tsp cardamom powder","1 tsp rose water","A few saffron strands"],"instructions":["Make sugar syrup: combine sugar and water in a pan. Bring to a boil and simmer until it reaches one-string consistency. Add cardamom, rose water and saffron.","Mix khoya, flour and baking soda. Add just enough milk to bind into a smooth, soft dough.","Divide into small portions. Roll into smooth balls without any cracks.","Deep fry on very low-medium heat, rolling continuously, until deep mahogany — about 8–10 minutes.","Drain briefly and immediately immerse in warm sugar syrup.","Allow to soak for at least 2 hours — they will double in size.","Serve warm or at room temperature, garnished with pistachios."],"prepTime":20,"cookTime":30,"servings":8,"cuisineType":"Pan-Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-gulab-jamun.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gulab%20Jamun%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.781Z"},{"id":80,"title":"Kheer","description":"Silky rice pudding slow-cooked in whole milk until thick and creamy, sweetened with sugar and fragrant with cardamom and saffron — the original Indian dessert.","ingredients":["1 litre full-fat milk","¼ cup basmati rice, washed","½ cup sugar","½ tsp cardamom powder","A generous pinch of saffron in warm milk","2 tbsp chopped almonds","2 tbsp pistachios, sliced","1 tbsp raisins","1 tsp rose water"],"instructions":["Bring milk to a boil in a heavy pot. Add washed rice.","Cook on medium-low heat, stirring frequently, until rice is completely soft and milk has thickened — about 30–35 minutes.","Add sugar and stir until dissolved. The kheer will thin slightly — continue cooking for 10 more minutes.","Add saffron milk and cardamom powder.","Add raisins and half the nuts. Cook 5 more minutes.","Remove from heat. Add rose water and stir.","Pour into serving bowls. Garnish with sliced pistachios and almonds. Serve warm or chilled."],"prepTime":10,"cookTime":50,"servings":6,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kheer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kheer%20Rice%20Pudding%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.784Z"},{"id":81,"title":"Rava Sheera","description":"Golden semolina halwa fragrant with ghee, cardamom and saffron — a quick, comforting Indian sweet that comes together in under 20 minutes.","ingredients":["1 cup fine rava (semolina)","1 cup sugar","2 cups water","3 tbsp ghee","½ tsp cardamom powder","A pinch of saffron in 2 tbsp warm milk","10 cashews","2 tbsp raisins","A pinch of yellow food colour (optional)"],"instructions":["Heat ghee in a heavy pan. Fry cashews until golden. Remove and set aside.","In the same ghee, roast rava on medium heat, stirring constantly, until it turns golden and fragrant — about 8 minutes.","Boil water with saffron milk. Carefully add the hot water to the roasted rava (it will splutter).","Stir vigorously and continuously to prevent lumps forming.","Add sugar, raisins and food colour if using. Mix well.","Cook on low heat, stirring, until the halwa thickens and ghee starts to release from the sides.","Add cardamom and fried cashews. Serve warm."],"prepTime":5,"cookTime":20,"servings":5,"cuisineType":"Pan-Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-rava-sheera.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rava%20Sheera%20Halwa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.786Z"},{"id":82,"title":"Payasam","description":"Kerala's festive vermicelli and milk pudding with cashews, raisins and cardamom — served as the divine finale of every Onam Sadya feast.","ingredients":["½ cup vermicelli (semiya), roasted","1 litre full-fat milk","½ cup sugar","½ tsp cardamom powder","2 tbsp ghee","¼ cup cashews","¼ cup raisins","A generous pinch of saffron"],"instructions":["Heat ghee in a heavy pan. Fry cashews until golden, then raisins until they plump. Remove and set aside.","Add vermicelli to the same ghee and roast until golden.","Add milk and bring to a boil. Reduce heat and simmer until vermicelli is completely cooked and milk thickens — about 15 minutes.","Add sugar and stir until dissolved. Continue cooking 5 more minutes.","Add saffron and cardamom powder.","Add the fried cashews and raisins. Stir.","Serve warm or chilled. The payasam will thicken further as it cools."],"prepTime":10,"cookTime":25,"servings":6,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-payasam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Semiya%20Payasam%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.790Z"},{"id":83,"title":"Sabudana Kheer","description":"Creamy, lustrous sago pearl pudding with saffron and cardamom — a light, cooling dessert that is equally a fasting-day staple.","ingredients":["½ cup sabudana (sago), soaked 2 hours","1 litre full-fat milk","½ cup sugar","½ tsp cardamom powder","A pinch of saffron","2 tbsp cashews and raisins","1 tbsp ghee"],"instructions":["Fry cashews and raisins in ghee until golden. Set aside.","Bring milk to a boil. Add soaked sabudana.","Cook on medium heat, stirring frequently, until sabudana turns translucent and milk thickens — about 20 minutes.","Add sugar and stir until dissolved.","Add saffron and cardamom. Cook 5 more minutes.","Top with fried nuts and raisins. Serve warm or chilled.","The kheer will thicken considerably as it cools — add milk if reheating."],"prepTime":10,"cookTime":30,"servings":5,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sabudana-kheer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sabudana%20Kheer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.793Z"},{"id":84,"title":"Jeera Rice","description":"Fragrant basmati rice toasted with cumin seeds in ghee — the simplest, most perfect accompaniment to any Indian dal or curry.","ingredients":["2 cups basmati rice, soaked 30 minutes","1 tsp cumin seeds","1 bay leaf","1 tbsp ghee","3½ cups water","Salt to taste"],"instructions":["Soak basmati rice in water for 30 minutes. Drain completely.","Heat ghee in a heavy pot. Add cumin seeds and bay leaf. Let cumin splutter and darken slightly.","Add the drained rice. Sauté gently for 2 minutes, coating each grain in ghee.","Add water and salt. Bring to a full boil.","Reduce heat to the lowest possible, cover tightly and cook for 12 minutes.","Remove from heat. Do not open the lid for 5 more minutes.","Fluff gently with a fork. Discard bay leaf. Serve with any dal or curry."],"prepTime":35,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-jeera-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Jeera%20Rice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.796Z"},{"id":85,"title":"Aloo Palak","description":"Tender potatoes bathed in a silky, garlicky spinach puree — a simple, everyday North Indian curry that is nutritious and deeply comforting.","ingredients":["3 medium potatoes, cubed and fried","400g spinach, blanched and pureed","1 onion, finely chopped","3 garlic cloves, minced","1 tsp ginger, grated","2 green chillies","½ tsp cumin seeds","½ tsp turmeric","½ tsp garam masala","2 tbsp oil","Salt to taste"],"instructions":["Blanch spinach in boiling water for 2 minutes. Transfer to ice water to preserve colour. Drain and puree smoothly.","Fry potato cubes in oil until golden. Drain and set aside.","In the same pan, add cumin seeds. When they splutter, add onions and cook until golden.","Add garlic, ginger and green chillies. Cook 2 minutes.","Add turmeric and spinach puree. Stir well. Add ½ cup water.","Simmer 5 minutes. Add the fried potatoes. Cook 8 more minutes.","Sprinkle garam masala and serve with roti."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-palak.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Palak%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.800Z"},{"id":86,"title":"Methi Malai Matar","description":"Methi Malai Matar is a creamy and flavorful dish made with fresh fenugreek leaves and green peas, perfect for pairing with roti or rice.","ingredients":["1 cup fresh methi leaves","1 cup green peas","1 medium onion","1-2 green chilies","1-inch ginger","1 cup cream","2 tablespoons oil or ghee","1 teaspoon cumin seeds","1/2 teaspoon garam masala","Salt to taste","Water as needed"],"instructions":["In a pan, heat oil or ghee and add cumin seeds.","Allow them to splutter.","Add the chopped onion and green chilies, sauté until the onions turn translucent.","Add grated ginger and sauté for a minute.","Stir in the green peas and chopped methi leaves.","Cook for about 5 minutes until the peas are tender.","Lower the flame and add the cream.","Mix well and allow it to cook for another 5-7 minutes.","If the mixture is too thick, add a little water to reach desired consistency.","Sprinkle garam masala and salt, stir well, and cook for another minute.","Adjust seasoning as needed.","Serve hot with roti, naan, or rice."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":[],"category":"main","imageUrl":"/api/recipes/86/image","youtubeUrl":"https://www.youtube.com/results?search_query=methi+malai+matar+recipe+indian+vegetarian","authorId":"test-user-chef","submittedBy":"testchef@example.com","submittedByName":"Test Chef","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-10T16:19:59.871Z"},{"id":87,"title":"Vegetable Wonton Soup","description":"A comforting and flavorful vegan soup filled with homemade vegetable wontons, perfect for a cozy meal.","ingredients":["1 cup all-purpose flour","Water (as needed for the dough)","1 cup finely chopped vegetables","1 teaspoon grated ginger","1 teaspoon soy sauce","Salt and pepper to taste","4 cups vegetable broth","2 cloves garlic, minced","1 teaspoon sesame oil","1-2 green onions, chopped","Soy sauce (to taste)","Bok choy or spinach (for added greens)"],"instructions":["Combine flour and water to form a smooth dough and let it rest for about 30 minutes.","Mix chopped vegetables, ginger, soy sauce, and seasonings in a bowl to prepare the filling.","Roll the dough thinly, cut into squares, and place a small amount of filling in the center before folding and sealing.","Boil water, add wontons, and cook until they float, which takes about 5-7 minutes.","In a pot, heat sesame oil, sauté garlic, add vegetable broth, and bring to a boil before adding bok choy and cooked wontons.","Taste and adjust seasoning, then garnish with green onions and enjoy your warm soup."],"prepTime":30,"cookTime":15,"servings":4,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/api/recipes/87/image","youtubeUrl":"https://www.youtube.com/results?search_query=vegetable+wonton+soup+recipe+indian+vegetarian","authorId":"55882372","submittedBy":"genieflavour@gmail.com","submittedByName":"Haigreeva Kondury","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-10T16:29:48.220Z"},{"id":88,"title":"Rajasthani Panchmel Dal","description":"Rajasthani Panchmel Dal is a rich and nutritious blend of five different lentils, offering a hearty and flavorful dish.","ingredients":["1/4 cup Toor Dal","1/4 cup Moong Dal","1/4 cup Masoor Dal","1/4 cup Chana Dal","1/4 cup Urad Dal","2 tablespoons Ghee","1 teaspoon Cumin seeds","1-2 Green chilies","1-inch Ginger","2-3 Garlic cloves","1 medium Onion","2-3 medium Tomatoes","1/2 teaspoon Turmeric powder","1 teaspoon Red chili powder","1 teaspoon Coriander powder","Salt to taste","Fresh coriander leaves for garnish","Lemon wedges for serving"],"instructions":["Wash the lentils thoroughly and soak them for 30 minutes.","Pressure cook the soaked lentils with 4 cups of water and salt for about 3-4 whistles or until soft.","In a pan, heat ghee or oil.","Add cumin seeds and let them splutter.","Add green chilies, ginger, and garlic and sauté for a minute.","Add chopped onions and cook until they turn golden brown.","Stir in the chopped tomatoes, turmeric, red chili powder, and coriander powder and cook until the tomatoes are soft.","Once the lentils are cooked, add them to the tempering.","Adjust the consistency with water if needed and simmer for 5-10 minutes.","Garnish with fresh coriander leaves and serve hot with rice or Indian bread.","Add lemon wedges on the side for an extra zing."],"prepTime":30,"cookTime":30,"servings":4,"cuisineType":"Rajasthani","dietaryTags":[],"category":"main","imageUrl":"/api/recipes/88/image","youtubeUrl":"https://www.youtube.com/results?search_query=rajasthani+panchmel+dal+recipe+indian+vegetarian","authorId":"test-community-user","submittedBy":"test-community-user","submittedByName":"Priya Sharma","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-10T17:23:17.699Z"},{"id":228,"title":"Lasooni Palak","description":"Lasooni Palak is a flavorful Indian dish made with spinach and garlic, perfect for a nutritious meal.","ingredients":["2 cups fresh spinach, washed and chopped","6-8 cloves garlic, finely chopped","1 tablespoon oil or ghee","1 teaspoon cumin seeds","1 green chili, slit (optional)","Salt to taste","A squeeze of lemon juice"],"instructions":["Heat oil in a pan and add cumin seeds.","Once they crackle, add the chopped garlic and sauté until golden.","Add the green chili if using and the chopped spinach.","Cook until the spinach wilts down.","Season with salt, and stir well.","Cook for another 2-3 minutes.","Remove from heat and add a squeeze of lemon juice before serving."],"prepTime":10,"cookTime":10,"servings":4,"cuisineType":"North Indian","dietaryTags":[],"category":"main","imageUrl":"/api/recipes/228/image","youtubeUrl":"https://www.youtube.com/results?search_query=lasooni+palak+recipe+indian+vegetarian","authorId":"55882372","submittedBy":"55882372","submittedByName":"Haigreeva Kondury","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-17T10:26:22.491Z"},{"id":229,"title":"Kadai Paneer","description":"Paneer and capsicum tossed in a fierce, freshly ground kadai masala of whole spices — smoky, aromatic and vibrantly orange.","ingredients":["300g paneer, cubed","2 capsicums, cut into squares","2 onions, cubed","3 tomatoes, pureed","1 tbsp ginger-garlic paste","2 dried red chillies","1 tsp coriander seeds","1 tsp cumin seeds","½ tsp fennel seeds","½ tsp red chilli powder","1 tsp garam masala","2 tbsp oil","Salt to taste"],"instructions":["Dry roast coriander seeds, cumin and fennel. Grind coarsely — this is your kadai masala.","Heat oil. Add dried red chillies and onions. Cook on high heat.","Add ginger-garlic paste, then tomato puree. Cook until oil separates.","Add ground kadai masala, red chilli, salt. Cook 3 minutes.","Add capsicum and paneer. Toss on high heat 5 minutes.","Sprinkle garam masala and serve with roti."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kadai-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kadai%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.052Z"},{"id":230,"title":"Aviyal","description":"Kerala's mixed vegetable curry in a coconut-yogurt-turmeric coating finished with coconut oil and curry leaves — vegetarian at its most elegant.","ingredients":["3 cups mixed vegetables (raw banana, yam, carrot, beans, drumstick)","1 cup fresh coconut, grated","3 green chillies","1 tsp cumin seeds","½ cup yogurt","½ tsp turmeric","1 tbsp coconut oil","10 curry leaves","Salt to taste"],"instructions":["Cut all vegetables into batons 4cm long. Cook in a little salted water with turmeric until just tender.","Grind coconut, green chillies and cumin to a coarse paste.","Add coconut paste to the cooked vegetables. Mix gently.","Simmer 5 minutes. Remove from heat.","Beat yogurt smooth and stir in. Add coconut oil and curry leaves.","Serve immediately with rice."],"prepTime":20,"cookTime":25,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aviyal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aviyal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.077Z"},{"id":231,"title":"Kootu","description":"A dry-ish Tamil curry of vegetables or legumes with freshly ground coconut paste — thicker than a curry, more substantial than a stir-fry.","ingredients":["1 cup raw banana or yam, cubed","1 cup chickpeas or black-eyed peas, cooked","½ cup fresh coconut, grated","2 dried red chillies","1 tsp cumin seeds","½ tsp black pepper","½ tsp turmeric","1 tbsp coconut oil","1 tsp mustard seeds","10 curry leaves","Salt to taste"],"instructions":["Cook vegetables until tender. Add cooked legumes and turmeric.","Grind coconut, red chillies, cumin and pepper to a coarse paste with a little water.","Add coconut paste to the vegetables. Mix and simmer 8 minutes.","Make tadka: heat coconut oil, splutter mustard seeds and curry leaves.","Pour tadka over kootu. Serve with rice and sambar."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kootu.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kootu%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.089Z"},{"id":232,"title":"Thoran","description":"Kerala's dry stir-fry of finely shredded vegetables with coconut and mustard seeds — the perfect side for rice meals.","ingredients":["3 cups beans or cabbage or carrot, finely shredded","½ cup fresh coconut, grated","3 green chillies, chopped","½ tsp turmeric","1 tbsp coconut oil","1 tsp mustard seeds","10 curry leaves","2 shallots, sliced","Salt to taste"],"instructions":["Mix shredded vegetable with turmeric and salt. Set aside 10 minutes.","Heat coconut oil. Add mustard seeds and let them splutter.","Add shallots, green chillies and curry leaves. Sauté briefly.","Add the vegetable and stir-fry on medium-high heat for 5 minutes.","Add grated coconut. Toss everything together and cook 3 more minutes.","Serve as a side with rice."],"prepTime":15,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-thoran.png","youtubeUrl":"https://www.youtube.com/results?search_query=Thoran%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.093Z"},{"id":233,"title":"Upma","description":"A savoury semolina porridge with vegetables and mustard tempering — South India's most popular breakfast, ready in 20 minutes.","ingredients":["1 cup coarse semolina (rava)","1 onion, finely chopped","2 green chillies, chopped","1 carrot, finely diced","½ cup peas","2 tbsp oil","1 tsp mustard seeds","1 tsp chana dal","1 tsp urad dal","10 curry leaves","2½ cups water","Salt to taste","Lemon juice and coriander to finish"],"instructions":["Dry roast semolina until lightly golden and fragrant. Set aside.","Heat oil. Splutter mustard seeds. Add chana dal and urad dal, fry until golden.","Add curry leaves, green chillies and onion. Sauté until onion is soft.","Add carrots and peas. Cook 3 minutes.","Add water and salt. Bring to a boil.","Slowly pour in semolina, stirring continuously. Cook 5 minutes until thick.","Finish with lemon juice and coriander."],"prepTime":5,"cookTime":20,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-upma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Upma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.096Z"},{"id":234,"title":"Poha","description":"Flattened rice flakes tossed with onions, mustard seeds, turmeric and lime — Maharashtra's quintessential breakfast, light and nourishing.","ingredients":["2 cups thick poha (flattened rice)","1 onion, finely chopped","2 green chillies, finely chopped","1 tsp mustard seeds","½ tsp turmeric","10 curry leaves","2 tbsp oil","¼ cup roasted peanuts","1 tsp sugar","Lime juice and fresh coriander to finish","Salt to taste"],"instructions":["Rinse poha gently in a colander until just soft. Drain. Sprinkle turmeric and sugar. Mix gently.","Heat oil. Splutter mustard seeds and curry leaves.","Add green chillies and onion. Sauté until translucent.","Add peanuts and stir briefly.","Add poha. Toss gently until everything is combined and heated through.","Finish with lime juice and coriander. Serve immediately."],"prepTime":10,"cookTime":10,"servings":3,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-poha.png","youtubeUrl":"https://www.youtube.com/results?search_query=Poha%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.100Z"},{"id":235,"title":"Dhokla","description":"Soft, spongy and tangy steamed chickpea flour cakes from Gujarat, topped with a mustard-green chilli tempering and coconut.","ingredients":["1½ cups chickpea flour","1 cup yogurt","1 tsp ginger-green chilli paste","1 tbsp lemon juice","1 tsp Eno fruit salt","½ tsp turmeric","1 tsp sugar","For tadka: 2 tbsp oil","1 tsp mustard seeds","2 green chillies, slit","1 tsp sesame seeds","10 curry leaves","Fresh coconut and coriander to garnish","Salt to taste"],"instructions":["Mix chickpea flour, yogurt, ginger-chilli paste, lemon juice, turmeric, sugar and salt. Mix smooth.","Grease a steaming tray. Just before steaming, add Eno and 2 tbsp water. Mix and pour immediately.","Steam for 20 minutes. Cool 5 minutes, then cut into squares.","Make tadka: heat oil, splutter mustard seeds, add green chillies, sesame and curry leaves.","Pour tadka over dhokla. Garnish with coconut and coriander."],"prepTime":10,"cookTime":25,"servings":6,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dhokla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dhokla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.103Z"},{"id":236,"title":"Thepla","description":"Soft, spiced Gujarati flatbreads made with fenugreek leaves — a beloved travel food and breakfast that stays soft for days.","ingredients":["2 cups whole wheat flour","1 cup fresh fenugreek leaves, finely chopped","2 tbsp yogurt","½ tsp turmeric","½ tsp red chilli powder","½ tsp cumin seeds","1 tsp sesame seeds","1 tbsp oil","Salt to taste","Oil for cooking"],"instructions":["Mix flour, fenugreek, yogurt, spices, sesame seeds and salt. Add enough water to make a soft dough.","Add oil and knead 5 minutes.","Divide into balls. Roll into thin circles.","Cook on a hot tawa with a little oil, pressing with a cloth until both sides have golden spots.","Serve with yogurt, pickle or a cup of chai."],"prepTime":15,"cookTime":20,"servings":4,"cuisineType":"Gujarati","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-thepla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Thepla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.106Z"},{"id":237,"title":"Stuffed Bhindi","description":"Okra slit and filled with a tangy masala of coconut, coriander and spices, then pan-fried until crisp — a brilliant way to cook bhindi.","ingredients":["500g okra (bhindi)","½ cup fresh coconut, grated","1 tsp coriander powder","1 tsp cumin powder","½ tsp red chilli powder","½ tsp amchur","½ tsp turmeric","1 tbsp oil","Salt to taste"],"instructions":["Wash and dry okra thoroughly. Slit lengthwise without cutting through.","Mix coconut, all spices and salt to make the stuffing.","Fill each okra with the stuffing.","Heat oil in a wide pan. Place okra in a single layer. Cook on medium heat.","Turn gently every 3 minutes until okra is tender and slightly crispy on all sides — about 15 minutes.","Serve as a side with dal and roti."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-stuffed-bhindi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Stuffed%20Bhindi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.112Z"},{"id":238,"title":"Lauki Kofta","description":"Soft bottle gourd dumplings in a smooth, mildly spiced tomato gravy — a delicate dish that showcases humble vegetables at their finest.","ingredients":["500g bottle gourd, grated","½ cup chickpea flour","1 tsp ginger, grated","1 green chilli, chopped","½ tsp red chilli powder","For gravy: 2 onions","3 tomatoes","1 tsp ginger-garlic paste","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","2 tbsp oil","Salt to taste","Oil for deep frying"],"instructions":["Squeeze out water from grated lauki. Mix with chickpea flour, ginger, chilli, salt and red chilli.","Shape into balls and deep-fry until golden. Drain.","For gravy: purée onions and tomatoes. Heat oil. Cook onion-tomato purée with ginger-garlic paste and spices until oil separates.","Add 1 cup water and simmer 10 minutes.","Add koftas just before serving. Simmer 3 minutes and serve."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-lauki-kofta.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lauki%20Kofta%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.117Z"},{"id":239,"title":"Chilli Paneer","description":"Indo-Chinese fried paneer tossed with capsicum, spring onions and a spicy soy-chilli sauce — the most popular starter in every Indian Chinese restaurant.","ingredients":["300g paneer, cubed","1 capsicum, diced","1 onion, diced","3 green chillies, slit","1 tbsp ginger-garlic paste","3 tbsp soy sauce","2 tbsp tomato ketchup","1 tbsp chilli sauce","1 tbsp cornflour mixed with water","2 tbsp oil","Spring onions to garnish","Salt and pepper"],"instructions":["Dust paneer lightly with cornflour. Shallow-fry until golden on all sides. Drain.","Heat oil in a wok. Add ginger-garlic paste, green chillies and onion on high heat.","Add capsicum. Toss on high heat 2 minutes.","Mix soy sauce, ketchup and chilli sauce. Add to the wok.","Add cornflour slurry and stir until sauce thickens.","Add fried paneer and toss to coat. Garnish with spring onions."],"prepTime":15,"cookTime":20,"servings":4,"cuisineType":"Fusion","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-chilli-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chilli%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.121Z"},{"id":240,"title":"Manchurian Cauliflower","description":"Crispy fried cauliflower florets in a dark, tangy Manchurian sauce — the vegetarian hero of India's beloved fusion Chinese cooking.","ingredients":["1 small cauliflower, cut into florets","For batter: ½ cup flour","¼ cup cornflour","½ tsp soy sauce","For sauce: 1 onion, diced","1 tbsp ginger-garlic paste","3 tbsp soy sauce","2 tbsp tomato ketchup","1 tbsp chilli sauce","1 tsp cornflour mixed in water","2 tbsp oil","Spring onions to garnish"],"instructions":["Make a batter with flour, cornflour, soy sauce and water. Coat cauliflower.","Deep fry until golden and crisp. Drain.","Heat oil in a wok. Fry onion and ginger-garlic paste on high heat.","Add all sauces. Stir and add cornflour slurry. Cook until sauce coats a spoon.","Add fried cauliflower. Toss. Serve immediately."],"prepTime":15,"cookTime":25,"servings":4,"cuisineType":"Fusion","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-manchurian-cauliflower.png","youtubeUrl":"https://www.youtube.com/results?search_query=Cauliflower%20Manchurian%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.124Z"},{"id":241,"title":"Idli","description":"Soft, steamed rice and lentil cakes that are the foundation of South Indian breakfast — gentle, nourishing and endlessly versatile.","ingredients":["2 cups idli rice","1 cup urad dal","1 tsp fenugreek seeds","Salt to taste"],"instructions":["Soak rice, urad dal and fenugreek seeds separately for 6 hours.","Grind urad dal to a very fluffy, light batter. Grind rice coarsely. Mix both and add salt.","Ferment in a warm place for 8–10 hours until batter doubles in volume.","Grease idli moulds. Pour batter. Steam for 12 minutes.","Cool 2 minutes before unmoulding. Serve with sambar and chutneys."],"prepTime":840,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-idli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Idli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.128Z"},{"id":242,"title":"Puttu","description":"Kerala's steamed breakfast cylinders of coarsely ground rice flour layered with coconut — eaten with banana or kadala curry.","ingredients":["2 cups puttu podi (coarsely ground rice flour)","1 cup fresh coconut, grated","½ tsp salt","Water to moisten"],"instructions":["Sprinkle salted water over puttu podi and rub until it resembles coarse, moistened sand. It should hold shape when pressed.","Fill the puttu maker (or perforated tin): alternate layers of coconut and rice flour mixture.","Steam for 5–7 minutes until steam comes through the top.","Turn out onto a plate. Serve with ripe banana and kadala curry."],"prepTime":10,"cookTime":10,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-puttu.png","youtubeUrl":"https://www.youtube.com/results?search_query=Puttu%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.131Z"},{"id":243,"title":"Kadala Curry","description":"Kerala's black chickpea curry in a coconut-based gravy — the traditional companion to puttu and appam at breakfast.","ingredients":["1 cup black chickpeas (kala chana), soaked overnight","1 cup fresh coconut, grated","2 dried red chillies","1 tsp coriander seeds","½ tsp black pepper","2 onions, sliced","2 tomatoes, chopped","1 tsp ginger paste","½ tsp turmeric","1 tbsp coconut oil","1 tsp mustard seeds","10 curry leaves","Salt to taste"],"instructions":["Pressure-cook black chickpeas until soft.","Dry roast coconut, red chillies, coriander seeds and pepper until coconut is golden. Grind to a smooth paste.","Heat coconut oil. Add mustard seeds and curry leaves. Add onions and ginger. Cook until golden.","Add tomatoes and turmeric. Cook until soft.","Add cooked chickpeas and coconut paste. Simmer 15 minutes.","Serve with puttu or appam."],"prepTime":480,"cookTime":40,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kadala-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kadala%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.134Z"},{"id":244,"title":"Appam","description":"Lacy, thin-edged Kerala bowl crepes with a soft, spongy centre — fermented rice and coconut make this a uniquely beautiful breakfast bread.","ingredients":["2 cups raw rice, soaked 6 hours","½ cup cooked rice","½ cup fresh coconut, grated","1 tsp dry yeast","1 tsp sugar","½ tsp salt","Water as needed"],"instructions":["Grind soaked raw rice, cooked rice and coconut together with a little water to a smooth batter.","Mix yeast and sugar in warm water. Add to batter. Ferment overnight.","Add salt and adjust consistency to a thin, pourable batter.","Heat an appam pan (or non-stick wok). Pour a ladle and swirl the pan to spread.","Cover and cook on medium-low heat for 3 minutes until edges are lacy and centre is cooked.","Serve with coconut milk or kadala curry."],"prepTime":600,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-appam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Appam%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.138Z"},{"id":245,"title":"Aloo Ki Sabzi","description":"Simple, everyday spiced potatoes made with cumin, coriander and amchur — a humble side that goes with everything.","ingredients":["5 medium potatoes, boiled and roughly mashed","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp amchur","½ tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Heat oil. Add cumin seeds and let them splutter.","Add turmeric and then potatoes. Toss to coat.","Add coriander powder, amchur, red chilli and salt.","Cook on medium heat, tossing every 2 minutes, for 10 minutes.","Garnish with coriander. Serve with puri or roti."],"prepTime":5,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Ki%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.142Z"},{"id":246,"title":"Chana Dal","description":"Split chickpea dal tempered with ghee, cumin and asafoetida — wholesome, protein-rich and deeply comforting.","ingredients":["1 cup chana dal","1 onion, finely chopped","2 tomatoes, chopped","1 tsp ginger-garlic paste","½ tsp turmeric","1 tsp coriander powder","½ tsp garam masala","2 tbsp ghee","1 tsp cumin seeds","2 dried red chillies","A pinch of asafoetida","Salt to taste"],"instructions":["Pressure-cook chana dal with turmeric and water for 3 whistles.","Heat ghee. Add cumin seeds, dried red chillies and asafoetida.","Add onions and cook until golden. Add ginger-garlic paste and tomatoes. Cook until oil separates.","Add cooked dal and salt. Simmer 10 minutes. Add garam masala.","Serve with rice or roti."],"prepTime":10,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-chana-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chana%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.145Z"},{"id":247,"title":"Arhar Dal","description":"Toor dal — the everyday lentil of most Indian homes — tempered with mustard, tomatoes and curry leaves. Warm and nourishing.","ingredients":["1 cup toor dal","2 tomatoes, chopped","1 tsp ginger, grated","2 green chillies","½ tsp turmeric","1 tbsp ghee","1 tsp mustard seeds","10 curry leaves","2 dried red chillies","A pinch of asafoetida","Fresh coriander","Salt to taste"],"instructions":["Pressure-cook toor dal with tomatoes, green chillies, ginger and turmeric for 3–4 whistles. Mash.","Add salt and bring to a simmer.","Heat ghee. Splutter mustard seeds, then curry leaves, dried red chillies and asafoetida.","Pour tadka over dal. Garnish with coriander.","Serve with steamed rice and ghee."],"prepTime":5,"cookTime":25,"servings":4,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-arhar-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Arhar%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.148Z"},{"id":248,"title":"Green Moong Dal","description":"Whole green mung beans in a light, garlicky tomato broth — clean, fresh and surprisingly filling.","ingredients":["1 cup whole green moong dal","2 tomatoes, chopped","1 tbsp ginger-garlic paste","½ tsp turmeric","1 tsp coriander powder","½ tsp garam masala","1 tbsp oil","1 tsp cumin seeds","Salt to taste","Lemon juice and coriander"],"instructions":["Soak moong dal 2 hours. Pressure-cook with turmeric for 3 whistles.","Heat oil. Add cumin seeds, then ginger-garlic paste and tomatoes. Cook until oil separates.","Add spices and cooked dal. Simmer 10 minutes.","Finish with lemon juice and coriander."],"prepTime":120,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-green-moong-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Green%20Moong%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.152Z"},{"id":249,"title":"Chana Saag","description":"Chickpeas and spinach simmered in a robust onion-tomato masala — hearty, nutritious and a delicious variation on the classic chana.","ingredients":["2 cups chickpeas, boiled","3 cups spinach, roughly chopped","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","2 tbsp oil","Salt to taste"],"instructions":["Heat oil. Add cumin seeds, then onions. Cook until golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add spices and chickpeas. Cook 5 minutes.","Add spinach and stir until wilted. Simmer 10 minutes.","Serve with roti or rice."],"prepTime":480,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-chana-saag.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chana%20Saag%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.155Z"},{"id":250,"title":"Moong Dal Chilla","description":"Savoury moong dal pancakes stuffed with spiced paneer — a high-protein, gluten-free breakfast or snack ready in 20 minutes.","ingredients":["1 cup yellow moong dal, soaked 3 hours","1 tsp ginger, grated","2 green chillies","½ tsp turmeric","Salt to taste","For stuffing: 100g paneer, crumbled","1 tbsp coriander, chopped","½ tsp cumin powder","Oil for cooking"],"instructions":["Grind soaked moong dal with ginger, green chillies and a little water to a smooth batter. Add turmeric and salt.","Mix paneer with coriander, cumin and salt for the stuffing.","Heat a non-stick pan. Pour a ladle of batter and spread thin.","Place stuffing on one half. Fold over and cook with oil until golden on both sides.","Serve with green chutney."],"prepTime":180,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-moong-dal-chilla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Moong%20Dal%20Chilla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.160Z"},{"id":251,"title":"Thalipeeth","description":"A multigrain savoury pancake from Maharashtra made with bhajani flour, vegetables and spices — crisp, satisfying and nutritious.","ingredients":["1½ cups bhajani flour (or mix of rice, jowar, bajra, wheat flours)","1 onion, finely chopped","2 tbsp coriander, chopped","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","Salt to taste","Oil for cooking"],"instructions":["Mix bhajani flour, onion, coriander, cumin, turmeric, red chilli and salt. Add water to make a firm dough.","Take a portion and flatten on a greased plastic sheet or damp cloth.","Transfer to a hot tawa. Make a small hole in the centre.","Drizzle oil around the edges and in the hole. Cook on medium heat until crispy on both sides.","Serve with yogurt and loni (white butter)."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-thalipeeth.png","youtubeUrl":"https://www.youtube.com/results?search_query=Thalipeeth%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.163Z"},{"id":252,"title":"Litti Chokha","description":"Bihar's pride — baked wheat dumplings filled with roasted sattu paste, served with charcoal-roasted vegetable mash.","ingredients":["For litti: 2 cups whole wheat flour","1 tbsp ghee","For filling: 1 cup sattu (roasted chana flour)","1 tbsp mustard oil","1 tsp ajwain","1 tsp kalonji","1 tsp lemon juice","Chopped green chillies and coriander","For chokha: 2 large aubergines (brinjal)","2 tomatoes","2 potatoes","Chopped onion","Mustard oil and spices"],"instructions":["Mix sattu with mustard oil, ajwain, kalonji, lemon juice, green chillies, coriander and salt. Filling should be crumbly.","Make wheat dough. Rest 20 minutes. Divide into balls. Stuff each ball with sattu filling and seal.","Bake in a preheated oven at 200°C for 25–30 minutes, turning once, or cook on a coal fire.","Roast brinjal, tomatoes and potatoes directly on the flame. Peel, mash with onion, mustard oil and spices for chokha.","Dip litti in ghee and serve with chokha."],"prepTime":30,"cookTime":40,"servings":4,"cuisineType":"East Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-litti-chokha.png","youtubeUrl":"https://www.youtube.com/results?search_query=Litti%20Chokha%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.166Z"},{"id":253,"title":"Aloo Dum","description":"Baby potatoes slow-cooked in a thick, spiced tomato gravy — the Kolkata version with fennel seeds and the Kashmiri version with yogurt are both transcendent.","ingredients":["500g baby potatoes, boiled and peeled","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp fennel seeds","1 tsp coriander powder","½ tsp garam masala","½ tsp red chilli powder","½ tsp turmeric","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Prick baby potatoes all over with a fork. Shallow-fry until golden on all sides.","Heat oil in the same pan. Add cumin and fennel seeds. Add onions and cook until deep golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add all spices and fried potatoes. Toss well. Add ½ cup water.","Cover and cook on low heat 20 minutes. Garnish and serve."],"prepTime":15,"cookTime":40,"servings":4,"cuisineType":"East Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-dum.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Dum%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.170Z"},{"id":254,"title":"Shorshe Ilish","description":"A beloved Bengali mustard-based curry — made vegan here with raw banana instead of hilsa fish, capturing all the pungent, aromatic flavour.","ingredients":["4 slices raw banana (or raw jackfruit), lightly fried","3 tbsp yellow mustard seeds","2 tbsp poppy seeds","4 green chillies","½ tsp turmeric","½ tsp red chilli powder","3 tbsp mustard oil","Salt to taste"],"instructions":["Soak mustard seeds and poppy seeds in water 30 minutes. Grind with green chillies and a little water to a smooth paste.","Heat mustard oil to smoking. Cool slightly.","Add the mustard paste. Cook on low heat 5 minutes, stirring.","Add turmeric, red chilli and salt. Add ½ cup water.","Add fried raw banana slices. Cover and cook 15 minutes on low heat.","Serve with steamed rice."],"prepTime":35,"cookTime":25,"servings":4,"cuisineType":"East Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-shorshe-ilish.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shorshe%20Baingan%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.173Z"},{"id":255,"title":"Coconut Rice","description":"Fragrant rice tossed with fresh coconut, mustard seeds and cashews — a simple, festive preparation from coastal South India.","ingredients":["2 cups cooked rice","1 cup fresh coconut, grated","2 tbsp oil","1 tsp mustard seeds","10 curry leaves","3 dried red chillies","¼ cup cashews","1 tsp chana dal","A pinch of asafoetida","Salt to taste"],"instructions":["Heat oil. Fry cashews until golden. Add mustard seeds, curry leaves, red chillies, chana dal and asafoetida.","Add grated coconut and fry 3 minutes.","Add rice and salt. Toss well.","Serve as a main or side."],"prepTime":5,"cookTime":10,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-coconut-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Coconut%20Rice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.177Z"},{"id":256,"title":"Tomato Rice","description":"Spiced tomato rice — a one-pot meal of rice cooked with tomatoes, onions and South Indian spices — tangy, aromatic and deeply comforting.","ingredients":["1 cup basmati rice","3 tomatoes, finely chopped","1 onion, finely chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","10 curry leaves","2 tbsp oil","Salt to taste"],"instructions":["Heat oil. Add cumin seeds and curry leaves. Add onion and cook until golden.","Add ginger-garlic paste and tomatoes. Cook until tomatoes are completely pulpy.","Add spices and washed rice. Stir to coat.","Add 1¾ cups water and salt. Bring to a boil. Cover and cook on low heat 15 minutes.","Rest 5 minutes. Fluff and serve."],"prepTime":5,"cookTime":25,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-tomato-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tomato%20Rice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.181Z"},{"id":257,"title":"Vangi Bath","description":"Karnataka's aubergine rice cooked with a special spice paste — a hearty, aromatic one-pot meal with deep South Indian flavours.","ingredients":["1 cup rice, cooked","2 small aubergines, cubed","2 tbsp vangi bath powder","1 tbsp tamarind paste","1 tbsp oil","1 tsp mustard seeds","10 curry leaves","A pinch of asafoetida","Salt to taste","Roasted peanuts to garnish"],"instructions":["Heat oil. Splutter mustard seeds, curry leaves and asafoetida. Add aubergine and cook until tender.","Add tamarind paste and vangi bath powder. Stir and cook 5 minutes.","Add rice and toss gently to combine.","Garnish with roasted peanuts. Serve with raita."],"prepTime":10,"cookTime":20,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-vangi-bath.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vangi%20Bath%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.184Z"},{"id":258,"title":"Kathi Roll","description":"Flaky paratha rolled up with spiced paneer, onions and chutneys — Kolkata's greatest street food contribution, now loved nationwide.","ingredients":["For paratha: 2 cups flour","Ghee","For filling: 200g paneer, sliced","1 capsicum, sliced","1 onion, sliced","1 tbsp ginger-garlic paste","1 tsp cumin powder","1 tsp coriander powder","½ tsp garam masala","½ tsp red chilli powder","Green chutney","Tamarind chutney","Sliced onion with lemon and chaat masala"],"instructions":["Make a soft paratha dough. Roll and cook parathas with ghee until flaky.","Sauté paneer, capsicum and onion with spices on high heat until slightly charred.","Spread green chutney on the paratha. Place paneer filling in the centre.","Top with raw onion salad. Drizzle tamarind chutney.","Roll tightly in foil. Serve hot."],"prepTime":20,"cookTime":25,"servings":4,"cuisineType":"East Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-kathi-roll.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kathi%20Roll%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.188Z"},{"id":259,"title":"Ragda Pattice","description":"Mumbai chaat legend — crispy potato patties on a bed of white pea ragda, topped with chutneys, onion and sev.","ingredients":["For pattice: 3 potatoes, boiled and mashed","Salt and pepper","For ragda: 1 cup white peas (vatana), soaked and boiled","1 tsp cumin seeds","½ tsp turmeric","2 tomatoes","Salt","For topping: tamarind chutney","Green chutney","Sev","Chopped onion","Chaat masala and coriander"],"instructions":["Make ragda: boil white peas. Cook with cumin, tomatoes, turmeric and salt until thick.","Season mashed potato. Shape into flat patties. Shallow-fry until golden on both sides.","Serve patties on a plate. Ladle ragda over them.","Top with both chutneys, onion, sev and chaat masala.","Serve immediately."],"prepTime":480,"cookTime":35,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-ragda-pattice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Ragda%20Pattice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.191Z"},{"id":260,"title":"Sev Puri","description":"Tiny flat puri crisps topped with potato, chutneys, onion and sev — perhaps the most popular chaat after pani puri.","ingredients":["20 flat puri crisps (or mini papdi)","2 potatoes, boiled and cubed","1 onion, finely chopped","Tamarind chutney","Green chutney","Thin sev","Chaat masala","Red chilli powder","Fresh coriander","Pomegranate seeds"],"instructions":["Arrange puri crisps on a serving plate.","Top each puri with a little potato, onion and coriander.","Drizzle tamarind and green chutneys generously.","Sprinkle chaat masala and red chilli.","Top with a generous shower of sev and pomegranate seeds. Serve immediately."],"prepTime":10,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-sev-puri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sev%20Puri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.195Z"},{"id":261,"title":"Pani Puri","description":"Hollow crispy spheres filled with spiced potato and dipped in icy mint-tamarind water — the king of Indian street food, one pierces your mouth with flavour.","ingredients":["24 puri shells (store-bought or homemade)","For pani: 1 cup mint leaves","½ cup coriander leaves","2 green chillies","1 tbsp tamarind paste","1 tsp cumin powder","1 tsp black salt","1 tsp chaat masala","3 cups chilled water","For filling: 2 potatoes, boiled and mashed","1 cup kala chana, boiled","1 tsp chaat masala"],"instructions":["Blend mint, coriander, green chillies, tamarind, cumin, black salt and chaat masala with 1 cup water. Strain. Add remaining cold water.","Mash potatoes with boiled chana and chaat masala for the filling.","Make a hole in each puri. Fill with a little potato mixture.","Dip immediately into the pani and eat in one bite."],"prepTime":20,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-pani-puri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pani%20Puri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.198Z"},{"id":262,"title":"Dahi Puri","description":"Hollow puri shells filled with potato and chickpea, then smothered with sweetened yogurt, chutneys and sev — the gentler cousin of pani puri.","ingredients":["20 hollow puri shells","2 potatoes, boiled and mashed","½ cup kala chana, boiled","1½ cups thick yogurt","1 tsp sugar","Tamarind chutney","Green chutney","Sev","Chaat masala","Red chilli powder","Coriander and pomegranate"],"instructions":["Sweeten yogurt with sugar. Beat smooth.","Make a hole in each puri. Fill with potato and chana.","Spoon sweetened yogurt over the puris.","Drizzle both chutneys generously.","Sprinkle chaat masala, red chilli, sev, pomegranate and coriander. Serve immediately."],"prepTime":10,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dahi-puri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dahi%20Puri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.201Z"},{"id":263,"title":"Kachori","description":"Flaky deep-fried pastry shells filled with spiced moong dal paste — Rajasthan's great contribution to Indian snack culture.","ingredients":["For dough: 2 cups all-purpose flour","3 tbsp oil","For filling: 1 cup moong dal, soaked and coarsely ground","1 tsp cumin seeds","1 tsp fennel seeds","½ tsp red chilli powder","½ tsp amchur","1 tsp coriander powder","Oil for deep frying","Salt to taste"],"instructions":["Mix flour, oil and salt with water to make a firm dough. Rest 20 minutes.","Dry cook ground moong dal in a pan with oil and all spices until dry and fragrant.","Roll dough into circles. Place filling. Seal into balls.","Deep-fry on low-medium heat, turning continuously, until golden and crisp.","Serve with tamarind chutney."],"prepTime":30,"cookTime":25,"servings":6,"cuisineType":"Rajasthani","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-kachori.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kachori%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.204Z"},{"id":264,"title":"Samosa","description":"The world's most recognised Indian snack — flaky pastry filled with spiced potatoes and peas, deep-fried to golden perfection.","ingredients":["For dough: 2 cups all-purpose flour","3 tbsp oil","½ tsp ajwain","For filling: 4 potatoes, boiled and cubed","½ cup peas","1 tsp cumin seeds","1 tsp coriander powder","½ tsp amchur","½ tsp garam masala","½ tsp red chilli powder","Fresh coriander","Oil for deep frying","Salt to taste"],"instructions":["Mix flour, oil, ajwain and salt. Add water and knead into a firm, stiff dough. Rest 20 minutes.","Make filling: heat 1 tbsp oil, add cumin seeds, add potatoes, peas and all spices. Cool.","Divide dough and roll into circles. Cut into half-moons. Form into cones, fill and seal.","Deep-fry on medium heat, turning, until golden and crisp — about 12 minutes.","Serve with mint chutney and tamarind chutney."],"prepTime":30,"cookTime":20,"servings":6,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-samosa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Samosa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.208Z"},{"id":265,"title":"Palak Soup","description":"A smooth, velvety spinach soup with garlic and cream — light enough for a starter, satisfying enough for a meal.","ingredients":["400g fresh spinach","1 onion, chopped","3 garlic cloves","1 cup vegetable broth","½ cup cream","1 tsp cumin","2 tbsp butter","Salt and pepper","Croutons to serve"],"instructions":["Melt butter. Sauté onion and garlic until soft.","Add spinach and broth. Cook 5 minutes.","Blend smooth. Return to heat.","Add cumin, cream, salt and pepper. Simmer 5 minutes.","Serve with croutons."],"prepTime":10,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-palak-soup.png","youtubeUrl":"https://www.youtube.com/results?search_query=Palak%20Soup%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.212Z"},{"id":266,"title":"Tomato Shorba","description":"A light, spiced Indian tomato broth with ginger, cumin and black pepper — a warming soup from royal Mughal kitchens.","ingredients":["6 ripe tomatoes, roughly chopped","1 onion, chopped","2 garlic cloves","1 inch ginger","1 tsp cumin seeds","½ tsp black pepper","½ tsp red chilli powder","2 cups vegetable broth","1 tbsp ghee","1 tsp sugar","Fresh coriander","Salt to taste"],"instructions":["Cook tomatoes, onion, garlic and ginger in broth until completely soft. Blend and strain.","Heat ghee. Add cumin seeds. Add the strained tomato broth.","Add spices, sugar and salt. Simmer 10 minutes.","Garnish with coriander and cream. Serve hot."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-tomato-shorba.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tomato%20Shorba%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.215Z"},{"id":267,"title":"Mulligatawny Soup","description":"The Anglo-Indian pepper soup with lentils, apple and coconut milk — born in the colonial era and still deeply loved.","ingredients":["½ cup red lentils","1 apple, peeled and chopped","1 onion, chopped","2 garlic cloves","1 tbsp curry powder","½ tsp turmeric","1 can coconut milk","3 cups vegetable broth","1 tbsp oil","Lemon juice","Salt to taste","Coriander to garnish"],"instructions":["Heat oil. Cook onion and garlic until soft. Add curry powder and turmeric.","Add apple, lentils and broth. Cook 25 minutes until lentils are soft.","Blend until smooth.","Return to heat. Add coconut milk and salt. Simmer 5 minutes.","Finish with lemon juice and coriander."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"Fusion","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mulligatawny-soup.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mulligatawny%20Soup%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.219Z"},{"id":268,"title":"Vegetable Jalfrezi","description":"A stir-fried toss of vegetables in a spicy, tangy tomato sauce with ginger and capsicum — vibrant, colourful and ready quickly.","ingredients":["1 carrot, cut into batons","1 capsicum, sliced","100g paneer, sliced","1 onion, sliced","2 tomatoes, chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","1 tsp garam masala","½ tsp turmeric","1 tsp red chilli powder","2 tbsp oil","Salt to taste"],"instructions":["Blanch carrots briefly. Heat oil on high heat.","Add cumin seeds. Add onion and cook until slightly charred.","Add ginger-garlic paste. Add tomatoes. Cook 3 minutes.","Add all spices. Add vegetables and paneer.","Toss on high heat 5 minutes until vegetables are slightly charred and sauce coats them.","Serve with naan."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-vegetable-jalfrezi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vegetable%20Jalfrezi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.223Z"},{"id":269,"title":"Paneer Pasanda","description":"Thin paneer slices sandwiched with a savoury nut stuffing, dipped in a golden batter and cooked in a royal Mughlai gravy.","ingredients":["300g paneer, sliced and stuffed with dried fruit and nut mixture","For gravy: 1 cup cashew paste","2 onions, pureed","1 tbsp ginger-garlic paste","½ cup yogurt","1 tsp garam masala","½ tsp turmeric","½ tsp red chilli powder","2 tbsp ghee","Saffron milk","Fresh cream","Salt to taste"],"instructions":["Stuff paneer slices with a mixture of chopped cashews, raisins and spices. Sandwich two pieces.","Shallow fry the stuffed paneer until golden. Set aside.","Make gravy: heat ghee. Cook onion puree until golden. Add ginger-garlic paste.","Add yogurt, cashew paste and all spices. Cook until oil separates.","Add saffron milk and cream. Simmer 5 minutes. Add paneer pasanda.","Serve with naan."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-pasanda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Pasanda%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.226Z"},{"id":270,"title":"Kofta Curry","description":"Soft vegetable and paneer dumplings in a rich tomato-cashew gravy — an elegant vegetarian take on the classic Indian meatball curry.","ingredients":["For kofta: 200g paneer","2 potatoes, boiled","½ cup spinach, blanched and chopped","1 tsp garam masala","Cornflour for binding","Oil for frying","For gravy: 2 onions, pureed","3 tomatoes, pureed","1 tbsp ginger-garlic paste","½ cup cashew paste","1 tsp coriander powder","1 tsp garam masala","½ tsp red chilli powder","½ tsp turmeric","2 tbsp oil"],"instructions":["Mix paneer, potato and spinach with garam masala and salt. Bind with cornflour. Shape into balls. Deep fry until golden.","Make gravy: cook onion puree until golden. Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add cashew paste and all spices. Simmer 10 minutes with ½ cup water.","Add koftas just before serving. Simmer 3 minutes.","Serve with naan."],"prepTime":25,"cookTime":45,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kofta-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kofta%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.229Z"},{"id":271,"title":"Achari Paneer","description":"Paneer cubes tossed in a sharp, tangy pickling spice masala of mustard, fenugreek and fennel — bold and unlike any other paneer dish.","ingredients":["300g paneer, cubed","1 tsp each: mustard seeds, fennel seeds, fenugreek seeds, kalonji, cumin seeds","3 tomatoes, pureed","1 onion, finely chopped","1 tbsp ginger-garlic paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp amchur","2 tbsp mustard oil","Salt to taste"],"instructions":["Heat mustard oil to smoking. Let cool slightly. Coarsely grind all 5 whole spices.","Sauté onion until golden. Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add turmeric, red chilli, amchur and the ground spice blend. Cook 2 minutes.","Add paneer. Toss and cook 5 minutes.","Serve with lachha paratha."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-achari-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Achari%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.232Z"},{"id":272,"title":"Hara Bhara Kabab","description":"Emerald-green spinach and peas patties with paneer and mild spices — a showstopping green starter that is also nutritious.","ingredients":["2 cups spinach, blanched and squeezed dry","1 cup peas, boiled and mashed","2 potatoes, boiled and mashed","100g paneer, crumbled","1 tsp cumin powder","1 tsp garam masala","1 tbsp cornflour","1 green chilli","Fresh coriander","Oil for shallow frying","Salt to taste"],"instructions":["Blend spinach, peas, green chilli and coriander to a coarse paste.","Mix with mashed potato, paneer, spices and cornflour. Season.","Shape into flat, round patties.","Shallow-fry on medium heat until crispy and deep green on both sides.","Serve with mint chutney."],"prepTime":20,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-hara-bhara-kabab.png","youtubeUrl":"https://www.youtube.com/results?search_query=Hara%20Bhara%20Kabab%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.236Z"},{"id":273,"title":"Mushroom Masala","description":"Button mushrooms in a rich, smoky onion-tomato masala — ready in 20 minutes and absolutely delicious with roomali roti.","ingredients":["400g button mushrooms, halved","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","1 tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Heat oil. Add cumin seeds. Add onions and cook until deep golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates, about 10 minutes.","Add all spices. Cook 2 minutes.","Add mushrooms. Toss and cook on high heat 8 minutes until mushrooms are cooked and slightly golden.","Garnish and serve."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mushroom-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mushroom%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.239Z"},{"id":274,"title":"Butter Paneer Masala","description":"Paneer in a makhani-style buttery tomato gravy made with cream and whole spices — the vegetarian answer to butter chicken.","ingredients":["300g paneer, cubed","For gravy: 5 tomatoes","2 onions","½ cup cashews","1 tbsp ginger-garlic paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander powder","½ tsp garam masala","3 tbsp butter","½ cup cream","1 tsp sugar","Salt to taste"],"instructions":["Boil tomatoes, onions and cashews together. Blend to a smooth purée.","Melt butter. Add ginger-garlic paste. Add tomato purée and cook 15 minutes, stirring.","Add all spices and sugar. Simmer 5 minutes.","Add cream and paneer. Simmer 5 minutes on low heat.","Serve with naan or paratha."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-butter-paneer-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Butter%20Paneer%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.242Z"},{"id":275,"title":"Neer Dosa","description":"Kerala-Karnataka's paper-thin lacy water crepe made with just rice and coconut — delicate, soft and the most elegant of all dosas.","ingredients":["1 cup raw rice, soaked 4 hours","¼ cup fresh coconut, grated","½ tsp salt","Water to thin the batter"],"instructions":["Drain rice and grind with coconut to an extremely thin, smooth batter. Add salt and enough water so it is almost as thin as milk.","Heat a dosa tawa. Pour a ladle of batter and quickly swirl the pan.","The batter will spread into a very thin crepe. Tiny holes will form.","Cover and cook on low heat for 1 minute. Do not flip.","Fold gently and serve with coconut chutney and sambar."],"prepTime":250,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-neer-dosa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Neer%20Dosa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.247Z"},{"id":276,"title":"Kanda Bhaji","description":"Crispy, lacy onion fritters made with chickpea flour — Maharashtra's favourite monsoon snack with a cup of masala chai.","ingredients":["3 large onions, thinly sliced","1 cup chickpea flour","2 green chillies, finely chopped","10 curry leaves, chopped","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","Fresh coriander","Oil for deep frying","Salt to taste"],"instructions":["Mix sliced onions with salt. Leave 5 minutes until they release moisture.","Add chickpea flour, green chillies, curry leaves, cumin, turmeric and coriander. Mix without adding water — the onion moisture is enough.","The mixture should be thick and sticky.","Drop spoonfuls into hot oil. Fry until golden and crispy.","Serve hot with green chutney and chai."],"prepTime":15,"cookTime":15,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kanda-bhaji.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kanda%20Bhaji%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.250Z"},{"id":277,"title":"Spinach Pakora","description":"Whole spinach leaves dipped in a spiced chickpea batter and deep-fried until gloriously crisp — simplest monsoon snack there is.","ingredients":["20 large fresh spinach leaves","For batter: 1 cup chickpea flour","½ tsp red chilli powder","½ tsp cumin powder","½ tsp ajwain","A pinch of baking soda","Salt","Water","Oil for deep frying"],"instructions":["Make a smooth, thick batter with all ingredients.","Wash and dry spinach leaves.","Dip each leaf in batter, coating both sides.","Deep fry until crisp and golden.","Serve immediately with mint chutney and tea."],"prepTime":10,"cookTime":10,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-spinach-pakora.png","youtubeUrl":"https://www.youtube.com/results?search_query=Spinach%20Pakora%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.253Z"},{"id":278,"title":"Paneer Pakora","description":"Thick paneer slices marinated in spiced yogurt, dipped in chickpea batter and fried until golden — the ultimate paneer starter.","ingredients":["300g paneer, cut into thick slices","For marinade: 1 tbsp yogurt","½ tsp red chilli powder","½ tsp garam masala","½ tsp chaat masala","For batter: 1 cup chickpea flour","½ tsp red chilli powder","½ tsp ajwain","A pinch of baking soda","Salt","Oil for deep frying"],"instructions":["Mix marinade ingredients. Coat paneer slices and leave 20 minutes.","Make a thick batter. Dip marinated paneer slices in batter.","Deep fry in hot oil until golden and crispy.","Drain. Sprinkle chaat masala.","Serve with mint chutney."],"prepTime":25,"cookTime":10,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-pakora.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Pakora%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.256Z"},{"id":279,"title":"Aloo Tikki Chaat","description":"Crispy potato tikkis drowning in yogurt, both chutneys, sev and chaat masala — the North Indian street classic elevated to its full glory.","ingredients":["6 aloo tikkis (refer to Aloo Tikki recipe)","1 cup yogurt, sweetened with sugar","Tamarind chutney","Green chutney","Thin sev","Red onion, finely chopped","Chaat masala","Red chilli powder","Cumin powder","Pomegranate seeds","Fresh coriander"],"instructions":["Arrange hot tikkis on a plate.","Spoon sweetened yogurt generously over them.","Drizzle tamarind and green chutneys.","Sprinkle chaat masala, red chilli and cumin.","Finish with sev, onion, pomegranate and coriander. Serve immediately."],"prepTime":5,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-tikki-chaat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Tikki%20Chaat%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.258Z"},{"id":280,"title":"Papdi Chaat","description":"Crispy papdi crackers loaded with potatoes, yogurt, chutneys and sev — a carnival of sweet, sour, spicy and crunchy.","ingredients":["30 papdi crackers","2 potatoes, boiled and cubed","½ cup kala chana, boiled","1½ cups yogurt, sweetened","Tamarind chutney","Green chutney","Thin sev","Chaat masala","Coriander and pomegranate"],"instructions":["Arrange papdi on a platter.","Top with potato cubes and kala chana.","Spoon sweetened yogurt generously.","Drizzle both chutneys.","Sprinkle chaat masala, sev, coriander and pomegranate. Serve at once."],"prepTime":10,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-papdi-chaat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Papdi%20Chaat%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.261Z"},{"id":281,"title":"Masala Chai","description":"India's beloved spiced milk tea brewed with ginger, cardamom, cinnamon and cloves — the perfect beginning to every day.","ingredients":["2 cups water","1 cup full-fat milk","2 tsp CTC black tea","1 inch ginger, bruised","3 cardamom pods, bruised","1 small cinnamon stick","2 cloves","½ tsp black peppercorns","Sugar to taste"],"instructions":["Combine water, ginger, cardamom, cinnamon, cloves and pepper in a saucepan. Boil 3 minutes.","Add tea. Boil 2 minutes.","Add milk. Bring to a full boil, then reduce heat. Simmer 2 minutes.","Strain into cups. Sweeten to taste."],"prepTime":2,"cookTime":8,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-masala-chai.png","youtubeUrl":"https://www.youtube.com/results?search_query=Masala%20Chai%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.264Z"},{"id":282,"title":"Amritsari Kulcha","description":"Stuffed, butter-smothered flatbread cooked in a tandoor — Amritsar's most iconic contribution to Punjab's culinary heritage.","ingredients":["For dough: 2 cups all-purpose flour","½ cup yogurt","1 tsp baking powder","Pinch of baking soda","1 tbsp oil","For stuffing: 3 potatoes, boiled and mashed","1 onion, finely chopped","1 green chilli","1 tsp ajwain","½ tsp red chilli powder","Fresh coriander","Butter to finish"],"instructions":["Mix flour, yogurt, baking powder, soda and oil. Knead into soft dough. Rest 1 hour.","Mix stuffing ingredients and season well.","Divide dough. Roll a ball flat. Place stuffing. Seal and roll gently.","Cook on a very hot tawa with butter until golden and puffed on both sides, pressing down with a cloth.","Serve with chole and sliced onion."],"prepTime":70,"cookTime":20,"servings":4,"cuisineType":"Punjabi","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-amritsari-kulcha.png","youtubeUrl":"https://www.youtube.com/results?search_query=Amritsari%20Kulcha%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.267Z"},{"id":283,"title":"Tandoori Roti","description":"Whole wheat flatbread baked at high heat until puffed and charred in places — the everyday bread of North India.","ingredients":["2 cups whole wheat flour","1 tsp baking powder","½ tsp salt","1 tsp oil","Water to knead","Butter or ghee to serve"],"instructions":["Knead flour, baking powder, salt, oil and water into a soft dough. Rest 20 minutes.","Divide into balls. Roll into circles about 3mm thick.","Place on a very hot tawa. When bubbles appear, flip and cook directly on the gas flame briefly until charred spots appear.","Brush with butter or ghee. Serve hot."],"prepTime":25,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-tandoori-roti.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tandoori%20Roti%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.270Z"},{"id":284,"title":"Naan","description":"Soft, pillowy leavened flatbread traditionally baked in a tandoor — the perfect partner for rich Indian curries.","ingredients":["2 cups all-purpose flour","½ cup yogurt","1 tsp dry yeast","1 tsp sugar","½ tsp baking powder","2 tbsp oil","Salt to taste","Butter and garlic to finish"],"instructions":["Dissolve yeast in warm water with sugar. Leave 10 minutes until frothy.","Mix with flour, yogurt, baking powder, oil and salt. Knead 10 minutes. Rest 1 hour until doubled.","Divide and roll into tear-drop shapes.","Cook on a hot, greased tawa until bubbles appear. Flip and hold briefly over a gas flame.","Brush with garlic butter. Serve hot."],"prepTime":70,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-naan.png","youtubeUrl":"https://www.youtube.com/results?search_query=Naan%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.273Z"},{"id":285,"title":"Bhakri","description":"Coarse millet or jowar flatbread from Maharashtra — rustic, slightly crumbly and the traditional vehicle for spicy curries.","ingredients":["2 cups jowar flour (or bajra flour)","Warm water","Salt to taste","Ghee or oil to serve"],"instructions":["Mix flour, salt and enough warm water to make a stiff, pliable dough.","Divide into balls. Pat each ball into a rough circle with wet hands (or roll between plastic sheets).","Cook on a dry hot tawa, pressing with a cloth to ensure even cooking.","Cook until both sides have brown patches.","Serve with pithla or sabzi and ghee."],"prepTime":10,"cookTime":15,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bhakri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bhakri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.277Z"},{"id":286,"title":"Pulao","description":"Fragrant basmati rice cooked with whole spices, vegetables and saffron — the elegant one-pot rice dish between a plain rice and a biryani.","ingredients":["1½ cups basmati rice, soaked 30 minutes","1 cup mixed vegetables (carrot, beans, peas)","1 onion, sliced","Whole spices: 1 bay leaf, 2 cardamom, 4 cloves, 1 cinnamon stick","1 tsp cumin seeds","1 tbsp ghee","A pinch of saffron in warm milk","2½ cups water","Salt to taste"],"instructions":["Heat ghee. Fry whole spices until fragrant. Add sliced onion and cook until golden.","Add vegetables and sauté 2 minutes.","Add drained rice. Sauté 2 minutes.","Add water, saffron milk and salt. Bring to a boil.","Cover and cook on low heat 15 minutes. Rest 5 minutes. Fluff and serve."],"prepTime":35,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-pulao.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vegetable%20Pulao%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.279Z"},{"id":287,"title":"Daliya Khichdi","description":"Broken wheat and lentil porridge with vegetables — nutritious, low-calorie and filling. Often prescribed as a health food, it tastes far better than that suggests.","ingredients":["1 cup broken wheat (daliya)","½ cup moong dal","1 cup mixed vegetables","1 tsp cumin seeds","½ tsp turmeric","1 tbsp ghee","A pinch of asafoetida","Salt to taste"],"instructions":["Dry roast daliya until light golden.","Heat ghee. Add cumin and asafoetida. Add vegetables and sauté.","Add daliya and dal. Add 4 cups water, turmeric and salt.","Pressure-cook 3 whistles. Open and mix well.","Serve hot with yogurt."],"prepTime":5,"cookTime":25,"servings":3,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-daliya-khichdi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Daliya%20Khichdi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.282Z"},{"id":288,"title":"Bread Upma","description":"Leftover bread cubes crumbled and tossed with mustard, vegetables and spices — a brilliant 10-minute breakfast.","ingredients":["6 slices bread, cut into small cubes","1 onion, finely chopped","1 tomato, chopped","2 green chillies","1 tsp mustard seeds","10 curry leaves","½ tsp turmeric","2 tbsp oil","Lemon juice and coriander","Salt to taste"],"instructions":["Heat oil. Splutter mustard seeds and curry leaves.","Add green chillies and onion. Cook until soft.","Add tomato and turmeric. Cook 2 minutes.","Add bread cubes. Toss gently until all the bread is coated and heated through.","Finish with lemon juice and coriander. Serve hot."],"prepTime":5,"cookTime":10,"servings":2,"cuisineType":"South Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-bread-upma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bread%20Upma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.285Z"},{"id":289,"title":"Egg Curry","description":"Hard-boiled eggs in a fragrant onion-tomato masala — this is the vegetarian community version made with boiled potatoes instead, equally satisfying.","ingredients":["4 potatoes, boiled and halved (substitute for eggs)","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","1 tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Score the potatoes for better absorption. Shallow-fry until golden.","Heat oil. Add cumin seeds. Add onions and cook until deep golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add all spices. Cook 2 minutes.","Add fried potatoes and ½ cup water. Simmer 15 minutes.","Garnish and serve with roti."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-egg-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.288Z"},{"id":290,"title":"Mixed Vegetable Curry","description":"A colourful, warming medley of seasonal vegetables in a richly spiced tomato gravy — endlessly adaptable to what's in your kitchen.","ingredients":["3 cups mixed vegetables (potato, carrot, beans, peas, cauliflower)","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","½ tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Steam or boil all vegetables until just tender.","Heat oil. Add cumin seeds. Add onions and cook until golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add spices. Add vegetables and stir to coat.","Add ½ cup water and simmer 10 minutes. Garnish and serve."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mixed-vegetable-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mixed%20Vegetable%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.293Z"},{"id":291,"title":"Navratan Korma","description":"Nine-gem korma — a mild, cream-based curry of vegetables, paneer, fruits and nuts from the Mughal kitchen. Subtly sweet and luxuriously rich.","ingredients":["1 cup mixed vegetables (carrot, peas, beans, potato, cauliflower)","100g paneer, cubed","2 tbsp cashews","1 tbsp raisins","1 can pineapple chunks (or fresh)","For gravy: 2 onions, pureed","½ cup cashew paste","½ cup cream","1 tbsp ginger-garlic paste","1 tsp garam masala","½ tsp turmeric","½ tsp red chilli powder","2 tbsp ghee","1 tsp sugar","Salt to taste"],"instructions":["Cook vegetables until tender. Fry cashews and raisins in ghee. Set aside.","Heat ghee. Cook onion purée until golden. Add ginger-garlic paste.","Add cashew paste, cream and spices. Simmer 10 minutes.","Add cooked vegetables, paneer and pineapple. Simmer 5 minutes.","Top with fried cashews and raisins. Serve with naan."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-navratan-korma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Navratan%20Korma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.300Z"},{"id":292,"title":"Soya Keema","description":"Minced soya granules cooked with onions, tomatoes and whole spices — a protein-rich vegetarian keema that closely mirrors the meaty original.","ingredients":["1 cup soya granules","2 onions, finely chopped","3 tomatoes, finely chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","1 tsp red chilli powder","2 tbsp oil","Fresh peas (optional)","Fresh coriander","Salt to taste"],"instructions":["Soak soya granules in hot water 10 minutes. Squeeze out water completely.","Heat oil. Add cumin seeds. Add onions and cook until golden.","Add ginger-garlic paste and tomatoes. Cook until oil separates.","Add all spices and soya granules. Mix well.","Add ½ cup water. Cook 15 minutes. Garnish and serve with pav or roti."],"prepTime":15,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-soya-keema.png","youtubeUrl":"https://www.youtube.com/results?search_query=Soya%20Keema%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.303Z"},{"id":293,"title":"Jackfruit Biryani","description":"Young green jackfruit slow-cooked in biryani spices until it pulls apart like tender meat — the plant-based biryani that will convert sceptics.","ingredients":["400g young green jackfruit, cut into pieces","2 cups basmati rice, parboiled","2 onions, thinly sliced and fried crispy","1 cup yogurt","1 tbsp ginger-garlic paste","2 tsp biryani masala","½ tsp garam masala","A pinch of saffron in warm milk","Fresh mint and coriander","3 tbsp ghee","Salt to taste"],"instructions":["Pressure-cook jackfruit with yogurt, ginger-garlic paste, biryani masala and salt for 3 whistles.","In a heavy pot, layer parboiled rice and jackfruit alternately.","Top with saffron milk, fried onions, mint, coriander and ghee.","Seal and cook on dum (very low heat) 20 minutes.","Serve with raita."],"prepTime":30,"cookTime":55,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-jackfruit-biryani.png","youtubeUrl":"https://www.youtube.com/results?search_query=Jackfruit%20Biryani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.306Z"},{"id":294,"title":"Paneer Lababdar","description":"A Punjabi restaurant favourite — paneer in a rich, slightly sweet onion-tomato-cashew gravy with a generous dose of cream.","ingredients":["300g paneer, cubed","2 onions, roughly chopped","3 tomatoes, chopped","10 cashews","1 tbsp ginger-garlic paste","1 tsp red chilli powder","1 tsp coriander powder","½ tsp garam masala","½ tsp kasuri methi","½ cup cream","2 tbsp butter","Salt to taste"],"instructions":["Boil onions, tomatoes and cashews together. Blend to a smooth purée.","Heat butter. Add the purée and cook 10 minutes, stirring.","Add ginger-garlic paste and all spices. Cook 5 minutes.","Add cream and kasuri methi. Simmer 3 minutes.","Add paneer. Cook 5 minutes on low heat. Serve with naan."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-lababdar.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Lababdar%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.309Z"},{"id":295,"title":"Aloo Methi","description":"Potatoes and fresh fenugreek leaves stir-fried with garlic and spices — a quick dry sabzi with a pleasantly bitter, fragrant edge.","ingredients":["3 medium potatoes, cubed","2 cups fresh fenugreek leaves, picked","3 garlic cloves, minced","½ tsp turmeric","½ tsp red chilli powder","1 tsp cumin seeds","2 tbsp oil","Salt to taste"],"instructions":["Heat oil. Add cumin seeds and garlic. Cook until garlic is golden.","Add potatoes and turmeric. Cook, stirring occasionally, 8 minutes.","Add fenugreek leaves and red chilli. Mix well.","Cover and cook on low heat 10 minutes until potatoes are tender.","Serve with roti."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-methi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Methi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.312Z"},{"id":296,"title":"Bharwa Shimla Mirch","description":"Capsicums stuffed with a spiced potato and paneer filling, cooked until soft and caramelised — a beautiful and satisfying main dish.","ingredients":["4 medium capsicums","For stuffing: 3 potatoes, boiled and mashed","100g paneer, crumbled","1 tsp cumin powder","½ tsp garam masala","½ tsp red chilli powder","Fresh coriander","2 tbsp oil","Salt to taste"],"instructions":["Cut caps off capsicums. Scoop out seeds.","Mix mashed potato, paneer, all spices and coriander. Season.","Stuff capsicums tightly with the mixture. Replace caps.","Heat oil in a pan. Place capsicums standing upright. Cover.","Cook on low heat, turning gently, 25 minutes until capsicums are soft and charred in spots.","Serve with roti."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bharwa-shimla-mirch.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bharwa%20Shimla%20Mirch%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.316Z"},{"id":297,"title":"Corn Masala","description":"Sweet corn kernels in a spiced, tangy onion-tomato masala — a cheerful, quick curry for monsoon and winter evenings.","ingredients":["3 cups corn kernels, boiled","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","½ tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Heat oil. Add cumin seeds. Add onions and cook until golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add spices. Cook 2 minutes.","Add corn kernels and ¼ cup water. Simmer 10 minutes.","Garnish and serve with roti or rice."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-corn-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Corn%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.319Z"},{"id":298,"title":"Besan Gatte Ka Pulao","description":"Chickpea flour dumplings cooked in a fragrant rice pilaf — a Rajasthani one-pot dish that is both festive and everyday.","ingredients":["1 cup basmati rice","For gatte: ½ cup chickpea flour","½ tsp ajwain","1 tbsp oil","Salt","2 tbsp oil","1 tsp cumin seeds","1 bay leaf","2 cardamom","1 onion, sliced","1 tomato, chopped","½ tsp turmeric","1 tsp coriander powder","2 cups water"],"instructions":["Make gatte dough. Roll into cylinders. Boil 8 minutes. Slice.","Heat oil. Add cumin, bay leaf, cardamom. Add onion and cook until golden.","Add tomato and spices. Cook until soft.","Add rice and sauté 2 minutes. Add water and salt. Bring to boil.","Add gatte pieces. Cover and cook on low heat 15 minutes."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-besan-gatte-ka-pulao.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gatte%20Pulao%20Rajasthani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.321Z"},{"id":299,"title":"Sindhi Kadhi","description":"A thick, tangy Sindhi curry made with chickpea flour and vegetables — no yogurt, all tamarind and a very particular flavour unlike any other kadhi.","ingredients":["3 tbsp chickpea flour","3 tbsp oil","2 cups mixed vegetables (potato, cluster beans, drumstick, lotus stem)","2 tbsp tamarind paste","½ tsp turmeric","1 tsp coriander powder","½ tsp red chilli powder","1 tsp cumin seeds","10 curry leaves","Salt to taste"],"instructions":["Heat oil. Add cumin seeds and curry leaves. Add chickpea flour and roast on medium heat for 8 minutes, stirring, until golden.","Add 4 cups water slowly, whisking to avoid lumps.","Add turmeric, coriander and red chilli. Simmer 10 minutes.","Add vegetables and tamarind paste. Cook until vegetables are tender.","Serve with rice."],"prepTime":15,"cookTime":35,"servings":4,"cuisineType":"West Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sindhi-kadhi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sindhi%20Kadhi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.324Z"},{"id":300,"title":"Lotus Stem Curry","description":"Sliced lotus stem in a tangy, spiced Kashmiri-style gravy — a uniquely textured vegetable with a beautiful, lacy cross-section.","ingredients":["300g lotus stem, sliced into rounds","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp fennel powder","½ tsp turmeric","1 tsp coriander powder","½ tsp garam masala","½ tsp red chilli powder","2 tbsp mustard oil","Salt to taste"],"instructions":["Boil lotus stem slices for 10 minutes. Drain.","Heat mustard oil to smoking. Cool slightly. Add onions and cook until golden.","Add ginger-garlic paste and tomato purée. Cook until oil separates.","Add all spices. Add lotus stem and ½ cup water.","Cover and cook 20 minutes until completely tender."],"prepTime":15,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-lotus-stem-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lotus%20Stem%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.326Z"},{"id":301,"title":"Turai Ki Sabzi","description":"Ridge gourd cooked with onions and minimal spices — a light, cooling vegetable dish perfect for summer.","ingredients":["4 ridge gourds (turai), peeled and sliced","1 onion, sliced","2 green chillies, slit","1 tsp cumin seeds","½ tsp turmeric","1 tsp coriander powder","2 tbsp oil","Salt to taste"],"instructions":["Heat oil. Add cumin seeds. Add onion and cook until soft.","Add green chillies, turmeric and turai. Mix.","Add coriander and salt. Stir. Cover and cook on low heat.","The turai will release water. Cook 15 minutes until completely soft.","Serve with roti."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-turai-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Turai%20Ki%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.329Z"},{"id":302,"title":"Beans Poriyal","description":"South Indian dry stir-fry of French beans with freshly grated coconut and a mustard-curry leaf tempering — everyday South Indian brilliance.","ingredients":["400g French beans, finely chopped","½ cup fresh coconut, grated","1 tbsp oil","1 tsp mustard seeds","1 tsp chana dal","10 curry leaves","2 dried red chillies","½ tsp turmeric","Salt to taste"],"instructions":["Boil beans in salted water until just tender. Drain.","Heat oil. Splutter mustard seeds. Add chana dal and fry golden. Add curry leaves and dried red chillies.","Add beans and turmeric. Toss well on medium heat 5 minutes.","Add grated coconut. Mix and cook 2 more minutes.","Serve as a side with rice and sambar."],"prepTime":10,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-beans-poriyal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Beans%20Poriyal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.333Z"},{"id":303,"title":"Kohlrabi Sabzi","description":"Knolkol (kohlrabi) cooked with simple North Indian spices — a mild, slightly sweet vegetable that is underrated and delicious.","ingredients":["4 medium kohlrabi (knolkol), peeled and cubed","1 onion, finely chopped","2 tomatoes, chopped","1 tsp cumin seeds","½ tsp turmeric","1 tsp coriander powder","½ tsp garam masala","2 tbsp oil","Salt to taste","Fresh coriander"],"instructions":["Heat oil. Add cumin seeds. Add onions and cook until soft.","Add tomatoes, turmeric and coriander powder. Cook until oil separates.","Add kohlrabi and salt. Stir to coat with the masala.","Add ¼ cup water. Cover and cook 20 minutes until tender.","Sprinkle garam masala and garnish with coriander."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kohlrabi-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kohlrabi%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.335Z"},{"id":304,"title":"Kathal Masala","description":"Raw jackfruit cooked in a bold, spiced North Indian masala — meaty in texture, absorbs spices beautifully and confounds non-vegetarians.","ingredients":["400g raw jackfruit, cut into chunks","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","1 tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Pressure-cook jackfruit with ½ tsp turmeric for 2 whistles.","Heat oil. Add cumin seeds. Add onions and cook until deep golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add all spices and cooked jackfruit. Toss and cook 10 minutes.","Garnish and serve with roti."],"prepTime":15,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kathal-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kathal%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.339Z"},{"id":305,"title":"Gawar Phali Ki Sabzi","description":"Cluster beans cooked with peanuts, sesame and coconut in the Rajasthani way — a flavourful, nutritious dry curry.","ingredients":["400g gawar phali (cluster beans), trimmed","¼ cup peanuts","2 tbsp sesame seeds","2 tbsp fresh coconut, grated","1 tsp cumin seeds","½ tsp turmeric","1 tsp coriander powder","½ tsp red chilli powder","2 tbsp oil","Salt to taste"],"instructions":["Boil cluster beans in salted water until tender. Drain.","Dry roast peanuts, sesame and coconut. Coarsely grind.","Heat oil. Add cumin seeds. Add beans and all spices.","Add the ground mixture. Toss well.","Cook on medium heat 8 minutes. Serve with bajra roti."],"prepTime":15,"cookTime":20,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-gawar-phali-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gawar%20Phali%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.342Z"},{"id":306,"title":"Achari Aloo","description":"Potatoes cooked in a tangy pickling spice masala — the sharp, pungent flavours make this dry sabzi deeply addictive.","ingredients":["4 medium potatoes, cubed","1 tsp each mustard seeds, fennel seeds, fenugreek seeds, kalonji","3 dried red chillies","1 tsp red chilli powder","1 tsp amchur","2 tbsp mustard oil","Salt to taste"],"instructions":["Heat mustard oil to smoking. Cool slightly.","Coarsely grind all 4 seeds and dried red chillies.","Add to the oil. Add potatoes and turmeric.","Cook on medium heat, stirring, until potatoes are golden and cooked.","Add amchur and salt. Serve with roti."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-achari-aloo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Achari%20Aloo%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.344Z"},{"id":307,"title":"Matar Ki Sabzi","description":"Simple green peas stir-fry with cumin, ginger and a touch of amchur — a winter staple that appears when fresh peas arrive at the market.","ingredients":["2 cups green peas, fresh or frozen","1 tsp ginger, grated","2 green chillies, chopped","1 tsp cumin seeds","½ tsp turmeric","½ tsp amchur","1 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Heat oil. Add cumin seeds. Add ginger and green chillies.","Add peas, turmeric and salt.","Cook on medium heat, tossing, for 8 minutes.","Add amchur and coriander. Serve with puri or roti."],"prepTime":5,"cookTime":12,"servings":3,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-matar-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Matar%20Ki%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.347Z"},{"id":308,"title":"Saag","description":"A seasonal mix of mustard leaves, spinach and bathua slow-cooked with ginger and cornmeal — Punjab's legendary winter green.","ingredients":["2 cups mustard leaves (sarson)","1 cup spinach","½ cup bathua (chenopodium) or more spinach","1 onion, chopped","3 garlic cloves","1 inch ginger","2 green chillies","2 tbsp cornmeal (maize flour)","2 tbsp ghee","Salt to taste"],"instructions":["Pressure-cook all greens with garlic, ginger and green chillies for 3 whistles.","Blend roughly (not smooth). Add cornmeal and cook 10 minutes, stirring.","Heat ghee in a separate pan. Cook onion until deep golden.","Pour the tadka over the saag. Mix.","Serve with makki ki roti and jaggery."],"prepTime":15,"cookTime":40,"servings":4,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-saag.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sarson%20Ka%20Saag%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.349Z"},{"id":309,"title":"Makhani Dal","description":"Yellow dal tarka with a luxurious touch of butter and cream — simpler than Dal Makhani and on the table in 30 minutes.","ingredients":["1 cup yellow toor dal","2 tomatoes, chopped","1 tbsp ginger-garlic paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander powder","2 tbsp butter","½ cup cream","1 tsp cumin seeds","Salt to taste","Fresh coriander"],"instructions":["Pressure-cook dal with tomatoes, turmeric and salt for 3 whistles. Mash.","Heat butter. Add cumin seeds and ginger-garlic paste. Cook 1 minute.","Add red chilli and coriander. Cook 1 minute.","Add to dal. Stir in cream. Simmer 5 minutes.","Garnish and serve."],"prepTime":5,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-makhani-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Makhani%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.352Z"},{"id":310,"title":"Bhandare Wali Dal","description":"The iconic yellow dal made in North Indian temple prasad style — simple spicing, lots of ghee, eaten with puri at religious gatherings.","ingredients":["1 cup chana dal","½ tsp turmeric","2 tbsp ghee","1 tsp cumin seeds","2 dried red chillies","A pinch of asafoetida","1 tsp coriander powder","½ tsp red chilli powder","Salt to taste"],"instructions":["Pressure-cook chana dal with turmeric and salt for 3 whistles until soft.","Heat ghee. Add cumin seeds, dried red chillies and asafoetida.","Add coriander and red chilli powder. Cook 30 seconds.","Add to cooked dal. Mix. Simmer 5 minutes.","Serve with puri and potato sabzi."],"prepTime":5,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bhandare-wali-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Temple%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.355Z"},{"id":311,"title":"Carrot Semolina Upma","description":"Carrot Semolina Upma is a delicious and nutritious South Indian dish.","ingredients":["1 cup semolina (sooji)","1 medium carrot, finely chopped","1 onion, finely chopped","2-3 green chilies, slit","1 tsp mustard seeds","1 tsp urad dal (split black gram)","1/2 tsp cumin seeds","A few curry leaves","2 cups water","Salt to taste","2 tbsp oil","Fresh coriander leaves for garnishing (optional)"],"instructions":["In a pan, dry roast the semolina on low heat until lightly golden and set aside.","In the same pan, heat oil and add mustard seeds, urad dal, cumin seeds, and curry leaves, sautéing until they splutter.","Add chopped onion and green chilies, cooking until the onions are translucent, then add chopped carrots and sauté for a few minutes.","Add water and salt to the pan, bringing it to a boil, then gradually add the roasted semolina while stirring continuously to avoid lumps.","Cover and cook on low heat for 3-4 minutes, and once the semolina absorbs the water, fluff it with a fork and garnish with coriander before serving hot."],"prepTime":10,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":[],"category":"main","imageUrl":"/api/recipes/311/image","youtubeUrl":"https://www.youtube.com/results?search_query=carrot+semolina+upma+recipe+indian+vegetarian","authorId":"55882372","submittedBy":"55882372","submittedByName":"Haigreeva Kondury","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-17T11:02:37.113Z"}]
6:27:19 PM [express] GET /api/recipes 200 in 18ms :: [{"id":312,"title":"Cottage Cheese & Hemp Bowl","description":"A quick, protein-packed no-cook bowl of creamy cottage cheese layered with nutty hemp hearts and cool cucumber — ready in 2 minutes and delivering 30g+ protein.","ingredients":["1 cup cottage cheese","3 tbsp hemp hearts","½ cup cucumber, sliced","Pinch of black pepper","Pinch of chilli flakes (optional)","Fresh dill or chives to garnish"],"instructions":["Spoon cottage cheese into a bowl.","Layer cucumber slices on top.","Sprinkle hemp hearts evenly over the bowl.","Season with black pepper and chilli flakes.","Garnish with fresh herbs and serve immediately."],"prepTime":2,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-cottage-cheese-hemp-bowl.png","youtubeUrl":"https://www.youtube.com/results?search_query=Cottage%20Cheese%20Hemp%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.864Z"},{"id":313,"title":"Greek Yogurt Whey Mix","description":"Thick non-fat Greek yogurt blended with a scoop of vanilla whey protein and topped with walnuts — a creamy, high-protein snack or breakfast with minimal effort.","ingredients":["1 cup non-fat Greek yogurt","½ scoop vanilla whey protein powder","2 tbsp walnuts, roughly chopped","1 tsp honey (optional)","A pinch of cinnamon"],"instructions":["Spoon Greek yogurt into a bowl.","Stir in vanilla whey protein until smooth.","Top with walnuts and a pinch of cinnamon.","Drizzle with honey if desired.","Serve immediately."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-greek-yogurt-whey-mix.png","youtubeUrl":"https://www.youtube.com/results?search_query=Greek%20Yogurt%20Protein%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.897Z"},{"id":314,"title":"Savory Tofu Toast","description":"Slices of pressed extra-firm tofu piled on high-protein bread with creamy avocado and a shower of nutritional yeast — a satisfying no-cook open sandwich.","ingredients":["3 slices extra-firm tofu, pressed and sliced","2 slices high-protein bread","½ avocado, mashed","2 tbsp nutritional yeast","1 tsp lemon juice","Salt, pepper and chilli flakes","Microgreens to garnish"],"instructions":["Toast the bread if desired (or serve as is for fully no-cook).","Spread mashed avocado on the bread. Season with lemon, salt and pepper.","Lay tofu slices on top.","Shower generously with nutritional yeast and chilli flakes.","Garnish with microgreens and serve."],"prepTime":5,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-savory-tofu-toast.png","youtubeUrl":"https://www.youtube.com/results?search_query=Savory%20Tofu%20Toast%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.901Z"},{"id":315,"title":"Peanut Butter Greek Yogurt Dip","description":"Greek yogurt swirled with peanut butter creates a thick, protein-rich dip that pairs perfectly with apple slices or celery sticks for a nourishing snack.","ingredients":["1 cup Greek yogurt","1 tbsp natural peanut butter","1 tsp honey","½ tsp cinnamon","Apple slices or celery sticks to serve"],"instructions":["Combine Greek yogurt, peanut butter, honey and cinnamon in a small bowl.","Stir until fully incorporated and creamy.","Serve immediately with apple slices or celery sticks for dipping."],"prepTime":3,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-peanut-butter-greek-yogurt-dip.png","youtubeUrl":"https://www.youtube.com/results?search_query=Peanut%20Butter%20Yogurt%20Dip%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.904Z"},{"id":316,"title":"Tofu Egg Salad","description":"Crumbled firm tofu mimics the texture of egg salad, mixed with tangy Greek yogurt instead of mayo, mustard and turmeric for colour — a brilliant vegan protein lunch.","ingredients":["200g firm tofu, pressed and crumbled","3 tbsp Greek yogurt","1 tsp Dijon mustard","½ tsp turmeric","1 tbsp spring onions, sliced","Salt and pepper","Paprika to garnish","Bread or crackers to serve"],"instructions":["Crumble pressed tofu into a bowl with your hands to create a chunky texture.","Add Greek yogurt, mustard, turmeric, spring onions, salt and pepper.","Mix until well combined. Taste and adjust seasoning.","Garnish with paprika and serve on bread, crackers or lettuce cups."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-tofu-egg-salad.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tofu%20Egg%20Salad%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.907Z"},{"id":317,"title":"Ricotta & Almond Plate","description":"Velvety ricotta topped with slivered almonds and a delicate drizzle of honey — a simple, elegant Italian-inspired protein plate.","ingredients":["½ cup ricotta cheese","2 tbsp slivered almonds","1 tsp honey","A pinch of sea salt","Fresh thyme or lemon zest to garnish","Crackers or crostini to serve"],"instructions":["Spoon ricotta onto a small serving plate and spread slightly.","Scatter slivered almonds over the top.","Drizzle with honey and a tiny pinch of sea salt.","Garnish with fresh thyme or a little lemon zest.","Serve with crackers or crostini."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-ricotta-almond-plate.png","youtubeUrl":"https://www.youtube.com/results?search_query=Ricotta%20Almond%20Plate%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.911Z"},{"id":318,"title":"Paneer Salad (Raw)","description":"Cubes of fresh paneer tossed with chaat masala, lemon juice and raw sprouts — a quick Indian-inspired high-protein salad that needs zero cooking.","ingredients":["200g fresh paneer, cubed","1 cup mixed sprouts (moong, chickpea)","½ red onion, finely sliced","1 tomato, diced","1 green chilli, finely chopped (optional)","1 tsp chaat masala","Juice of 1 lemon","Fresh coriander and mint"],"instructions":["Combine paneer cubes, sprouts, red onion, tomato and green chilli in a bowl.","Sprinkle chaat masala and squeeze lemon juice over the top.","Toss gently so paneer doesn't break.","Garnish with coriander and mint. Serve immediately."],"prepTime":8,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-paneer-salad-raw.png","youtubeUrl":"https://www.youtube.com/results?search_query=Raw%20Paneer%20Salad%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.916Z"},{"id":319,"title":"Chickpea Tuna Salad","description":"Smashed chickpeas mixed with Greek yogurt, capers and optional seaweed flakes create an addictive plant-based tuna-style filling for wraps or toast.","ingredients":["1 can chickpeas, drained and rinsed","3 tbsp Greek yogurt","1 tbsp capers","1 tbsp seaweed flakes (optional, for a sea flavour)","1 tsp Dijon mustard","1 tsp lemon juice","Salt and pepper","High-protein wrap or bread to serve"],"instructions":["Drain and rinse chickpeas. Place in a bowl and smash roughly with a fork — keep some texture.","Add Greek yogurt, capers, seaweed flakes, mustard and lemon juice.","Mix well. Season with salt and pepper.","Serve inside a wrap, on toast or over salad greens."],"prepTime":8,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-chickpea-tuna-salad.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chickpea%20Tuna%20Salad%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.921Z"},{"id":320,"title":"Lentil & Feta Bowl","description":"Ready-to-eat canned lentils with crumbled feta, olives and a lemon dressing — a protein-and-fibre powerhouse lunch that requires no cooking whatsoever.","ingredients":["1 can brown or green lentils, drained and rinsed","60g feta cheese, crumbled","¼ cup Kalamata olives, halved","½ cucumber, diced","1 tbsp olive oil","1 tbsp lemon juice","1 tsp dried oregano","Salt and pepper","Fresh parsley"],"instructions":["Rinse lentils and place in a bowl.","Add olives, cucumber and crumbled feta.","Drizzle with olive oil and lemon juice. Sprinkle oregano, salt and pepper.","Toss gently. Garnish with parsley and serve."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-lentil-feta-bowl.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lentil%20Feta%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.925Z"},{"id":321,"title":"Three-Bean Salad","description":"Kidney beans, black beans and chickpeas tossed in a bright lime-cumin dressing — a classic high-protein no-cook salad that keeps well in the fridge for days.","ingredients":["½ cup kidney beans, canned and rinsed","½ cup black beans, canned and rinsed","½ cup chickpeas, canned and rinsed","½ red onion, finely diced","1 capsicum, diced","Juice of 2 limes","2 tbsp olive oil","1 tsp cumin powder","1 tsp coriander powder","Salt and pepper","Fresh coriander"],"instructions":["Combine all three beans in a large bowl.","Add red onion and capsicum.","Whisk together lime juice, olive oil, cumin, coriander, salt and pepper.","Pour dressing over beans and toss well.","Garnish with coriander. Rest 10 minutes for flavours to develop before serving."],"prepTime":10,"cookTime":0,"servings":4,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-three-bean-salad.png","youtubeUrl":"https://www.youtube.com/results?search_query=Three%20Bean%20Salad%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.929Z"},{"id":322,"title":"Edamame & Hummus Wrap","description":"Thawed shelled edamame with a thick spread of hummus in a high-protein tortilla — fast, filling and easily customisable with your favourite vegetables.","ingredients":["½ cup shelled edamame, thawed","3 tbsp hummus","1 high-protein tortilla","¼ avocado, sliced","¼ cup baby spinach","¼ cup grated carrot","1 tsp lemon juice","Salt and pepper","Chilli flakes (optional)"],"instructions":["Lay the tortilla flat. Spread hummus thickly across the surface.","Layer spinach, carrot and avocado slices.","Scatter edamame evenly. Drizzle with lemon juice, salt, pepper and chilli flakes.","Roll the tortilla tightly, slice in half and serve."],"prepTime":5,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-edamame-hummus-wrap.png","youtubeUrl":"https://www.youtube.com/results?search_query=Edamame%20Hummus%20Wrap%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.934Z"},{"id":323,"title":"White Bean & Pesto Mash","description":"Cannellini beans mashed with vibrant pesto and topped with pumpkin seeds — a creamy, protein-rich spread for toast, crackers or a simple side.","ingredients":["1 can cannellini beans, drained and rinsed","2 tbsp store-bought basil pesto","2 tbsp pumpkin seeds","1 tsp lemon juice","Salt and pepper","Fresh basil to garnish","Toast or crackers to serve"],"instructions":["Drain and rinse cannellini beans. Mash with a fork to your preferred texture — smooth or chunky.","Stir in pesto and lemon juice. Season with salt and pepper.","Spoon onto a plate. Top with pumpkin seeds and fresh basil.","Serve on toast or crackers."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-white-bean-pesto-mash.png","youtubeUrl":"https://www.youtube.com/results?search_query=White%20Bean%20Pesto%20Mash%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.945Z"},{"id":324,"title":"Chia Seed Protein Pudding","description":"Chia seeds soaked overnight in creamy soy milk with a scoop of plant-based protein powder — a set-and-forget breakfast that is thick, filling and nutritious.","ingredients":["4 tbsp chia seeds","1½ cups unsweetened soy milk","1 scoop plant-based vanilla protein powder","1 tsp maple syrup","½ tsp vanilla extract","Fresh berries and granola to top"],"instructions":["Whisk together soy milk, protein powder, maple syrup and vanilla extract in a jar.","Add chia seeds and stir well. Wait 5 minutes and stir again to prevent clumping.","Cover and refrigerate overnight (or at least 4 hours).","Top with fresh berries and granola just before serving."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-chia-seed-protein-pudding.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chia%20Protein%20Pudding%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.948Z"},{"id":325,"title":"Pumpkin Seed Trail Mix","description":"A satisfying handful of dry-roasted soy nuts, pumpkin seeds and almonds — a portable, protein-dense snack delivering 15–20g protein per cup.","ingredients":["½ cup roasted soy nuts","½ cup pumpkin seeds (pepitas)","½ cup almonds","¼ cup dried cranberries or raisins","1 tsp smoked paprika (optional)","Pinch of sea salt"],"instructions":["Combine soy nuts, pumpkin seeds, almonds and dried cranberries in a bowl.","Season with smoked paprika and sea salt if desired. Toss to mix.","Portion into snack bags or a jar.","Keeps for up to 2 weeks in an airtight container."],"prepTime":3,"cookTime":0,"servings":4,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-pumpkin-seed-trail-mix.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pumpkin%20Seed%20Trail%20Mix%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.952Z"},{"id":326,"title":"Overnight Oats with Soy","description":"Rolled oats soaked overnight in high-protein soy milk with almond butter and chia seeds — wake up to a creamy, ready-to-eat breakfast packed with protein and fibre.","ingredients":["½ cup rolled oats","¾ cup unsweetened soy milk","1 tbsp almond butter","1 tbsp chia seeds","1 tsp maple syrup or honey","½ tsp vanilla extract","Fresh fruit and nuts to top"],"instructions":["Combine oats, soy milk, almond butter, chia seeds, sweetener and vanilla in a jar.","Stir well to incorporate the almond butter.","Cover and refrigerate overnight or for at least 6 hours.","In the morning, stir and add a splash of soy milk if too thick.","Top with fresh fruit and nuts and serve cold."],"prepTime":5,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-overnight-oats-with-soy.png","youtubeUrl":"https://www.youtube.com/results?search_query=Overnight%20Oats%20Soy%20Milk%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.955Z"},{"id":327,"title":"Chocolate Banana Protein Shake","description":"A thick, indulgent protein shake blending chocolate protein powder, creamy soy milk and peanut butter with a ripe banana — tastes like dessert but fuels like a meal.","ingredients":["1 scoop chocolate whey or plant protein powder","1 cup soy milk","1 ripe banana","1 tbsp peanut butter","4 ice cubes","½ tsp cocoa powder (optional, for extra depth)"],"instructions":["Add all ingredients to a blender.","Blend on high for 45 seconds until completely smooth and creamy.","Pour into a glass and serve immediately.","Add more ice for a thicker, colder shake."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-chocolate-banana-protein-shake.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chocolate%20Banana%20Protein%20Shake%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.958Z"},{"id":328,"title":"Berry Green Smoothie","description":"Spinach, Greek yogurt, fresh blueberries and hemp seeds blended into a vibrant, protein-rich smoothie — you won't taste the greens but you'll feel the benefits.","ingredients":["1 cup fresh spinach","¾ cup Greek yogurt","½ cup blueberries (fresh or frozen)","3 tbsp hemp seeds","½ cup water or milk","1 tsp honey","3 ice cubes"],"instructions":["Add spinach, Greek yogurt, blueberries, hemp seeds, water, honey and ice to a blender.","Blend on high for 60 seconds until completely smooth.","Pour into a glass and serve immediately.","Add more liquid for a thinner consistency."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-berry-green-smoothie.png","youtubeUrl":"https://www.youtube.com/results?search_query=Berry%20Green%20Smoothie%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.961Z"},{"id":329,"title":"Coffee Protein Frappe","description":"Cold brew coffee blended with soy milk and vanilla protein powder over ice — the ultimate protein-packed alternative to a coffee shop frappe.","ingredients":["1 cup cold brew coffee","¾ cup soy milk","1 scoop vanilla protein powder","1 cup ice","1 tsp maple syrup (optional)","Whipped cream to top (optional)"],"instructions":["Add cold brew, soy milk, protein powder, maple syrup and ice to a blender.","Blend on high for 30 seconds until frothy and smooth.","Pour into a tall glass. Top with whipped cream if desired.","Serve immediately."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-coffee-protein-frappe.png","youtubeUrl":"https://www.youtube.com/results?search_query=Coffee%20Protein%20Frappe%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.964Z"},{"id":330,"title":"Savory Oat Bran","description":"Cold-soaked oat bran stirred with creamy cottage cheese and cracked black pepper — a surprisingly savoury, extremely high-protein breakfast that requires zero heat.","ingredients":["½ cup oat bran","½ cup cold water or milk","½ cup cottage cheese","¼ tsp black pepper","Pinch of sea salt","1 tbsp chives or spring onion, sliced","Optional: a drizzle of olive oil"],"instructions":["Combine oat bran and cold water or milk in a bowl. Stir and soak 5 minutes.","The oat bran will absorb the liquid and soften without cooking.","Stir in cottage cheese, pepper and salt.","Top with chives and a drizzle of olive oil if desired. Serve immediately."],"prepTime":8,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-savory-oat-bran.png","youtubeUrl":"https://www.youtube.com/results?search_query=Savory%20Oat%20Bran%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.968Z"},{"id":331,"title":"Quinoa Salad (Pre-cooked)","description":"Ready-to-eat vacuum-sealed quinoa tossed with tomatoes, cucumber, lemon and herbs — a complete protein salad that takes under 5 minutes to assemble.","ingredients":["1 pack pre-cooked vacuum-sealed quinoa (250g)","1 tomato, diced","½ cucumber, diced","¼ red onion, finely sliced","2 tbsp olive oil","Juice of 1 lemon","1 tsp dried mint or fresh herbs","Salt and pepper","Feta cheese (optional)"],"instructions":["Empty pre-cooked quinoa into a bowl. Fluff gently with a fork.","Add tomato, cucumber and red onion.","Drizzle with olive oil and lemon juice. Season with herbs, salt and pepper.","Toss well. Crumble feta on top if using.","Serve immediately or refrigerate for later."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-quinoa-salad-pre-cooked.png","youtubeUrl":"https://www.youtube.com/results?search_query=Quinoa%20Salad%20No%20Cook%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.971Z"},{"id":332,"title":"Seitan Deli Sandwich","description":"Pre-packaged seitan slices layered on high-protein bread with mustard, crisp lettuce and pickles — a no-cook, meaty-textured vegetarian deli sandwich.","ingredients":["4 slices pre-packaged seitan","2 slices high-protein or sprouted grain bread","1 tbsp Dijon or whole grain mustard","2 leaves romaine lettuce","2 slices tomato","4 pickle slices","Salt and pepper"],"instructions":["Lay bread slices out. Spread mustard on both slices.","Layer lettuce leaves on one slice.","Add seitan slices, tomato and pickles.","Season with salt and pepper. Close the sandwich.","Slice in half and serve."],"prepTime":5,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-seitan-deli-sandwich.png","youtubeUrl":"https://www.youtube.com/results?search_query=Seitan%20Sandwich%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.975Z"},{"id":333,"title":"Tempeh Strips & Guacamole","description":"Pre-steamed ready-to-eat tempeh strips dipped in spicy avocado guacamole — a protein and healthy-fat combo that makes for a seriously satisfying snack.","ingredients":["150g pre-steamed tempeh, sliced into strips","For guacamole: 2 ripe avocados","1 lime, juiced","1 green chilli, minced","1 small tomato, diced","¼ red onion, finely chopped","Salt","Fresh coriander"],"instructions":["Mash avocados with lime juice and salt until creamy.","Fold in green chilli, tomato, red onion and coriander.","Arrange tempeh strips on a serving plate.","Serve with the spicy guacamole for dipping."],"prepTime":8,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-tempeh-strips-guacamole.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tempeh%20Guacamole%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.978Z"},{"id":334,"title":"Nutty Protein Balls","description":"No-bake energy balls made with raw oats, peanut butter, honey and protein powder — rolled into bites and refrigerated, they're the ultimate high-protein snack to make ahead.","ingredients":["1 cup rolled oats","½ cup natural peanut butter","3 tbsp honey or maple syrup","1 scoop protein powder (vanilla or chocolate)","2 tbsp chia seeds","2 tbsp dark chocolate chips (optional)","Pinch of salt"],"instructions":["Mix oats, peanut butter, honey, protein powder, chia seeds and salt in a bowl until a dough forms.","If too dry, add a teaspoon of water. If too wet, add more oats.","Roll heaped tablespoons of the mixture into balls.","Place on a lined tray and refrigerate for at least 30 minutes to firm up.","Store in an airtight container in the fridge for up to 1 week."],"prepTime":10,"cookTime":0,"servings":12,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-nutty-protein-balls.png","youtubeUrl":"https://www.youtube.com/results?search_query=Nutty%20Protein%20Balls%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.981Z"},{"id":335,"title":"Almond Butter & Hemp Toast","description":"Sprouted grain bread spread thick with almond butter and showered in hemp hearts — a simple, crunchy, high-protein toast requiring absolutely no cooking.","ingredients":["2 slices sprouted grain bread","2 tbsp almond butter","2 tbsp hemp hearts","½ banana, sliced (optional)","Drizzle of honey","Pinch of cinnamon"],"instructions":["Spread almond butter thickly over both slices of bread.","Sprinkle hemp hearts generously over the almond butter.","Add banana slices if using.","Drizzle with honey and a pinch of cinnamon.","Serve immediately."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-almond-butter-hemp-toast.png","youtubeUrl":"https://www.youtube.com/results?search_query=Almond%20Butter%20Hemp%20Toast%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.984Z"},{"id":336,"title":"Skyr Fruit Bowl","description":"Thick, tangy Icelandic Skyr — even higher in protein than Greek yogurt — layered with flaxseeds and fresh berries for a beautiful, nutrient-dense breakfast bowl.","ingredients":["200g Skyr (Icelandic yogurt)","1 tbsp ground flaxseeds","½ cup mixed berries (strawberries, blueberries, raspberries)","1 tbsp granola","1 tsp honey","A few fresh mint leaves"],"instructions":["Spoon Skyr into a bowl.","Stir in ground flaxseeds.","Arrange mixed berries on top.","Scatter granola and drizzle with honey.","Garnish with fresh mint and serve immediately."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-skyr-fruit-bowl.png","youtubeUrl":"https://www.youtube.com/results?search_query=Skyr%20Fruit%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.986Z"}]
