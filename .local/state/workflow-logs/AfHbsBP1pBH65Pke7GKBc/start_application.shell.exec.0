6:34:25 PM [express] GET /api/recipes 200 in 63ms :: [{"id":1,"title":"Palak Paneer","description":"Creamy cottage cheese cubes in a vibrant, spiced spinach gravy — the quintessential North Indian comfort food.","ingredients":["500g fresh spinach (palak), washed","250g paneer, cut into cubes","2 medium onions, finely chopped","2 tomatoes, pureed","1 tbsp ginger-garlic paste","2 green chillies, slit","1 tsp cumin seeds","1 tsp garam masala","1 tsp coriander powder","½ tsp turmeric powder","½ tsp red chilli powder","3 tbsp fresh cream","2 tbsp ghee or oil","Salt to taste"],"instructions":["Blanch spinach in boiling water for 2 minutes, then transfer immediately to ice cold water to retain its green colour.","Drain the spinach and blend into a smooth puree. Set aside.","Heat ghee in a kadhai over medium heat. Add cumin seeds and let them splutter.","Add onions and sauté until golden brown, about 8–10 minutes. Add ginger-garlic paste and cook 2 minutes more.","Add tomato puree and all dry spices. Cook until oil separates from the masala, about 8 minutes.","Pour in the spinach puree and mix well. Add ½ cup water and bring to a gentle simmer.","Slide in the paneer cubes and stir gently. Cook for 5 minutes so paneer absorbs the flavours.","Stir in fresh cream and taste for seasoning. Serve hot with roti or steamed rice."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free","Jain Friendly"],"category":"main","imageUrl":"/stock-images/recipe-palak-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Palak%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.654Z"},{"id":2,"title":"Masoor Dal Tadka","description":"Earthy red lentils simmered to silky perfection, finished with a smoky tempering of ghee, cumin and dried chillies.","ingredients":["1 cup masoor dal (red lentils), rinsed","1 medium onion, finely chopped","2 tomatoes, chopped","1 tbsp ginger-garlic paste","1 tsp turmeric powder","1 tsp red chilli powder","1 tsp cumin seeds","2 dry red chillies","1 tsp mustard seeds","8–10 curry leaves","2 tbsp ghee","Fresh coriander for garnish","Salt to taste","Lemon juice to taste"],"instructions":["Pressure cook lentils with turmeric, salt and 3 cups water for 3 whistles until completely soft. Mash lightly.","Heat 1 tbsp oil in a pan. Sauté onions until lightly golden, then add ginger-garlic paste and cook 2 minutes.","Add tomatoes and cook until they break down and oil separates, about 8 minutes.","Stir in red chilli powder and add the cooked lentils. Mix well and simmer 10 minutes adding water for desired consistency.","For tadka: heat ghee in a small pan until smoking. Add cumin seeds, mustard seeds, dry chillies and curry leaves.","Once seeds pop, pour the sizzling tadka over the dal immediately.","Finish with a squeeze of lemon juice and fresh coriander. Serve with rice or roti."],"prepTime":10,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-masoor-dal-tadka.png","youtubeUrl":"https://www.youtube.com/results?search_query=Masoor%20Dal%20Tadka%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.658Z"},{"id":3,"title":"Dosa with Coconut Chutney","description":"Crispy, lacy fermented rice and lentil crepes — South India's most beloved breakfast, served with fresh coconut chutney.","ingredients":["2 cups parboiled rice","½ cup urad dal (split black lentils)","1 tsp fenugreek seeds","Salt to taste","Oil for cooking","For Coconut Chutney:","1 cup fresh grated coconut","2 green chillies","1 small piece ginger","½ cup roasted chana dal","Salt to taste","For chutney tadka:","1 tsp mustard seeds","8 curry leaves","1 dry red chilli","1 tbsp oil"],"instructions":["Soak rice, urad dal and fenugreek seeds in water overnight or for 8 hours. Grind to a smooth batter adding water gradually.","Add salt and ferment the batter in a warm place for 8–12 hours until it rises and turns slightly sour.","For coconut chutney: blend coconut, green chillies, ginger, roasted chana dal and salt with water to a smooth consistency.","Prepare chutney tadka: heat oil, add mustard seeds, curry leaves and dry red chilli. Pour over chutney and mix.","Heat a flat non-stick tawa or iron griddle on medium-high. Rub with a cut onion to season.","Pour a ladleful of batter in the centre and spread in circular motion to a thin crepe.","Drizzle oil around the edges and cook until golden and crisp. Fold and serve hot with coconut chutney."],"prepTime":20,"cookTime":20,"servings":6,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dosa-with-coconut-chutney.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dosa%20with%20Coconut%20Chutney%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.661Z"},{"id":4,"title":"Gujarati Dhokla","description":"Soft, spongy steamed gram flour cakes — light, tangy and irresistibly topped with a sweet-spicy mustard seed tempering.","ingredients":["1 cup besan (gram flour)","¾ cup yogurt, whisked","1 tsp ginger-green chilli paste","1 tsp lemon juice","1 tsp sugar","1 tsp Eno fruit salt (or baking soda)","Salt to taste","For tadka:","2 tbsp oil","1 tsp mustard seeds","8–10 curry leaves","2 green chillies, slit","1 tbsp sugar dissolved in ¼ cup water","Fresh coriander and grated coconut for garnish"],"instructions":["Mix besan, yogurt, ginger-chilli paste, lemon juice, sugar and salt into a smooth batter. Add water if needed — should be of thick pouring consistency.","Grease a steaming thali or cake tin thoroughly with oil.","Add Eno fruit salt to the batter, mix quickly and pour immediately into the greased tin.","Steam on high heat for 15–18 minutes until a toothpick inserted comes out clean.","Allow to cool 5 minutes. Cut into diamond or square shapes.","For tadka: heat oil, add mustard seeds and let them pop. Add curry leaves and green chillies.","Pour the sugar water into the tadka (it will splutter) and then pour over the dhokla immediately.","Garnish with coriander and coconut. Serve with green chutney."],"prepTime":15,"cookTime":20,"servings":6,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-gujarati-dhokla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gujarati%20Dhokla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.665Z"},{"id":5,"title":"Rajma Masala","description":"Hearty kidney beans slow-cooked in a rich, deeply spiced tomato-onion gravy — Punjab's beloved soul food.","ingredients":["1½ cups rajma (kidney beans), soaked overnight","2 large onions, finely chopped","3 large tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","2 bay leaves","1 black cardamom","1 tsp coriander powder","1 tsp cumin powder","½ tsp turmeric","1 tsp red chilli powder","1 tsp garam masala","2 tbsp oil or ghee","Fresh coriander to garnish","Salt to taste"],"instructions":["Pressure cook soaked rajma with salt and 4 cups water for 5–6 whistles until completely tender. Reserve the cooking liquid.","Heat oil in a heavy pan. Add cumin seeds, bay leaves and black cardamom. Let them crackle.","Add onions and cook on medium heat, stirring often, until deep golden brown — about 15 minutes. Don't rush this step.","Add ginger-garlic paste and cook 3 minutes until raw smell disappears.","Add tomato puree and all dry spices except garam masala. Cook on medium heat stirring often until oil separates — about 12 minutes.","Add the boiled rajma along with the cooking liquid. Stir well and bring to a boil.","Simmer on low heat for 20–25 minutes, mashing some beans lightly to thicken the gravy.","Add garam masala and adjust seasoning. Garnish with coriander and serve with steamed basmati rice."],"prepTime":20,"cookTime":60,"servings":5,"cuisineType":"Punjabi","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-rajma-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rajma%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.668Z"},{"id":6,"title":"Aloo Gobi","description":"A rustic, dry-style curry of potatoes and cauliflower stir-fried with whole spices and fresh coriander — simple and deeply satisfying.","ingredients":["3 medium potatoes, cut into cubes","1 small cauliflower, cut into florets","1 large onion, thinly sliced","2 tomatoes, chopped","1 tsp cumin seeds","1 tsp ginger, grated","1 tsp coriander powder","½ tsp turmeric","½ tsp red chilli powder","½ tsp amchur (dry mango powder)","½ tsp garam masala","3 tbsp oil","Fresh coriander to garnish","Salt to taste"],"instructions":["Parboil the potato cubes in salted water for 5 minutes until slightly tender but not fully cooked. Drain and set aside.","Heat oil in a wide pan or kadhai on medium-high heat. Add cumin seeds and let them splutter.","Add onions and cook until lightly golden. Add grated ginger and cook 1 minute.","Add tomatoes and cook until soft. Add all dry spices except garam masala and amchur.","Add cauliflower florets and potatoes. Toss gently to coat with the masala.","Cover and cook on low heat for 15 minutes, stirring occasionally, until both vegetables are tender.","Remove lid, increase heat and cook 3–4 minutes to dry out any moisture.","Sprinkle amchur and garam masala. Toss and garnish generously with fresh coriander."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free","Jain Friendly"],"category":"main","imageUrl":"/stock-images/recipe-aloo-gobi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Gobi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.672Z"},{"id":7,"title":"Sambar","description":"A nourishing South Indian lentil broth packed with vegetables and the complex warmth of freshly ground sambar powder.","ingredients":["½ cup toor dal (split pigeon peas)","1 cup mixed vegetables (drumstick, brinjal, carrot, pumpkin)","1 tomato, quartered","1 small onion, quartered","1 tbsp tamarind paste","2 tbsp sambar powder","½ tsp turmeric","For tadka:","1 tbsp oil","1 tsp mustard seeds","½ tsp cumin seeds","10–12 curry leaves","2 dry red chillies","A pinch of asafoetida (hing)","Salt to taste","Fresh coriander to garnish"],"instructions":["Pressure cook toor dal with turmeric and 2 cups water for 4 whistles until completely mushy. Whisk until smooth.","In a pot, cook the vegetables in 2 cups water with turmeric and salt until just tender.","Add tamarind paste diluted in ½ cup water, sambar powder, tomato and onion to the vegetables. Boil 10 minutes.","Add the cooked dal to the vegetables and mix well. Add water to adjust consistency — sambar should be slightly thin.","Simmer together for 10 minutes until all flavours meld. Taste and adjust salt.","For tadka: heat oil until smoking. Add mustard seeds and wait for them to pop. Add cumin, dry chillies, curry leaves and hing.","Pour the tadka into the sambar immediately. Garnish with coriander and serve hot with idli or rice."],"prepTime":15,"cookTime":40,"servings":5,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sambar.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sambar%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.675Z"},{"id":8,"title":"Chana Masala","description":"Bold, tangy and deeply spiced chickpeas in a thick, complex masala — a Punjabi classic that pairs perfectly with bhature or rice.","ingredients":["1½ cups chickpeas (chana), soaked overnight","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","2 tsp chana masala powder","1 tsp coriander powder","½ tsp red chilli powder","½ tsp turmeric","1 tsp amchur (dry mango powder)","½ tsp garam masala","2 tbsp oil","Fresh coriander, onion rings and lemon wedges to serve","Salt to taste"],"instructions":["Pressure cook chickpeas with salt and a tea bag (for colour) in 3 cups water for 6–7 whistles until completely tender. Discard tea bag.","Heat oil in a heavy pan. Add cumin seeds and let them splutter.","Add onions and cook until deep golden brown — this is key to the flavour, takes about 12–15 minutes.","Add ginger-garlic paste and cook 2 minutes. Add tomato puree and cook until oil separates, about 10 minutes.","Add chana masala powder, coriander powder, red chilli powder and turmeric. Cook 3 minutes more.","Add the cooked chickpeas with some liquid. Mix well and bring to a boil.","Simmer 20 minutes, pressing some chickpeas against the pan to thicken the gravy naturally.","Finish with amchur and garam masala. Serve garnished with coriander, onion rings and a squeeze of lemon."],"prepTime":20,"cookTime":55,"servings":5,"cuisineType":"Punjabi","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-chana-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chana%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.679Z"},{"id":9,"title":"Baingan Bharta","description":"Smoky, fire-roasted aubergine mashed with spices and herbs — a rustic North Indian classic with complex charred depth.","ingredients":["2 large aubergines (baingan)","2 medium onions, finely chopped","2 tomatoes, finely chopped","4 garlic cloves, minced","1 tbsp ginger, grated","2 green chillies, finely chopped","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp red chilli powder","½ tsp garam masala","2 tbsp mustard oil (or any oil)","Fresh coriander to garnish","Salt to taste"],"instructions":["Apply oil all over the aubergines and roast directly on a gas flame, turning with tongs, until skin is completely charred and flesh is completely soft — about 15 minutes.","Place in a bowl covered with foil for 10 minutes. Peel off all charred skin under running water.","Mash the flesh roughly, keeping some texture. Set aside.","Heat oil in a pan. Add cumin seeds. Once they splutter, add onions and cook until golden.","Add garlic, ginger and green chillies. Cook 3 minutes. Add tomatoes and cook until completely broken down.","Add all dry spices and cook the masala 5 minutes more.","Add the mashed aubergine and mix thoroughly. Cook 10 minutes, stirring often.","Adjust salt and finish with garam masala. Garnish abundantly with fresh coriander."],"prepTime":15,"cookTime":40,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-baingan-bharta.png","youtubeUrl":"https://www.youtube.com/results?search_query=Baingan%20Bharta%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.681Z"},{"id":10,"title":"Rasam","description":"A thin, peppery, tamarind-tomato broth — South India's restorative soup that warms from within, served over rice or as a digestif.","ingredients":["2 tbsp toor dal, cooked and mashed","2 tomatoes, blended","1 tbsp tamarind paste","1 tsp black pepper, coarsely crushed","1 tsp cumin powder","1 tsp rasam powder","½ tsp turmeric","3 garlic cloves, crushed","For tadka:","1 tbsp ghee","1 tsp mustard seeds","A pinch of asafoetida","10 curry leaves","2 dry red chillies","Fresh coriander to garnish","Salt to taste"],"instructions":["Combine tomato puree, tamarind paste, turmeric, salt and 2 cups water in a pot. Bring to a boil.","Add crushed garlic, black pepper, cumin powder and rasam powder. Simmer 10 minutes.","Add the cooked, mashed dal and mix well. Thin with more water — rasam should be very watery.","Bring to a full rolling boil for 2 minutes. The top should be frothy. Remove from heat immediately — don't overcook.","For tadka: heat ghee until smoking. Add mustard seeds and wait for them to pop.","Add asafoetida, curry leaves and dry chillies. They will crisp up in seconds.","Pour tadka into the rasam. Garnish with coriander and serve immediately over rice or in small cups as a soup."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-rasam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rasam%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.685Z"},{"id":11,"title":"Paneer Butter Masala","description":"Silky, mildly spiced cottage cheese in a velvety tomato-cashew gravy with butter and cream — India's most celebrated restaurant curry.","ingredients":["300g paneer, cubed","2 onions, roughly chopped","4 tomatoes, roughly chopped","15 cashews, soaked 30 minutes","1 tbsp ginger-garlic paste","2 tsp kashmiri red chilli powder","1 tsp coriander powder","1 tsp sugar","½ tsp garam masala","3 tbsp butter","4 tbsp fresh cream","1 bay leaf","2 green cardamoms","Salt to taste","Dried fenugreek leaves (kasuri methi) to finish"],"instructions":["Heat 1 tbsp butter in a pan. Sauté onions until translucent. Add tomatoes and cashews and cook until tomatoes are soft.","Cool the mixture and blend into a completely smooth, silky puree. Strain through a sieve for extra smoothness.","In the same pan, heat remaining butter. Add bay leaf, cardamom and ginger-garlic paste. Cook 2 minutes.","Add the strained tomato-cashew puree. Add kashmiri chilli powder, coriander powder and sugar.","Cook the gravy on medium heat for 15 minutes until it thickens and butter begins to float on top.","Add paneer cubes and fold gently. Simmer 5 minutes.","Stir in fresh cream and adjust seasoning. Crush dried fenugreek leaves between palms and stir in.","Finish with a swirl of cream and serve with buttery naan or fragrant basmati rice."],"prepTime":20,"cookTime":40,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free","Jain Friendly"],"category":"main","imageUrl":"/stock-images/recipe-paneer-butter-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Butter%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.688Z"},{"id":12,"title":"Khichdi","description":"The ultimate Indian comfort food — a wholesome, golden one-pot of rice and lentils cooked with warming spices. Nourishing and healing.","ingredients":["½ cup basmati rice, rinsed","½ cup moong dal (yellow split lentils), rinsed","1 small onion, finely chopped","1 tomato, chopped","1 tsp ginger, grated","1 tsp cumin seeds","¼ tsp turmeric","¼ tsp asafoetida (hing)","1 tsp ghee","2 tbsp extra ghee to serve","Salt to taste","Fresh coriander to garnish"],"instructions":["Dry roast moong dal in a pan for 3–4 minutes until lightly golden and fragrant. Set aside.","Heat ghee in a pressure cooker. Add cumin seeds and asafoetida. When seeds crackle, add onions.","Sauté onions until translucent. Add ginger and cook 1 minute. Add tomatoes and cook 3 minutes.","Add turmeric and salt. Add the rice and roasted moong dal. Mix to coat with the ghee and spices.","Add 3 cups water. Pressure cook for 3 whistles, then simmer on low for 5 minutes.","Allow pressure to release naturally. Open and mash gently — khichdi should be creamy, not grainy.","Thin with hot water if needed. Serve in bowls, topped generously with ghee and fresh coriander."],"prepTime":10,"cookTime":25,"servings":3,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-khichdi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Khichdi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T13:41:16.691Z"},{"id":13,"title":"Dal Makhani","description":"Velvety whole black lentils and kidney beans slow-cooked overnight with butter and cream — the crown jewel of Punjabi cooking.","ingredients":["1 cup whole urad dal (black lentils)","¼ cup rajma (kidney beans)","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp red chilli powder","1 tsp cumin seeds","¼ tsp turmeric","3 tbsp butter","3 tbsp fresh cream","1 tsp kasuri methi (dried fenugreek leaves)","Salt to taste"],"instructions":["Soak urad dal and rajma overnight in plenty of water. Pressure cook with salt for 8–10 whistles until very soft.","Heat butter in a heavy pan. Add cumin seeds. When they crackle, add onions and cook until deep golden.","Add ginger-garlic paste and cook 3 minutes. Add tomato puree and all dry spices.","Cook the masala until butter separates — about 15 minutes.","Add the cooked lentils and beans with their cooking liquid. Stir well and bring to a boil.","Reduce heat to very low and simmer for at least 30 minutes, stirring occasionally, until thick and creamy.","Crush kasuri methi and add. Stir in cream. Serve with a final knob of butter and naan or rice."],"prepTime":20,"cookTime":90,"servings":6,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dal-makhani.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dal%20Makhani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.574Z"},{"id":14,"title":"Matar Paneer","description":"Fresh garden peas and golden fried paneer in a fragrant, mildly spiced tomato gravy — a wholesome North Indian everyday favourite.","ingredients":["200g paneer, cubed and lightly fried","1 cup fresh or frozen peas","2 onions, blended to paste","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp red chilli powder","½ tsp turmeric","½ tsp garam masala","2 tbsp oil","2 tbsp fresh cream (optional)","Fresh coriander to garnish","Salt to taste"],"instructions":["Lightly fry paneer cubes in oil until golden on all sides. Remove and soak in warm water for 10 minutes.","Heat oil in a pan. Add cumin seeds. When they splutter, add onion paste and cook until light brown.","Add ginger-garlic paste and cook 2 minutes. Add tomato puree and all dry spices except garam masala.","Cook masala until oil separates — about 10 minutes.","Add peas and ½ cup water. Cover and cook until peas are tender — about 8 minutes.","Add the fried paneer cubes. Stir gently and simmer 5 minutes.","Add garam masala and cream. Garnish with coriander and serve with chapati or rice."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-matar-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Matar%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.580Z"},{"id":15,"title":"Shahi Paneer","description":"Mughal-inspired cottage cheese in a rich, aromatic gravy of cashews, cream and whole spices — regal, indulgent and utterly sublime.","ingredients":["300g paneer, cut into cubes","2 onions, roughly chopped","20 cashews, soaked","4 tomatoes, pureed","1 tbsp ginger-garlic paste","2 green cardamoms","4 cloves","1 cinnamon stick","1 tsp kashmiri chilli powder","1 tsp coriander powder","4 tbsp fresh cream","2 tbsp ghee","1 tbsp rose water","Salt to taste"],"instructions":["Sauté onions in ghee until golden. Cool and blend with soaked cashews into a smooth paste.","In the same pan, add whole spices (cardamom, cloves, cinnamon) and ginger-garlic paste. Cook 2 minutes.","Add tomato puree and cook until oil separates, about 10 minutes.","Add the onion-cashew paste. Cook on medium heat, stirring, for 8 minutes until gravy is rich and thick.","Add kashmiri chilli powder, coriander powder and salt. Stir in cream.","Add paneer cubes and gently fold in. Simmer 5 minutes.","Add rose water in the end for a royal fragrance. Serve with naan or basmati pulao."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-shahi-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shahi%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.586Z"},{"id":16,"title":"Malai Kofta","description":"Melt-in-your-mouth fried paneer and potato balls served in a luscious, golden cream and cashew gravy — pure festive indulgence.","ingredients":["200g paneer, grated","2 medium potatoes, boiled and mashed","2 tbsp cornflour","Salt and spices for kofta","Oil for deep frying","2 onions, finely chopped","4 tomatoes, pureed","20 cashews, soaked and blended","1 tsp kashmiri chilli powder","1 tsp coriander powder","4 tbsp cream","2 tbsp butter","Salt to taste"],"instructions":["Mix grated paneer, mashed potato, cornflour, salt and a pinch of spices. Divide into smooth balls.","Deep fry koftas on medium heat until golden and crisp. Drain on paper towels.","Sauté onions in butter until translucent. Add tomato puree and cook until oil separates.","Add the blended cashew paste and stir well. Add kashmiri chilli powder and coriander powder.","Simmer the gravy for 10 minutes until thick and creamy. Stir in cream.","Just before serving, gently place koftas in the gravy. Do not boil or they will break.","Garnish with a drizzle of cream and serve immediately with naan or paratha."],"prepTime":30,"cookTime":40,"servings":5,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-malai-kofta.png","youtubeUrl":"https://www.youtube.com/results?search_query=Malai%20Kofta%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.591Z"},{"id":17,"title":"Kadhai Paneer","description":"Robust, semi-dry cottage cheese with capsicum and onions cooked in a freshly ground kadhai spice blend — bold, aromatic, restaurant-style.","ingredients":["300g paneer, cut into cubes","2 bell peppers (capsicum), cubed","2 onions, cut into chunks","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp coriander seeds, coarsely crushed","1 tsp cumin seeds","½ tsp black pepper, coarsely crushed","2 dry red chillies","1 tsp garam masala","2 tbsp oil","Fresh coriander and ginger julienne to garnish","Salt to taste"],"instructions":["Dry roast coriander seeds, cumin seeds and dry red chillies. Coarsely crush in a mortar.","Heat oil in a kadhai. Add the crushed spice mix and let it bloom for 30 seconds.","Add onion chunks and bell peppers. Stir-fry on high heat for 3–4 minutes keeping them slightly crunchy.","Remove the vegetables and set aside. In the same pan, add ginger-garlic paste and cook 2 minutes.","Add tomato puree and cook until oil separates, about 10 minutes.","Return the vegetables to the pan. Add paneer cubes and toss gently.","Cook 5–7 minutes. Sprinkle garam masala. Garnish with coriander and ginger julienne."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kadhai-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kadhai%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.596Z"},{"id":18,"title":"Aloo Paratha","description":"Golden, flaky whole wheat flatbreads stuffed with a spiced mashed potato filling — Punjab's beloved breakfast, served with white butter.","ingredients":["2 cups whole wheat flour (atta)","Water to knead dough","Salt to taste","4 medium potatoes, boiled and mashed","2 green chillies, finely chopped","1 tsp ginger, grated","1 tsp cumin seeds","1 tsp amchur (dry mango powder)","½ tsp red chilli powder","Fresh coriander, chopped","Ghee or butter for cooking"],"instructions":["Knead whole wheat flour with water and salt into a smooth, soft dough. Cover and rest 30 minutes.","Mix mashed potatoes with green chillies, ginger, cumin, amchur, red chilli powder, coriander and salt.","Divide dough into golf ball-sized portions. Roll one into a small disc.","Place a generous ball of potato filling in the centre. Bring edges together to seal and flatten into a ball.","Gently roll out into a thick paratha, about 20cm diameter, without letting the filling burst out.","Cook on a hot tawa, applying ghee, until both sides are golden with brown spots — about 3 minutes per side.","Serve hot with white butter, yogurt and pickles."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"Punjabi","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-aloo-paratha.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Paratha%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.600Z"},{"id":19,"title":"Chole Bhature","description":"Fiery, tangy Punjabi chickpea curry paired with deep-fried, puffed leavened bread — the iconic street food duo loved across North India.","ingredients":["1½ cups chickpeas, soaked overnight","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","2 tsp chana masala powder","1 tsp coriander powder","1 tsp red chilli powder","2 cups all-purpose flour (for bhature)","½ cup yogurt (for bhature)","1 tsp baking powder","Oil for deep frying","Salt to taste"],"instructions":["Pressure cook chickpeas with salt for 6–7 whistles until very tender.","Sauté onions in oil until deep golden. Add ginger-garlic paste, then tomato puree and all spices.","Add cooked chickpeas with liquid. Simmer 20 minutes until gravy is thick.","For bhature: mix flour, yogurt, baking powder, salt and oil. Knead to a smooth dough. Rest 1 hour.","Divide dough into portions and roll into oval shapes about 5mm thick.","Deep fry in hot oil until golden and puffed on both sides.","Serve chole with bhature, sliced onions and pickles."],"prepTime":30,"cookTime":50,"servings":5,"cuisineType":"Punjabi","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-chole-bhature.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chole%20Bhature%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.603Z"},{"id":20,"title":"Paneer Tikka","description":"Tandoor-kissed cubes of marinated cottage cheese with bell peppers and onions — smoky, spiced and irresistibly charred.","ingredients":["300g paneer, cut into thick cubes","1 red bell pepper, cut into cubes","1 green bell pepper, cut into cubes","1 large onion, cut into chunks","4 tbsp thick yogurt","1 tbsp ginger-garlic paste","1 tsp kashmiri chilli powder","1 tsp chaat masala","½ tsp cumin powder","½ tsp garam masala","2 tbsp oil","Lemon juice to taste","Salt to taste"],"instructions":["Mix yogurt, ginger-garlic paste, kashmiri chilli powder, cumin, garam masala, oil, lemon juice and salt.","Add paneer cubes, bell peppers and onions to the marinade. Toss gently. Marinate for at least 1 hour.","Thread paneer and vegetables alternately onto skewers.","Grill on a very hot grill pan or oven grill at 220°C for 15–20 minutes, turning once, until charred.","Brush with butter during the last 2 minutes for extra flavour.","Sprinkle with chaat masala and a squeeze of lemon.","Serve with mint-coriander chutney and sliced onion rings."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-tikka.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Tikka%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.607Z"},{"id":21,"title":"Jeera Aloo","description":"Simply perfect cumin-spiced potatoes — dry, fragrant and addictive, ready in minutes. A staple side dish for any Indian meal.","ingredients":["4 medium potatoes, boiled and cubed","2 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp amchur (dry mango powder)","½ tsp red chilli powder","2 tbsp oil","Fresh coriander to garnish","Salt to taste"],"instructions":["Boil potatoes until just tender but not mushy. Peel and cut into cubes.","Heat oil in a pan over medium-high heat. Add cumin seeds and let them splutter and brown.","Add the boiled potato cubes. Toss to coat in the cumin oil.","Add coriander powder, turmeric and red chilli powder. Toss well.","Cook on medium-high heat for 5–7 minutes, tossing occasionally, until potatoes get slightly crispy edges.","Sprinkle amchur powder and salt. Toss and taste.","Garnish generously with fresh coriander. Serve with dal and rice or as a side with any main."],"prepTime":5,"cookTime":15,"servings":3,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-jeera-aloo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Jeera%20Aloo%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.611Z"},{"id":22,"title":"Kadhi Pakora","description":"Tangy yogurt-based curry with golden gram flour fritters — a warming, soul-satisfying Punjabi dish best enjoyed with steamed rice.","ingredients":["1 cup yogurt, whisked","4 tbsp besan (gram flour), divided","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander powder","For pakoras: 1 medium onion, sliced","1 green chilli, chopped","Oil for deep frying","For tadka: 2 tbsp ghee","1 tsp cumin seeds","1 tsp mustard seeds","4–5 dry red chillies","A pinch of asafoetida","Salt to taste"],"instructions":["Whisk yogurt with 3 tbsp besan, turmeric, salt and 2 cups water to a smooth, lump-free mixture.","Mix remaining 1 tbsp besan with sliced onions, green chilli, salt and a splash of water to make pakora batter.","Deep fry spoonfuls of pakora batter until golden. Drain and set aside.","Pour the yogurt mixture into a pot. Bring to a boil, stirring constantly to prevent curdling.","Reduce heat and simmer the kadhi for 20–25 minutes, stirring occasionally, until it thickens slightly.","Add the fried pakoras. Simmer 5 more minutes.","For tadka: heat ghee, add cumin, mustard seeds, dry chillies and asafoetida. Pour over kadhi and serve."],"prepTime":20,"cookTime":40,"servings":5,"cuisineType":"Punjabi","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-kadhi-pakora.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kadhi%20Pakora%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.615Z"},{"id":23,"title":"Tawa Pulao","description":"Mumbai street-style smoky fried rice cooked on a flat tawa with pav bhaji masala — vibrant, spicy and irresistibly fragrant.","ingredients":["2 cups cooked basmati rice","1 onion, finely chopped","2 tomatoes, chopped","1 bell pepper, diced","½ cup peas","2 tbsp pav bhaji masala","1 tsp red chilli powder","½ tsp turmeric","2 tbsp butter","Fresh coriander to garnish","Lemon juice to serve","Salt to taste"],"instructions":["Cook rice until just done — each grain should be separate. Spread on a plate and cool.","Heat butter on a flat tawa or wide pan over high heat.","Add onions and sauté on high flame until lightly charred at the edges.","Add tomatoes and cook on high heat, mashing lightly. Add bell peppers and peas.","Add pav bhaji masala, red chilli powder and turmeric. Mix well and cook 2 minutes.","Add the cooked rice and toss everything together on high heat for 3–4 minutes.","Squeeze lemon juice, garnish with coriander and serve with lemon wedges."],"prepTime":10,"cookTime":20,"servings":3,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-tawa-pulao.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tawa%20Pulao%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.618Z"},{"id":24,"title":"Saag Aloo","description":"Tender potatoes in a richly spiced, wilted spinach and fenugreek leaf base — a rustic North Indian classic that's earthy and warming.","ingredients":["3 medium potatoes, cut into cubes","400g spinach (palak), blanched","1 cup fenugreek leaves (methi)","1 onion, finely chopped","2 tomatoes, chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp red chilli powder","2 tbsp oil","Salt to taste"],"instructions":["Blanch spinach and fenugreek leaves in boiling water for 2 minutes. Drain and blend coarsely.","Parboil potato cubes in salted water until slightly tender. Drain and set aside.","Heat oil in a pan. Add cumin seeds. When they splutter, add onions and cook until golden.","Add ginger-garlic paste and cook 2 minutes. Add tomatoes and cook until soft.","Add all dry spices and cook the masala 5 minutes.","Add the potatoes and toss to coat. Cook 5 minutes.","Add the blended greens and mix well. Cover and cook 10 minutes until everything is combined.","Adjust seasoning and serve with makki ki roti or paratha."],"prepTime":15,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-saag-aloo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Saag%20Aloo%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.622Z"},{"id":25,"title":"Paneer Bhurji","description":"Scrambled cottage cheese stir-fried with spiced onions, tomatoes and peppers — a quick, protein-packed Indian breakfast or snack.","ingredients":["300g paneer, crumbled","1 large onion, finely chopped","2 tomatoes, finely chopped","1 bell pepper, diced","2 green chillies, finely chopped","1 tsp ginger, grated","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","½ tsp garam masala","2 tbsp oil","Fresh coriander to garnish","Salt to taste"],"instructions":["Heat oil in a pan. Add cumin seeds and let them splutter.","Add green chillies and grated ginger. Cook 30 seconds.","Add onions and sauté until golden. Add bell peppers and cook 2 minutes.","Add tomatoes and cook until they completely break down, about 5 minutes.","Add turmeric, red chilli powder and salt. Mix well.","Add crumbled paneer and toss everything together on high heat.","Cook 3–4 minutes, stirring often. Sprinkle garam masala and fresh coriander.","Serve hot with buttered toast or paratha."],"prepTime":10,"cookTime":15,"servings":3,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-bhurji.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Bhurji%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.625Z"},{"id":26,"title":"Bharwa Bhindi","description":"Whole okra stuffed with a tangy masala of coriander, cumin and amchur — a delicate dry sabzi that pairs beautifully with dal and rice.","ingredients":["500g bhindi (okra), wiped clean","1 tsp coriander powder","1 tsp cumin powder","½ tsp amchur (dry mango powder)","½ tsp fennel powder","½ tsp red chilli powder","¼ tsp turmeric","Salt to taste","2 tbsp oil","1 tsp lemon juice"],"instructions":["Trim the top and bottom of each bhindi. Make a vertical slit lengthwise without cutting all the way through.","Mix all the dry spices with salt. Add lemon juice to make a slightly moist masala.","Using a spoon or finger, stuff each bhindi generously with the masala mixture.","Heat oil in a wide, heavy-bottomed pan over medium heat.","Arrange the stuffed bhindi in a single layer. Cover and cook 5 minutes.","Gently turn and cook the other side, covered, for another 5 minutes.","Remove lid and cook on medium-high for 3–4 more minutes until bhindi is tender and slightly crispy.","Serve with dal and rotis."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bharwa-bhindi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bharwa%20Bhindi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.628Z"},{"id":27,"title":"Makki Ki Roti with Sarson Ka Saag","description":"The great Punjabi winter duo — crispy yellow corn flatbread paired with slow-cooked mustard greens, finished with a generous knob of white butter.","ingredients":["2 cups makki ka atta (corn flour)","Hot water to knead","Salt to taste","Ghee for cooking","500g sarson (mustard greens), chopped","200g spinach, chopped","100g bathua (lamb's quarters) or more spinach","1 onion, finely chopped","2 green chillies","1 tbsp ginger, grated","2 tbsp ghee","1 tsp maize flour to thicken saag","White butter to serve"],"instructions":["Pressure cook sarson, spinach and bathua with a little water and salt for 4–5 whistles. Mash coarsely.","Heat ghee in a pan. Sauté onions until golden. Add ginger and green chillies.","Add the mashed greens. Mix in maize flour to thicken. Simmer 20 minutes on low heat.","For makki ki roti: mix corn flour, salt and enough hot water to make a soft dough.","Flatten each portion into a thick disc (about 5mm) by hand on a piece of plastic wrap.","Cook on a tawa with ghee over medium heat until golden on both sides — about 4 minutes per side.","Serve roti with saag and a generous knob of white butter on top."],"prepTime":25,"cookTime":45,"servings":4,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-makki-ki-roti-with-sarson-ka-saag.png","youtubeUrl":"https://www.youtube.com/results?search_query=Makki%20Ki%20Roti%20Sarson%20Ka%20Saag%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.631Z"},{"id":28,"title":"Mix Veg Curry","description":"A colourful medley of seasonal vegetables in a fragrant, mildly spiced tomato-onion gravy — versatile, nutritious and endlessly customisable.","ingredients":["2 carrots, diced","1 potato, diced","½ cup French beans, chopped","½ cup cauliflower florets","½ cup peas","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","2 tbsp oil","Salt to taste"],"instructions":["Parboil carrots and potatoes in salted water for 5 minutes. Set aside.","Heat oil in a pan. Add cumin seeds. When they splutter, add onions and cook until golden.","Add ginger-garlic paste and cook 2 minutes. Add tomato puree and all dry spices except garam masala.","Cook masala until oil separates — about 8 minutes.","Add all the vegetables including French beans, cauliflower and peas.","Add ½ cup water. Cover and cook 12–15 minutes until all vegetables are tender.","Sprinkle garam masala, stir and serve hot with roti or rice."],"prepTime":20,"cookTime":30,"servings":5,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mix-veg-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mix%20Veg%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.634Z"},{"id":29,"title":"Mushroom Do Pyaaza","description":"Button mushrooms cooked twice with onions in a rich, restaurant-style masala — earthy, fragrant and wonderfully indulgent.","ingredients":["400g button mushrooms, halved","3 large onions, 2 finely chopped, 1 cut into chunks","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp red chilli powder","½ tsp garam masala","2 tbsp oil","Fresh coriander and ginger julienne to garnish","Salt to taste"],"instructions":["Sauté mushrooms in 1 tbsp oil on high heat until lightly browned and all moisture evaporates. Set aside.","Heat remaining oil. Add cumin seeds. When they crackle, add finely chopped onions.","Cook onions until deep golden. Add ginger-garlic paste and cook 2 minutes.","Add tomato puree and all dry spices except garam masala. Cook until oil separates.","Add the browned mushrooms and the chunky onions. Stir well.","Cook on medium heat for 8–10 minutes until mushrooms are cooked through and masala clings.","Sprinkle garam masala. Garnish with coriander and ginger julienne. Serve with naan."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mushroom-do-pyaaza.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mushroom%20Do%20Pyaaza%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.637Z"},{"id":30,"title":"Lauki Chana Dal","description":"Bottle gourd and split chickpeas cooked together in a light, mildly spiced curry — digestible, comforting and beautifully simple.","ingredients":["1 medium lauki (bottle gourd), peeled and cubed","½ cup chana dal (split chickpeas), soaked 1 hour","1 onion, finely chopped","2 tomatoes, chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","½ tsp coriander powder","2 tbsp oil","Fresh coriander to garnish","Salt to taste"],"instructions":["Pressure cook chana dal with turmeric and 1 cup water for 2 whistles — it should be cooked but hold its shape.","Heat oil in a pressure cooker. Add cumin seeds. When they crackle, add onions and cook until golden.","Add ginger-garlic paste and cook 2 minutes. Add tomatoes and cook until soft.","Add all dry spices and salt. Cook the masala 3 minutes.","Add lauki cubes and the cooked chana dal. Mix well.","Add 1 cup water. Pressure cook for 2 whistles.","Open, adjust consistency and seasoning. Garnish with coriander and serve with roti."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-lauki-chana-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lauki%20Chana%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.641Z"},{"id":31,"title":"Idli with Sambar","description":"Pillowy-soft steamed rice and lentil cakes served with a hearty, vegetable-packed sambar — the quintessential South Indian breakfast.","ingredients":["2 cups idli rice (or parboiled rice)","½ cup urad dal","1 tsp fenugreek seeds","Salt to taste","½ cup toor dal (for sambar)","1 cup mixed vegetables","2 tbsp sambar powder","1 tbsp tamarind paste","1 tsp mustard seeds","10 curry leaves","2 dry red chillies","A pinch of asafoetida","1 tbsp oil"],"instructions":["Soak rice, urad dal and fenugreek seeds separately for 6 hours. Grind urad dal first until very fluffy.","Grind rice to a slightly coarse batter. Mix both batters with salt. Ferment overnight.","Grease idli moulds. Pour batter into moulds and steam for 10–12 minutes until cooked through.","For sambar: pressure cook toor dal until mushy. Cook vegetables in water with turmeric.","Add sambar powder, tamarind and cooked dal to vegetables. Simmer 15 minutes.","Prepare tadka with mustard seeds, curry leaves, dry chillies and asafoetida. Add to sambar.","Serve hot idlis with sambar and coconut chutney."],"prepTime":20,"cookTime":30,"servings":6,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-idli-with-sambar.png","youtubeUrl":"https://www.youtube.com/results?search_query=Idli%20with%20Sambar%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.643Z"},{"id":32,"title":"Uttapam","description":"Thick, pancake-style dosas topped with colourful diced vegetables — crispy at the edges, soft in the centre, utterly satisfying.","ingredients":["2 cups dosa batter (fermented)","1 onion, finely chopped","2 tomatoes, finely chopped","1 bell pepper, diced","2 green chillies, finely chopped","Fresh coriander, chopped","Oil for cooking","Salt to taste"],"instructions":["Prepare dosa batter by soaking and fermenting rice and urad dal (or use ready-made batter).","Mix the chopped vegetables together.","Heat a tawa on medium heat. Grease lightly with oil.","Pour a ladleful of batter and gently spread into a thick circle (don't make it too thin).","While the batter is still wet, scatter a generous amount of mixed vegetables on top. Press lightly.","Drizzle oil around the edges. Cook 3–4 minutes until the bottom is golden.","Flip carefully and cook the vegetable side for 2–3 minutes. Serve with sambar and chutney."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-uttapam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Uttapam%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.646Z"},{"id":33,"title":"Pongal","description":"Sacred comfort — a creamy, peppery porridge of rice and moong dal cooked with ghee, cashews and whole spices, served at sunrise.","ingredients":["1 cup raw rice","½ cup moong dal","2 tsp black pepper, coarsely crushed","1 tsp cumin seeds","10–12 cashews","10 curry leaves","1 tbsp ginger, grated","A pinch of asafoetida","3 tbsp ghee","Salt to taste"],"instructions":["Dry roast moong dal until lightly golden and fragrant.","Wash rice and roasted dal together. Pressure cook with 5 cups water and salt for 5 whistles until very soft.","Mash well until the rice and dal merge into a thick, creamy porridge. Add hot water if too thick.","Heat ghee in a small pan. Add cashews and fry until golden. Remove and set aside.","In the same ghee, add cumin seeds, black pepper, curry leaves and asafoetida.","When spices splutter, add grated ginger and cook 30 seconds.","Pour the entire tempering over the pongal. Add fried cashews. Mix and serve hot with sambar and chutney."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-pongal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pongal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.649Z"},{"id":34,"title":"Medu Vada","description":"Crispy, doughnut-shaped urad dal fritters with a crunchy exterior and fluffy interior — the indispensable sidekick to idli and sambar.","ingredients":["1 cup urad dal (split black lentils), soaked 4 hours","1 tsp ginger, finely grated","2 green chillies, finely chopped","10 curry leaves, chopped","½ tsp black pepper","A pinch of asafoetida","Salt to taste","Oil for deep frying"],"instructions":["Drain soaked urad dal and grind to a very thick, fluffy batter using minimal water. The batter should be stiff.","Add ginger, green chillies, curry leaves, black pepper, asafoetida and salt. Mix well.","Wet your hands. Take a small portion of batter and shape into a ball. Make a hole in the centre with your thumb.","Heat oil for deep frying. Slide the vada carefully into the hot oil.","Fry on medium heat for 3–4 minutes, turning once, until deep golden and crisp.","Drain on paper towels.","Serve immediately with sambar and coconut chutney."],"prepTime":20,"cookTime":25,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-medu-vada.png","youtubeUrl":"https://www.youtube.com/results?search_query=Medu%20Vada%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.652Z"},{"id":35,"title":"Masala Dosa","description":"A crispy, paper-thin crepe wrapped around a fragrant spiced potato filling — South India's most famous export, beloved worldwide.","ingredients":["2 cups fermented dosa batter","3 medium potatoes, boiled and coarsely mashed","1 onion, thinly sliced","2 green chillies, slit","1 tsp mustard seeds","10 curry leaves","½ tsp turmeric","2 tbsp oil","Fresh coriander for filling","Salt to taste","Oil for cooking dosa"],"instructions":["For the filling: heat oil, add mustard seeds. When they pop, add curry leaves and green chillies.","Add sliced onions and cook until translucent. Add turmeric and salt.","Add mashed potatoes and mix well. Fold in fresh coriander. Set aside.","Heat a tawa on medium-high. Grease lightly.","Pour a ladleful of batter and spread immediately into a very thin circle.","Drizzle oil around edges. Cook until the base is crisp and golden.","Place potato filling in the centre. Fold the dosa over and serve immediately with sambar and chutneys."],"prepTime":15,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-masala-dosa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Masala%20Dosa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.655Z"},{"id":36,"title":"Avial","description":"Kerala's treasured mixed vegetable stew in a thick, tangy coconut-yogurt gravy — a celebration of seasonal vegetables in temple-style cooking.","ingredients":["2 cups mixed vegetables (raw banana, drumstick, yam, carrot, beans, raw mango)","1 cup fresh grated coconut","2 green chillies","1 tsp cumin seeds","½ cup sour yogurt","½ tsp turmeric","1 tbsp coconut oil","10 curry leaves","Salt to taste"],"instructions":["Cook vegetables in salted water with turmeric until just tender but still holding their shape.","Grind coconut, green chillies and cumin seeds with a little water to a coarse paste.","Drain most of the cooking water from vegetables, leaving just a little.","Add the coconut paste to the vegetables and mix well. Cook on low heat for 5 minutes.","Remove from heat. Add whisked sour yogurt and stir gently — do not boil after adding yogurt.","Heat coconut oil and add curry leaves. When they splutter, pour over the avial.","Serve with rice or as a side for a South Indian feast."],"prepTime":20,"cookTime":25,"servings":5,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-avial.png","youtubeUrl":"https://www.youtube.com/results?search_query=Avial%20Kerala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.658Z"},{"id":37,"title":"Curd Rice","description":"Cooling, comforting rice mixed with yogurt and tempered with mustard and curry leaves — the definitive South Indian palate cleanser and meal ender.","ingredients":["2 cups cooked rice","1½ cups yogurt, whisked","¼ cup milk","1 tsp mustard seeds","1 tsp cumin seeds","10 curry leaves","2 dry red chillies","2 green chillies, finely chopped","1 tsp ginger, grated","A pinch of asafoetida","2 tbsp oil","Pomegranate seeds and coriander to garnish","Salt to taste"],"instructions":["Mash the cooked rice slightly. Allow it to cool completely.","Mix whisked yogurt and milk into the rice. Season with salt. The mixture should be creamy.","Heat oil in a small pan. Add mustard seeds and let them pop.","Add cumin seeds, dry red chillies, curry leaves and asafoetida.","Add grated ginger and green chillies. Cook 30 seconds.","Pour the tempering over the curd rice and mix well.","Garnish with pomegranate seeds and fresh coriander. Serve at room temperature or chilled."],"prepTime":10,"cookTime":10,"servings":3,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-curd-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Curd%20Rice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.661Z"},{"id":38,"title":"Lemon Rice","description":"Bright, sunshine-yellow turmeric and lemon-infused rice with a crunchy peanut and curry leaf tempering — tangy, vibrant and irresistible.","ingredients":["2 cups cooked rice","Juice of 1 lemon","½ tsp turmeric","2 tbsp oil","1 tsp mustard seeds","1 tsp chana dal","1 tsp urad dal","2–3 dry red chillies","10 curry leaves","¼ cup roasted peanuts","A pinch of asafoetida","Salt to taste"],"instructions":["Cook rice until just done. Spread on a plate to cool completely — each grain should be separate.","Heat oil in a large pan. Add mustard seeds and let them pop.","Add chana dal, urad dal and dry red chillies. Fry until dals turn golden.","Add curry leaves and asafoetida. Sauté 30 seconds.","Add turmeric and immediately add the cooled rice. Toss gently.","Add peanuts, lemon juice and salt. Toss everything together.","Taste and adjust lemon juice. Serve warm or at room temperature."],"prepTime":10,"cookTime":15,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-lemon-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lemon%20Rice%20South%20Indian%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.664Z"},{"id":39,"title":"Bisi Bele Bath","description":"Karnataka's legendary one-pot of rice, lentils and vegetables simmered with an aromatic masala — nourishing, complex and deeply satisfying.","ingredients":["1 cup rice","½ cup toor dal","1 cup mixed vegetables (carrots, beans, peas, potato)","2 tbsp bisi bele bath masala powder","1 tbsp tamarind paste","1 tsp jaggery","½ tsp turmeric","For tadka: 2 tbsp ghee","1 tsp mustard seeds","10 cashews","10 curry leaves","2 dry red chillies","A pinch of asafoetida","Salt to taste"],"instructions":["Pressure cook toor dal with turmeric and 2 cups water for 4 whistles. Mash completely.","Cook rice with vegetables in 3 cups water until tender.","Combine the cooked dal with the rice-vegetable mixture in a large pot.","Add tamarind paste, bisi bele bath masala, jaggery and salt. Mix well.","Cook on medium heat for 10–15 minutes, stirring, until everything comes together and thickens.","For tadka: heat ghee, fry cashews until golden. Add mustard seeds, curry leaves, chillies and asafoetida.","Pour the tadka over the bisi bele bath. Serve hot with raita and papad."],"prepTime":20,"cookTime":45,"servings":5,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bisi-bele-bath.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bisi%20Bele%20Bath%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.667Z"},{"id":40,"title":"Rava Upma","description":"A quick, savoury semolina porridge cooked with onions, mustard seeds and curry leaves — South India's beloved 15-minute morning staple.","ingredients":["1 cup rava (semolina), dry roasted","1 medium onion, finely chopped","2 green chillies, slit","1 tsp mustard seeds","1 tsp chana dal","1 tsp urad dal","10 curry leaves","A pinch of asafoetida","2 tbsp oil or ghee","2½ cups water, boiling","Salt to taste","Fresh coriander and grated coconut to garnish"],"instructions":["Dry roast rava on medium heat until lightly golden and fragrant. Set aside.","Heat oil in a pan. Add mustard seeds and let them pop.","Add chana dal and urad dal. Fry until lightly golden.","Add green chillies, curry leaves and asafoetida. Sauté 30 seconds.","Add onions and cook until translucent.","Add boiling water and salt. Bring to a rolling boil.","Add roasted rava in a steady stream, stirring continuously to prevent lumps.","Cover and cook 3–4 minutes until rava is cooked through. Garnish and serve."],"prepTime":5,"cookTime":15,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-rava-upma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rava%20Upma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.669Z"},{"id":41,"title":"Tamarind Rice","description":"Puliyodarai — tangy, peppery tamarind rice with a punchy tempering of peanuts and spices, a South Indian temple offering and travel staple.","ingredients":["2 cups cooked rice","2 tbsp thick tamarind paste","¼ cup roasted peanuts","2 tbsp sesame seeds, toasted","2 tbsp oil","1 tsp mustard seeds","1 tsp chana dal","1 tsp urad dal","3–4 dry red chillies","10 curry leaves","½ tsp turmeric","A pinch of asafoetida","1 tsp jaggery","Salt to taste"],"instructions":["Spread cooked rice on a plate and allow to cool — grains must be separate.","Mix tamarind paste with ½ cup water, turmeric, jaggery and salt.","Heat oil in a pan. Add mustard seeds and let them pop.","Add chana dal, urad dal and dry red chillies. Fry until golden.","Add curry leaves, asafoetida and peanuts. Toss 1 minute.","Add the tamarind mixture. Cook on medium heat for 5 minutes until it thickens slightly.","Add the cooked rice and toss gently to coat every grain. Add sesame seeds and serve."],"prepTime":10,"cookTime":15,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-tamarind-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tamarind%20Rice%20Puliyodarai%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.672Z"},{"id":42,"title":"Pesarattu","description":"Green moong dal crepes from Andhra Pradesh — protein-rich, crispy and flavoured with ginger and green chillies. Served with upma stuffing.","ingredients":["1 cup whole green moong dal, soaked 6 hours","2–3 green chillies","1 tbsp ginger, grated","A pinch of asafoetida","Salt to taste","Oil for cooking","Ginger, green chillies and onion to scatter on top"],"instructions":["Drain soaked moong dal. Grind with green chillies, ginger, asafoetida and salt to a smooth batter.","The batter should be like dosa batter — not too thick, not too thin.","Heat a tawa on medium-high. Grease lightly.","Pour a ladleful of batter and spread into a thin circle.","Scatter finely chopped ginger, green chillies and onion on top.","Drizzle oil around edges. Cook 3–4 minutes until crispy at the bottom.","Fold and serve with ginger chutney or upma stuffed inside."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-pesarattu.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pesarattu%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.674Z"},{"id":43,"title":"Rava Idli","description":"Instant semolina idlis that need no fermentation — fluffy, spongy and ready in under 30 minutes. A modern South Indian breakfast essential.","ingredients":["1 cup rava (semolina)","¾ cup yogurt","½ tsp baking soda","1 tsp mustard seeds","1 tsp chana dal","10 curry leaves","2 green chillies, chopped","1 tbsp oil","Fresh coriander, chopped","Cashews for topping","Salt to taste"],"instructions":["Dry roast rava until fragrant. Cool completely.","Heat oil. Add mustard seeds, chana dal, curry leaves and green chillies. Sauté 1 minute.","Mix roasted rava, yogurt, salt and the tempering together. Add water if needed to make a thick batter.","Rest the batter for 10 minutes.","Just before steaming, add baking soda and mix gently.","Grease idli moulds. Place a cashew in each mould. Pour batter.","Steam for 10–12 minutes until a toothpick comes out clean. Serve with sambar and chutney."],"prepTime":15,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-rava-idli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rava%20Idli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.678Z"},{"id":44,"title":"Kesari Bath","description":"Golden semolina halwa perfumed with saffron, fragrant with cardamom and studded with cashews and raisins — a South Indian festive sweet.","ingredients":["1 cup rava (semolina)","¾ cup sugar","2 cups water","A pinch of saffron, soaked in warm milk","½ tsp cardamom powder","3 tbsp ghee","10 cashews","2 tbsp raisins","A drop of orange or yellow food colour (optional)"],"instructions":["Dry roast rava in ghee on medium heat until golden and fragrant — about 5 minutes.","In a separate pan, boil water with sugar and saffron (with its milk) until sugar dissolves.","Pour the hot sugar syrup slowly into the roasted rava, stirring constantly to prevent lumps.","Cook on low heat, stirring, until the mixture thickens and leaves the sides of the pan.","In a small pan, fry cashews and raisins in ghee until golden.","Add cardamom powder and the fried nuts to the kesari. Mix well.","Serve warm, shaped into portions or directly from the pan."],"prepTime":5,"cookTime":20,"servings":5,"cuisineType":"South Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-kesari-bath.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kesari%20Bath%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.680Z"},{"id":45,"title":"Undhiyu","description":"Gujarati's crown jewel — a mixed winter vegetable and muthiya casserole slow-cooked with a fragrant coconut-herb masala. A labour of love.","ingredients":["500g mixed vegetables (surti papdi, raw banana, purple yam, brinjal, sweet potato)","For muthiyas: 1 cup methi leaves, chopped","1 cup besan (gram flour)","1 tsp ginger-chilli paste","For masala: 1 cup fresh grated coconut","1 cup fresh coriander","2 tbsp sesame seeds","1 tbsp sugar","1 tsp cumin seeds","4 garlic cloves","2 tbsp oil","Salt to taste"],"instructions":["For muthiyas: mix methi leaves, besan, ginger-chilli paste, salt and oil to a stiff dough. Shape into small cylinders. Deep fry until golden.","Grind coconut, coriander, sesame seeds, garlic, cumin, sugar and salt to a coarse masala.","Cut all vegetables into large chunks. Slit brinjals and stuff with the coconut masala.","Heat oil in a heavy pot. Layer vegetables, starting with hardest at the bottom.","Add muthiyas on top. Pour remaining masala over everything.","Add oil and a splash of water. Cover tightly and cook on very low heat for 30–40 minutes.","Gently stir once halfway through. Serve with puris."],"prepTime":45,"cookTime":50,"servings":6,"cuisineType":"Gujarati","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-undhiyu.png","youtubeUrl":"https://www.youtube.com/results?search_query=Undhiyu%20Gujarati%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.683Z"},{"id":46,"title":"Dal Dhokli","description":"Wholesome whole wheat flour dumplings simmered in a sweet-sour-spicy toor dal — Gujarat's ultimate one-pot comfort food.","ingredients":["1 cup toor dal","1 cup whole wheat flour","1 tbsp besan (gram flour)","1 tsp ginger-chilli paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander powder","1 tbsp tamarind paste","1 tbsp jaggery","1 tsp mustard seeds","10 curry leaves","2 tbsp ghee","Fresh coriander to garnish","Salt to taste"],"instructions":["Pressure cook toor dal with turmeric for 4 whistles. Mash and add tamarind, jaggery, salt and spices.","Simmer the dal for 10 minutes, adjusting consistency with water.","Mix whole wheat flour, besan, ginger-chilli paste, turmeric, salt and a little oil. Knead to stiff dough.","Roll the dough thin and cut into diamond shapes (dhoklis).","Drop dhoklis into the simmering dal. Cook 10–12 minutes until they are cooked through.","Prepare tadka with mustard seeds, curry leaves in ghee. Pour over the dal dhokli.","Garnish with coriander. Serve piping hot with ghee drizzled on top."],"prepTime":20,"cookTime":40,"servings":4,"cuisineType":"Gujarati","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-dal-dhokli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dal%20Dhokli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.686Z"},{"id":47,"title":"Khandvi","description":"Paper-thin, melt-in-your-mouth gram flour rolls in a tangy yogurt base — a Gujarati snack of extraordinary texture and elegance.","ingredients":["1 cup besan (gram flour)","1 cup yogurt","2 cups water","½ tsp turmeric","1 tsp ginger-chilli paste","Salt to taste","For tadka: 2 tbsp oil","1 tsp mustard seeds","1 tsp sesame seeds","10 curry leaves","2 dry red chillies","Fresh coriander and grated coconut to garnish"],"instructions":["Whisk besan, yogurt, water, turmeric, ginger-chilli paste and salt into a completely smooth, lump-free mixture.","Cook the mixture in a heavy pan on medium heat, stirring constantly without stopping for 10–12 minutes until very thick.","Immediately spread a thin layer on a greased surface or on the back of a steel plate.","Allow to cool for 5 minutes. Cut into 7cm wide strips.","Roll each strip tightly from one end to make a cylinder. Arrange on a serving plate.","Heat oil for tadka. Add mustard seeds, sesame seeds, curry leaves and dry chillies.","Pour tadka over khandvi. Garnish with coriander and coconut."],"prepTime":10,"cookTime":20,"servings":5,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-khandvi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Khandvi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.688Z"},{"id":48,"title":"Methi Thepla","description":"Soft, spiced flatbreads packed with fresh fenugreek leaves — Gujarat's ultimate travel food that stays fresh for days.","ingredients":["2 cups whole wheat flour","1 cup fresh methi (fenugreek) leaves, washed and chopped","½ cup yogurt","1 tsp ginger-chilli paste","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","½ tsp ajwain (carom seeds)","2 tbsp oil","Salt to taste","Oil for cooking"],"instructions":["Mix all dry ingredients — flour, cumin, turmeric, red chilli, ajwain and salt.","Add methi leaves, ginger-chilli paste, yogurt and oil. Mix well.","Knead to a soft, smooth dough using water if needed. Rest 15 minutes.","Divide into equal portions. Roll each into a thin circle.","Cook on a hot tawa over medium heat, applying oil on both sides.","Cook until golden spots appear on both sides — about 2 minutes per side.","Serve with yogurt, pickle or raw mango chutney."],"prepTime":20,"cookTime":20,"servings":5,"cuisineType":"Gujarati","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-methi-thepla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Methi%20Thepla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.691Z"},{"id":49,"title":"Sev Tameta Nu Shaak","description":"Juicy tomatoes cooked in a tangy sweet-spice Gujarati gravy, finished generously with crunchy sev — a quick, vibrant everyday sabzi.","ingredients":["4 large tomatoes, roughly chopped","1 onion, finely chopped","1 tsp ginger-chilli paste","1 tsp mustard seeds","½ tsp cumin seeds","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander-cumin powder","1 tsp sugar","2 tbsp oil","Fresh coriander","Salt to taste","1 cup sev (fried chickpea noodles) to top"],"instructions":["Heat oil. Add mustard seeds and cumin seeds. Let them splutter.","Add onions and cook until translucent. Add ginger-chilli paste and cook 1 minute.","Add chopped tomatoes. Cook on medium heat until tomatoes break down completely — about 8 minutes.","Add turmeric, red chilli powder, coriander-cumin powder, sugar and salt.","Cook 5 more minutes until the sabzi comes together and oil separates.","Add fresh coriander.","Serve immediately topped generously with sev. The contrast of hot gravy and crunchy sev is essential."],"prepTime":10,"cookTime":20,"servings":3,"cuisineType":"Gujarati","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sev-tameta-nu-shaak.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sev%20Tameta%20Nu%20Shaak%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.694Z"},{"id":50,"title":"Gujarati Kadhi","description":"A thin, sweet-sour yogurt and gram flour broth tempered with whole spices — lighter, more delicate and more complex than its Punjabi counterpart.","ingredients":["2 cups yogurt, whisked","3 tbsp besan (gram flour)","1 tsp ginger-chilli paste","1 tsp sugar","Salt to taste","2 tbsp ghee","1 tsp mustard seeds","½ tsp cumin seeds","4–5 cloves","2 cinnamon sticks","10–12 curry leaves","3 dry red chillies","A pinch of asafoetida"],"instructions":["Whisk yogurt, besan, ginger-chilli paste, sugar, salt and 2 cups water until completely smooth.","Pour into a pot and heat on medium, stirring constantly until it comes to a boil.","Reduce heat and simmer 15–20 minutes, stirring occasionally, until slightly thickened.","For tadka: heat ghee until hot. Add mustard seeds and let them pop.","Add cumin seeds, cloves, cinnamon, curry leaves, dry chillies and asafoetida.","Pour the sizzling tadka into the kadhi.","Adjust seasoning. Serve with khichdi or rice for a perfect Gujarati meal."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-gujarati-kadhi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gujarati%20Kadhi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.697Z"},{"id":51,"title":"Patra","description":"Colocasia leaves smeared with a tangy besan paste, rolled, steamed and then fried — a Gujarati snack of incredible textural genius.","ingredients":["6 large colocasia (arvi) leaves","2 cups besan (gram flour)","2 tbsp tamarind paste","2 tbsp jaggery","1 tsp ginger-chilli paste","1 tsp coriander-cumin powder","½ tsp turmeric","Salt to taste","Oil for frying","For tadka: mustard seeds, sesame seeds, curry leaves"],"instructions":["Mix besan with tamarind, jaggery, ginger-chilli paste, spices and enough water to make a smooth, spreadable paste.","Wash colocasia leaves and dry completely. Trim the central vein to make it pliable.","Apply a thin, even layer of the besan paste on one side of a leaf.","Stack 2–3 leaves on top of each other (paste side up) and roll tightly from the wider end.","Secure with a thread and steam for 20 minutes. Allow to cool.","Slice into rounds. Shallow-fry or pan-fry until crispy on both sides.","Prepare tadka and pour over. Garnish with coconut and coriander."],"prepTime":30,"cookTime":35,"servings":5,"cuisineType":"Gujarati","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-patra.png","youtubeUrl":"https://www.youtube.com/results?search_query=Patra%20Gujarati%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.700Z"},{"id":52,"title":"Dabeli","description":"Mumbai's famous street sandwich — a soft pav filled with a tangy spiced potato mixture, chutneys, pomegranate and crunchy sev. Pure joy.","ingredients":["4 pav buns","3 medium potatoes, boiled and mashed","1 tbsp dabeli masala","1 tbsp tamarind chutney","1 tbsp green chutney","1 tsp red garlic chutney","Butter for toasting","¼ cup pomegranate seeds","¼ cup roasted peanuts","½ cup sev","Fresh coriander","Salt to taste"],"instructions":["Mix mashed potatoes with dabeli masala, a spoonful of tamarind chutney and salt.","Divide potato mixture into portions, shaping each into a flat patty.","Slit pav buns without separating them completely.","Apply butter inside and toast on a hot tawa until golden.","Spread green chutney and garlic chutney inside the bun.","Place the potato patty inside. Top with tamarind chutney, pomegranate seeds, peanuts and sev.","Garnish with coriander. Press and serve immediately."],"prepTime":20,"cookTime":15,"servings":4,"cuisineType":"Gujarati","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-dabeli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dabeli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.702Z"},{"id":53,"title":"Batata Vada","description":"Golden, crunchy gram flour-coated fried potato balls — the heart of the beloved Vada Pav. Addictive, spicy and utterly perfect.","ingredients":["4 medium potatoes, boiled and mashed","1 tsp ginger-green chilli paste","1 tsp mustard seeds","10 curry leaves","½ tsp turmeric","1 tbsp fresh coriander, chopped","1 tsp lemon juice","For batter: 1 cup besan","½ tsp turmeric","A pinch of baking soda","Salt to taste","Oil for deep frying"],"instructions":["Heat 1 tsp oil. Add mustard seeds, curry leaves and ginger-chilli paste.","Add turmeric and the mashed potatoes. Mix well. Add lemon juice, coriander and salt.","Divide into equal portions and roll into smooth balls.","Make a thick batter with besan, turmeric, baking soda, salt and water.","Heat oil for deep frying. Dip each potato ball in the batter to coat completely.","Fry in hot oil until golden and crispy — about 3–4 minutes.","Serve hot with garlic chutney and green chutney."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-batata-vada.png","youtubeUrl":"https://www.youtube.com/results?search_query=Batata%20Vada%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.704Z"},{"id":54,"title":"Dal Baati Churma","description":"Rajasthan's iconic trio — hard, baked wheat balls served with five-lentil dal and crumbled sweet churma, all drowned in ghee.","ingredients":["For baati: 2 cups whole wheat flour","½ cup semolina","½ cup ghee","Salt to taste","For dal: ¼ cup each chana dal, toor dal, moong dal, urad dal, masoor dal","2 onions, 3 tomatoes","1 tbsp ginger-garlic paste","Whole spices and red chilli powder","2 tbsp ghee","For churma: baati, jaggery, cardamom, ghee"],"instructions":["For baati: mix flour, semolina, ghee and salt. Add water to make a stiff dough. Rest 20 minutes.","Shape into round balls. Bake in a preheated oven at 180°C for 25–30 minutes until hard and golden.","Break open and dip in ghee before serving.","For panchratan dal: pressure cook all dals together with turmeric. Prepare a masala with onions, tomatoes and spices.","Combine cooked dal with masala. Simmer 15 minutes. Add a final tadka of ghee and red chillies.","For churma: crumble leftover baked baati and mix with melted jaggery, ghee and cardamom.","Serve baati with dal poured over, alongside churma and extra ghee."],"prepTime":30,"cookTime":60,"servings":6,"cuisineType":"Rajasthani","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-dal-baati-churma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dal%20Baati%20Churma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.707Z"},{"id":55,"title":"Gatte Ki Sabzi","description":"Spiced gram flour dumplings in a tangy yogurt-based curry — Rajasthan's ingenious solution to cooking in a region with few fresh vegetables.","ingredients":["2 cups besan (gram flour)","½ tsp ajwain (carom seeds)","½ tsp red chilli powder","½ tsp turmeric","2 tbsp oil","For curry: 1 cup yogurt, whisked","1 onion, finely chopped","2 tomatoes, pureed","1 tsp coriander powder","1 tsp cumin seeds","Salt to taste"],"instructions":["Mix besan with ajwain, red chilli, turmeric, oil and salt. Add water to make a stiff dough.","Roll into long cylinders (1 cm thick). Boil in salted water for 8–10 minutes until cooked through.","Cool and cut into 2 cm pieces (gattas). Reserve the cooking water.","Heat oil. Add cumin seeds. Sauté onions until golden. Add tomato puree and spices. Cook until oil separates.","Add whisked yogurt gradually, stirring constantly on medium heat.","Cook the yogurt masala for 8–10 minutes until it thickens.","Add gattas and the reserved cooking water. Simmer 10 minutes. Serve with roti or rice."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"Rajasthani","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-gatte-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gatte%20Ki%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.710Z"},{"id":56,"title":"Ker Sangri","description":"The signature Rajasthani desert berry and dried beans dish — tangy, spicy and exotic, cooked with an aromatic blend of dry spices.","ingredients":["1 cup sangri (dried Rajasthani beans), soaked overnight","½ cup ker (dried desert berries), soaked 3 hours","2 tbsp oil","½ tsp asafoetida","1 tsp coriander powder","1 tsp red chilli powder","½ tsp amchur (dry mango powder)","½ tsp turmeric","1 tsp fennel powder","Dry red chillies","Salt to taste"],"instructions":["Wash soaked sangri and ker thoroughly several times to remove any bitterness.","Boil sangri and ker in separate pots until tender. Drain.","Heat oil in a pan. Add asafoetida and dry red chillies.","Add the cooked sangri and ker. Toss well.","Add all the dry spices — coriander, red chilli, amchur, turmeric and fennel powder.","Stir-fry on medium heat for 8–10 minutes until spices coat the beans and berries.","Adjust seasoning. Serve as a dry sabzi with bajra roti and dal."],"prepTime":20,"cookTime":25,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-ker-sangri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Ker%20Sangri%20Rajasthani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.712Z"},{"id":57,"title":"Pyaaz Kachori","description":"Flaky, golden-fried pastry puffs stuffed with a zesty spiced onion filling — Jodhpur's famous breakfast kachori, best eaten warm.","ingredients":["2 cups all-purpose flour","¼ cup oil (for dough)","Salt to taste","For filling: 3 large onions, finely chopped","1 tsp fennel seeds","½ tsp cumin seeds","1 tsp coriander powder","1 tsp red chilli powder","1 tsp amchur","2 tbsp besan, dry roasted","Oil for deep frying"],"instructions":["Knead flour with oil, salt and water to a firm dough. Cover and rest 30 minutes.","Heat 2 tbsp oil. Sauté onions until completely soft and dry — about 15 minutes.","Add all spices and roasted besan. Mix and cook 3 more minutes. Cool the filling.","Divide dough into equal portions. Roll into circles.","Place a tablespoon of filling in the centre. Bring edges up and seal tightly.","Flatten gently into a round disc.","Deep fry on medium-low heat for 8–10 minutes until very crispy and golden. Serve with tamarind chutney."],"prepTime":30,"cookTime":35,"servings":6,"cuisineType":"Rajasthani","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-pyaaz-kachori.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pyaaz%20Kachori%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.715Z"},{"id":58,"title":"Rajasthani Kadhi","description":"A sour, deeply flavoured yogurt curry unique to Rajasthan — thinner than Punjabi kadhi, studded with fried pakoras and rich with spices.","ingredients":["1½ cups yogurt","3 tbsp besan (gram flour)","1 tsp ginger-garlic paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander-cumin powder","2 tbsp ghee","1 tsp cumin seeds","4 dry red chillies","A pinch of asafoetida","Fresh coriander to garnish","Salt to taste"],"instructions":["Whisk yogurt, besan, turmeric, red chilli, ginger-garlic paste and salt with 3 cups water until smooth.","Pour into a pot. Bring to a boil on medium heat, stirring constantly.","Reduce heat and simmer 20–25 minutes, stirring often, until kadhi thickens slightly.","Heat ghee in a small pan. Add cumin seeds, dry chillies and asafoetida.","When spices splutter, add coriander-cumin powder. Cook 30 seconds.","Pour the tadka into the kadhi. Stir and taste for seasoning.","Garnish with coriander. Serve with basmati rice or bajre ki roti."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-rajasthani-kadhi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rajasthani%20Kadhi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.718Z"},{"id":59,"title":"Mirchi Vada","description":"Large green chillies stuffed with a tangy potato filling, dipped in besan batter and deep-fried — Jodhpur's fiery signature street snack.","ingredients":["8 large, mild green chillies (banana peppers)","3 medium potatoes, boiled and mashed","1 tsp amchur (dry mango powder)","1 tsp cumin powder","½ tsp red chilli powder","Fresh coriander","For batter: 1 cup besan","½ tsp turmeric","Salt","Oil for deep frying"],"instructions":["Make a lengthwise slit in each green chilli and remove the seeds.","Mix mashed potatoes with amchur, cumin, red chilli, coriander and salt.","Stuff each chilli generously with the potato mixture.","Make a thick batter with besan, turmeric, salt and water.","Heat oil for deep frying. Dip each stuffed chilli in batter to coat completely.","Fry in batches until golden and crispy all around.","Serve immediately with tamarind chutney and green chutney."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mirchi-vada.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mirchi%20Vada%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.720Z"},{"id":60,"title":"Aloo Posto","description":"Potatoes cooked in a velvety paste of poppy seeds — Bengali cuisine's most iconic vegetarian dish, simple yet deeply addictive.","ingredients":["4 medium potatoes, cut into cubes","4 tbsp posto (khus khus / white poppy seeds)","2–3 green chillies, slit","½ tsp turmeric","½ tsp red chilli powder","1 tbsp mustard oil","Salt to taste","A pinch of sugar"],"instructions":["Soak poppy seeds in warm water for 1 hour. Grind with green chillies and a little water to a smooth paste.","Heat mustard oil in a pan until it smokes slightly. Reduce to medium.","Add potatoes, turmeric and salt. Stir well. Cover and cook 10 minutes, stirring occasionally.","Add the poppy seed paste and red chilli powder. Mix gently.","Add ¼ cup water. Cover and cook 10 more minutes until potatoes are completely tender.","Add a pinch of sugar. Stir and check seasoning.","Serve with steamed white rice. The dish should be semi-dry."],"prepTime":15,"cookTime":25,"servings":3,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-posto.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Posto%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.724Z"},{"id":61,"title":"Cholar Dal","description":"Bengal gram cooked with fresh coconut and fragrant whole spices — a festive Bengali dal, aromatic with cardamom and sweet with raisins.","ingredients":["1 cup chana dal (Bengal gram), soaked 1 hour","¼ cup fresh coconut, cut into thin strips","2 tbsp raisins","2 bay leaves","2 dry red chillies","2 green cardamoms","1 cinnamon stick","½ tsp turmeric","1 tsp cumin seeds","1 tsp ginger, grated","1 tsp ghee","1 tsp sugar","Salt to taste"],"instructions":["Pressure cook chana dal with turmeric and 2 cups water for 3 whistles until cooked but holding shape.","Heat ghee. Fry coconut strips until lightly golden. Remove and set aside.","In the same ghee, add bay leaves, dry chillies, cardamom and cinnamon.","Add grated ginger and cumin seeds. Cook 30 seconds.","Add the cooked dal. Mix gently — the dal should not be mushy.","Add sugar, salt, fried coconut and raisins. Simmer 5 minutes.","Serve with luchi (puri) or rice."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-cholar-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Cholar%20Dal%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.726Z"},{"id":62,"title":"Shukto","description":"A bittersweet Bengali mixed vegetable stew made with bitter gourd and seasonal produce, tempered with mustard and a touch of milk.","ingredients":["1 bitter gourd (karela), sliced","1 raw banana, cubed","1 drumstick, cut into pieces","1 potato, cubed","½ cup red radish, sliced","1 tsp mustard paste","1 tsp ginger paste","1 tbsp poppy seed paste","½ cup milk","1 tsp panch phoron (Bengali five-spice)","1 tbsp mustard oil","Salt and a pinch of sugar"],"instructions":["Heat mustard oil. Add panch phoron and let it splutter.","Add bitter gourd and fry on medium heat until lightly golden.","Add all other vegetables and toss well.","Add ginger paste, mustard paste and poppy seed paste. Stir.","Add 1 cup water and salt. Cover and cook 15 minutes until vegetables are tender.","Pour in milk and add a pinch of sugar. Stir gently and simmer 3–4 more minutes.","Serve as the first dish of a Bengali meal with steamed rice."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-shukto.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shukto%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.729Z"},{"id":63,"title":"Begun Bhaja","description":"Crispy, golden fried aubergine rounds marinated with turmeric and chilli — a simple Bengali classic that outshines its humble ingredients.","ingredients":["1 large aubergine (brinjal), cut into thick round slices","1 tsp turmeric","1 tsp red chilli powder","1 tsp salt","Mustard oil for frying"],"instructions":["Cut aubergine into thick rounds (about 1 cm). Score one side lightly with a knife.","Mix turmeric, red chilli powder and salt together.","Apply the spice mix generously on both sides of each slice. Let marinate 15 minutes.","Heat generous mustard oil in a flat pan on medium heat.","Add the aubergine slices and fry on medium heat until golden and crispy on the bottom — about 5 minutes.","Flip and fry the other side until equally golden and crispy.","Serve as a starter or side with dal and rice."],"prepTime":15,"cookTime":15,"servings":3,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-begun-bhaja.png","youtubeUrl":"https://www.youtube.com/results?search_query=Begun%20Bhaja%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.732Z"},{"id":64,"title":"Mochar Ghonto","description":"A rich Bengali dry curry made from banana blossoms with grated coconut and whole spices — sophisticated vegetable cooking at its finest.","ingredients":["1 banana flower (mocha), cleaned and chopped","1 medium potato, diced","¼ cup fresh grated coconut","2 bay leaves","1 tsp panch phoron","1 tsp ginger, grated","½ tsp turmeric","1 tsp cumin-coriander powder","1 tsp sugar","2 tbsp mustard oil","Salt to taste"],"instructions":["Cleaning banana flower: remove outer petals, chop the inner florets, removing stamens. Soak in salted water 30 minutes.","Drain and squeeze out water completely. The flower should be as dry as possible.","Heat mustard oil. Add bay leaves and panch phoron. Let them splutter.","Add potato and cook until half done.","Add grated ginger and the banana flower. Stir well.","Add turmeric, cumin-coriander powder, sugar and salt. Toss and cook covered for 15 minutes.","Add grated coconut and mix. Cook uncovered for 5 more minutes until dry. Serve with rice."],"prepTime":40,"cookTime":30,"servings":4,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mochar-ghonto.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mochar%20Ghonto%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.735Z"},{"id":65,"title":"Niramish Alur Dom","description":"Bengali slow-cooked whole potatoes in a fragrant, spiced gravy without onion or garlic — a pure, temple-style offering of extraordinary flavour.","ingredients":["500g baby potatoes or small potatoes","2 tomatoes, pureed","1 tsp ginger, grated","½ tsp turmeric","1 tsp cumin-coriander powder","1 tsp red chilli powder","1 tsp Bengali garam masala","1 tsp sugar","1 tsp panch phoron","2 bay leaves","2 tbsp mustard oil","Fresh coriander","Salt to taste"],"instructions":["Parboil potatoes with skin on. Peel and prick all over with a fork.","Fry the potatoes in hot mustard oil until golden all around. Set aside.","In the same oil, add panch phoron and bay leaves.","Add grated ginger and tomato puree. Cook until oil separates.","Add all dry spices, sugar and salt. Cook 3 minutes.","Add the fried potatoes. Pour 1 cup water and stir gently.","Cover and simmer 15 minutes. Add Bengali garam masala and coriander. Serve with luchi."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"Bengali","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-niramish-alur-dom.png","youtubeUrl":"https://www.youtube.com/results?search_query=Niramish%20Alur%20Dom%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.738Z"},{"id":66,"title":"Misal Pav","description":"Fiery sprouted moth bean curry topped with crunchy chivda, onion, tomatoes and lemon — Maharashtra's most satisfying street breakfast.","ingredients":["2 cups sprouted moth beans (matki)","1 onion, finely chopped","2 tomatoes, finely chopped","2 tbsp misal masala or goda masala","1 tsp red chilli powder","½ tsp turmeric","1 tbsp ginger-garlic paste","2 tbsp oil","4 pav buns","1 cup farsan / chivda (crunchy mix)","Lemon, coriander and onion to serve","Salt to taste"],"instructions":["Pressure cook sprouted moth beans with salt and turmeric for 2 whistles. They should be just cooked.","Heat oil. Add ginger-garlic paste and cook 1 minute. Add onions and sauté until golden.","Add tomatoes and cook until soft. Add misal masala, red chilli powder and salt.","Add the cooked sprouts with their cooking water. Bring to a boil.","Simmer 10 minutes until the curry (usal) is thick and spicy.","To serve: place usal in a bowl, top with farsan, chopped onions, tomatoes, coriander and a squeeze of lemon.","Serve with buttered pav on the side."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-misal-pav.png","youtubeUrl":"https://www.youtube.com/results?search_query=Misal%20Pav%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.741Z"},{"id":67,"title":"Vada Pav","description":"The original Indian veggie burger — a crispy spiced potato vada nestled in a soft pav with fiery chutneys. Mumbai's soul on a plate.","ingredients":["4 pav buns","4 batata vadas (see Batata Vada recipe)","Green chutney (coriander-mint-garlic)","Dry garlic chutney (dry red chilli, garlic, salt)","Tamarind chutney","Fresh coriander","Fried green chillies to serve"],"instructions":["Prepare batata vadas by mixing mashed potato with spices, rolling into balls and dipping in besan batter.","Deep fry the vadas until golden and crispy. Set aside.","Slit the pav buns without separating them completely.","Apply green chutney generously on one side inside the bun.","Apply dry garlic chutney on the other side.","Place a hot vada inside and press gently.","Serve with tamarind chutney and a fried green chilli on the side."],"prepTime":30,"cookTime":20,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-vada-pav.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vada%20Pav%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.744Z"},{"id":68,"title":"Puran Poli","description":"Sweet, fragrant flatbread stuffed with a golden jaggery and chana dal filling — Maharashtra's beloved festive bread served with ghee.","ingredients":["1 cup chana dal, soaked","¾ cup jaggery (gur)","½ tsp cardamom powder","¼ tsp nutmeg powder","2 cups whole wheat flour","½ cup all-purpose flour","Turmeric for colour","Oil to knead dough","Ghee to serve","Salt to taste"],"instructions":["Pressure cook chana dal for 4 whistles until completely soft. Drain excess water.","Cook dal with jaggery on medium heat, stirring until it forms a thick, dry mixture (puran).","Add cardamom and nutmeg. Cool and pass through a sieve for a smooth filling.","Knead a soft, pliable dough with both flours, turmeric, oil and water.","Take a dough ball, flatten and place a generous portion of puran filling in the centre. Seal edges.","Gently roll out into a thin circle — the filling should not tear through.","Cook on a hot tawa on medium heat, applying ghee generously, until golden on both sides."],"prepTime":30,"cookTime":40,"servings":8,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-puran-poli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Puran%20Poli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.747Z"},{"id":69,"title":"Bharli Vangi","description":"Tiny brinjals stuffed to bursting with a nutty, tangy coconut-peanut masala and slow-cooked in their own steam — Maharashtrian cooking at its finest.","ingredients":["8–10 small round brinjals","½ cup roasted peanuts, coarsely ground","¼ cup fresh grated coconut","1 onion, finely chopped and fried golden","2 tbsp sesame seeds, roasted","1 tbsp goda masala","1 tsp red chilli powder","1 tsp coriander-cumin powder","1 tsp tamarind paste","1 tsp jaggery","2 tbsp oil","Salt to taste"],"instructions":["Mix peanuts, coconut, fried onion, sesame seeds, goda masala, red chilli, coriander-cumin, tamarind, jaggery and salt.","Make two deep cross slits in each brinjal from the bottom end, keeping the stem intact.","Generously stuff each brinjal with the masala mixture.","Heat oil in a heavy-bottomed pan. Place stuffed brinjals in a single layer.","Add any remaining masala around the brinjals. Sprinkle a little water.","Cover and cook on low heat for 20–25 minutes, turning once very gently.","Serve with bhakri (jowar roti) or rice."],"prepTime":25,"cookTime":30,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bharli-vangi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bharli%20Vangi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.751Z"},{"id":70,"title":"Sabudana Khichdi","description":"Soft, non-sticky tapioca pearls cooked with roasted peanuts, ginger and curry leaves — Maharashtra's favourite fasting food and a textural joy.","ingredients":["1 cup sabudana (sago / tapioca pearls)","½ cup roasted peanuts, coarsely crushed","2 medium potatoes, boiled and cubed","2 green chillies, finely chopped","1 tsp ginger, grated","1 tsp cumin seeds","10 curry leaves","1 tsp lemon juice","1 tsp sugar","2 tbsp oil or ghee","Fresh coriander to garnish","Salt to taste"],"instructions":["Wash sabudana in several changes of water. Soak for 4 hours. Each pearl should be separate and soft but not mushy.","Drain and spread on a cloth to dry for 20 minutes. This prevents sticky clumping.","Heat oil or ghee. Add cumin seeds and curry leaves. When they crackle, add green chillies and ginger.","Add the boiled potato cubes and cook 3 minutes.","Add the soaked sabudana. Toss gently over medium heat.","Add crushed peanuts, sugar, salt and lemon juice. Toss everything together.","Cook 5 minutes, tossing gently, until sabudana is cooked through and translucent. Garnish and serve."],"prepTime":20,"cookTime":15,"servings":3,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sabudana-khichdi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sabudana%20Khichdi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.754Z"},{"id":71,"title":"Amti","description":"Maharashtra's everyday toor dal with goda masala and kokum — tangy, slightly sweet and spiced with this regional masala blend. A Maharashtrian staple.","ingredients":["1 cup toor dal, pressure cooked","1 tsp goda masala","½ tsp red chilli powder","½ tsp turmeric","2 pieces kokum (or 1 tsp tamarind paste)","1 tsp jaggery","1 tbsp oil","1 tsp mustard seeds","10 curry leaves","2 dry red chillies","A pinch of asafoetida","Fresh coriander to garnish","Salt to taste"],"instructions":["Cook toor dal until completely soft. Whisk until smooth.","Add goda masala, red chilli powder, turmeric, kokum, jaggery and salt. Mix well.","Add water to achieve a medium-thin consistency. Bring to a boil.","Simmer 10 minutes until flavours meld and dal takes on a slightly tangy-sweet note.","For tadka: heat oil. Add mustard seeds, dry red chillies, curry leaves and asafoetida.","Pour the tadka into the amti. Stir and taste.","Garnish with coriander and serve with steamed rice and papad."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-amti.png","youtubeUrl":"https://www.youtube.com/results?search_query=Amti%20Maharashtrian%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.757Z"},{"id":72,"title":"Vegetable Biryani","description":"Fragrant, long-grained basmati rice layered with spiced vegetables and slow-cooked by the dum method — a festive one-pot masterpiece.","ingredients":["2 cups basmati rice, soaked 30 minutes","2 cups mixed vegetables (carrots, beans, peas, cauliflower, potato)","2 onions, thinly sliced and fried crispy","3 tomatoes, pureed","1 tbsp ginger-garlic paste","¾ cup yogurt","Whole spices (cloves, cardamom, cinnamon, bay leaf, star anise)","2 tsp biryani masala","A pinch of saffron in warm milk","Fresh mint and coriander leaves","3 tbsp ghee","Salt to taste"],"instructions":["Parboil basmati rice until 70% cooked. Drain and set aside.","Cook a spiced vegetable masala: sauté whole spices, then onions, ginger-garlic paste, tomatoes and yogurt.","Add vegetables and biryani masala. Cook until vegetables are half done.","In a heavy pot, layer half the parboiled rice, then the vegetable masala, then remaining rice.","Top with saffron milk, fried onions, mint, coriander and dollops of ghee.","Seal the pot with foil and a tight lid. Cook on very low heat for 20 minutes (dum method).","Open at the table. Gently mix from the sides. Serve with raita and salan."],"prepTime":30,"cookTime":50,"servings":6,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-vegetable-biryani.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vegetable%20Biryani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.759Z"},{"id":73,"title":"Pav Bhaji","description":"Mumbai's favourite street food — a thick, spiced mash of mixed vegetables cooked on a tawa with a generous knob of butter, served with soft toasted pav.","ingredients":["4 medium potatoes, boiled and mashed","1 cup cauliflower florets","½ cup peas","2 carrots, boiled","2 onions, finely chopped","3 tomatoes, finely chopped","2 tbsp pav bhaji masala","1 tsp red chilli powder","1 tsp ginger-garlic paste","4 tbsp butter","8 pav buns","Lemon, coriander and onion to serve","Salt to taste"],"instructions":["Boil all vegetables and mash them completely — everything should be a smooth mash.","Heat butter on a tawa. Add ginger-garlic paste and onions. Cook on high heat until onions are golden.","Add tomatoes and cook on high heat, mashing them.","Add pav bhaji masala, red chilli powder and salt. Mix well.","Add the mashed vegetables. Mix everything together, adding a little water if needed.","Mash and cook on high heat for 10 minutes until bhaji is smooth, thick and shiny.","Slit and butter the pav buns. Toast on the tawa until golden. Serve with bhaji, lemon and coriander."],"prepTime":20,"cookTime":30,"servings":5,"cuisineType":"Maharashtrian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-pav-bhaji.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pav%20Bhaji%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.763Z"},{"id":74,"title":"Aloo Tikki","description":"Crispy shallow-fried potato patties seasoned with cumin and coriander — the ultimate Indian street food snack, served with three chutneys.","ingredients":["4 large potatoes, boiled and mashed","2 tbsp breadcrumbs or cornflour","1 tsp cumin seeds, roasted and crushed","1 tsp coriander powder","1 tsp amchur (dry mango powder)","½ tsp garam masala","2 green chillies, finely chopped","Fresh coriander, chopped","Salt to taste","Oil for shallow frying"],"instructions":["Mix mashed potatoes with breadcrumbs, cumin, coriander, amchur, garam masala, green chillies, coriander and salt.","Divide into equal portions and shape into flat, round patties about 1 cm thick.","Refrigerate for 15 minutes to firm up.","Heat a thin layer of oil in a flat pan on medium-high heat.","Place tikkis and cook without disturbing for 4–5 minutes until the bottom is deep golden and crispy.","Flip carefully and cook the other side for 4–5 minutes.","Serve hot with mint chutney, tamarind chutney and yogurt."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-aloo-tikki.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Tikki%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.766Z"},{"id":75,"title":"Bhel Puri","description":"The iconic Mumbai beach snack — puffed rice tossed with onions, tomatoes, sev and the essential trio of chutneys. Tangy, crunchy, addictive.","ingredients":["3 cups puffed rice (murmura)","1 cup sev","1 onion, finely chopped","2 tomatoes, finely chopped","1 potato, boiled and cubed","2 tbsp green chutney (coriander-mint)","2 tbsp tamarind chutney","1 tsp chaat masala","½ tsp cumin powder","Fresh coriander","Lemon juice to taste","Salt to taste"],"instructions":["This dish must be assembled and served immediately or the puffed rice will go soggy.","In a large bowl, combine puffed rice and sev.","Add onions, tomatoes and boiled potato cubes.","Add green chutney and tamarind chutney. Toss well.","Add chaat masala, cumin powder, salt and lemon juice.","Toss everything together very quickly.","Serve immediately in newspaper cones or small bowls topped with extra sev and coriander."],"prepTime":15,"cookTime":0,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-bhel-puri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bhel%20Puri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.769Z"},{"id":76,"title":"Dahi Vada","description":"Soft, fluffy lentil dumplings submerged in sweetened yogurt and topped with tamarind chutney, cumin and pomegranate — a cooling Indian classic.","ingredients":["1 cup urad dal, soaked 4 hours and ground to fluffy batter","2 cups thick yogurt, whisked smooth","2 tsp sugar","1 tsp cumin powder, roasted","1 tsp red chilli powder","Tamarind chutney","Green chutney","Chaat masala","Pomegranate seeds and coriander","Oil for deep frying","Salt to taste"],"instructions":["Grind soaked urad dal with minimal water to a very fluffy batter. Add salt.","Deep fry spoonfuls of batter on medium heat until golden. Drain.","Soak the fried vadas in warm water for 10 minutes to soften. Squeeze out excess water gently.","Whisk yogurt with sugar, salt and a pinch of cumin. Chill well.","Arrange soaked vadas in a serving dish. Pour chilled yogurt over them.","Drizzle tamarind chutney and green chutney generously.","Sprinkle cumin powder, red chilli, chaat masala, pomegranate and coriander. Serve immediately."],"prepTime":20,"cookTime":25,"servings":5,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dahi-vada.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dahi%20Vada%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.772Z"},{"id":77,"title":"Handvo","description":"A savoury Gujarati baked or pan-fried mixed dal and rice cake loaded with bottle gourd and sesame — crispy outside, moist and flavourful inside.","ingredients":["1 cup rice","½ cup chana dal","¼ cup toor dal","¼ cup urad dal","1 cup bottle gourd (lauki), grated","½ cup yogurt","1 tsp ginger-chilli paste","1 tsp Eno fruit salt","For tadka: 2 tbsp oil, 1 tsp mustard seeds, 1 tsp sesame seeds, 8 curry leaves, 2 dry red chillies","Salt to taste"],"instructions":["Soak rice and all dals together overnight. Grind to a coarse batter with yogurt.","Add grated lauki, ginger-chilli paste and salt. Ferment for 8 hours.","Just before cooking, add Eno fruit salt and mix gently.","Heat oil in a heavy-bottomed pan. Add mustard seeds, sesame seeds, curry leaves and dry red chillies.","Pour the batter into the pan. Cover and cook on low heat for 20 minutes.","Flip the handvo (as one large cake) and cook the other side 15 minutes until golden and crispy.","Slice and serve with green chutney."],"prepTime":20,"cookTime":40,"servings":6,"cuisineType":"Gujarati","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-handvo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Handvo%20Gujarati%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.776Z"},{"id":78,"title":"Gajar Ka Halwa","description":"Slow-cooked grated carrots in rich, saffron-kissed milk with sugar, cardamom, ghee and garnished with golden cashews — winter's greatest dessert.","ingredients":["1 kg red carrots, peeled and grated","1 litre full-fat milk","¾ cup sugar","3 tbsp ghee","½ tsp cardamom powder","A generous pinch of saffron in 2 tbsp warm milk","¼ cup cashews and raisins, fried in ghee","2 tbsp khoya (dried milk solids) (optional for richness)"],"instructions":["Heat ghee in a heavy, wide kadhai. Add grated carrots and sauté on medium heat for 10 minutes.","Add the milk and bring to a boil. Reduce heat to medium.","Cook, stirring every 5 minutes, until all the milk is absorbed — about 30–35 minutes.","Add sugar, saffron milk and khoya if using. Stir well.","Continue cooking until the halwa comes together, leaves the sides of the pan and is shiny — about 10 minutes.","Add cardamom powder and mix.","Top with fried cashews and raisins. Serve warm or at room temperature."],"prepTime":20,"cookTime":50,"servings":8,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-gajar-ka-halwa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gajar%20Ka%20Halwa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.779Z"},{"id":79,"title":"Gulab Jamun","description":"Soft, spongy milk-solid dumplings deep-fried until mahogany and soaked in a cardamom and rose-scented sugar syrup — India's most beloved mithai.","ingredients":["1 cup khoya (mawa), crumbled","¼ cup all-purpose flour (maida)","A pinch of baking soda","Milk to bind","Oil or ghee for deep frying","For syrup: 2 cups sugar","1½ cups water","½ tsp cardamom powder","1 tsp rose water","A few saffron strands"],"instructions":["Make sugar syrup: combine sugar and water in a pan. Bring to a boil and simmer until it reaches one-string consistency. Add cardamom, rose water and saffron.","Mix khoya, flour and baking soda. Add just enough milk to bind into a smooth, soft dough.","Divide into small portions. Roll into smooth balls without any cracks.","Deep fry on very low-medium heat, rolling continuously, until deep mahogany — about 8–10 minutes.","Drain briefly and immediately immerse in warm sugar syrup.","Allow to soak for at least 2 hours — they will double in size.","Serve warm or at room temperature, garnished with pistachios."],"prepTime":20,"cookTime":30,"servings":8,"cuisineType":"Pan-Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-gulab-jamun.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gulab%20Jamun%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.781Z"},{"id":80,"title":"Kheer","description":"Silky rice pudding slow-cooked in whole milk until thick and creamy, sweetened with sugar and fragrant with cardamom and saffron — the original Indian dessert.","ingredients":["1 litre full-fat milk","¼ cup basmati rice, washed","½ cup sugar","½ tsp cardamom powder","A generous pinch of saffron in warm milk","2 tbsp chopped almonds","2 tbsp pistachios, sliced","1 tbsp raisins","1 tsp rose water"],"instructions":["Bring milk to a boil in a heavy pot. Add washed rice.","Cook on medium-low heat, stirring frequently, until rice is completely soft and milk has thickened — about 30–35 minutes.","Add sugar and stir until dissolved. The kheer will thin slightly — continue cooking for 10 more minutes.","Add saffron milk and cardamom powder.","Add raisins and half the nuts. Cook 5 more minutes.","Remove from heat. Add rose water and stir.","Pour into serving bowls. Garnish with sliced pistachios and almonds. Serve warm or chilled."],"prepTime":10,"cookTime":50,"servings":6,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kheer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kheer%20Rice%20Pudding%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.784Z"},{"id":81,"title":"Rava Sheera","description":"Golden semolina halwa fragrant with ghee, cardamom and saffron — a quick, comforting Indian sweet that comes together in under 20 minutes.","ingredients":["1 cup fine rava (semolina)","1 cup sugar","2 cups water","3 tbsp ghee","½ tsp cardamom powder","A pinch of saffron in 2 tbsp warm milk","10 cashews","2 tbsp raisins","A pinch of yellow food colour (optional)"],"instructions":["Heat ghee in a heavy pan. Fry cashews until golden. Remove and set aside.","In the same ghee, roast rava on medium heat, stirring constantly, until it turns golden and fragrant — about 8 minutes.","Boil water with saffron milk. Carefully add the hot water to the roasted rava (it will splutter).","Stir vigorously and continuously to prevent lumps forming.","Add sugar, raisins and food colour if using. Mix well.","Cook on low heat, stirring, until the halwa thickens and ghee starts to release from the sides.","Add cardamom and fried cashews. Serve warm."],"prepTime":5,"cookTime":20,"servings":5,"cuisineType":"Pan-Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-rava-sheera.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rava%20Sheera%20Halwa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.786Z"},{"id":82,"title":"Payasam","description":"Kerala's festive vermicelli and milk pudding with cashews, raisins and cardamom — served as the divine finale of every Onam Sadya feast.","ingredients":["½ cup vermicelli (semiya), roasted","1 litre full-fat milk","½ cup sugar","½ tsp cardamom powder","2 tbsp ghee","¼ cup cashews","¼ cup raisins","A generous pinch of saffron"],"instructions":["Heat ghee in a heavy pan. Fry cashews until golden, then raisins until they plump. Remove and set aside.","Add vermicelli to the same ghee and roast until golden.","Add milk and bring to a boil. Reduce heat and simmer until vermicelli is completely cooked and milk thickens — about 15 minutes.","Add sugar and stir until dissolved. Continue cooking 5 more minutes.","Add saffron and cardamom powder.","Add the fried cashews and raisins. Stir.","Serve warm or chilled. The payasam will thicken further as it cools."],"prepTime":10,"cookTime":25,"servings":6,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-payasam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Semiya%20Payasam%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.790Z"},{"id":83,"title":"Sabudana Kheer","description":"Creamy, lustrous sago pearl pudding with saffron and cardamom — a light, cooling dessert that is equally a fasting-day staple.","ingredients":["½ cup sabudana (sago), soaked 2 hours","1 litre full-fat milk","½ cup sugar","½ tsp cardamom powder","A pinch of saffron","2 tbsp cashews and raisins","1 tbsp ghee"],"instructions":["Fry cashews and raisins in ghee until golden. Set aside.","Bring milk to a boil. Add soaked sabudana.","Cook on medium heat, stirring frequently, until sabudana turns translucent and milk thickens — about 20 minutes.","Add sugar and stir until dissolved.","Add saffron and cardamom. Cook 5 more minutes.","Top with fried nuts and raisins. Serve warm or chilled.","The kheer will thicken considerably as it cools — add milk if reheating."],"prepTime":10,"cookTime":30,"servings":5,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sabudana-kheer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sabudana%20Kheer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.793Z"},{"id":84,"title":"Jeera Rice","description":"Fragrant basmati rice toasted with cumin seeds in ghee — the simplest, most perfect accompaniment to any Indian dal or curry.","ingredients":["2 cups basmati rice, soaked 30 minutes","1 tsp cumin seeds","1 bay leaf","1 tbsp ghee","3½ cups water","Salt to taste"],"instructions":["Soak basmati rice in water for 30 minutes. Drain completely.","Heat ghee in a heavy pot. Add cumin seeds and bay leaf. Let cumin splutter and darken slightly.","Add the drained rice. Sauté gently for 2 minutes, coating each grain in ghee.","Add water and salt. Bring to a full boil.","Reduce heat to the lowest possible, cover tightly and cook for 12 minutes.","Remove from heat. Do not open the lid for 5 more minutes.","Fluff gently with a fork. Discard bay leaf. Serve with any dal or curry."],"prepTime":35,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-jeera-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Jeera%20Rice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.796Z"},{"id":85,"title":"Aloo Palak","description":"Tender potatoes bathed in a silky, garlicky spinach puree — a simple, everyday North Indian curry that is nutritious and deeply comforting.","ingredients":["3 medium potatoes, cubed and fried","400g spinach, blanched and pureed","1 onion, finely chopped","3 garlic cloves, minced","1 tsp ginger, grated","2 green chillies","½ tsp cumin seeds","½ tsp turmeric","½ tsp garam masala","2 tbsp oil","Salt to taste"],"instructions":["Blanch spinach in boiling water for 2 minutes. Transfer to ice water to preserve colour. Drain and puree smoothly.","Fry potato cubes in oil until golden. Drain and set aside.","In the same pan, add cumin seeds. When they splutter, add onions and cook until golden.","Add garlic, ginger and green chillies. Cook 2 minutes.","Add turmeric and spinach puree. Stir well. Add ½ cup water.","Simmer 5 minutes. Add the fried potatoes. Cook 8 more minutes.","Sprinkle garam masala and serve with roti."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-palak.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Palak%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-10T15:41:13.800Z"},{"id":86,"title":"Methi Malai Matar","description":"Methi Malai Matar is a creamy and flavorful dish made with fresh fenugreek leaves and green peas, perfect for pairing with roti or rice.","ingredients":["1 cup fresh methi leaves","1 cup green peas","1 medium onion","1-2 green chilies","1-inch ginger","1 cup cream","2 tablespoons oil or ghee","1 teaspoon cumin seeds","1/2 teaspoon garam masala","Salt to taste","Water as needed"],"instructions":["In a pan, heat oil or ghee and add cumin seeds.","Allow them to splutter.","Add the chopped onion and green chilies, sauté until the onions turn translucent.","Add grated ginger and sauté for a minute.","Stir in the green peas and chopped methi leaves.","Cook for about 5 minutes until the peas are tender.","Lower the flame and add the cream.","Mix well and allow it to cook for another 5-7 minutes.","If the mixture is too thick, add a little water to reach desired consistency.","Sprinkle garam masala and salt, stir well, and cook for another minute.","Adjust seasoning as needed.","Serve hot with roti, naan, or rice."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":[],"category":"main","imageUrl":"/api/recipes/86/image","youtubeUrl":"https://www.youtube.com/results?search_query=methi+malai+matar+recipe+indian+vegetarian","authorId":"test-user-chef","submittedBy":"testchef@example.com","submittedByName":"Test Chef","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-10T16:19:59.871Z"},{"id":87,"title":"Vegetable Wonton Soup","description":"A comforting and flavorful vegan soup filled with homemade vegetable wontons, perfect for a cozy meal.","ingredients":["1 cup all-purpose flour","Water (as needed for the dough)","1 cup finely chopped vegetables","1 teaspoon grated ginger","1 teaspoon soy sauce","Salt and pepper to taste","4 cups vegetable broth","2 cloves garlic, minced","1 teaspoon sesame oil","1-2 green onions, chopped","Soy sauce (to taste)","Bok choy or spinach (for added greens)"],"instructions":["Combine flour and water to form a smooth dough and let it rest for about 30 minutes.","Mix chopped vegetables, ginger, soy sauce, and seasonings in a bowl to prepare the filling.","Roll the dough thinly, cut into squares, and place a small amount of filling in the center before folding and sealing.","Boil water, add wontons, and cook until they float, which takes about 5-7 minutes.","In a pot, heat sesame oil, sauté garlic, add vegetable broth, and bring to a boil before adding bok choy and cooked wontons.","Taste and adjust seasoning, then garnish with green onions and enjoy your warm soup."],"prepTime":30,"cookTime":15,"servings":4,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/api/recipes/87/image","youtubeUrl":"https://www.youtube.com/results?search_query=vegetable+wonton+soup+recipe+indian+vegetarian","authorId":"55882372","submittedBy":"genieflavour@gmail.com","submittedByName":"Haigreeva Kondury","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-10T16:29:48.220Z"},{"id":88,"title":"Rajasthani Panchmel Dal","description":"Rajasthani Panchmel Dal is a rich and nutritious blend of five different lentils, offering a hearty and flavorful dish.","ingredients":["1/4 cup Toor Dal","1/4 cup Moong Dal","1/4 cup Masoor Dal","1/4 cup Chana Dal","1/4 cup Urad Dal","2 tablespoons Ghee","1 teaspoon Cumin seeds","1-2 Green chilies","1-inch Ginger","2-3 Garlic cloves","1 medium Onion","2-3 medium Tomatoes","1/2 teaspoon Turmeric powder","1 teaspoon Red chili powder","1 teaspoon Coriander powder","Salt to taste","Fresh coriander leaves for garnish","Lemon wedges for serving"],"instructions":["Wash the lentils thoroughly and soak them for 30 minutes.","Pressure cook the soaked lentils with 4 cups of water and salt for about 3-4 whistles or until soft.","In a pan, heat ghee or oil.","Add cumin seeds and let them splutter.","Add green chilies, ginger, and garlic and sauté for a minute.","Add chopped onions and cook until they turn golden brown.","Stir in the chopped tomatoes, turmeric, red chili powder, and coriander powder and cook until the tomatoes are soft.","Once the lentils are cooked, add them to the tempering.","Adjust the consistency with water if needed and simmer for 5-10 minutes.","Garnish with fresh coriander leaves and serve hot with rice or Indian bread.","Add lemon wedges on the side for an extra zing."],"prepTime":30,"cookTime":30,"servings":4,"cuisineType":"Rajasthani","dietaryTags":[],"category":"main","imageUrl":"/api/recipes/88/image","youtubeUrl":"https://www.youtube.com/results?search_query=rajasthani+panchmel+dal+recipe+indian+vegetarian","authorId":"test-community-user","submittedBy":"test-community-user","submittedByName":"Priya Sharma","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-10T17:23:17.699Z"},{"id":228,"title":"Lasooni Palak","description":"Lasooni Palak is a flavorful Indian dish made with spinach and garlic, perfect for a nutritious meal.","ingredients":["2 cups fresh spinach, washed and chopped","6-8 cloves garlic, finely chopped","1 tablespoon oil or ghee","1 teaspoon cumin seeds","1 green chili, slit (optional)","Salt to taste","A squeeze of lemon juice"],"instructions":["Heat oil in a pan and add cumin seeds.","Once they crackle, add the chopped garlic and sauté until golden.","Add the green chili if using and the chopped spinach.","Cook until the spinach wilts down.","Season with salt, and stir well.","Cook for another 2-3 minutes.","Remove from heat and add a squeeze of lemon juice before serving."],"prepTime":10,"cookTime":10,"servings":4,"cuisineType":"North Indian","dietaryTags":[],"category":"main","imageUrl":"/api/recipes/228/image","youtubeUrl":"https://www.youtube.com/results?search_query=lasooni+palak+recipe+indian+vegetarian","authorId":"55882372","submittedBy":"55882372","submittedByName":"Haigreeva Kondury","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-17T10:26:22.491Z"},{"id":229,"title":"Kadai Paneer","description":"Paneer and capsicum tossed in a fierce, freshly ground kadai masala of whole spices — smoky, aromatic and vibrantly orange.","ingredients":["300g paneer, cubed","2 capsicums, cut into squares","2 onions, cubed","3 tomatoes, pureed","1 tbsp ginger-garlic paste","2 dried red chillies","1 tsp coriander seeds","1 tsp cumin seeds","½ tsp fennel seeds","½ tsp red chilli powder","1 tsp garam masala","2 tbsp oil","Salt to taste"],"instructions":["Dry roast coriander seeds, cumin and fennel. Grind coarsely — this is your kadai masala.","Heat oil. Add dried red chillies and onions. Cook on high heat.","Add ginger-garlic paste, then tomato puree. Cook until oil separates.","Add ground kadai masala, red chilli, salt. Cook 3 minutes.","Add capsicum and paneer. Toss on high heat 5 minutes.","Sprinkle garam masala and serve with roti."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kadai-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kadai%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.052Z"},{"id":230,"title":"Aviyal","description":"Kerala's mixed vegetable curry in a coconut-yogurt-turmeric coating finished with coconut oil and curry leaves — vegetarian at its most elegant.","ingredients":["3 cups mixed vegetables (raw banana, yam, carrot, beans, drumstick)","1 cup fresh coconut, grated","3 green chillies","1 tsp cumin seeds","½ cup yogurt","½ tsp turmeric","1 tbsp coconut oil","10 curry leaves","Salt to taste"],"instructions":["Cut all vegetables into batons 4cm long. Cook in a little salted water with turmeric until just tender.","Grind coconut, green chillies and cumin to a coarse paste.","Add coconut paste to the cooked vegetables. Mix gently.","Simmer 5 minutes. Remove from heat.","Beat yogurt smooth and stir in. Add coconut oil and curry leaves.","Serve immediately with rice."],"prepTime":20,"cookTime":25,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aviyal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aviyal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.077Z"},{"id":231,"title":"Kootu","description":"A dry-ish Tamil curry of vegetables or legumes with freshly ground coconut paste — thicker than a curry, more substantial than a stir-fry.","ingredients":["1 cup raw banana or yam, cubed","1 cup chickpeas or black-eyed peas, cooked","½ cup fresh coconut, grated","2 dried red chillies","1 tsp cumin seeds","½ tsp black pepper","½ tsp turmeric","1 tbsp coconut oil","1 tsp mustard seeds","10 curry leaves","Salt to taste"],"instructions":["Cook vegetables until tender. Add cooked legumes and turmeric.","Grind coconut, red chillies, cumin and pepper to a coarse paste with a little water.","Add coconut paste to the vegetables. Mix and simmer 8 minutes.","Make tadka: heat coconut oil, splutter mustard seeds and curry leaves.","Pour tadka over kootu. Serve with rice and sambar."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kootu.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kootu%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.089Z"},{"id":232,"title":"Thoran","description":"Kerala's dry stir-fry of finely shredded vegetables with coconut and mustard seeds — the perfect side for rice meals.","ingredients":["3 cups beans or cabbage or carrot, finely shredded","½ cup fresh coconut, grated","3 green chillies, chopped","½ tsp turmeric","1 tbsp coconut oil","1 tsp mustard seeds","10 curry leaves","2 shallots, sliced","Salt to taste"],"instructions":["Mix shredded vegetable with turmeric and salt. Set aside 10 minutes.","Heat coconut oil. Add mustard seeds and let them splutter.","Add shallots, green chillies and curry leaves. Sauté briefly.","Add the vegetable and stir-fry on medium-high heat for 5 minutes.","Add grated coconut. Toss everything together and cook 3 more minutes.","Serve as a side with rice."],"prepTime":15,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-thoran.png","youtubeUrl":"https://www.youtube.com/results?search_query=Thoran%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.093Z"},{"id":233,"title":"Upma","description":"A savoury semolina porridge with vegetables and mustard tempering — South India's most popular breakfast, ready in 20 minutes.","ingredients":["1 cup coarse semolina (rava)","1 onion, finely chopped","2 green chillies, chopped","1 carrot, finely diced","½ cup peas","2 tbsp oil","1 tsp mustard seeds","1 tsp chana dal","1 tsp urad dal","10 curry leaves","2½ cups water","Salt to taste","Lemon juice and coriander to finish"],"instructions":["Dry roast semolina until lightly golden and fragrant. Set aside.","Heat oil. Splutter mustard seeds. Add chana dal and urad dal, fry until golden.","Add curry leaves, green chillies and onion. Sauté until onion is soft.","Add carrots and peas. Cook 3 minutes.","Add water and salt. Bring to a boil.","Slowly pour in semolina, stirring continuously. Cook 5 minutes until thick.","Finish with lemon juice and coriander."],"prepTime":5,"cookTime":20,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-upma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Upma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.096Z"},{"id":234,"title":"Poha","description":"Flattened rice flakes tossed with onions, mustard seeds, turmeric and lime — Maharashtra's quintessential breakfast, light and nourishing.","ingredients":["2 cups thick poha (flattened rice)","1 onion, finely chopped","2 green chillies, finely chopped","1 tsp mustard seeds","½ tsp turmeric","10 curry leaves","2 tbsp oil","¼ cup roasted peanuts","1 tsp sugar","Lime juice and fresh coriander to finish","Salt to taste"],"instructions":["Rinse poha gently in a colander until just soft. Drain. Sprinkle turmeric and sugar. Mix gently.","Heat oil. Splutter mustard seeds and curry leaves.","Add green chillies and onion. Sauté until translucent.","Add peanuts and stir briefly.","Add poha. Toss gently until everything is combined and heated through.","Finish with lime juice and coriander. Serve immediately."],"prepTime":10,"cookTime":10,"servings":3,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-poha.png","youtubeUrl":"https://www.youtube.com/results?search_query=Poha%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.100Z"},{"id":235,"title":"Dhokla","description":"Soft, spongy and tangy steamed chickpea flour cakes from Gujarat, topped with a mustard-green chilli tempering and coconut.","ingredients":["1½ cups chickpea flour","1 cup yogurt","1 tsp ginger-green chilli paste","1 tbsp lemon juice","1 tsp Eno fruit salt","½ tsp turmeric","1 tsp sugar","For tadka: 2 tbsp oil","1 tsp mustard seeds","2 green chillies, slit","1 tsp sesame seeds","10 curry leaves","Fresh coconut and coriander to garnish","Salt to taste"],"instructions":["Mix chickpea flour, yogurt, ginger-chilli paste, lemon juice, turmeric, sugar and salt. Mix smooth.","Grease a steaming tray. Just before steaming, add Eno and 2 tbsp water. Mix and pour immediately.","Steam for 20 minutes. Cool 5 minutes, then cut into squares.","Make tadka: heat oil, splutter mustard seeds, add green chillies, sesame and curry leaves.","Pour tadka over dhokla. Garnish with coconut and coriander."],"prepTime":10,"cookTime":25,"servings":6,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dhokla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dhokla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.103Z"},{"id":236,"title":"Thepla","description":"Soft, spiced Gujarati flatbreads made with fenugreek leaves — a beloved travel food and breakfast that stays soft for days.","ingredients":["2 cups whole wheat flour","1 cup fresh fenugreek leaves, finely chopped","2 tbsp yogurt","½ tsp turmeric","½ tsp red chilli powder","½ tsp cumin seeds","1 tsp sesame seeds","1 tbsp oil","Salt to taste","Oil for cooking"],"instructions":["Mix flour, fenugreek, yogurt, spices, sesame seeds and salt. Add enough water to make a soft dough.","Add oil and knead 5 minutes.","Divide into balls. Roll into thin circles.","Cook on a hot tawa with a little oil, pressing with a cloth until both sides have golden spots.","Serve with yogurt, pickle or a cup of chai."],"prepTime":15,"cookTime":20,"servings":4,"cuisineType":"Gujarati","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-thepla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Thepla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.106Z"},{"id":237,"title":"Stuffed Bhindi","description":"Okra slit and filled with a tangy masala of coconut, coriander and spices, then pan-fried until crisp — a brilliant way to cook bhindi.","ingredients":["500g okra (bhindi)","½ cup fresh coconut, grated","1 tsp coriander powder","1 tsp cumin powder","½ tsp red chilli powder","½ tsp amchur","½ tsp turmeric","1 tbsp oil","Salt to taste"],"instructions":["Wash and dry okra thoroughly. Slit lengthwise without cutting through.","Mix coconut, all spices and salt to make the stuffing.","Fill each okra with the stuffing.","Heat oil in a wide pan. Place okra in a single layer. Cook on medium heat.","Turn gently every 3 minutes until okra is tender and slightly crispy on all sides — about 15 minutes.","Serve as a side with dal and roti."],"prepTime":20,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-stuffed-bhindi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Stuffed%20Bhindi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.112Z"},{"id":238,"title":"Lauki Kofta","description":"Soft bottle gourd dumplings in a smooth, mildly spiced tomato gravy — a delicate dish that showcases humble vegetables at their finest.","ingredients":["500g bottle gourd, grated","½ cup chickpea flour","1 tsp ginger, grated","1 green chilli, chopped","½ tsp red chilli powder","For gravy: 2 onions","3 tomatoes","1 tsp ginger-garlic paste","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","2 tbsp oil","Salt to taste","Oil for deep frying"],"instructions":["Squeeze out water from grated lauki. Mix with chickpea flour, ginger, chilli, salt and red chilli.","Shape into balls and deep-fry until golden. Drain.","For gravy: purée onions and tomatoes. Heat oil. Cook onion-tomato purée with ginger-garlic paste and spices until oil separates.","Add 1 cup water and simmer 10 minutes.","Add koftas just before serving. Simmer 3 minutes and serve."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-lauki-kofta.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lauki%20Kofta%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.117Z"},{"id":239,"title":"Chilli Paneer","description":"Indo-Chinese fried paneer tossed with capsicum, spring onions and a spicy soy-chilli sauce — the most popular starter in every Indian Chinese restaurant.","ingredients":["300g paneer, cubed","1 capsicum, diced","1 onion, diced","3 green chillies, slit","1 tbsp ginger-garlic paste","3 tbsp soy sauce","2 tbsp tomato ketchup","1 tbsp chilli sauce","1 tbsp cornflour mixed with water","2 tbsp oil","Spring onions to garnish","Salt and pepper"],"instructions":["Dust paneer lightly with cornflour. Shallow-fry until golden on all sides. Drain.","Heat oil in a wok. Add ginger-garlic paste, green chillies and onion on high heat.","Add capsicum. Toss on high heat 2 minutes.","Mix soy sauce, ketchup and chilli sauce. Add to the wok.","Add cornflour slurry and stir until sauce thickens.","Add fried paneer and toss to coat. Garnish with spring onions."],"prepTime":15,"cookTime":20,"servings":4,"cuisineType":"Fusion","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-chilli-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chilli%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.121Z"},{"id":240,"title":"Manchurian Cauliflower","description":"Crispy fried cauliflower florets in a dark, tangy Manchurian sauce — the vegetarian hero of India's beloved fusion Chinese cooking.","ingredients":["1 small cauliflower, cut into florets","For batter: ½ cup flour","¼ cup cornflour","½ tsp soy sauce","For sauce: 1 onion, diced","1 tbsp ginger-garlic paste","3 tbsp soy sauce","2 tbsp tomato ketchup","1 tbsp chilli sauce","1 tsp cornflour mixed in water","2 tbsp oil","Spring onions to garnish"],"instructions":["Make a batter with flour, cornflour, soy sauce and water. Coat cauliflower.","Deep fry until golden and crisp. Drain.","Heat oil in a wok. Fry onion and ginger-garlic paste on high heat.","Add all sauces. Stir and add cornflour slurry. Cook until sauce coats a spoon.","Add fried cauliflower. Toss. Serve immediately."],"prepTime":15,"cookTime":25,"servings":4,"cuisineType":"Fusion","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-manchurian-cauliflower.png","youtubeUrl":"https://www.youtube.com/results?search_query=Cauliflower%20Manchurian%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.124Z"},{"id":241,"title":"Idli","description":"Soft, steamed rice and lentil cakes that are the foundation of South Indian breakfast — gentle, nourishing and endlessly versatile.","ingredients":["2 cups idli rice","1 cup urad dal","1 tsp fenugreek seeds","Salt to taste"],"instructions":["Soak rice, urad dal and fenugreek seeds separately for 6 hours.","Grind urad dal to a very fluffy, light batter. Grind rice coarsely. Mix both and add salt.","Ferment in a warm place for 8–10 hours until batter doubles in volume.","Grease idli moulds. Pour batter. Steam for 12 minutes.","Cool 2 minutes before unmoulding. Serve with sambar and chutneys."],"prepTime":840,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-idli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Idli%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.128Z"},{"id":242,"title":"Puttu","description":"Kerala's steamed breakfast cylinders of coarsely ground rice flour layered with coconut — eaten with banana or kadala curry.","ingredients":["2 cups puttu podi (coarsely ground rice flour)","1 cup fresh coconut, grated","½ tsp salt","Water to moisten"],"instructions":["Sprinkle salted water over puttu podi and rub until it resembles coarse, moistened sand. It should hold shape when pressed.","Fill the puttu maker (or perforated tin): alternate layers of coconut and rice flour mixture.","Steam for 5–7 minutes until steam comes through the top.","Turn out onto a plate. Serve with ripe banana and kadala curry."],"prepTime":10,"cookTime":10,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-puttu.png","youtubeUrl":"https://www.youtube.com/results?search_query=Puttu%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.131Z"},{"id":243,"title":"Kadala Curry","description":"Kerala's black chickpea curry in a coconut-based gravy — the traditional companion to puttu and appam at breakfast.","ingredients":["1 cup black chickpeas (kala chana), soaked overnight","1 cup fresh coconut, grated","2 dried red chillies","1 tsp coriander seeds","½ tsp black pepper","2 onions, sliced","2 tomatoes, chopped","1 tsp ginger paste","½ tsp turmeric","1 tbsp coconut oil","1 tsp mustard seeds","10 curry leaves","Salt to taste"],"instructions":["Pressure-cook black chickpeas until soft.","Dry roast coconut, red chillies, coriander seeds and pepper until coconut is golden. Grind to a smooth paste.","Heat coconut oil. Add mustard seeds and curry leaves. Add onions and ginger. Cook until golden.","Add tomatoes and turmeric. Cook until soft.","Add cooked chickpeas and coconut paste. Simmer 15 minutes.","Serve with puttu or appam."],"prepTime":480,"cookTime":40,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kadala-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kadala%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.134Z"},{"id":244,"title":"Appam","description":"Lacy, thin-edged Kerala bowl crepes with a soft, spongy centre — fermented rice and coconut make this a uniquely beautiful breakfast bread.","ingredients":["2 cups raw rice, soaked 6 hours","½ cup cooked rice","½ cup fresh coconut, grated","1 tsp dry yeast","1 tsp sugar","½ tsp salt","Water as needed"],"instructions":["Grind soaked raw rice, cooked rice and coconut together with a little water to a smooth batter.","Mix yeast and sugar in warm water. Add to batter. Ferment overnight.","Add salt and adjust consistency to a thin, pourable batter.","Heat an appam pan (or non-stick wok). Pour a ladle and swirl the pan to spread.","Cover and cook on medium-low heat for 3 minutes until edges are lacy and centre is cooked.","Serve with coconut milk or kadala curry."],"prepTime":600,"cookTime":20,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-appam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Appam%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.138Z"},{"id":245,"title":"Aloo Ki Sabzi","description":"Simple, everyday spiced potatoes made with cumin, coriander and amchur — a humble side that goes with everything.","ingredients":["5 medium potatoes, boiled and roughly mashed","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp amchur","½ tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Heat oil. Add cumin seeds and let them splutter.","Add turmeric and then potatoes. Toss to coat.","Add coriander powder, amchur, red chilli and salt.","Cook on medium heat, tossing every 2 minutes, for 10 minutes.","Garnish with coriander. Serve with puri or roti."],"prepTime":5,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Ki%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.142Z"},{"id":246,"title":"Chana Dal","description":"Split chickpea dal tempered with ghee, cumin and asafoetida — wholesome, protein-rich and deeply comforting.","ingredients":["1 cup chana dal","1 onion, finely chopped","2 tomatoes, chopped","1 tsp ginger-garlic paste","½ tsp turmeric","1 tsp coriander powder","½ tsp garam masala","2 tbsp ghee","1 tsp cumin seeds","2 dried red chillies","A pinch of asafoetida","Salt to taste"],"instructions":["Pressure-cook chana dal with turmeric and water for 3 whistles.","Heat ghee. Add cumin seeds, dried red chillies and asafoetida.","Add onions and cook until golden. Add ginger-garlic paste and tomatoes. Cook until oil separates.","Add cooked dal and salt. Simmer 10 minutes. Add garam masala.","Serve with rice or roti."],"prepTime":10,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-chana-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chana%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.145Z"},{"id":247,"title":"Arhar Dal","description":"Toor dal — the everyday lentil of most Indian homes — tempered with mustard, tomatoes and curry leaves. Warm and nourishing.","ingredients":["1 cup toor dal","2 tomatoes, chopped","1 tsp ginger, grated","2 green chillies","½ tsp turmeric","1 tbsp ghee","1 tsp mustard seeds","10 curry leaves","2 dried red chillies","A pinch of asafoetida","Fresh coriander","Salt to taste"],"instructions":["Pressure-cook toor dal with tomatoes, green chillies, ginger and turmeric for 3–4 whistles. Mash.","Add salt and bring to a simmer.","Heat ghee. Splutter mustard seeds, then curry leaves, dried red chillies and asafoetida.","Pour tadka over dal. Garnish with coriander.","Serve with steamed rice and ghee."],"prepTime":5,"cookTime":25,"servings":4,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-arhar-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Arhar%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.148Z"},{"id":248,"title":"Green Moong Dal","description":"Whole green mung beans in a light, garlicky tomato broth — clean, fresh and surprisingly filling.","ingredients":["1 cup whole green moong dal","2 tomatoes, chopped","1 tbsp ginger-garlic paste","½ tsp turmeric","1 tsp coriander powder","½ tsp garam masala","1 tbsp oil","1 tsp cumin seeds","Salt to taste","Lemon juice and coriander"],"instructions":["Soak moong dal 2 hours. Pressure-cook with turmeric for 3 whistles.","Heat oil. Add cumin seeds, then ginger-garlic paste and tomatoes. Cook until oil separates.","Add spices and cooked dal. Simmer 10 minutes.","Finish with lemon juice and coriander."],"prepTime":120,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-green-moong-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Green%20Moong%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.152Z"},{"id":249,"title":"Chana Saag","description":"Chickpeas and spinach simmered in a robust onion-tomato masala — hearty, nutritious and a delicious variation on the classic chana.","ingredients":["2 cups chickpeas, boiled","3 cups spinach, roughly chopped","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","2 tbsp oil","Salt to taste"],"instructions":["Heat oil. Add cumin seeds, then onions. Cook until golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add spices and chickpeas. Cook 5 minutes.","Add spinach and stir until wilted. Simmer 10 minutes.","Serve with roti or rice."],"prepTime":480,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-chana-saag.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chana%20Saag%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.155Z"},{"id":250,"title":"Moong Dal Chilla","description":"Savoury moong dal pancakes stuffed with spiced paneer — a high-protein, gluten-free breakfast or snack ready in 20 minutes.","ingredients":["1 cup yellow moong dal, soaked 3 hours","1 tsp ginger, grated","2 green chillies","½ tsp turmeric","Salt to taste","For stuffing: 100g paneer, crumbled","1 tbsp coriander, chopped","½ tsp cumin powder","Oil for cooking"],"instructions":["Grind soaked moong dal with ginger, green chillies and a little water to a smooth batter. Add turmeric and salt.","Mix paneer with coriander, cumin and salt for the stuffing.","Heat a non-stick pan. Pour a ladle of batter and spread thin.","Place stuffing on one half. Fold over and cook with oil until golden on both sides.","Serve with green chutney."],"prepTime":180,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-moong-dal-chilla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Moong%20Dal%20Chilla%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.160Z"},{"id":251,"title":"Thalipeeth","description":"A multigrain savoury pancake from Maharashtra made with bhajani flour, vegetables and spices — crisp, satisfying and nutritious.","ingredients":["1½ cups bhajani flour (or mix of rice, jowar, bajra, wheat flours)","1 onion, finely chopped","2 tbsp coriander, chopped","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","Salt to taste","Oil for cooking"],"instructions":["Mix bhajani flour, onion, coriander, cumin, turmeric, red chilli and salt. Add water to make a firm dough.","Take a portion and flatten on a greased plastic sheet or damp cloth.","Transfer to a hot tawa. Make a small hole in the centre.","Drizzle oil around the edges and in the hole. Cook on medium heat until crispy on both sides.","Serve with yogurt and loni (white butter)."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-thalipeeth.png","youtubeUrl":"https://www.youtube.com/results?search_query=Thalipeeth%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.163Z"},{"id":252,"title":"Litti Chokha","description":"Bihar's pride — baked wheat dumplings filled with roasted sattu paste, served with charcoal-roasted vegetable mash.","ingredients":["For litti: 2 cups whole wheat flour","1 tbsp ghee","For filling: 1 cup sattu (roasted chana flour)","1 tbsp mustard oil","1 tsp ajwain","1 tsp kalonji","1 tsp lemon juice","Chopped green chillies and coriander","For chokha: 2 large aubergines (brinjal)","2 tomatoes","2 potatoes","Chopped onion","Mustard oil and spices"],"instructions":["Mix sattu with mustard oil, ajwain, kalonji, lemon juice, green chillies, coriander and salt. Filling should be crumbly.","Make wheat dough. Rest 20 minutes. Divide into balls. Stuff each ball with sattu filling and seal.","Bake in a preheated oven at 200°C for 25–30 minutes, turning once, or cook on a coal fire.","Roast brinjal, tomatoes and potatoes directly on the flame. Peel, mash with onion, mustard oil and spices for chokha.","Dip litti in ghee and serve with chokha."],"prepTime":30,"cookTime":40,"servings":4,"cuisineType":"East Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-litti-chokha.png","youtubeUrl":"https://www.youtube.com/results?search_query=Litti%20Chokha%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.166Z"},{"id":253,"title":"Aloo Dum","description":"Baby potatoes slow-cooked in a thick, spiced tomato gravy — the Kolkata version with fennel seeds and the Kashmiri version with yogurt are both transcendent.","ingredients":["500g baby potatoes, boiled and peeled","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp fennel seeds","1 tsp coriander powder","½ tsp garam masala","½ tsp red chilli powder","½ tsp turmeric","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Prick baby potatoes all over with a fork. Shallow-fry until golden on all sides.","Heat oil in the same pan. Add cumin and fennel seeds. Add onions and cook until deep golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add all spices and fried potatoes. Toss well. Add ½ cup water.","Cover and cook on low heat 20 minutes. Garnish and serve."],"prepTime":15,"cookTime":40,"servings":4,"cuisineType":"East Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-dum.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Dum%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.170Z"},{"id":254,"title":"Shorshe Ilish","description":"A beloved Bengali mustard-based curry — made vegan here with raw banana instead of hilsa fish, capturing all the pungent, aromatic flavour.","ingredients":["4 slices raw banana (or raw jackfruit), lightly fried","3 tbsp yellow mustard seeds","2 tbsp poppy seeds","4 green chillies","½ tsp turmeric","½ tsp red chilli powder","3 tbsp mustard oil","Salt to taste"],"instructions":["Soak mustard seeds and poppy seeds in water 30 minutes. Grind with green chillies and a little water to a smooth paste.","Heat mustard oil to smoking. Cool slightly.","Add the mustard paste. Cook on low heat 5 minutes, stirring.","Add turmeric, red chilli and salt. Add ½ cup water.","Add fried raw banana slices. Cover and cook 15 minutes on low heat.","Serve with steamed rice."],"prepTime":35,"cookTime":25,"servings":4,"cuisineType":"East Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-shorshe-ilish.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shorshe%20Baingan%20Bengali%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.173Z"},{"id":255,"title":"Coconut Rice","description":"Fragrant rice tossed with fresh coconut, mustard seeds and cashews — a simple, festive preparation from coastal South India.","ingredients":["2 cups cooked rice","1 cup fresh coconut, grated","2 tbsp oil","1 tsp mustard seeds","10 curry leaves","3 dried red chillies","¼ cup cashews","1 tsp chana dal","A pinch of asafoetida","Salt to taste"],"instructions":["Heat oil. Fry cashews until golden. Add mustard seeds, curry leaves, red chillies, chana dal and asafoetida.","Add grated coconut and fry 3 minutes.","Add rice and salt. Toss well.","Serve as a main or side."],"prepTime":5,"cookTime":10,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-coconut-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Coconut%20Rice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.177Z"},{"id":256,"title":"Tomato Rice","description":"Spiced tomato rice — a one-pot meal of rice cooked with tomatoes, onions and South Indian spices — tangy, aromatic and deeply comforting.","ingredients":["1 cup basmati rice","3 tomatoes, finely chopped","1 onion, finely chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","10 curry leaves","2 tbsp oil","Salt to taste"],"instructions":["Heat oil. Add cumin seeds and curry leaves. Add onion and cook until golden.","Add ginger-garlic paste and tomatoes. Cook until tomatoes are completely pulpy.","Add spices and washed rice. Stir to coat.","Add 1¾ cups water and salt. Bring to a boil. Cover and cook on low heat 15 minutes.","Rest 5 minutes. Fluff and serve."],"prepTime":5,"cookTime":25,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-tomato-rice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tomato%20Rice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.181Z"},{"id":257,"title":"Vangi Bath","description":"Karnataka's aubergine rice cooked with a special spice paste — a hearty, aromatic one-pot meal with deep South Indian flavours.","ingredients":["1 cup rice, cooked","2 small aubergines, cubed","2 tbsp vangi bath powder","1 tbsp tamarind paste","1 tbsp oil","1 tsp mustard seeds","10 curry leaves","A pinch of asafoetida","Salt to taste","Roasted peanuts to garnish"],"instructions":["Heat oil. Splutter mustard seeds, curry leaves and asafoetida. Add aubergine and cook until tender.","Add tamarind paste and vangi bath powder. Stir and cook 5 minutes.","Add rice and toss gently to combine.","Garnish with roasted peanuts. Serve with raita."],"prepTime":10,"cookTime":20,"servings":3,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-vangi-bath.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vangi%20Bath%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.184Z"},{"id":258,"title":"Kathi Roll","description":"Flaky paratha rolled up with spiced paneer, onions and chutneys — Kolkata's greatest street food contribution, now loved nationwide.","ingredients":["For paratha: 2 cups flour","Ghee","For filling: 200g paneer, sliced","1 capsicum, sliced","1 onion, sliced","1 tbsp ginger-garlic paste","1 tsp cumin powder","1 tsp coriander powder","½ tsp garam masala","½ tsp red chilli powder","Green chutney","Tamarind chutney","Sliced onion with lemon and chaat masala"],"instructions":["Make a soft paratha dough. Roll and cook parathas with ghee until flaky.","Sauté paneer, capsicum and onion with spices on high heat until slightly charred.","Spread green chutney on the paratha. Place paneer filling in the centre.","Top with raw onion salad. Drizzle tamarind chutney.","Roll tightly in foil. Serve hot."],"prepTime":20,"cookTime":25,"servings":4,"cuisineType":"East Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-kathi-roll.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kathi%20Roll%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.188Z"},{"id":259,"title":"Ragda Pattice","description":"Mumbai chaat legend — crispy potato patties on a bed of white pea ragda, topped with chutneys, onion and sev.","ingredients":["For pattice: 3 potatoes, boiled and mashed","Salt and pepper","For ragda: 1 cup white peas (vatana), soaked and boiled","1 tsp cumin seeds","½ tsp turmeric","2 tomatoes","Salt","For topping: tamarind chutney","Green chutney","Sev","Chopped onion","Chaat masala and coriander"],"instructions":["Make ragda: boil white peas. Cook with cumin, tomatoes, turmeric and salt until thick.","Season mashed potato. Shape into flat patties. Shallow-fry until golden on both sides.","Serve patties on a plate. Ladle ragda over them.","Top with both chutneys, onion, sev and chaat masala.","Serve immediately."],"prepTime":480,"cookTime":35,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-ragda-pattice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Ragda%20Pattice%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.191Z"},{"id":260,"title":"Sev Puri","description":"Tiny flat puri crisps topped with potato, chutneys, onion and sev — perhaps the most popular chaat after pani puri.","ingredients":["20 flat puri crisps (or mini papdi)","2 potatoes, boiled and cubed","1 onion, finely chopped","Tamarind chutney","Green chutney","Thin sev","Chaat masala","Red chilli powder","Fresh coriander","Pomegranate seeds"],"instructions":["Arrange puri crisps on a serving plate.","Top each puri with a little potato, onion and coriander.","Drizzle tamarind and green chutneys generously.","Sprinkle chaat masala and red chilli.","Top with a generous shower of sev and pomegranate seeds. Serve immediately."],"prepTime":10,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-sev-puri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sev%20Puri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.195Z"},{"id":261,"title":"Pani Puri","description":"Hollow crispy spheres filled with spiced potato and dipped in icy mint-tamarind water — the king of Indian street food, one pierces your mouth with flavour.","ingredients":["24 puri shells (store-bought or homemade)","For pani: 1 cup mint leaves","½ cup coriander leaves","2 green chillies","1 tbsp tamarind paste","1 tsp cumin powder","1 tsp black salt","1 tsp chaat masala","3 cups chilled water","For filling: 2 potatoes, boiled and mashed","1 cup kala chana, boiled","1 tsp chaat masala"],"instructions":["Blend mint, coriander, green chillies, tamarind, cumin, black salt and chaat masala with 1 cup water. Strain. Add remaining cold water.","Mash potatoes with boiled chana and chaat masala for the filling.","Make a hole in each puri. Fill with a little potato mixture.","Dip immediately into the pani and eat in one bite."],"prepTime":20,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-pani-puri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pani%20Puri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.198Z"},{"id":262,"title":"Dahi Puri","description":"Hollow puri shells filled with potato and chickpea, then smothered with sweetened yogurt, chutneys and sev — the gentler cousin of pani puri.","ingredients":["20 hollow puri shells","2 potatoes, boiled and mashed","½ cup kala chana, boiled","1½ cups thick yogurt","1 tsp sugar","Tamarind chutney","Green chutney","Sev","Chaat masala","Red chilli powder","Coriander and pomegranate"],"instructions":["Sweeten yogurt with sugar. Beat smooth.","Make a hole in each puri. Fill with potato and chana.","Spoon sweetened yogurt over the puris.","Drizzle both chutneys generously.","Sprinkle chaat masala, red chilli, sev, pomegranate and coriander. Serve immediately."],"prepTime":10,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-dahi-puri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dahi%20Puri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.201Z"},{"id":263,"title":"Kachori","description":"Flaky deep-fried pastry shells filled with spiced moong dal paste — Rajasthan's great contribution to Indian snack culture.","ingredients":["For dough: 2 cups all-purpose flour","3 tbsp oil","For filling: 1 cup moong dal, soaked and coarsely ground","1 tsp cumin seeds","1 tsp fennel seeds","½ tsp red chilli powder","½ tsp amchur","1 tsp coriander powder","Oil for deep frying","Salt to taste"],"instructions":["Mix flour, oil and salt with water to make a firm dough. Rest 20 minutes.","Dry cook ground moong dal in a pan with oil and all spices until dry and fragrant.","Roll dough into circles. Place filling. Seal into balls.","Deep-fry on low-medium heat, turning continuously, until golden and crisp.","Serve with tamarind chutney."],"prepTime":30,"cookTime":25,"servings":6,"cuisineType":"Rajasthani","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-kachori.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kachori%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.204Z"},{"id":264,"title":"Samosa","description":"The world's most recognised Indian snack — flaky pastry filled with spiced potatoes and peas, deep-fried to golden perfection.","ingredients":["For dough: 2 cups all-purpose flour","3 tbsp oil","½ tsp ajwain","For filling: 4 potatoes, boiled and cubed","½ cup peas","1 tsp cumin seeds","1 tsp coriander powder","½ tsp amchur","½ tsp garam masala","½ tsp red chilli powder","Fresh coriander","Oil for deep frying","Salt to taste"],"instructions":["Mix flour, oil, ajwain and salt. Add water and knead into a firm, stiff dough. Rest 20 minutes.","Make filling: heat 1 tbsp oil, add cumin seeds, add potatoes, peas and all spices. Cool.","Divide dough and roll into circles. Cut into half-moons. Form into cones, fill and seal.","Deep-fry on medium heat, turning, until golden and crisp — about 12 minutes.","Serve with mint chutney and tamarind chutney."],"prepTime":30,"cookTime":20,"servings":6,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-samosa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Samosa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.208Z"},{"id":265,"title":"Palak Soup","description":"A smooth, velvety spinach soup with garlic and cream — light enough for a starter, satisfying enough for a meal.","ingredients":["400g fresh spinach","1 onion, chopped","3 garlic cloves","1 cup vegetable broth","½ cup cream","1 tsp cumin","2 tbsp butter","Salt and pepper","Croutons to serve"],"instructions":["Melt butter. Sauté onion and garlic until soft.","Add spinach and broth. Cook 5 minutes.","Blend smooth. Return to heat.","Add cumin, cream, salt and pepper. Simmer 5 minutes.","Serve with croutons."],"prepTime":10,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-palak-soup.png","youtubeUrl":"https://www.youtube.com/results?search_query=Palak%20Soup%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.212Z"},{"id":266,"title":"Tomato Shorba","description":"A light, spiced Indian tomato broth with ginger, cumin and black pepper — a warming soup from royal Mughal kitchens.","ingredients":["6 ripe tomatoes, roughly chopped","1 onion, chopped","2 garlic cloves","1 inch ginger","1 tsp cumin seeds","½ tsp black pepper","½ tsp red chilli powder","2 cups vegetable broth","1 tbsp ghee","1 tsp sugar","Fresh coriander","Salt to taste"],"instructions":["Cook tomatoes, onion, garlic and ginger in broth until completely soft. Blend and strain.","Heat ghee. Add cumin seeds. Add the strained tomato broth.","Add spices, sugar and salt. Simmer 10 minutes.","Garnish with coriander and cream. Serve hot."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-tomato-shorba.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tomato%20Shorba%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.215Z"},{"id":267,"title":"Mulligatawny Soup","description":"The Anglo-Indian pepper soup with lentils, apple and coconut milk — born in the colonial era and still deeply loved.","ingredients":["½ cup red lentils","1 apple, peeled and chopped","1 onion, chopped","2 garlic cloves","1 tbsp curry powder","½ tsp turmeric","1 can coconut milk","3 cups vegetable broth","1 tbsp oil","Lemon juice","Salt to taste","Coriander to garnish"],"instructions":["Heat oil. Cook onion and garlic until soft. Add curry powder and turmeric.","Add apple, lentils and broth. Cook 25 minutes until lentils are soft.","Blend until smooth.","Return to heat. Add coconut milk and salt. Simmer 5 minutes.","Finish with lemon juice and coriander."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"Fusion","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mulligatawny-soup.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mulligatawny%20Soup%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.219Z"},{"id":268,"title":"Vegetable Jalfrezi","description":"A stir-fried toss of vegetables in a spicy, tangy tomato sauce with ginger and capsicum — vibrant, colourful and ready quickly.","ingredients":["1 carrot, cut into batons","1 capsicum, sliced","100g paneer, sliced","1 onion, sliced","2 tomatoes, chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","1 tsp garam masala","½ tsp turmeric","1 tsp red chilli powder","2 tbsp oil","Salt to taste"],"instructions":["Blanch carrots briefly. Heat oil on high heat.","Add cumin seeds. Add onion and cook until slightly charred.","Add ginger-garlic paste. Add tomatoes. Cook 3 minutes.","Add all spices. Add vegetables and paneer.","Toss on high heat 5 minutes until vegetables are slightly charred and sauce coats them.","Serve with naan."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-vegetable-jalfrezi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vegetable%20Jalfrezi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.223Z"},{"id":269,"title":"Paneer Pasanda","description":"Thin paneer slices sandwiched with a savoury nut stuffing, dipped in a golden batter and cooked in a royal Mughlai gravy.","ingredients":["300g paneer, sliced and stuffed with dried fruit and nut mixture","For gravy: 1 cup cashew paste","2 onions, pureed","1 tbsp ginger-garlic paste","½ cup yogurt","1 tsp garam masala","½ tsp turmeric","½ tsp red chilli powder","2 tbsp ghee","Saffron milk","Fresh cream","Salt to taste"],"instructions":["Stuff paneer slices with a mixture of chopped cashews, raisins and spices. Sandwich two pieces.","Shallow fry the stuffed paneer until golden. Set aside.","Make gravy: heat ghee. Cook onion puree until golden. Add ginger-garlic paste.","Add yogurt, cashew paste and all spices. Cook until oil separates.","Add saffron milk and cream. Simmer 5 minutes. Add paneer pasanda.","Serve with naan."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-pasanda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Pasanda%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.226Z"},{"id":270,"title":"Kofta Curry","description":"Soft vegetable and paneer dumplings in a rich tomato-cashew gravy — an elegant vegetarian take on the classic Indian meatball curry.","ingredients":["For kofta: 200g paneer","2 potatoes, boiled","½ cup spinach, blanched and chopped","1 tsp garam masala","Cornflour for binding","Oil for frying","For gravy: 2 onions, pureed","3 tomatoes, pureed","1 tbsp ginger-garlic paste","½ cup cashew paste","1 tsp coriander powder","1 tsp garam masala","½ tsp red chilli powder","½ tsp turmeric","2 tbsp oil"],"instructions":["Mix paneer, potato and spinach with garam masala and salt. Bind with cornflour. Shape into balls. Deep fry until golden.","Make gravy: cook onion puree until golden. Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add cashew paste and all spices. Simmer 10 minutes with ½ cup water.","Add koftas just before serving. Simmer 3 minutes.","Serve with naan."],"prepTime":25,"cookTime":45,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kofta-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kofta%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.229Z"},{"id":271,"title":"Achari Paneer","description":"Paneer cubes tossed in a sharp, tangy pickling spice masala of mustard, fenugreek and fennel — bold and unlike any other paneer dish.","ingredients":["300g paneer, cubed","1 tsp each: mustard seeds, fennel seeds, fenugreek seeds, kalonji, cumin seeds","3 tomatoes, pureed","1 onion, finely chopped","1 tbsp ginger-garlic paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp amchur","2 tbsp mustard oil","Salt to taste"],"instructions":["Heat mustard oil to smoking. Let cool slightly. Coarsely grind all 5 whole spices.","Sauté onion until golden. Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add turmeric, red chilli, amchur and the ground spice blend. Cook 2 minutes.","Add paneer. Toss and cook 5 minutes.","Serve with lachha paratha."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-achari-paneer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Achari%20Paneer%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.232Z"},{"id":272,"title":"Hara Bhara Kabab","description":"Emerald-green spinach and peas patties with paneer and mild spices — a showstopping green starter that is also nutritious.","ingredients":["2 cups spinach, blanched and squeezed dry","1 cup peas, boiled and mashed","2 potatoes, boiled and mashed","100g paneer, crumbled","1 tsp cumin powder","1 tsp garam masala","1 tbsp cornflour","1 green chilli","Fresh coriander","Oil for shallow frying","Salt to taste"],"instructions":["Blend spinach, peas, green chilli and coriander to a coarse paste.","Mix with mashed potato, paneer, spices and cornflour. Season.","Shape into flat, round patties.","Shallow-fry on medium heat until crispy and deep green on both sides.","Serve with mint chutney."],"prepTime":20,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-hara-bhara-kabab.png","youtubeUrl":"https://www.youtube.com/results?search_query=Hara%20Bhara%20Kabab%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.236Z"},{"id":273,"title":"Mushroom Masala","description":"Button mushrooms in a rich, smoky onion-tomato masala — ready in 20 minutes and absolutely delicious with roomali roti.","ingredients":["400g button mushrooms, halved","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","1 tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Heat oil. Add cumin seeds. Add onions and cook until deep golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates, about 10 minutes.","Add all spices. Cook 2 minutes.","Add mushrooms. Toss and cook on high heat 8 minutes until mushrooms are cooked and slightly golden.","Garnish and serve."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mushroom-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mushroom%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.239Z"},{"id":274,"title":"Butter Paneer Masala","description":"Paneer in a makhani-style buttery tomato gravy made with cream and whole spices — the vegetarian answer to butter chicken.","ingredients":["300g paneer, cubed","For gravy: 5 tomatoes","2 onions","½ cup cashews","1 tbsp ginger-garlic paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander powder","½ tsp garam masala","3 tbsp butter","½ cup cream","1 tsp sugar","Salt to taste"],"instructions":["Boil tomatoes, onions and cashews together. Blend to a smooth purée.","Melt butter. Add ginger-garlic paste. Add tomato purée and cook 15 minutes, stirring.","Add all spices and sugar. Simmer 5 minutes.","Add cream and paneer. Simmer 5 minutes on low heat.","Serve with naan or paratha."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-butter-paneer-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Butter%20Paneer%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.242Z"},{"id":275,"title":"Neer Dosa","description":"Kerala-Karnataka's paper-thin lacy water crepe made with just rice and coconut — delicate, soft and the most elegant of all dosas.","ingredients":["1 cup raw rice, soaked 4 hours","¼ cup fresh coconut, grated","½ tsp salt","Water to thin the batter"],"instructions":["Drain rice and grind with coconut to an extremely thin, smooth batter. Add salt and enough water so it is almost as thin as milk.","Heat a dosa tawa. Pour a ladle of batter and quickly swirl the pan.","The batter will spread into a very thin crepe. Tiny holes will form.","Cover and cook on low heat for 1 minute. Do not flip.","Fold gently and serve with coconut chutney and sambar."],"prepTime":250,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-neer-dosa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Neer%20Dosa%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.247Z"},{"id":276,"title":"Kanda Bhaji","description":"Crispy, lacy onion fritters made with chickpea flour — Maharashtra's favourite monsoon snack with a cup of masala chai.","ingredients":["3 large onions, thinly sliced","1 cup chickpea flour","2 green chillies, finely chopped","10 curry leaves, chopped","1 tsp cumin seeds","½ tsp turmeric","½ tsp red chilli powder","Fresh coriander","Oil for deep frying","Salt to taste"],"instructions":["Mix sliced onions with salt. Leave 5 minutes until they release moisture.","Add chickpea flour, green chillies, curry leaves, cumin, turmeric and coriander. Mix without adding water — the onion moisture is enough.","The mixture should be thick and sticky.","Drop spoonfuls into hot oil. Fry until golden and crispy.","Serve hot with green chutney and chai."],"prepTime":15,"cookTime":15,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kanda-bhaji.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kanda%20Bhaji%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.250Z"},{"id":277,"title":"Spinach Pakora","description":"Whole spinach leaves dipped in a spiced chickpea batter and deep-fried until gloriously crisp — simplest monsoon snack there is.","ingredients":["20 large fresh spinach leaves","For batter: 1 cup chickpea flour","½ tsp red chilli powder","½ tsp cumin powder","½ tsp ajwain","A pinch of baking soda","Salt","Water","Oil for deep frying"],"instructions":["Make a smooth, thick batter with all ingredients.","Wash and dry spinach leaves.","Dip each leaf in batter, coating both sides.","Deep fry until crisp and golden.","Serve immediately with mint chutney and tea."],"prepTime":10,"cookTime":10,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-spinach-pakora.png","youtubeUrl":"https://www.youtube.com/results?search_query=Spinach%20Pakora%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.253Z"},{"id":278,"title":"Paneer Pakora","description":"Thick paneer slices marinated in spiced yogurt, dipped in chickpea batter and fried until golden — the ultimate paneer starter.","ingredients":["300g paneer, cut into thick slices","For marinade: 1 tbsp yogurt","½ tsp red chilli powder","½ tsp garam masala","½ tsp chaat masala","For batter: 1 cup chickpea flour","½ tsp red chilli powder","½ tsp ajwain","A pinch of baking soda","Salt","Oil for deep frying"],"instructions":["Mix marinade ingredients. Coat paneer slices and leave 20 minutes.","Make a thick batter. Dip marinated paneer slices in batter.","Deep fry in hot oil until golden and crispy.","Drain. Sprinkle chaat masala.","Serve with mint chutney."],"prepTime":25,"cookTime":10,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-pakora.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Pakora%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.256Z"},{"id":279,"title":"Aloo Tikki Chaat","description":"Crispy potato tikkis drowning in yogurt, both chutneys, sev and chaat masala — the North Indian street classic elevated to its full glory.","ingredients":["6 aloo tikkis (refer to Aloo Tikki recipe)","1 cup yogurt, sweetened with sugar","Tamarind chutney","Green chutney","Thin sev","Red onion, finely chopped","Chaat masala","Red chilli powder","Cumin powder","Pomegranate seeds","Fresh coriander"],"instructions":["Arrange hot tikkis on a plate.","Spoon sweetened yogurt generously over them.","Drizzle tamarind and green chutneys.","Sprinkle chaat masala, red chilli and cumin.","Finish with sev, onion, pomegranate and coriander. Serve immediately."],"prepTime":5,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-tikki-chaat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Tikki%20Chaat%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.258Z"},{"id":280,"title":"Papdi Chaat","description":"Crispy papdi crackers loaded with potatoes, yogurt, chutneys and sev — a carnival of sweet, sour, spicy and crunchy.","ingredients":["30 papdi crackers","2 potatoes, boiled and cubed","½ cup kala chana, boiled","1½ cups yogurt, sweetened","Tamarind chutney","Green chutney","Thin sev","Chaat masala","Coriander and pomegranate"],"instructions":["Arrange papdi on a platter.","Top with potato cubes and kala chana.","Spoon sweetened yogurt generously.","Drizzle both chutneys.","Sprinkle chaat masala, sev, coriander and pomegranate. Serve at once."],"prepTime":10,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-papdi-chaat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Papdi%20Chaat%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.261Z"},{"id":281,"title":"Masala Chai","description":"India's beloved spiced milk tea brewed with ginger, cardamom, cinnamon and cloves — the perfect beginning to every day.","ingredients":["2 cups water","1 cup full-fat milk","2 tsp CTC black tea","1 inch ginger, bruised","3 cardamom pods, bruised","1 small cinnamon stick","2 cloves","½ tsp black peppercorns","Sugar to taste"],"instructions":["Combine water, ginger, cardamom, cinnamon, cloves and pepper in a saucepan. Boil 3 minutes.","Add tea. Boil 2 minutes.","Add milk. Bring to a full boil, then reduce heat. Simmer 2 minutes.","Strain into cups. Sweeten to taste."],"prepTime":2,"cookTime":8,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-masala-chai.png","youtubeUrl":"https://www.youtube.com/results?search_query=Masala%20Chai%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.264Z"},{"id":282,"title":"Amritsari Kulcha","description":"Stuffed, butter-smothered flatbread cooked in a tandoor — Amritsar's most iconic contribution to Punjab's culinary heritage.","ingredients":["For dough: 2 cups all-purpose flour","½ cup yogurt","1 tsp baking powder","Pinch of baking soda","1 tbsp oil","For stuffing: 3 potatoes, boiled and mashed","1 onion, finely chopped","1 green chilli","1 tsp ajwain","½ tsp red chilli powder","Fresh coriander","Butter to finish"],"instructions":["Mix flour, yogurt, baking powder, soda and oil. Knead into soft dough. Rest 1 hour.","Mix stuffing ingredients and season well.","Divide dough. Roll a ball flat. Place stuffing. Seal and roll gently.","Cook on a very hot tawa with butter until golden and puffed on both sides, pressing down with a cloth.","Serve with chole and sliced onion."],"prepTime":70,"cookTime":20,"servings":4,"cuisineType":"Punjabi","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-amritsari-kulcha.png","youtubeUrl":"https://www.youtube.com/results?search_query=Amritsari%20Kulcha%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.267Z"},{"id":283,"title":"Tandoori Roti","description":"Whole wheat flatbread baked at high heat until puffed and charred in places — the everyday bread of North India.","ingredients":["2 cups whole wheat flour","1 tsp baking powder","½ tsp salt","1 tsp oil","Water to knead","Butter or ghee to serve"],"instructions":["Knead flour, baking powder, salt, oil and water into a soft dough. Rest 20 minutes.","Divide into balls. Roll into circles about 3mm thick.","Place on a very hot tawa. When bubbles appear, flip and cook directly on the gas flame briefly until charred spots appear.","Brush with butter or ghee. Serve hot."],"prepTime":25,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-tandoori-roti.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tandoori%20Roti%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.270Z"},{"id":284,"title":"Naan","description":"Soft, pillowy leavened flatbread traditionally baked in a tandoor — the perfect partner for rich Indian curries.","ingredients":["2 cups all-purpose flour","½ cup yogurt","1 tsp dry yeast","1 tsp sugar","½ tsp baking powder","2 tbsp oil","Salt to taste","Butter and garlic to finish"],"instructions":["Dissolve yeast in warm water with sugar. Leave 10 minutes until frothy.","Mix with flour, yogurt, baking powder, oil and salt. Knead 10 minutes. Rest 1 hour until doubled.","Divide and roll into tear-drop shapes.","Cook on a hot, greased tawa until bubbles appear. Flip and hold briefly over a gas flame.","Brush with garlic butter. Serve hot."],"prepTime":70,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":[],"category":"main","imageUrl":"/stock-images/recipe-naan.png","youtubeUrl":"https://www.youtube.com/results?search_query=Naan%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.273Z"},{"id":285,"title":"Bhakri","description":"Coarse millet or jowar flatbread from Maharashtra — rustic, slightly crumbly and the traditional vehicle for spicy curries.","ingredients":["2 cups jowar flour (or bajra flour)","Warm water","Salt to taste","Ghee or oil to serve"],"instructions":["Mix flour, salt and enough warm water to make a stiff, pliable dough.","Divide into balls. Pat each ball into a rough circle with wet hands (or roll between plastic sheets).","Cook on a dry hot tawa, pressing with a cloth to ensure even cooking.","Cook until both sides have brown patches.","Serve with pithla or sabzi and ghee."],"prepTime":10,"cookTime":15,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bhakri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bhakri%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.277Z"},{"id":286,"title":"Pulao","description":"Fragrant basmati rice cooked with whole spices, vegetables and saffron — the elegant one-pot rice dish between a plain rice and a biryani.","ingredients":["1½ cups basmati rice, soaked 30 minutes","1 cup mixed vegetables (carrot, beans, peas)","1 onion, sliced","Whole spices: 1 bay leaf, 2 cardamom, 4 cloves, 1 cinnamon stick","1 tsp cumin seeds","1 tbsp ghee","A pinch of saffron in warm milk","2½ cups water","Salt to taste"],"instructions":["Heat ghee. Fry whole spices until fragrant. Add sliced onion and cook until golden.","Add vegetables and sauté 2 minutes.","Add drained rice. Sauté 2 minutes.","Add water, saffron milk and salt. Bring to a boil.","Cover and cook on low heat 15 minutes. Rest 5 minutes. Fluff and serve."],"prepTime":35,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-pulao.png","youtubeUrl":"https://www.youtube.com/results?search_query=Vegetable%20Pulao%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.279Z"},{"id":287,"title":"Daliya Khichdi","description":"Broken wheat and lentil porridge with vegetables — nutritious, low-calorie and filling. Often prescribed as a health food, it tastes far better than that suggests.","ingredients":["1 cup broken wheat (daliya)","½ cup moong dal","1 cup mixed vegetables","1 tsp cumin seeds","½ tsp turmeric","1 tbsp ghee","A pinch of asafoetida","Salt to taste"],"instructions":["Dry roast daliya until light golden.","Heat ghee. Add cumin and asafoetida. Add vegetables and sauté.","Add daliya and dal. Add 4 cups water, turmeric and salt.","Pressure-cook 3 whistles. Open and mix well.","Serve hot with yogurt."],"prepTime":5,"cookTime":25,"servings":3,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-daliya-khichdi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Daliya%20Khichdi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.282Z"},{"id":288,"title":"Bread Upma","description":"Leftover bread cubes crumbled and tossed with mustard, vegetables and spices — a brilliant 10-minute breakfast.","ingredients":["6 slices bread, cut into small cubes","1 onion, finely chopped","1 tomato, chopped","2 green chillies","1 tsp mustard seeds","10 curry leaves","½ tsp turmeric","2 tbsp oil","Lemon juice and coriander","Salt to taste"],"instructions":["Heat oil. Splutter mustard seeds and curry leaves.","Add green chillies and onion. Cook until soft.","Add tomato and turmeric. Cook 2 minutes.","Add bread cubes. Toss gently until all the bread is coated and heated through.","Finish with lemon juice and coriander. Serve hot."],"prepTime":5,"cookTime":10,"servings":2,"cuisineType":"South Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-bread-upma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bread%20Upma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.285Z"},{"id":289,"title":"Egg Curry","description":"Hard-boiled eggs in a fragrant onion-tomato masala — this is the vegetarian community version made with boiled potatoes instead, equally satisfying.","ingredients":["4 potatoes, boiled and halved (substitute for eggs)","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","1 tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Score the potatoes for better absorption. Shallow-fry until golden.","Heat oil. Add cumin seeds. Add onions and cook until deep golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add all spices. Cook 2 minutes.","Add fried potatoes and ½ cup water. Simmer 15 minutes.","Garnish and serve with roti."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-egg-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.288Z"},{"id":290,"title":"Mixed Vegetable Curry","description":"A colourful, warming medley of seasonal vegetables in a richly spiced tomato gravy — endlessly adaptable to what's in your kitchen.","ingredients":["3 cups mixed vegetables (potato, carrot, beans, peas, cauliflower)","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","½ tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Steam or boil all vegetables until just tender.","Heat oil. Add cumin seeds. Add onions and cook until golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add spices. Add vegetables and stir to coat.","Add ½ cup water and simmer 10 minutes. Garnish and serve."],"prepTime":15,"cookTime":30,"servings":4,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-mixed-vegetable-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mixed%20Vegetable%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.293Z"},{"id":291,"title":"Navratan Korma","description":"Nine-gem korma — a mild, cream-based curry of vegetables, paneer, fruits and nuts from the Mughal kitchen. Subtly sweet and luxuriously rich.","ingredients":["1 cup mixed vegetables (carrot, peas, beans, potato, cauliflower)","100g paneer, cubed","2 tbsp cashews","1 tbsp raisins","1 can pineapple chunks (or fresh)","For gravy: 2 onions, pureed","½ cup cashew paste","½ cup cream","1 tbsp ginger-garlic paste","1 tsp garam masala","½ tsp turmeric","½ tsp red chilli powder","2 tbsp ghee","1 tsp sugar","Salt to taste"],"instructions":["Cook vegetables until tender. Fry cashews and raisins in ghee. Set aside.","Heat ghee. Cook onion purée until golden. Add ginger-garlic paste.","Add cashew paste, cream and spices. Simmer 10 minutes.","Add cooked vegetables, paneer and pineapple. Simmer 5 minutes.","Top with fried cashews and raisins. Serve with naan."],"prepTime":20,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-navratan-korma.png","youtubeUrl":"https://www.youtube.com/results?search_query=Navratan%20Korma%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.300Z"},{"id":292,"title":"Soya Keema","description":"Minced soya granules cooked with onions, tomatoes and whole spices — a protein-rich vegetarian keema that closely mirrors the meaty original.","ingredients":["1 cup soya granules","2 onions, finely chopped","3 tomatoes, finely chopped","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","1 tsp red chilli powder","2 tbsp oil","Fresh peas (optional)","Fresh coriander","Salt to taste"],"instructions":["Soak soya granules in hot water 10 minutes. Squeeze out water completely.","Heat oil. Add cumin seeds. Add onions and cook until golden.","Add ginger-garlic paste and tomatoes. Cook until oil separates.","Add all spices and soya granules. Mix well.","Add ½ cup water. Cook 15 minutes. Garnish and serve with pav or roti."],"prepTime":15,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-soya-keema.png","youtubeUrl":"https://www.youtube.com/results?search_query=Soya%20Keema%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.303Z"},{"id":293,"title":"Jackfruit Biryani","description":"Young green jackfruit slow-cooked in biryani spices until it pulls apart like tender meat — the plant-based biryani that will convert sceptics.","ingredients":["400g young green jackfruit, cut into pieces","2 cups basmati rice, parboiled","2 onions, thinly sliced and fried crispy","1 cup yogurt","1 tbsp ginger-garlic paste","2 tsp biryani masala","½ tsp garam masala","A pinch of saffron in warm milk","Fresh mint and coriander","3 tbsp ghee","Salt to taste"],"instructions":["Pressure-cook jackfruit with yogurt, ginger-garlic paste, biryani masala and salt for 3 whistles.","In a heavy pot, layer parboiled rice and jackfruit alternately.","Top with saffron milk, fried onions, mint, coriander and ghee.","Seal and cook on dum (very low heat) 20 minutes.","Serve with raita."],"prepTime":30,"cookTime":55,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-jackfruit-biryani.png","youtubeUrl":"https://www.youtube.com/results?search_query=Jackfruit%20Biryani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.306Z"},{"id":294,"title":"Paneer Lababdar","description":"A Punjabi restaurant favourite — paneer in a rich, slightly sweet onion-tomato-cashew gravy with a generous dose of cream.","ingredients":["300g paneer, cubed","2 onions, roughly chopped","3 tomatoes, chopped","10 cashews","1 tbsp ginger-garlic paste","1 tsp red chilli powder","1 tsp coriander powder","½ tsp garam masala","½ tsp kasuri methi","½ cup cream","2 tbsp butter","Salt to taste"],"instructions":["Boil onions, tomatoes and cashews together. Blend to a smooth purée.","Heat butter. Add the purée and cook 10 minutes, stirring.","Add ginger-garlic paste and all spices. Cook 5 minutes.","Add cream and kasuri methi. Simmer 3 minutes.","Add paneer. Cook 5 minutes on low heat. Serve with naan."],"prepTime":10,"cookTime":30,"servings":4,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-paneer-lababdar.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Lababdar%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.309Z"},{"id":295,"title":"Aloo Methi","description":"Potatoes and fresh fenugreek leaves stir-fried with garlic and spices — a quick dry sabzi with a pleasantly bitter, fragrant edge.","ingredients":["3 medium potatoes, cubed","2 cups fresh fenugreek leaves, picked","3 garlic cloves, minced","½ tsp turmeric","½ tsp red chilli powder","1 tsp cumin seeds","2 tbsp oil","Salt to taste"],"instructions":["Heat oil. Add cumin seeds and garlic. Cook until garlic is golden.","Add potatoes and turmeric. Cook, stirring occasionally, 8 minutes.","Add fenugreek leaves and red chilli. Mix well.","Cover and cook on low heat 10 minutes until potatoes are tender.","Serve with roti."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-aloo-methi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aloo%20Methi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.312Z"},{"id":296,"title":"Bharwa Shimla Mirch","description":"Capsicums stuffed with a spiced potato and paneer filling, cooked until soft and caramelised — a beautiful and satisfying main dish.","ingredients":["4 medium capsicums","For stuffing: 3 potatoes, boiled and mashed","100g paneer, crumbled","1 tsp cumin powder","½ tsp garam masala","½ tsp red chilli powder","Fresh coriander","2 tbsp oil","Salt to taste"],"instructions":["Cut caps off capsicums. Scoop out seeds.","Mix mashed potato, paneer, all spices and coriander. Season.","Stuff capsicums tightly with the mixture. Replace caps.","Heat oil in a pan. Place capsicums standing upright. Cover.","Cook on low heat, turning gently, 25 minutes until capsicums are soft and charred in spots.","Serve with roti."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bharwa-shimla-mirch.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bharwa%20Shimla%20Mirch%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.316Z"},{"id":297,"title":"Corn Masala","description":"Sweet corn kernels in a spiced, tangy onion-tomato masala — a cheerful, quick curry for monsoon and winter evenings.","ingredients":["3 cups corn kernels, boiled","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","½ tsp garam masala","½ tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Heat oil. Add cumin seeds. Add onions and cook until golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add spices. Cook 2 minutes.","Add corn kernels and ¼ cup water. Simmer 10 minutes.","Garnish and serve with roti or rice."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-corn-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Corn%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.319Z"},{"id":298,"title":"Besan Gatte Ka Pulao","description":"Chickpea flour dumplings cooked in a fragrant rice pilaf — a Rajasthani one-pot dish that is both festive and everyday.","ingredients":["1 cup basmati rice","For gatte: ½ cup chickpea flour","½ tsp ajwain","1 tbsp oil","Salt","2 tbsp oil","1 tsp cumin seeds","1 bay leaf","2 cardamom","1 onion, sliced","1 tomato, chopped","½ tsp turmeric","1 tsp coriander powder","2 cups water"],"instructions":["Make gatte dough. Roll into cylinders. Boil 8 minutes. Slice.","Heat oil. Add cumin, bay leaf, cardamom. Add onion and cook until golden.","Add tomato and spices. Cook until soft.","Add rice and sauté 2 minutes. Add water and salt. Bring to boil.","Add gatte pieces. Cover and cook on low heat 15 minutes."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Vegan"],"category":"main","imageUrl":"/stock-images/recipe-besan-gatte-ka-pulao.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gatte%20Pulao%20Rajasthani%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.321Z"},{"id":299,"title":"Sindhi Kadhi","description":"A thick, tangy Sindhi curry made with chickpea flour and vegetables — no yogurt, all tamarind and a very particular flavour unlike any other kadhi.","ingredients":["3 tbsp chickpea flour","3 tbsp oil","2 cups mixed vegetables (potato, cluster beans, drumstick, lotus stem)","2 tbsp tamarind paste","½ tsp turmeric","1 tsp coriander powder","½ tsp red chilli powder","1 tsp cumin seeds","10 curry leaves","Salt to taste"],"instructions":["Heat oil. Add cumin seeds and curry leaves. Add chickpea flour and roast on medium heat for 8 minutes, stirring, until golden.","Add 4 cups water slowly, whisking to avoid lumps.","Add turmeric, coriander and red chilli. Simmer 10 minutes.","Add vegetables and tamarind paste. Cook until vegetables are tender.","Serve with rice."],"prepTime":15,"cookTime":35,"servings":4,"cuisineType":"West Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-sindhi-kadhi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sindhi%20Kadhi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.324Z"},{"id":300,"title":"Lotus Stem Curry","description":"Sliced lotus stem in a tangy, spiced Kashmiri-style gravy — a uniquely textured vegetable with a beautiful, lacy cross-section.","ingredients":["300g lotus stem, sliced into rounds","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp fennel powder","½ tsp turmeric","1 tsp coriander powder","½ tsp garam masala","½ tsp red chilli powder","2 tbsp mustard oil","Salt to taste"],"instructions":["Boil lotus stem slices for 10 minutes. Drain.","Heat mustard oil to smoking. Cool slightly. Add onions and cook until golden.","Add ginger-garlic paste and tomato purée. Cook until oil separates.","Add all spices. Add lotus stem and ½ cup water.","Cover and cook 20 minutes until completely tender."],"prepTime":15,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-lotus-stem-curry.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lotus%20Stem%20Curry%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.326Z"},{"id":301,"title":"Turai Ki Sabzi","description":"Ridge gourd cooked with onions and minimal spices — a light, cooling vegetable dish perfect for summer.","ingredients":["4 ridge gourds (turai), peeled and sliced","1 onion, sliced","2 green chillies, slit","1 tsp cumin seeds","½ tsp turmeric","1 tsp coriander powder","2 tbsp oil","Salt to taste"],"instructions":["Heat oil. Add cumin seeds. Add onion and cook until soft.","Add green chillies, turmeric and turai. Mix.","Add coriander and salt. Stir. Cover and cook on low heat.","The turai will release water. Cook 15 minutes until completely soft.","Serve with roti."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-turai-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Turai%20Ki%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.329Z"},{"id":302,"title":"Beans Poriyal","description":"South Indian dry stir-fry of French beans with freshly grated coconut and a mustard-curry leaf tempering — everyday South Indian brilliance.","ingredients":["400g French beans, finely chopped","½ cup fresh coconut, grated","1 tbsp oil","1 tsp mustard seeds","1 tsp chana dal","10 curry leaves","2 dried red chillies","½ tsp turmeric","Salt to taste"],"instructions":["Boil beans in salted water until just tender. Drain.","Heat oil. Splutter mustard seeds. Add chana dal and fry golden. Add curry leaves and dried red chillies.","Add beans and turmeric. Toss well on medium heat 5 minutes.","Add grated coconut. Mix and cook 2 more minutes.","Serve as a side with rice and sambar."],"prepTime":10,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-beans-poriyal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Beans%20Poriyal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.333Z"},{"id":303,"title":"Kohlrabi Sabzi","description":"Knolkol (kohlrabi) cooked with simple North Indian spices — a mild, slightly sweet vegetable that is underrated and delicious.","ingredients":["4 medium kohlrabi (knolkol), peeled and cubed","1 onion, finely chopped","2 tomatoes, chopped","1 tsp cumin seeds","½ tsp turmeric","1 tsp coriander powder","½ tsp garam masala","2 tbsp oil","Salt to taste","Fresh coriander"],"instructions":["Heat oil. Add cumin seeds. Add onions and cook until soft.","Add tomatoes, turmeric and coriander powder. Cook until oil separates.","Add kohlrabi and salt. Stir to coat with the masala.","Add ¼ cup water. Cover and cook 20 minutes until tender.","Sprinkle garam masala and garnish with coriander."],"prepTime":10,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kohlrabi-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kohlrabi%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.335Z"},{"id":304,"title":"Kathal Masala","description":"Raw jackfruit cooked in a bold, spiced North Indian masala — meaty in texture, absorbs spices beautifully and confounds non-vegetarians.","ingredients":["400g raw jackfruit, cut into chunks","2 onions, finely chopped","3 tomatoes, pureed","1 tbsp ginger-garlic paste","1 tsp cumin seeds","1 tsp coriander powder","½ tsp turmeric","1 tsp garam masala","1 tsp red chilli powder","2 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Pressure-cook jackfruit with ½ tsp turmeric for 2 whistles.","Heat oil. Add cumin seeds. Add onions and cook until deep golden.","Add ginger-garlic paste and tomato puree. Cook until oil separates.","Add all spices and cooked jackfruit. Toss and cook 10 minutes.","Garnish and serve with roti."],"prepTime":15,"cookTime":35,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-kathal-masala.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kathal%20Masala%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.339Z"},{"id":305,"title":"Gawar Phali Ki Sabzi","description":"Cluster beans cooked with peanuts, sesame and coconut in the Rajasthani way — a flavourful, nutritious dry curry.","ingredients":["400g gawar phali (cluster beans), trimmed","¼ cup peanuts","2 tbsp sesame seeds","2 tbsp fresh coconut, grated","1 tsp cumin seeds","½ tsp turmeric","1 tsp coriander powder","½ tsp red chilli powder","2 tbsp oil","Salt to taste"],"instructions":["Boil cluster beans in salted water until tender. Drain.","Dry roast peanuts, sesame and coconut. Coarsely grind.","Heat oil. Add cumin seeds. Add beans and all spices.","Add the ground mixture. Toss well.","Cook on medium heat 8 minutes. Serve with bajra roti."],"prepTime":15,"cookTime":20,"servings":4,"cuisineType":"Rajasthani","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-gawar-phali-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gawar%20Phali%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.342Z"},{"id":306,"title":"Achari Aloo","description":"Potatoes cooked in a tangy pickling spice masala — the sharp, pungent flavours make this dry sabzi deeply addictive.","ingredients":["4 medium potatoes, cubed","1 tsp each mustard seeds, fennel seeds, fenugreek seeds, kalonji","3 dried red chillies","1 tsp red chilli powder","1 tsp amchur","2 tbsp mustard oil","Salt to taste"],"instructions":["Heat mustard oil to smoking. Cool slightly.","Coarsely grind all 4 seeds and dried red chillies.","Add to the oil. Add potatoes and turmeric.","Cook on medium heat, stirring, until potatoes are golden and cooked.","Add amchur and salt. Serve with roti."],"prepTime":10,"cookTime":20,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-achari-aloo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Achari%20Aloo%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.344Z"},{"id":307,"title":"Matar Ki Sabzi","description":"Simple green peas stir-fry with cumin, ginger and a touch of amchur — a winter staple that appears when fresh peas arrive at the market.","ingredients":["2 cups green peas, fresh or frozen","1 tsp ginger, grated","2 green chillies, chopped","1 tsp cumin seeds","½ tsp turmeric","½ tsp amchur","1 tbsp oil","Fresh coriander","Salt to taste"],"instructions":["Heat oil. Add cumin seeds. Add ginger and green chillies.","Add peas, turmeric and salt.","Cook on medium heat, tossing, for 8 minutes.","Add amchur and coriander. Serve with puri or roti."],"prepTime":5,"cookTime":12,"servings":3,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-matar-ki-sabzi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Matar%20Ki%20Sabzi%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.347Z"},{"id":308,"title":"Saag","description":"A seasonal mix of mustard leaves, spinach and bathua slow-cooked with ginger and cornmeal — Punjab's legendary winter green.","ingredients":["2 cups mustard leaves (sarson)","1 cup spinach","½ cup bathua (chenopodium) or more spinach","1 onion, chopped","3 garlic cloves","1 inch ginger","2 green chillies","2 tbsp cornmeal (maize flour)","2 tbsp ghee","Salt to taste"],"instructions":["Pressure-cook all greens with garlic, ginger and green chillies for 3 whistles.","Blend roughly (not smooth). Add cornmeal and cook 10 minutes, stirring.","Heat ghee in a separate pan. Cook onion until deep golden.","Pour the tadka over the saag. Mix.","Serve with makki ki roti and jaggery."],"prepTime":15,"cookTime":40,"servings":4,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-saag.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sarson%20Ka%20Saag%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.349Z"},{"id":309,"title":"Makhani Dal","description":"Yellow dal tarka with a luxurious touch of butter and cream — simpler than Dal Makhani and on the table in 30 minutes.","ingredients":["1 cup yellow toor dal","2 tomatoes, chopped","1 tbsp ginger-garlic paste","½ tsp turmeric","1 tsp red chilli powder","1 tsp coriander powder","2 tbsp butter","½ cup cream","1 tsp cumin seeds","Salt to taste","Fresh coriander"],"instructions":["Pressure-cook dal with tomatoes, turmeric and salt for 3 whistles. Mash.","Heat butter. Add cumin seeds and ginger-garlic paste. Cook 1 minute.","Add red chilli and coriander. Cook 1 minute.","Add to dal. Stir in cream. Simmer 5 minutes.","Garnish and serve."],"prepTime":5,"cookTime":25,"servings":4,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-makhani-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Makhani%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.352Z"},{"id":310,"title":"Bhandare Wali Dal","description":"The iconic yellow dal made in North Indian temple prasad style — simple spicing, lots of ghee, eaten with puri at religious gatherings.","ingredients":["1 cup chana dal","½ tsp turmeric","2 tbsp ghee","1 tsp cumin seeds","2 dried red chillies","A pinch of asafoetida","1 tsp coriander powder","½ tsp red chilli powder","Salt to taste"],"instructions":["Pressure-cook chana dal with turmeric and salt for 3 whistles until soft.","Heat ghee. Add cumin seeds, dried red chillies and asafoetida.","Add coriander and red chilli powder. Cook 30 seconds.","Add to cooked dal. Mix. Simmer 5 minutes.","Serve with puri and potato sabzi."],"prepTime":5,"cookTime":30,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"main","imageUrl":"/stock-images/recipe-bhandare-wali-dal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Temple%20Dal%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-17T10:52:55.355Z"},{"id":311,"title":"Carrot Semolina Upma","description":"Carrot Semolina Upma is a delicious and nutritious South Indian dish.","ingredients":["1 cup semolina (sooji)","1 medium carrot, finely chopped","1 onion, finely chopped","2-3 green chilies, slit","1 tsp mustard seeds","1 tsp urad dal (split black gram)","1/2 tsp cumin seeds","A few curry leaves","2 cups water","Salt to taste","2 tbsp oil","Fresh coriander leaves for garnishing (optional)"],"instructions":["In a pan, dry roast the semolina on low heat until lightly golden and set aside.","In the same pan, heat oil and add mustard seeds, urad dal, cumin seeds, and curry leaves, sautéing until they splutter.","Add chopped onion and green chilies, cooking until the onions are translucent, then add chopped carrots and sauté for a few minutes.","Add water and salt to the pan, bringing it to a boil, then gradually add the roasted semolina while stirring continuously to avoid lumps.","Cover and cook on low heat for 3-4 minutes, and once the semolina absorbs the water, fluff it with a fork and garnish with coriander before serving hot."],"prepTime":10,"cookTime":15,"servings":4,"cuisineType":"South Indian","dietaryTags":[],"category":"main","imageUrl":"/api/recipes/311/image","youtubeUrl":"https://www.youtube.com/results?search_query=carrot+semolina+upma+recipe+indian+vegetarian","authorId":"55882372","submittedBy":"55882372","submittedByName":"Haigreeva Kondury","submittedByImage":null,"isUserSubmitted":true,"challengeId":null,"createdAt":"2026-03-17T11:02:37.113Z"}]
6:34:27 PM [express] GET /api/recipes 200 in 29ms :: [{"id":89,"title":"Rasgulla","description":"Pillowy soft cottage cheese balls boiled in light sugar syrup — Bengal's most iconic and beloved mithai.","ingredients":["1 litre full-fat milk","2 tbsp lemon juice or vinegar","1½ cups sugar","4 cups water","1 tsp rose water","A pinch of saffron"],"instructions":["Boil milk and add lemon juice slowly while stirring until whey separates clearly from chenna.","Drain through muslin cloth, wash the chenna under cold water to remove sourness, and hang for 30 minutes.","Knead the chenna on a flat surface for 8–10 minutes until completely smooth and soft with no graininess.","Roll into smooth balls the size of large marbles — ensure no cracks on the surface.","Prepare sugar syrup in a wide pan: boil sugar and water together. Gently slide in chenna balls.","Cover and cook on medium heat for 18–20 minutes until the rasgullas puff up and look spongy.","Cool in syrup. Add rose water. Chill and serve."],"prepTime":45,"cookTime":25,"servings":20,"cuisineType":"Bengali","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-rasgulla.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rasgulla%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.381Z"},{"id":90,"title":"Rasmalai","description":"Flattened cottage cheese discs soaking in saffron and cardamom-scented thickened milk — the queen of Bengali sweets.","ingredients":["1 litre full-fat milk (for chenna)","2 tbsp lemon juice","1 litre full-fat milk (for ras)","½ cup sugar","½ tsp cardamom powder","A generous pinch of saffron","2 tbsp pistachios, sliced","2 tbsp almonds, slivered","1 tsp rose water"],"instructions":["Make chenna from 1 litre milk, knead smooth, and shape into small flat discs.","Boil discs in thin sugar syrup (1 cup sugar, 4 cups water) covered for 15 minutes until spongy. Remove and squeeze gently.","Thicken the other 1 litre milk on medium heat, stirring frequently, until reduced to half.","Add sugar, saffron, and cardamom. Stir until sugar dissolves. Add rose water.","Gently place the spongy discs into the thickened milk (ras).","Simmer 5 minutes. Cool completely then refrigerate for at least 2 hours.","Serve chilled, garnished with pistachios and almonds."],"prepTime":30,"cookTime":40,"servings":10,"cuisineType":"Bengali","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-rasmalai.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rasmalai%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.619Z"},{"id":91,"title":"Mishti Doi","description":"Caramelised jaggery-sweetened baked yogurt from Bengal — thick, creamy and uniquely fragrant with earthen flavour.","ingredients":["1 litre full-fat milk","4 tbsp jaggery or raw sugar","2 tbsp plain yogurt (as starter)","A pinch of cardamom powder"],"instructions":["Heat milk and reduce it to three-quarters of original volume, stirring often.","Dissolve jaggery in the warm milk — the milk will turn a caramel golden colour.","Cool to lukewarm (40°C). Add yogurt starter and cardamom. Mix gently.","Pour into small earthen pots or bowls. Cover with foil.","Set in a warm place for 6–8 hours or overnight until firmly set.","Refrigerate for 2 hours before serving. The texture should be creamy yet firm."],"prepTime":10,"cookTime":30,"servings":6,"cuisineType":"Bengali","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-mishti-doi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mishti%20Doi%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.622Z"},{"id":92,"title":"Chhena Poda","description":"Odisha's burnt cottage cheese dessert — caramelised, slightly smoky and fragrant with cardamom and camphor. Lord Jagannath's favourite.","ingredients":["500g fresh chenna (cottage cheese)","¾ cup sugar","2 tbsp semolina (rava)","½ tsp cardamom powder","A tiny pinch of camphor (edible)","2 tbsp cashews, chopped","1 tbsp ghee"],"instructions":["Preheat oven to 200°C. Grease a baking tin with ghee.","Mix chenna, sugar, semolina, cardamom, and camphor together until smooth.","Fold in chopped cashews. Pour into the greased tin.","Sprinkle a little sugar on top to help caramelisation.","Bake at 200°C for 50–60 minutes until the top is a deep golden-brown and a skewer comes out clean.","Cool completely. Invert on a plate. The bottom will be caramelised dark brown — this is correct.","Slice and serve. Keeps well for 2–3 days at room temperature."],"prepTime":15,"cookTime":60,"servings":8,"cuisineType":"East Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-chhena-poda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chhena%20Poda%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.627Z"},{"id":93,"title":"Sandesh","description":"Delicate melt-in-mouth cottage cheese sweet from Bengal — subtly flavoured with rose and saffron, shaped into petals.","ingredients":["500g fresh chenna","½ cup powdered sugar","½ tsp cardamom powder","A pinch of saffron in 1 tbsp warm milk","1 tsp rose water","Pistachios for garnish"],"instructions":["Knead fresh chenna on a flat surface for 5 minutes until smooth and free of lumps.","Add powdered sugar and knead again until it comes together into a dough.","Cook this mixture in a heavy pan on low heat for 5–7 minutes, stirring continuously until it leaves the sides.","Add saffron milk, cardamom, and rose water. Mix well.","Remove from heat. Cool slightly, then press into moulds or shape by hand.","Garnish with a sliver of pistachio pressed into the top.","Refrigerate 1 hour before serving."],"prepTime":20,"cookTime":10,"servings":15,"cuisineType":"Bengali","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-sandesh.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sandesh%20Bengali%20sweet%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.631Z"},{"id":94,"title":"Chum Chum","description":"Elongated cottage cheese sweet from Bengal, soaked in sugar syrup and rolled in khoya or coconut — festive and celebratory.","ingredients":["1 litre milk (for chenna)","2 tbsp lemon juice","1½ cups sugar","4 cups water","½ cup khoya or dessicated coconut","1 tsp rose water","A few drops of food colour (optional)"],"instructions":["Prepare chenna, knead smooth, and shape into elongated oval fingers.","Cook in thin sugar syrup (covered) for 15 minutes. Allow to sponge up syrup as they cool.","For white chum chum: roll in mawa or dessicated coconut.","For coloured: lightly colour the outer coating.","Slit gently and stuff with sweetened khoya mixed with cardamom.","Arrange on a plate and chill before serving."],"prepTime":40,"cookTime":20,"servings":12,"cuisineType":"Bengali","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-chum-chum.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chum%20Chum%20Bengali%20sweet%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.633Z"},{"id":95,"title":"Pantua","description":"Bengal's dark fried milk dumplings — cousin to gulab jamun but made with chenna, soaked in saffron syrup.","ingredients":["500g chenna (fresh cottage cheese)","3 tbsp all-purpose flour","A pinch of baking powder","Oil or ghee for frying","1½ cups sugar","2 cups water","½ tsp cardamom powder","A few saffron strands"],"instructions":["Mix chenna, flour, and baking powder. Knead into a smooth soft dough.","Prepare thin sugar syrup by boiling sugar, water, cardamom, and saffron together.","Divide dough into small smooth balls ensuring no cracks.","Deep fry on low-medium heat until deep mahogany brown, rolling continuously — about 8 minutes.","Drain and immediately immerse in warm sugar syrup.","Soak for at least 2 hours. They will absorb syrup and become soft and spongy.","Serve warm or at room temperature."],"prepTime":20,"cookTime":30,"servings":15,"cuisineType":"Bengali","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-pantua.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pantua%20Bengali%20sweet%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.637Z"},{"id":96,"title":"Boondi Ladoo","description":"Golden gram flour droplets soaked in cardamom sugar syrup and rolled into round ladoos — the most celebrated Indian festival sweet.","ingredients":["2 cups besan (chickpea flour)","Water to make batter","Oil for deep frying","2 cups sugar","1 cup water","1 tsp cardamom powder","10 cashews, halved","2 tbsp raisins","A pinch of saffron"],"instructions":["Make a smooth, flowing batter by mixing besan with water — it should flow through a perforated spoon easily.","Heat oil. Drop batter through a boondi jharni (perforated ladle) to make tiny spherical droplets. Fry until golden.","Make a one-string sugar syrup: boil sugar, water and saffron. Test by pulling a thread between fingers.","Remove from heat. Add fried boondi, cardamom, cashews and raisins. Mix quickly.","When cool enough to handle, wet hands with water and shape into firm round balls.","Work fast as the mixture hardens as it cools.","Allow to set for 30 minutes. Store in an airtight container."],"prepTime":20,"cookTime":30,"servings":20,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"dessert","imageUrl":"/stock-images/recipe-boondi-ladoo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Boondi%20Ladoo%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.640Z"},{"id":97,"title":"Besan Ladoo","description":"Rich, melt-in-mouth gram flour ladoos roasted slowly in ghee with cardamom — essential Diwali mithai from North India.","ingredients":["2 cups besan (chickpea flour)","¾ cup ghee","1 cup powdered sugar","1 tsp cardamom powder","10 cashews, chopped","2 tbsp raisins"],"instructions":["Heat ghee in a heavy pan on low flame. Add besan.","Roast on low heat, stirring continuously for 20–25 minutes until besan turns golden and the raw smell disappears completely.","The mixture will become liquid initially and then thicken as moisture evaporates.","Remove from heat and cool for 10 minutes — it should be warm but handleable.","Add powdered sugar, cardamom, cashews and raisins. Mix thoroughly.","Shape into round balls while still warm. If too crumbly, add a few drops of warm ghee.","Cool completely before storing."],"prepTime":10,"cookTime":30,"servings":20,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-besan-ladoo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Besan%20Ladoo%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.644Z"},{"id":98,"title":"Motichoor Ladoo","description":"Fine-grain boondi cooked into perfectly spherical, saffron-gold ladoos — softer and more delicate than regular boondi ladoo.","ingredients":["2 cups besan","Water for thin batter","Oil for frying","2 cups sugar","1 cup water","1 tsp cardamom powder","Saffron strands","A few drops of orange food colour","Rose water"],"instructions":["Make a very thin, pourable batter with besan — thinner than regular boondi batter.","Use a fine-holed jharni or a spoon to drizzle batter into hot oil — boondi should be tiny pearl-like spheres.","Fry until just lightly golden (not dark). Drain.","Prepare sugar syrup to one-string consistency. Add colour, saffron, and rose water.","Add boondi to syrup while syrup is hot. Mash slightly with the back of a spoon.","Cool to handling temperature. Shape into round balls by pressing firmly.","Decorate with a pistachio or silver vark."],"prepTime":25,"cookTime":30,"servings":20,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"dessert","imageUrl":"/stock-images/recipe-motichoor-ladoo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Motichoor%20Ladoo%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.648Z"},{"id":99,"title":"Coconut Ladoo","description":"Quick five-ingredient coconut sweet — fresh coconut cooked with condensed milk and cardamom, shaped in minutes.","ingredients":["2 cups fresh grated coconut (or dessicated)","½ cup sweetened condensed milk","½ tsp cardamom powder","2 tbsp ghee","Dessicated coconut for rolling"],"instructions":["Heat ghee in a pan. Add grated coconut and stir for 2 minutes.","Add condensed milk and cardamom. Cook on medium-low heat, stirring continuously.","Cook until the mixture thickens and leaves the sides of the pan, about 8 minutes.","Remove from heat. Cool until handleable.","Grease hands with ghee and roll into smooth balls.","Roll each ball in dessicated coconut. Decorate with a pistachio.","Refrigerate 30 minutes to firm up."],"prepTime":10,"cookTime":12,"servings":15,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-coconut-ladoo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Coconut%20Ladoo%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.652Z"},{"id":100,"title":"Rava Ladoo","description":"Roasted semolina ladoos with cashews and raisins — quick, nutty and fragrant with ghee and cardamom.","ingredients":["2 cups fine semolina (rava)","¾ cup sugar, powdered","½ cup ghee","½ tsp cardamom powder","10 cashews, chopped","2 tbsp raisins","2 tbsp grated coconut (optional)"],"instructions":["Dry roast semolina in a pan on low heat for 10 minutes until lightly golden and fragrant.","Heat ghee and add cashews and raisins. Fry briefly until golden.","Mix roasted rava with powdered sugar, cardamom, cashews, raisins, and coconut.","Add warm ghee to the rava mixture. Mix thoroughly.","While still warm, press firmly into round balls. If crumbly, add a few drops of warm milk.","Shape quickly — the mixture hardens as it cools.","Store in an airtight container at room temperature for up to 1 week."],"prepTime":10,"cookTime":15,"servings":18,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-rava-ladoo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rava%20Ladoo%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.655Z"},{"id":101,"title":"Til Ladoo","description":"Sesame and jaggery ladoos eaten on Makar Sankranti — crunchy, nutty and packed with iron and warmth.","ingredients":["2 cups white sesame seeds","1 cup jaggery, grated","2 tbsp peanuts, roasted","1 tsp ghee","½ tsp cardamom powder","A pinch of dry ginger powder"],"instructions":["Dry roast sesame seeds on low heat until they splutter and turn lightly golden. Cool.","Roast peanuts and crush coarsely.","Melt jaggery in 2 tbsp water on medium heat until it reaches soft ball stage — a drop in cold water should form a soft ball.","Remove from heat. Quickly add sesame seeds, peanuts, cardamom, and dry ginger.","Mix well. With greased hands, quickly shape into small balls.","Work fast as the mixture hardens quickly as it cools.","Store in an airtight tin. Keeps for 2 weeks."],"prepTime":10,"cookTime":15,"servings":20,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-til-ladoo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Til%20Ladoo%20Sesame%20Jaggery%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.658Z"},{"id":102,"title":"Peanut Ladoo","description":"Roasted peanuts and jaggery pressed into satisfying ladoos — a protein-rich, natural, minimally sweetened energy ball.","ingredients":["2 cups roasted peanuts, skinned","¾ cup jaggery, grated","½ tsp cardamom powder","1 tsp ghee"],"instructions":["Grind half the roasted peanuts into a coarse powder. Keep the rest whole or halved.","Melt jaggery in 2 tbsp water to soft ball stage.","Remove from heat. Add peanut powder, whole peanuts, cardamom, and ghee.","Mix quickly and shape into balls while warm.","These ladoos are firm at room temperature — no refrigeration needed.","Store in an airtight jar for up to 2 weeks."],"prepTime":10,"cookTime":10,"servings":15,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-peanut-ladoo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Peanut%20Ladoo%20Jaggery%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.661Z"},{"id":103,"title":"Kaju Katli","description":"Thin diamond-shaped cashew sweet with a smooth, melt-in-mouth texture — India's most gifted and prized mithai.","ingredients":["2 cups cashew nuts","½ cup sugar","¼ cup water","A pinch of cardamom","1 tsp ghee","Silver vark (edible silver leaf) for decoration"],"instructions":["Grind raw cashews to a fine powder in a dry grinder. Do not over-grind or it will release oil.","Boil sugar and water to one-string consistency.","Add cashew powder on very low heat, stirring constantly.","Cook until the mixture leaves the sides and forms a soft dough — about 5 minutes.","Remove from heat. Add cardamom and ghee. Knead gently while warm.","Roll between two parchment sheets to 4mm thickness. Apply silver vark.","Cool 20 minutes and cut into diamond shapes with a sharp knife."],"prepTime":15,"cookTime":15,"servings":30,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-kaju-katli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kaju%20Katli%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.663Z"},{"id":104,"title":"Milk Barfi","description":"Simple yet luxurious condensed milk and khoya barfi — creamy, fragrant and cuts into clean perfect squares.","ingredients":["1 cup khoya (mawa), grated","½ cup sweetened condensed milk","½ cup milk powder","½ tsp cardamom powder","1 tbsp ghee","Pistachios for garnish"],"instructions":["Heat ghee in a heavy pan. Add khoya and stir on low heat until it melts.","Add condensed milk and milk powder. Stir continuously on low heat.","Cook for 10–12 minutes until the mixture thickens and leaves the sides of the pan.","Add cardamom. Mix well.","Pour into a greased plate. Spread evenly. Press pistachios on top.","Cool completely for 1 hour before cutting into squares or diamonds."],"prepTime":5,"cookTime":15,"servings":20,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-milk-barfi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Milk%20Barfi%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.667Z"},{"id":105,"title":"Coconut Barfi","description":"Two-tone coconut sweet — a layer of golden jaggery coconut and white sugar coconut fused together into a beautiful barfi.","ingredients":["3 cups fresh grated coconut","1 cup sugar","½ cup jaggery","½ tsp cardamom powder","1 tbsp ghee","A pinch of saffron"],"instructions":["Divide coconut in half.","Make white layer: cook one half with sugar in a pan, stirring until dry. Add cardamom.","Make golden layer: cook other half with jaggery and ghee until dry. Add saffron.","Grease a plate. Spread white layer. Press golden layer on top.","Cover with another plate and press firmly to fuse layers together.","Cool for 2 hours. Cut into squares — the two-tone layers will be visible."],"prepTime":15,"cookTime":20,"servings":20,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-coconut-barfi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Coconut%20Barfi%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.670Z"},{"id":106,"title":"Pista Barfi","description":"Elegant vivid green pistachio fudge — subtly fragrant with rose water and cardamom, decorated with silver leaf.","ingredients":["2 cups pistachios, soaked and peeled","½ cup sugar","¼ cup water","½ tsp cardamom powder","1 tsp rose water","1 tbsp ghee","Silver vark for garnish"],"instructions":["Soak pistachios in warm water for 1 hour. Peel the skins.","Grind peeled pistachios to a fine powder. The natural green colour should show.","Cook sugar and water to one-string consistency.","Add pistachio powder and cook on very low heat, stirring until dough forms.","Add rose water, cardamom, and ghee. Knead gently.","Roll to 5mm thickness on parchment. Apply silver vark.","Cool and cut into diamond or square shapes."],"prepTime":70,"cookTime":15,"servings":25,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-pista-barfi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pista%20Barfi%20Pistachio%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.673Z"},{"id":107,"title":"Besan Barfi","description":"Chickpea flour barfi slow-roasted in ghee — deeply nutty, crumbly and richly flavoured with cardamom.","ingredients":["2 cups besan","¾ cup ghee","1 cup sugar","¼ cup water","1 tsp cardamom powder","10 cashews for garnish"],"instructions":["Roast besan in ghee on low heat for 25 minutes, stirring constantly, until deep golden and fragrant.","Separately make sugar syrup to one-string consistency.","Remove besan from heat. Pour syrup over it. Add cardamom. Mix quickly.","Pour into greased plate. Spread evenly. Decorate with cashews.","Cool 2 hours before cutting into squares.","Store in an airtight container up to 1 week."],"prepTime":5,"cookTime":35,"servings":20,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-besan-barfi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Besan%20Barfi%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.676Z"},{"id":108,"title":"Moong Dal Halwa","description":"Rajasthani slow-cooked yellow lentil halwa — deeply nutty, ghee-soaked and saffron-fragrant. A labour of love worth every minute.","ingredients":["1 cup yellow moong dal, soaked 3 hours","½ cup ghee","1 cup sugar","2 cups water","½ tsp cardamom powder","A generous pinch of saffron","2 tbsp almonds and cashews","1 tbsp raisins"],"instructions":["Drain soaked moong dal and grind to a coarse paste without adding water.","Heat ghee in a heavy pan. Add dal paste and cook on low-medium heat, stirring continuously.","Keep cooking and stirring for 40–45 minutes — the mixture will first turn yellow, then golden brown.","Meanwhile, make sugar syrup by boiling sugar and water together with saffron.","When dal is golden and aromatic, carefully pour in the hot sugar syrup. It will splutter — stir quickly.","Cook until all liquid is absorbed and ghee starts to separate. Add cardamom.","Garnish with fried nuts and raisins. Serve hot."],"prepTime":180,"cookTime":50,"servings":8,"cuisineType":"Rajasthani","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-moong-dal-halwa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Moong%20Dal%20Halwa%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.679Z"},{"id":109,"title":"Badam Halwa","description":"Sumptuous almond pudding in saffron-kissed ghee — South India's most treasured festive sweet, dense and utterly luxurious.","ingredients":["1 cup almonds, soaked and peeled","¾ cup sugar","¼ cup water","3 tbsp ghee","½ tsp cardamom powder","A generous pinch of saffron in 2 tbsp warm milk","A few drops of yellow food colour (optional)"],"instructions":["Soak almonds overnight. Peel the skins. Grind to a smooth paste with 2 tbsp water.","Heat ghee in a heavy pan. Add almond paste and cook on medium heat, stirring.","Make sugar syrup with sugar and water. Add saffron milk.","Pour syrup into the almond mixture. Stir continuously on medium heat.","Cook until halwa thickens, turns golden, and ghee separates from the sides — about 20 minutes.","Add cardamom. The halwa should hold its shape when a spoonful is dropped on a plate.","Serve warm garnished with slivered almonds and pistachios."],"prepTime":480,"cookTime":25,"servings":6,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-badam-halwa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Badam%20Halwa%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.681Z"},{"id":110,"title":"Bread Halwa","description":"Quick and indulgent bread pudding halwa — torn bread pieces fried in ghee and cooked with condensed milk and saffron.","ingredients":["6 thick bread slices, crusts removed","3 tbsp ghee","½ cup sugar","1 cup milk","½ cup condensed milk","½ tsp cardamom powder","Saffron strands","2 tbsp cashews and raisins"],"instructions":["Tear bread into small pieces. Fry in ghee in a heavy pan until golden on all sides.","In the same pan, add milk, condensed milk, and sugar. Stir to mix.","Add saffron and cook on medium heat, mashing the bread gently.","Fry cashews and raisins in a separate spoon of ghee. Add to halwa.","Cook until the mixture comes together and becomes thick, about 10 minutes.","Add cardamom. The halwa should look glossy.","Serve warm."],"prepTime":10,"cookTime":20,"servings":6,"cuisineType":"North Indian","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-bread-halwa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bread%20Halwa%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.684Z"},{"id":111,"title":"Lauki Ka Halwa","description":"Bottle gourd cooked slow in milk until creamy and sweet — a surprisingly delicious halwa light enough for everyday enjoyment.","ingredients":["500g bottle gourd (lauki), peeled and grated","½ litre full-fat milk","½ cup sugar","3 tbsp ghee","½ tsp cardamom powder","2 tbsp khoya (optional)","Cashews for garnish"],"instructions":["Squeeze out excess water from grated lauki.","Cook lauki in milk on medium heat, stirring often, until milk is absorbed and lauki is tender — 25 minutes.","Add sugar and ghee. Stir continuously on medium heat.","Cook until the halwa leaves the sides and comes together — 15 more minutes.","Add khoya if using, and cardamom. Mix well.","Fry cashews in a little ghee and add on top.","Serve hot or warm."],"prepTime":20,"cookTime":45,"servings":6,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-lauki-ka-halwa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lauki%20Ka%20Halwa%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.687Z"},{"id":112,"title":"Banana Halwa","description":"Kerala-style ripe banana halwa — caramelised in ghee until deep, jammy and glossy with the sweetness of ripe nendran bananas.","ingredients":["6 ripe nendran bananas (or ripe plantains)","1 cup sugar","4 tbsp ghee","½ tsp cardamom powder","A pinch of salt","Cashews and raisins for garnish"],"instructions":["Peel and mash bananas to a smooth pulp.","Cook banana pulp in a heavy pan on medium heat, stirring until it reduces — 10 minutes.","Add sugar and ghee. Stir continuously on medium-high heat.","The halwa will turn darker and caramelise as water evaporates — about 25–30 minutes.","Keep stirring to prevent burning. The halwa is done when it is very thick, shiny, and leaves the pan sides.","Add cardamom and salt. Fry cashews and raisins in ghee and add.","Spread in a greased dish. Cool and cut into pieces, or serve warm."],"prepTime":10,"cookTime":40,"servings":8,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-banana-halwa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Banana%20Halwa%20Kerala%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.690Z"},{"id":113,"title":"Mysore Pak","description":"Karnataka's legendary melt-in-mouth besan sweet — ghee-soaked, fragrant and porous, consumed in just one blissful bite.","ingredients":["1 cup besan (chickpea flour)","1 cup sugar","¾ cup water","1 cup ghee (plus more as needed)","½ tsp cardamom powder"],"instructions":["Sieve besan. Slowly add 6 tbsp warm ghee and mix to a smooth paste.","Cook sugar and water to one-string syrup. Keep the syrup hot.","Add besan paste to the hot syrup on medium heat, stirring briskly.","Continue stirring while adding the remaining ghee in small batches, a few tablespoons at a time.","The mixture will bubble and foam — keep stirring. When it no longer sticks to the pan and appears honeycombed, it's ready.","Quickly pour into a greased plate — it sets within minutes.","Cut into squares while still slightly warm using a sharp knife. Cool before removing."],"prepTime":10,"cookTime":20,"servings":20,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/api/recipes/113/image","youtubeUrl":"https://www.youtube.com/results?search_query=Mysore%20Pak%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.693Z"},{"id":114,"title":"Jalebi","description":"Crispy, pretzel-shaped deep-fried spirals soaked in cardamom and saffron sugar syrup — India's most festive street sweet.","ingredients":["1 cup all-purpose flour","2 tbsp cornflour","¼ tsp baking powder","½ cup yogurt","Water to make batter","Oil for frying","1½ cups sugar","¾ cup water","½ tsp cardamom powder","Saffron strands","A few drops of orange food colour"],"instructions":["Mix flour, cornflour, baking powder, yogurt, and water to a smooth, flowing batter. Rest 30 minutes (or ferment overnight).","Make sugar syrup: boil sugar, water, saffron, and cardamom to one-string consistency. Keep warm.","Heat oil in a flat pan to 170°C. Add colour to batter.","Pour batter into a squeeze bottle or piping bag. Pipe spirals into the hot oil.","Fry 2 minutes per side until crisp and golden.","Drain briefly and immediately immerse in warm sugar syrup for 1 minute.","Serve immediately while warm and crispy."],"prepTime":40,"cookTime":30,"servings":15,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"dessert","imageUrl":"/stock-images/recipe-jalebi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Jalebi%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.695Z"},{"id":115,"title":"Malpua","description":"Pan-fried sweet pancakes soaked in saffron syrup and served with thickened rabri — a festive Holi delicacy.","ingredients":["1 cup all-purpose flour","2 tbsp semolina","½ cup khoya, crumbled","1 tsp fennel seeds","Milk to make batter","Ghee or oil for shallow frying","1½ cups sugar","¾ cup water","Saffron and cardamom for syrup"],"instructions":["Mix flour, semolina, khoya, and fennel seeds. Add enough milk to make a thick, pourable pancake batter.","Rest the batter for 30 minutes.","Prepare sugar syrup with saffron and cardamom.","Heat ghee in a flat pan. Pour ladlefuls of batter to make small thick pancakes.","Fry on medium heat until golden on both sides — about 3 minutes per side.","Drain and immediately dip in sugar syrup for 1 minute.","Serve with chilled rabri and a sprinkle of pistachios."],"prepTime":40,"cookTime":20,"servings":10,"cuisineType":"North Indian","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-malpua.png","youtubeUrl":"https://www.youtube.com/results?search_query=Malpua%20sweet%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.698Z"},{"id":116,"title":"Shahi Tukda","description":"Mughal royal bread pudding — fried bread triangles soaked in sugar syrup, covered in saffron rabri and topped with silver leaf.","ingredients":["6 bread slices, cut into triangles","Ghee for frying","1 litre full-fat milk (for rabri)","½ cup sugar","Saffron and cardamom","1 cup thin sugar syrup","Silver vark and pistachios for garnish"],"instructions":["Fry bread triangles in ghee until deep golden. Drain on paper.","Make rabri: reduce 1 litre milk on medium heat with sugar and saffron, stirring every few minutes, until it thickens to half — about 30 minutes.","Dip each fried bread piece in thin sugar syrup for 1 minute.","Arrange in a serving dish. Pour thick rabri over.","Refrigerate 1 hour.","Serve chilled topped with pistachios, almonds, and silver vark."],"prepTime":15,"cookTime":45,"servings":6,"cuisineType":"North Indian","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-shahi-tukda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shahi%20Tukda%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.701Z"},{"id":117,"title":"Kalakand","description":"Grainy, crumbly Indian milk cake made from reduced milk and paneer — subtly sweet with a distinctive chewy texture.","ingredients":["1 litre full-fat milk","1 cup paneer, crumbled","½ cup sugar","½ tsp cardamom powder","A pinch of saffron","Pistachios for garnish"],"instructions":["Boil milk in a heavy pan. Add crumbled paneer — the mixture will separate and granulate.","Cook on medium-high heat, stirring continuously until very thick and the moisture evaporates — 25 minutes.","Add sugar and stir for 10 more minutes until the mixture leaves the pan sides.","Add saffron and cardamom.","Pour into a greased plate. Press down to compact.","Decorate with pistachios.","Cool completely (1–2 hours). Cut into squares."],"prepTime":10,"cookTime":40,"servings":12,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-kalakand.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kalakand%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.704Z"},{"id":118,"title":"Peda","description":"Soft, melt-in-mouth milk fudge flavoured with cardamom and saffron — simple yet exquisite, offered to deities across India.","ingredients":["1 cup khoya (mawa)","¼ cup powdered sugar","½ tsp cardamom powder","A pinch of saffron in 1 tsp warm milk","Pistachios for pressing into top"],"instructions":["Crumble khoya in a heavy pan. Cook on low heat, stirring until it melts and begins to change colour slightly — 5 minutes.","Remove from heat. Cool slightly.","Mix in powdered sugar, cardamom, and saffron milk. Mix well.","The mixture should be pliable like soft dough.","Divide into portions. Roll into balls and flatten slightly to a disc shape.","Press a pistachio into the centre of each peda.","Refrigerate 30 minutes to firm up. Serve at room temperature."],"prepTime":10,"cookTime":10,"servings":15,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-peda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Peda%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.708Z"},{"id":119,"title":"Kesar Peda","description":"Saffron-golden milk fudge from Mathura — fragrant, soft and deeply orange-yellow from generous kesar.","ingredients":["1 cup khoya","¼ cup sweetened condensed milk","¼ cup powdered sugar","½ tsp cardamom powder","1 tsp saffron soaked in 2 tbsp warm milk","Pistachios for garnish"],"instructions":["Cook khoya and condensed milk together in a heavy pan on low heat for 8 minutes, stirring.","Add powdered sugar and kesar milk. Stir for 5 more minutes.","The mixture will turn vivid golden-yellow from the saffron.","Remove from heat and cool until handleable.","Shape into small round discs. Press a pistachio sliver on top.","Refrigerate before serving."],"prepTime":5,"cookTime":15,"servings":12,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-kesar-peda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kesar%20Peda%20Mathura%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.711Z"},{"id":120,"title":"Shrikhand","description":"Maharashtra's luxurious strained yogurt dessert — thick, silky and fragrant with cardamom, saffron and pistachios.","ingredients":["1 kg full-fat yogurt, hung overnight","¾ cup powdered sugar","½ tsp cardamom powder","A generous pinch of saffron in 2 tbsp warm milk","2 tbsp pistachios, slivered","2 tbsp almonds, slivered","1 tsp rose water"],"instructions":["Hang yogurt in muslin cloth overnight (8 hours) in the refrigerator — liquid whey drains away leaving thick chakka.","Whisk the hung yogurt (chakka) until smooth and creamy.","Add powdered sugar and whisk until dissolved.","Add saffron milk, cardamom, and rose water. Mix.","Fold in most of the pistachios and almonds.","Refrigerate 2 hours.","Serve chilled in small bowls garnished with remaining nuts."],"prepTime":480,"cookTime":0,"servings":6,"cuisineType":"Maharashtrian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-shrikhand.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shrikhand%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.714Z"},{"id":121,"title":"Amrakhand","description":"Mango shrikhand — Maharashtra's summer celebration in a bowl: hung yogurt whipped with Alphonso mango pulp and saffron.","ingredients":["500g yogurt, hung overnight","¾ cup Alphonso mango pulp (or fresh mango)","½ cup powdered sugar","½ tsp cardamom powder","A pinch of saffron","Mango slices and pistachios for garnish"],"instructions":["Whisk hung yogurt until smooth.","Add mango pulp, powdered sugar, cardamom, and saffron. Whisk together.","Taste and adjust sweetness — ripe Alphonso mangoes add natural sweetness.","Refrigerate at least 2 hours.","Serve in small bowls with fresh mango slices and pistachios."],"prepTime":480,"cookTime":0,"servings":6,"cuisineType":"Maharashtrian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-amrakhand.png","youtubeUrl":"https://www.youtube.com/results?search_query=Amrakhand%20Mango%20Shrikhand%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.717Z"},{"id":122,"title":"Rabri","description":"Slow-reduced thickened sweetened milk with layers of cream — eaten with jalebi, ladoos, or on its own as a chilled dessert.","ingredients":["1 litre full-fat milk","½ cup sugar","½ tsp cardamom powder","A generous pinch of saffron","1 tsp rose water","2 tbsp pistachios and almonds, slivered"],"instructions":["Pour milk into a wide, heavy kadhai. Bring to a boil.","Lower to medium heat. As cream forms on the surface, fold it to the sides of the pan (do not stir it back in).","Keep collecting the cream layers on the sides as the milk reduces.","Cook for 40–50 minutes until milk reduces to one-third.","Add sugar, saffron, and cardamom. Stir gently.","Scrape all the cream layers back into the milk.","Add rose water. Cool. Refrigerate. Serve chilled with garnish."],"prepTime":5,"cookTime":55,"servings":6,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-rabri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rabri%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.720Z"},{"id":123,"title":"Phirni","description":"Creamy ground rice and milk pudding set in earthen bowls — subtly scented with rose and decorated with pistachios.","ingredients":["3 tbsp basmati rice, soaked and ground to paste","1 litre full-fat milk","½ cup sugar","½ tsp cardamom powder","1 tsp rose water","A pinch of saffron","Pistachios and almonds for garnish"],"instructions":["Soak basmati rice for 30 minutes. Drain and grind with 2 tbsp milk to a smooth paste.","Boil milk in a heavy pan. Add rice paste in a thin stream while stirring to prevent lumps.","Cook on medium heat, stirring continuously, until it thickens noticeably — about 20 minutes.","Add sugar, saffron, and cardamom. Cook 5 more minutes.","Remove from heat. Add rose water.","Pour into small earthen bowls (kulhads) or bowls. Refrigerate 3 hours until set.","Serve chilled, decorated with pistachios."],"prepTime":40,"cookTime":30,"servings":6,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-phirni.png","youtubeUrl":"https://www.youtube.com/results?search_query=Phirni%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.723Z"},{"id":124,"title":"Malai Kulfi","description":"Classic Indian frozen dessert — thickened condensed milk, cardamom and saffron frozen in conical moulds for that distinctive dense creamy texture.","ingredients":["1 litre full-fat milk","½ cup condensed milk","½ cup sugar","½ tsp cardamom powder","A generous pinch of saffron","2 tbsp pistachios, slivered","1 tsp rose water","2 tbsp cornflour dissolved in 3 tbsp milk"],"instructions":["Boil milk in a heavy pan. Add cornflour mixture — stir quickly to prevent lumps.","Add condensed milk, sugar, and saffron. Cook on medium heat, stirring, until reduced by half — 25 minutes.","Cool to room temperature. Add cardamom, rose water and most of the pistachios.","Pour into kulfi moulds or popsicle moulds. Insert sticks.","Freeze overnight or for at least 8 hours.","To serve, run the mould briefly under warm water and unmould.","Garnish with slivered pistachios and serve immediately."],"prepTime":10,"cookTime":30,"servings":8,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-malai-kulfi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Malai%20Kulfi%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.726Z"},{"id":125,"title":"Mango Kulfi","description":"Summer's greatest pleasure — Alphonso mango puree blended with thickened condensed milk and frozen to creamy perfection.","ingredients":["1 cup Alphonso mango pulp","½ cup condensed milk","¾ cup heavy cream","¼ cup sugar (adjust)","½ tsp cardamom powder","1 tsp lime juice"],"instructions":["Whisk together mango pulp, condensed milk, cream, and sugar until smooth.","Taste and adjust sweetness — ripe mangoes reduce sugar needed.","Add cardamom and lime juice.","Pour into kulfi moulds or popsicle moulds. Freeze overnight.","Unmould by briefly running under warm water.","Serve immediately with a slice of fresh mango."],"prepTime":10,"cookTime":5,"servings":6,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-mango-kulfi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mango%20Kulfi%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.728Z"},{"id":126,"title":"Pista Kulfi","description":"Vivid green pistachio frozen dessert — intensely nutty and fragrant, the kulfi of choice at north Indian weddings.","ingredients":["1 litre full-fat milk","½ cup condensed milk","¾ cup pistachios, soaked and peeled","½ cup sugar","½ tsp cardamom powder","Green food colour (optional)"],"instructions":["Peel soaked pistachios. Grind half into a paste, chop the rest.","Reduce milk on medium heat with condensed milk for 20 minutes, stirring often.","Add pistachio paste, sugar, and cardamom. Stir well.","Cool completely. Fold in chopped pistachios.","Pour into kulfi moulds and freeze overnight.","Unmould and serve immediately."],"prepTime":70,"cookTime":25,"servings":8,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-pista-kulfi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pista%20Kulfi%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.731Z"},{"id":127,"title":"Ghevar","description":"Rajasthan's Teej festival disc sweet — a crispy honeycomb lattice soaked in saffron syrup and layered with rabri.","ingredients":["2 cups all-purpose flour","3 tbsp ghee","Ice cold water","Oil or ghee for deep frying","2 cups sugar","1 cup water","Saffron and cardamom","Rabri and pistachios for topping"],"instructions":["Mix flour, ghee, and enough ice cold water to form a thin, watery batter.","Heat ghee in a cylindrical pan (a deep saucepan works). Drop batter in a thin stream into the centre.","The batter will spread and create a lacy disc. Keep adding batter in stages.","Fry until golden and crispy, rotating carefully.","Prepare saffron sugar syrup. Soak ghevar in syrup briefly.","Layer with chilled rabri. Garnish with pistachios and silver vark.","Serve at room temperature."],"prepTime":20,"cookTime":30,"servings":4,"cuisineType":"Rajasthani","dietaryTags":[],"category":"dessert","imageUrl":"/api/recipes/127/image","youtubeUrl":"https://www.youtube.com/results?search_query=Ghevar%20Rajasthani%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.733Z"},{"id":128,"title":"Churma Ladoo","description":"Rajasthani coarse wheat ladoos made from baati (baked wheat balls) crushed with ghee and jaggery — rustic and deeply satisfying.","ingredients":["2 cups whole wheat flour","½ cup ghee","¼ cup milk","Oil for deep frying","½ cup jaggery, grated","½ tsp cardamom powder","2 tbsp almonds and cashews"],"instructions":["Mix flour, ghee, and milk to a stiff dough. Divide into balls.","Deep fry the balls on low heat until cooked through and golden — 15 minutes.","Cool and crush coarsely in a mortar or food processor.","Heat jaggery with 1 tbsp water until it melts.","Mix crushed wheat with jaggery, remaining ghee, cardamom, and nuts.","Shape into round ladoos while warm.","Serve warm or at room temperature."],"prepTime":20,"cookTime":25,"servings":15,"cuisineType":"Rajasthani","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-churma-ladoo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Churma%20Ladoo%20Rajasthani%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.736Z"},{"id":129,"title":"Gujiya","description":"Holi's crowning delight — crescent-shaped deep-fried pastries filled with spiced khoya, coconut and dried fruit.","ingredients":["2 cups all-purpose flour","4 tbsp ghee","Water to knead","1 cup khoya (mawa)","¼ cup grated coconut","¼ cup powdered sugar","2 tbsp raisins","2 tbsp cashews","½ tsp cardamom powder","Oil for frying","Sugar syrup for coating"],"instructions":["Rub ghee into flour until crumbly. Add water gradually to form a stiff dough. Rest 30 minutes.","For filling: crumble and roast khoya in a pan for 5 minutes. Cool. Mix with coconut, sugar, raisins, cashews, and cardamom.","Roll dough thin. Cut into circles using a cutter.","Place filling on one half. Fold and crimp the edges using a fork or gujiya mould.","Deep fry on medium-low heat until golden all over — 8 minutes.","Dip in sugar syrup if desired. Drain on paper.","Store in an airtight container for up to 1 week."],"prepTime":45,"cookTime":30,"servings":20,"cuisineType":"North Indian","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-gujiya.png","youtubeUrl":"https://www.youtube.com/results?search_query=Gujiya%20Holi%20sweet%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.738Z"},{"id":130,"title":"Ada Pradhaman","description":"Kerala Onam's royal payasam — rice ada (flat rice flakes) cooked in coconut milk and jaggery with fried coconut and cashews.","ingredients":["100g rice ada","2 cups jaggery","1½ cups thick coconut milk","2 cups thin coconut milk","3 tbsp ghee","¼ cup cashews","¼ cup sliced coconut","A pinch of cardamom and dry ginger powder"],"instructions":["Boil ada in water until soft (about 20 minutes). Drain and set aside.","Dissolve jaggery in 1 cup warm water. Strain and bring to a boil.","Add cooked ada to jaggery. Stir and cook 10 minutes until thick.","Add thin coconut milk and cook 5 more minutes.","Lower heat. Add thick coconut milk — do NOT boil after this.","Stir in cardamom and dry ginger.","Fry cashews and coconut in ghee until golden. Pour over payasam."],"prepTime":25,"cookTime":40,"servings":8,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-ada-pradhaman.png","youtubeUrl":"https://www.youtube.com/results?search_query=Ada%20Pradhaman%20Onam%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.741Z"},{"id":131,"title":"Unniyappam","description":"Small round Kerala fried rice balls sweet with banana and jaggery — made in an appam pan and offered at temples.","ingredients":["1 cup rice flour","2 ripe bananas, mashed","½ cup jaggery, dissolved","¼ cup coconut, grated","1 tsp sesame seeds","½ tsp cardamom powder","A pinch of baking powder","Coconut oil for frying"],"instructions":["Dissolve jaggery in ¼ cup warm water. Strain.","Mix rice flour, mashed banana, jaggery syrup, coconut, sesame, cardamom, and baking powder to a thick batter.","Rest 30 minutes.","Heat an appam/appe pan (or muffin tin). Add a few drops of coconut oil into each cavity.","Pour batter into each cavity — fill ¾ full.","Cook on medium heat. When the edges set, flip each one using a skewer.","Cook until dark golden brown and cooked through."],"prepTime":35,"cookTime":20,"servings":20,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-unniyappam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Unniyappam%20Kerala%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.744Z"},{"id":132,"title":"Modak","description":"Ganesh's beloved steamed sweet dumpling — rice flour shells filled with jaggery-coconut-cardamom stuffing. Essential for Ganesh Chaturthi.","ingredients":["1 cup rice flour","1 cup boiling water","A pinch of salt","1 tsp ghee","For filling: 1 cup fresh grated coconut","¾ cup jaggery","½ tsp cardamom powder","1 tbsp sesame seeds (optional)"],"instructions":["Make filling: cook coconut and jaggery in a pan until jaggery melts and mixture comes together. Add cardamom. Cool.","Pour boiling water and salt over rice flour. Mix quickly with a spoon, then knead with greased hands to smooth dough.","Divide into balls. Flatten each ball into a cup shape using wet hands.","Place a spoon of filling in the centre. Pleat and seal the top into a cone shape.","Steam the modaks for 10–12 minutes until translucent.","Brush with ghee and serve warm with a drizzle of ghee."],"prepTime":25,"cookTime":20,"servings":12,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-modak.png","youtubeUrl":"https://www.youtube.com/results?search_query=Ukadiche%20Modak%20Ganesh%20Chaturthi%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.747Z"},{"id":133,"title":"Fried Modak","description":"Crispy deep-fried version of the beloved modak — golden crescent-shaped pastry filled with coconut-jaggery for Ganesh Chaturthi.","ingredients":["1 cup all-purpose flour","1 tbsp ghee","Water to knead","1 cup fresh coconut, grated","¾ cup jaggery","½ tsp cardamom powder","Oil for frying"],"instructions":["Rub ghee into flour until crumbly. Add water to form a medium-stiff dough. Rest 20 minutes.","Make filling: cook coconut with jaggery until thick. Add cardamom. Cool.","Roll dough thin. Cut into circles.","Fill with coconut mixture. Fold into half-moon and seal edges by pleating or pressing with a fork.","Deep fry on medium heat until golden all over.","Drain on paper and serve warm or at room temperature."],"prepTime":30,"cookTime":20,"servings":15,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"dessert","imageUrl":"/stock-images/recipe-fried-modak.png","youtubeUrl":"https://www.youtube.com/results?search_query=Fried%20Modak%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.750Z"},{"id":134,"title":"Paal Payasam","description":"Tamil Nadu's beloved plain milk rice pudding — rice slow-cooked in whole milk for hours until thick, creamy and naturally sweet.","ingredients":["¼ cup raw rice (sona masuri or gobindobhog)","2 litres full-fat milk","¾ cup sugar","½ tsp cardamom powder","A generous pinch of saffron","2 tbsp ghee","2 tbsp cashews and raisins"],"instructions":["Fry cashews and raisins in ghee. Set aside.","Boil milk in a heavy pot. Add washed rice.","Cook on medium-low heat for 45–60 minutes, stirring frequently, until rice is completely cooked and milk has reduced to thick consistency.","Add sugar, saffron, and cardamom. Stir well and cook 10 more minutes.","The payasam should coat a spoon thickly.","Add fried cashews and raisins.","Serve warm or chilled — both are equally delicious."],"prepTime":5,"cookTime":70,"servings":8,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-paal-payasam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paal%20Payasam%20Rice%20Milk%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.753Z"},{"id":135,"title":"Sweet Pongal","description":"Chakkarai Pongal — Tamil Nadu's sacred harvest festival sweet of rice and split moong dal cooked with jaggery, ghee and cashews.","ingredients":["½ cup raw rice","¼ cup yellow moong dal","¾ cup jaggery","3 tbsp ghee","2 cups water","1½ cups milk","½ tsp cardamom powder","A pinch of nutmeg","2 tbsp cashews","2 tbsp raisins","A few edible camphor flakes (optional)"],"instructions":["Dry roast moong dal for 2 minutes. Cook rice and dal together with water and milk in a pressure cooker for 3 whistles.","Mash the cooked mixture well.","Dissolve jaggery in ½ cup warm water. Strain.","Cook the rice-dal mixture with jaggery syrup on medium heat, stirring until thick — 10 minutes.","Add ghee, cardamom, and nutmeg.","Fry cashews and raisins in ghee and add.","Serve warm with an extra drizzle of ghee."],"prepTime":10,"cookTime":30,"servings":6,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-sweet-pongal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sweet%20Pongal%20Chakkarai%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.756Z"},{"id":136,"title":"Kozhukattai","description":"Steamed rice flour dumplings from Tamil Nadu with sesame-jaggery filling — beautiful triangular or sphere-shaped temple prasad.","ingredients":["1 cup rice flour","1 cup boiling water","Salt and ghee","For filling: ½ cup black sesame seeds","½ cup jaggery","¼ cup grated coconut","½ tsp cardamom"],"instructions":["Make filling: roast sesame seeds, grind coarsely. Mix with melted jaggery, coconut and cardamom.","Pour boiling water over rice flour with salt. Mix with ghee and knead to smooth pliable dough.","Take a portion, flatten it in your palm, place filling inside and shape into a triangle or ball.","Steam for 10–12 minutes until the dough turns translucent.","Serve warm with a little ghee drizzled on top."],"prepTime":20,"cookTime":20,"servings":12,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-kozhukattai.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kozhukattai%20Tamil%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.759Z"},{"id":137,"title":"Chakka Pradhaman","description":"Jackfruit payasam from Kerala — ripe jackfruit cooked with coconut milk and jaggery, fragrant with cardamom and dry ginger.","ingredients":["1 cup ripe jackfruit (fresh or canned), mashed","1 cup jaggery","2 cups coconut milk (thin)","1 cup coconut milk (thick)","2 tbsp ghee","¼ cup cashews","¼ cup sliced coconut","½ tsp cardamom powder","A pinch of dry ginger"],"instructions":["Cook jackfruit pulp in a pan on low heat until soft.","Add jaggery and cook, stirring, until jaggery melts and mixture thickens — 15 minutes.","Add thin coconut milk. Cook on medium heat for 10 more minutes.","Lower heat. Add thick coconut milk — stir gently, do not boil.","Add cardamom and dry ginger.","Fry cashews and sliced coconut in ghee until golden. Pour over payasam.","Serve warm or at room temperature."],"prepTime":20,"cookTime":35,"servings":6,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-chakka-pradhaman.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chakka%20Pradhaman%20Jackfruit%20Payasam%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.762Z"},{"id":138,"title":"Elaneer Payasam","description":"Tender coconut pudding — soft coconut jelly pieces in sweetened thickened milk with saffron. Light and cooling.","ingredients":["2 tender coconuts (water and jelly)","1 litre full-fat milk","½ cup sugar","½ tsp cardamom powder","A pinch of saffron"],"instructions":["Collect the tender coconut water. Scrape out the soft jelly from inside.","Boil milk and reduce by one-third, stirring often.","Add sugar, saffron, and cardamom.","Pour in coconut water. Gently add coconut jelly pieces.","Cook very gently on low heat for 5 minutes — don't overcook the jelly.","Chill and serve cold."],"prepTime":20,"cookTime":25,"servings":4,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-elaneer-payasam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Elaneer%20Payasam%20Tender%20Coconut%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.765Z"},{"id":139,"title":"Mohanthal","description":"Gujarat's beloved chickpea flour fudge — coarse, nutty and richly flavoured, given as prasad at the Dwarkadhish temple.","ingredients":["2 cups coarse besan (chickpea flour)","¾ cup ghee","1 cup sugar","½ cup water","½ tsp cardamom powder","A pinch of saffron","¼ cup milk","2 tbsp pistachios and almonds"],"instructions":["Mix besan with 2 tbsp warm ghee and enough milk to make a crumbly mixture. Sieve through a coarse sieve.","Heat remaining ghee in a heavy pan. Add the crumbly besan and roast on low heat, stirring continuously for 25–30 minutes until golden and fragrant.","Prepare sugar syrup to one-string consistency with saffron.","Remove besan from heat. Pour syrup over immediately. Add cardamom. Mix quickly.","Pour into a greased plate. Smooth the top. Press nuts on top.","Cool completely. Cut into diamond shapes."],"prepTime":10,"cookTime":40,"servings":20,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-mohanthal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mohanthal%20Gujarati%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.768Z"},{"id":140,"title":"Sukhdi","description":"Gudpapdi — Gujarat's simplest winter sweet: whole wheat flour roasted in ghee with jaggery, eaten warm as an energy food.","ingredients":["1 cup whole wheat flour","½ cup ghee","½ cup jaggery, grated","½ tsp cardamom powder","2 tbsp sesame seeds (optional)"],"instructions":["Heat ghee in a heavy pan. Add wheat flour.","Roast on medium-low heat, stirring continuously for 15–20 minutes until golden and fragrant.","Remove from heat. Cool slightly.","Add jaggery and cardamom. Mix quickly — jaggery will melt from the residual heat.","Add sesame seeds if using. Mix well.","Pour onto greased plate while still liquid. Spread evenly.","Cut into squares while warm. Cool completely before removing from plate."],"prepTime":5,"cookTime":25,"servings":15,"cuisineType":"Gujarati","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-sukhdi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sukhdi%20Gudpapdi%20Gujarati%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.771Z"},{"id":141,"title":"Kopra Pak","description":"Dry desiccated coconut fudge from Gujarat — three-layered (white, yellow, green) coconut sweet that's Diwali box essential.","ingredients":["3 cups desiccated coconut","1 cup sugar","¼ cup water","3 tbsp ghee","½ tsp cardamom","Food colour (yellow and green for layers)","½ tsp rose water"],"instructions":["Cook sugar and water to one-string syrup. Add ghee.","Divide syrup into three portions.","Mix 1 cup coconut into each portion. Add white, yellow, and green colour respectively.","Cook each portion for 5 minutes separately until thick.","Grease a plate. Layer white, then yellow, then green coconut mixture.","Press firmly. Cool and cut into small squares."],"prepTime":15,"cookTime":20,"servings":25,"cuisineType":"Gujarati","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-kopra-pak.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kopra%20Pak%20Gujarati%20coconut%20sweet%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.774Z"},{"id":142,"title":"Chakli","description":"Crispy coiled spiral savoury snack from Maharashtra — made from rice and urad dal flour, deep fried until perfectly crunchy.","ingredients":["2 cups rice flour","¼ cup urad dal flour","2 tbsp ghee","1 tsp cumin seeds","1 tsp sesame seeds","½ tsp turmeric","½ tsp red chilli powder","Salt to taste","Water to knead","Oil for frying"],"instructions":["Mix all flours with ghee, cumin, sesame, turmeric, chilli, and salt.","Add hot water gradually to make a medium-stiff dough.","Fill a chakli press with the dough. Pipe spirals onto parchment or directly into hot oil.","Fry on medium-low heat for 3–4 minutes per side until golden and crispy.","Drain on paper. Cool completely before storing.","Store in an airtight container — stays crispy for 2 weeks."],"prepTime":20,"cookTime":30,"servings":30,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-chakli.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chakli%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.777Z"},{"id":143,"title":"Murukku","description":"Tamil Nadu's iconic crunchy sesame rice spirals — a must for Diwali and Krishnashtami, equally beloved as a tea-time snack.","ingredients":["2 cups rice flour","¼ cup urad dal flour, roasted","1 tbsp sesame seeds","1 tbsp butter","½ tsp cumin powder","½ tsp asafoetida","Salt to taste","Water to knead","Oil for frying"],"instructions":["Mix rice flour, urad flour, sesame seeds, butter, cumin, asafoetida, and salt.","Add water gradually and knead to a smooth, medium-stiff dough.","Fill a murukku press with the star disc attachment.","Press spirals directly into hot oil (170°C).","Fry on medium heat, turning once, until golden and the sizzling slows — about 4 minutes.","Drain and cool completely. Store in airtight container."],"prepTime":20,"cookTime":30,"servings":30,"cuisineType":"South Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-murukku.png","youtubeUrl":"https://www.youtube.com/results?search_query=Murukku%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.780Z"},{"id":144,"title":"Peanut Chikki","description":"Crunchy peanut brittle with jaggery — the ultimate quick Indian sweet, made in minutes and lasting weeks.","ingredients":["2 cups roasted peanuts, skinned","1 cup jaggery, grated","2 tbsp water","1 tsp ghee"],"instructions":["Grease a plate or baking sheet with ghee.","Cook jaggery with water in a heavy pan, stirring until it reaches hard crack stage — test: a drop in cold water should snap sharply.","Quickly stir in roasted peanuts.","Pour onto the greased plate immediately.","Spread with a greased spatula or rolling pin to ½ cm thickness.","Score into pieces while still warm. Cool completely.","Break along scored lines. Store in airtight jar."],"prepTime":10,"cookTime":15,"servings":20,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-peanut-chikki.png","youtubeUrl":"https://www.youtube.com/results?search_query=Peanut%20Chikki%20Jaggery%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.782Z"},{"id":145,"title":"Sesame Chikki","description":"Til ki chikki — toasted sesame seed brittle with jaggery, thin and snappy. Essential at Lohri and Makar Sankranti.","ingredients":["2 cups white sesame seeds","1 cup jaggery","2 tbsp water","1 tsp ghee"],"instructions":["Dry roast sesame seeds on low heat until they splutter and turn golden. Cool.","Melt jaggery with water to hard crack stage (test in cold water).","Add toasted sesame seeds quickly. Stir.","Pour onto a greased surface immediately. Spread paper thin using a greased rolling pin.","Score into rectangles while soft. Cool completely.","Break along scored lines. The chikki should be translucent and snappy."],"prepTime":10,"cookTime":15,"servings":20,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-sesame-chikki.png","youtubeUrl":"https://www.youtube.com/results?search_query=Til%20Chikki%20Sesame%20Brittle%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.785Z"},{"id":146,"title":"Mathri","description":"Flaky, buttery savoury crackers from North India — seasoned with ajwain, black pepper and cumin. Perfect with pickle and chai.","ingredients":["2 cups all-purpose flour","½ cup ghee","1 tsp ajwain (carom seeds)","1 tsp black pepper, coarsely crushed","½ tsp cumin seeds","Salt to taste","Water to knead","Oil for frying"],"instructions":["Rub ghee into flour until it resembles breadcrumbs.","Add ajwain, black pepper, cumin, and salt. Mix.","Add cold water gradually to form a stiff dough. Do NOT over-knead.","Rest 20 minutes.","Roll small portions into thin circles (3mm thick). Prick all over with a fork.","Deep fry on low-medium heat until golden and crispy — about 5 minutes.","Drain and cool. Store in airtight tin for up to 2 weeks."],"prepTime":25,"cookTime":25,"servings":20,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"dessert","imageUrl":"/stock-images/recipe-mathri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mathri%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.788Z"},{"id":147,"title":"Namak Pare","description":"Diamond-shaped crispy savoury crackers — lightly seasoned, perfectly golden and impossible to stop eating.","ingredients":["2 cups all-purpose flour","3 tbsp ghee","1 tsp ajwain","½ tsp black pepper","Salt to taste","Water to knead","Oil for deep frying"],"instructions":["Rub ghee into flour. Add ajwain, pepper, and salt.","Add water to make a medium-stiff dough. Rest 20 minutes.","Roll thin (2–3mm). Cut into diamond shapes using a knife.","Deep fry on low-medium heat until light golden — 4–5 minutes.","Drain and cool completely. They crisp up more as they cool.","Store in airtight container for 2 weeks."],"prepTime":25,"cookTime":25,"servings":25,"cuisineType":"North Indian","dietaryTags":["Vegan"],"category":"dessert","imageUrl":"/stock-images/recipe-namak-pare.png","youtubeUrl":"https://www.youtube.com/results?search_query=Namak%20Pare%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.791Z"},{"id":148,"title":"Shakarpare","description":"Sweet diamond-shaped fried pastry — lightly sweet with a crispy bite, a Diwali must-have across North India.","ingredients":["2 cups all-purpose flour","3 tbsp ghee","½ cup powdered sugar","½ tsp cardamom powder","Milk to knead","Oil for frying"],"instructions":["Rub ghee into flour. Add powdered sugar and cardamom.","Add milk gradually to form a stiff dough. Do not over-knead.","Roll to 3mm thickness. Cut into diamond shapes.","Deep fry on low-medium heat until light golden — they should NOT be dark.","Cool completely — they harden as they cool.","Store in airtight tin for 2 weeks."],"prepTime":20,"cookTime":20,"servings":25,"cuisineType":"North Indian","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-shakarpare.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shakarpare%20Diwali%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.794Z"},{"id":149,"title":"Patishapta","description":"Bengali thin rice crepes rolled with coconut and nolen gur filling — a winter Makar Sankranti festival delight.","ingredients":["1 cup rice flour","¼ cup all-purpose flour","¼ cup semolina","2 cups milk","1 tbsp sugar","Ghee for cooking","For filling: 2 cups grated coconut","1 cup nolen gur (or jaggery)","½ tsp cardamom"],"instructions":["Make filling: cook grated coconut with jaggery on low heat until it comes together. Add cardamom. Cool.","Mix rice flour, plain flour, semolina, milk, and sugar to a smooth, thin, flowing batter.","Heat a flat pan and brush with ghee. Pour a thin ladleful of batter.","Spread into a thin circle (like a crepe). Cook 1 minute until set.","Place a line of coconut filling in the centre. Roll the crepe around it.","Repeat with remaining batter.","Serve warm drizzled with a little extra jaggery."],"prepTime":20,"cookTime":25,"servings":12,"cuisineType":"Bengali","dietaryTags":["Vegan"],"category":"dessert","imageUrl":"/stock-images/recipe-patishapta.png","youtubeUrl":"https://www.youtube.com/results?search_query=Patishapta%20Bengali%20crepe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.796Z"},{"id":150,"title":"Misti Polao","description":"Bengali sweet saffron rice — lightly sweetened basmati cooked with raisins and cashews, served on festive occasions.","ingredients":["2 cups basmati rice","½ cup sugar","3 tbsp ghee","¼ cup raisins","¼ cup cashews","½ tsp cardamom powder","A generous pinch of saffron","3½ cups water"],"instructions":["Soak basmati rice 30 minutes. Drain.","Heat ghee in a heavy pot. Fry cashews until golden. Remove.","Add raisins and fry briefly. Remove.","Add sugar to the same ghee. Cook until it caramelises to a light golden colour.","Add rice and stir to coat with caramel.","Add water, saffron, and cardamom. Bring to a boil.","Cover and cook on lowest heat for 12 minutes. Fluff. Serve with cashews and raisins."],"prepTime":35,"cookTime":20,"servings":6,"cuisineType":"Bengali","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-misti-polao.png","youtubeUrl":"https://www.youtube.com/results?search_query=Misti%20Polao%20Bengali%20Sweet%20Rice%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.799Z"},{"id":151,"title":"Pinni","description":"Punjab's warming winter sweet — whole wheat flour and edible gum roasted in ghee with jaggery, nuts and dried coconut.","ingredients":["2 cups whole wheat flour","3 tbsp edible gum (gond)","½ cup ghee","½ cup jaggery, grated","¼ cup almonds, chopped","¼ cup cashews, chopped","2 tbsp dried coconut","½ tsp cardamom powder","2 tbsp dry ginger powder"],"instructions":["Fry edible gum in ghee until it puffs up like popcorn. Remove and crush lightly.","In the same ghee, roast flour on low heat for 20–25 minutes until golden and nutty.","Remove from heat. Cool slightly.","Melt jaggery with 2 tbsp water. Pour over flour. Add gond, nuts, coconut, cardamom, and dry ginger.","Mix well. Shape into medium balls while warm.","Allow to cool and harden. Keeps for 2 weeks in airtight container."],"prepTime":15,"cookTime":30,"servings":20,"cuisineType":"Punjabi","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-pinni.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pinni%20Punjabi%20winter%20sweet%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.802Z"},{"id":152,"title":"Balushahi","description":"Honey-dipped, flaky deep-fried pastry discs — lighter than a donut and more complex than a barfi. A North Indian wedding essential.","ingredients":["2 cups all-purpose flour","½ cup ghee","¼ cup yogurt","A pinch of baking soda","Oil for frying","2 cups sugar","1 cup water","Saffron and cardamom for syrup","Pistachios for garnish"],"instructions":["Rub ghee into flour until crumbly. Add baking soda.","Add yogurt and mix gently. Add a little water if needed to bring dough together — it should be soft and flaky.","Rest 30 minutes.","Divide into round balls. Flatten into discs. Press thumb in the centre of each.","Deep fry on very low heat (don't rush!) for 12–15 minutes until golden and cooked through.","Drain. Dip in warm sugar syrup for 2 minutes.","Remove. Sprinkle with pistachios. Allow syrup to set."],"prepTime":35,"cookTime":25,"servings":15,"cuisineType":"North Indian","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-balushahi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Balushahi%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.805Z"},{"id":153,"title":"Petha","description":"Agra's crystalline translucent white gourd sweet — soft, chewy and soaked in fragrant sugar syrup. Agra's most famous export.","ingredients":["1 kg ash gourd (white pumpkin)","2 cups sugar","1 cup water","½ tsp citric acid (or alum)","½ tsp cardamom powder","Saffron strands","Rose water"],"instructions":["Peel and cut ash gourd into blocks. Pierce all over with a fork.","Soak in alum water for 30 minutes to firm the texture.","Rinse and par-boil until just tender but still holding shape.","Prepare sugar syrup. Add gourd pieces and cook on low heat for 30 minutes until translucent.","Add cardamom, saffron, and rose water.","Cook until the pieces absorb most of the syrup and turn glossy.","Cool and serve. The petha should be slightly sticky and translucent."],"prepTime":60,"cookTime":45,"servings":12,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-petha.png","youtubeUrl":"https://www.youtube.com/results?search_query=Agra%20Petha%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.807Z"},{"id":154,"title":"Imarti","description":"Urad dal spirals deep-fried and soaked in saffron syrup — crispier and denser than jalebi, with a characteristic slightly sticky exterior.","ingredients":["1 cup urad dal, soaked 4 hours","Oil for frying","1½ cups sugar","¾ cup water","½ tsp cardamom","Saffron strands","Orange food colour (optional)"],"instructions":["Grind soaked dal with very little water to a thick, smooth, fluffy batter.","Add colour and mix. The batter should be thick enough to hold a spiral shape.","Make sugar syrup to one-string consistency. Add saffron and cardamom.","Fill batter into a piping bag or squeeze bottle with a small round nozzle.","Heat oil to 160°C. Pipe concentric spirals into the oil.","Fry until golden, turning once — 3 minutes per side.","Soak in warm syrup for 2 minutes. Serve warm."],"prepTime":240,"cookTime":30,"servings":12,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-imarti.png","youtubeUrl":"https://www.youtube.com/results?search_query=Imarti%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.810Z"},{"id":155,"title":"Sohan Halwa","description":"Dense, toffee-like Punjab halwa made with wheat starch, sugar and ghee — chewy and rich, a winter speciality.","ingredients":["1 cup cornflour or wheat starch","3 cups sugar","2 cups water","½ cup ghee","½ tsp cardamom","A pinch of saffron","¼ cup almonds, pistachios, and cashews"],"instructions":["Dissolve cornflour in 1 cup cold water until smooth.","Cook sugar and remaining water to a thick syrup.","Slowly add cornflour mixture to syrup, stirring vigorously over medium heat.","Add ghee in batches, stirring continuously until the halwa is very thick and pulls away from the pan — 25 minutes.","Add saffron and cardamom.","Pour into a greased plate. Top with nuts. Cool and cut into pieces."],"prepTime":10,"cookTime":35,"servings":15,"cuisineType":"Punjabi","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-sohan-halwa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sohan%20Halwa%20Punjab%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.812Z"},{"id":156,"title":"Falooda","description":"Mumbai's iconic layered rose-milk dessert drink — falooda noodles, basil seeds, rose syrup, milk, and ice cream in a tall glass.","ingredients":["¼ cup falooda sev (thin vermicelli)","2 tbsp sabja (basil/tukmaria seeds), soaked","3 tbsp rose syrup","1 cup cold milk","2 scoops vanilla or rose ice cream","1 tsp cornflour","Red/pink jelly (optional)"],"instructions":["Cook falooda sev in boiling water for 2 minutes. Drain and cool in cold water.","Soak sabja seeds in water for 20 minutes until they bloom.","Dissolve cornflour in 2 tbsp cold milk. Heat remaining milk and add cornflour mixture. Stir until slightly thickened. Cool.","In a tall glass: add rose syrup, then falooda sev, then soaked sabja seeds.","Pour cold milk over gently.","Top with ice cream scoops.","Drizzle more rose syrup. Serve immediately with a long spoon and straw."],"prepTime":25,"cookTime":5,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-falooda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Falooda%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.815Z"},{"id":157,"title":"Kulfi Falooda","description":"The ultimate Indian street dessert — creamy pistachio kulfi over rose falooda noodles, sabja seeds and rose syrup.","ingredients":["1 kulfi (malai or pista, sliced)","¼ cup falooda sev, cooked","2 tbsp sabja seeds, soaked","3 tbsp rose syrup","1 cup cold milk","Chopped pistachios for garnish"],"instructions":["Cook falooda sev per packet instructions. Drain and cool.","Soak sabja seeds until bloomed.","In a deep bowl or glass: pour rose syrup first.","Add falooda noodles and sabja seeds.","Pour cold milk.","Place sliced kulfi on top.","Sprinkle with chopped pistachios. Serve immediately."],"prepTime":15,"cookTime":5,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-kulfi-falooda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kulfi%20Falooda%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.818Z"},{"id":158,"title":"Thekua","description":"Bihar's sacred Chhath Puja offering — hard, dry wheat cookies fried in ghee, sweetened with jaggery and fragrant with anise.","ingredients":["2 cups whole wheat flour","½ cup jaggery, grated","3 tbsp ghee","1 tsp fennel seeds","½ tsp cardamom","¼ cup desiccated coconut","Milk to bind","Oil for frying"],"instructions":["Dissolve jaggery in 3 tbsp warm water.","Mix flour with ghee until crumbly. Add jaggery, fennel seeds, cardamom, and coconut.","Add milk gradually to form a stiff dough.","Press into a thekua mould or roll and cut into small ovals.","Deep fry on medium-low heat until dark golden and hard — about 8 minutes.","Drain and cool completely — they harden more as they cool.","Store in airtight container for 2 weeks."],"prepTime":20,"cookTime":25,"servings":20,"cuisineType":"East Indian","dietaryTags":["Vegan"],"category":"dessert","imageUrl":"/stock-images/recipe-thekua.png","youtubeUrl":"https://www.youtube.com/results?search_query=Thekua%20Chhath%20Puja%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.821Z"},{"id":159,"title":"Anarsa","description":"Maharashtrian Diwali rice cookie — soaked rice ground with jaggery, fried in ghee and rolled in poppy seeds.","ingredients":["2 cups rice, soaked 3 days and dried","1 cup jaggery, grated","½ cup poppy seeds (khus khus)","Oil or ghee for frying"],"instructions":["Soak rice for 3 days, changing water daily. Dry completely and grind to fine flour.","Knead rice flour with jaggery (no water needed — jaggery provides moisture). Knead to a stiff dough.","Divide into small balls. Press into small flat discs.","Press one side into poppy seeds — poppy seeds should coat one side.","Fry poppy seed side down first on low-medium heat until golden. Flip and fry the other side.","Drain on paper. Cool completely — they crisp up beautifully."],"prepTime":4320,"cookTime":25,"servings":20,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-anarsa.png","youtubeUrl":"https://www.youtube.com/results?search_query=Anarsa%20Diwali%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.824Z"},{"id":160,"title":"Karanji","description":"Maharashtrian gujiya — crescent pastry with coconut-semolina-jaggery filling, deep fried to golden crispiness for Diwali.","ingredients":["2 cups all-purpose flour","3 tbsp ghee","Water to knead","For filling: 1 cup desiccated coconut","½ cup semolina, dry roasted","½ cup powdered sugar","½ tsp cardamom","2 tbsp raisins","Oil for frying"],"instructions":["Rub ghee into flour. Add water to form a stiff dough. Rest 30 minutes.","Mix all filling ingredients together.","Roll dough thin. Cut into circles.","Fill with coconut mixture. Fold and crimp edges.","Deep fry on medium-low heat until golden all over — 8 minutes.","Drain and cool. Store in airtight container up to 1 week."],"prepTime":40,"cookTime":30,"servings":20,"cuisineType":"Maharashtrian","dietaryTags":["Vegan"],"category":"dessert","imageUrl":"/stock-images/recipe-karanji.png","youtubeUrl":"https://www.youtube.com/results?search_query=Karanji%20Maharashtrian%20Diwali%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.827Z"},{"id":161,"title":"Rava Kesari","description":"Karnataka's sunny orange semolina sweet — quick to make, fragrant with saffron and cardamom. Temple prasad and home favourite.","ingredients":["1 cup fine semolina (rava)","2½ cups water","¾ cup sugar","3 tbsp ghee","½ tsp cardamom powder","A generous pinch of saffron in 2 tbsp warm water","2 tbsp cashews","2 tbsp raisins","A few drops of orange food colour (optional)"],"instructions":["Heat ghee. Fry cashews and raisins until golden. Remove.","In the same ghee, roast semolina on medium heat for 5 minutes until lightly golden.","Boil water with colour and saffron. Slowly pour over roasted rava while stirring vigorously to prevent lumps.","Cook on medium heat, stirring, until rava absorbs all water.","Add sugar. Stir quickly as mixture thickens.","Add cardamom. Cook 3 more minutes until the kesari leaves the pan sides.","Garnish with fried cashews and raisins. Serve hot."],"prepTime":5,"cookTime":15,"servings":6,"cuisineType":"South Indian","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-rava-kesari.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rava%20Kesari%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.830Z"},{"id":162,"title":"Panchamrit","description":"Sacred temple prasad — the five-nectar mixture of milk, yogurt, honey, ghee and sugar, offered to the deity and served to devotees.","ingredients":["½ cup full-fat milk","½ cup yogurt","2 tbsp honey","1 tsp ghee","2 tbsp sugar","A pinch of cardamom","Tulsi leaves"],"instructions":["Combine milk and yogurt in a small bowl.","Add honey, ghee, and sugar. Stir gently until sugar dissolves.","Add a tiny pinch of cardamom powder.","Traditionally offered to the deity first, then distributed as prasad.","Serve in small portions — this is very sweet and rich.","Always prepare fresh. Do not refrigerate as it's meant to be consumed immediately."],"prepTime":5,"cookTime":0,"servings":6,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-panchamrit.png","youtubeUrl":"https://www.youtube.com/results?search_query=Panchamrit%20prasad%20recipe%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.833Z"},{"id":163,"title":"Anjeer Barfi","description":"Fig and milk fudge — naturally sweet dried figs blended with milk solids and nuts. A nutritious festive sweet.","ingredients":["1 cup dried figs (anjeer)","½ cup milk","½ cup khoya","¼ cup powdered sugar","½ tsp cardamom","2 tbsp almonds, pistachios","1 tbsp ghee"],"instructions":["Soak dried figs in warm milk for 30 minutes until soft.","Blend with soaking milk to a smooth paste.","Heat ghee in a pan. Cook fig paste on medium heat, stirring for 5 minutes.","Add khoya and powdered sugar. Stir for 10 more minutes until thick.","Add cardamom and nuts. Mix.","Pour into greased plate. Press nuts on top. Cool and cut into pieces."],"prepTime":35,"cookTime":20,"servings":15,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-anjeer-barfi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Anjeer%20Barfi%20Fig%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.836Z"},{"id":164,"title":"Khajoor Barfi","description":"Dates and nut fudge — no-cook, naturally sweetened with medjool dates, rich with cashews and coconut. Healthy festival sweet.","ingredients":["2 cups medjool dates, pitted","1 cup cashews","½ cup desiccated coconut","¼ cup almonds","½ tsp cardamom powder","1 tsp ghee","Pistachios for garnish"],"instructions":["Soak dates in warm water for 10 minutes if hard. Drain.","Process dates in a food processor to a sticky paste.","Coarsely grind cashews and almonds.","Mix date paste, nuts, coconut, and cardamom together with ghee.","Press into a greased dish. Press pistachios on top.","Refrigerate 2 hours. Cut into squares or roll into balls.","Store refrigerated for up to 2 weeks."],"prepTime":20,"cookTime":0,"servings":20,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-khajoor-barfi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Khajoor%20Barfi%20Dates%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.838Z"},{"id":165,"title":"Mawa Kachori","description":"Jodhpur's sinful fried pastry filled with khoya, dry fruits and nuts — soaked in sugar syrup. A Rajasthani pride.","ingredients":["2 cups all-purpose flour","3 tbsp ghee","Water to knead","For filling: 1 cup khoya","¼ cup sugar","¼ cup mixed nuts (cashews, raisins, almonds)","½ tsp cardamom","Oil for frying","2 cups thin sugar syrup"],"instructions":["Make a medium-soft dough with flour, ghee, and water. Rest 20 minutes.","Make filling: cook khoya with sugar and cardamom for 5 minutes. Add nuts. Cool.","Roll small circles of dough. Fill generously with khoya mixture.","Seal and shape into rounds. Press slightly flat.","Deep fry on low-medium heat until golden all over — 10 minutes.","Soak in sugar syrup for 3 minutes.","Drain. Serve warm or at room temperature."],"prepTime":30,"cookTime":30,"servings":12,"cuisineType":"Rajasthani","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-mawa-kachori.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mawa%20Kachori%20Jodhpur%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.841Z"},{"id":166,"title":"Paneer Kheer","description":"Cottage cheese rice pudding — crumbled fresh paneer simmered in saffron and cardamom milk for a silky, protein-rich dessert.","ingredients":["200g paneer, crumbled","1 litre full-fat milk","½ cup sugar","½ tsp cardamom powder","A generous pinch of saffron","2 tbsp basmati rice, soaked and ground","2 tbsp pistachios, slivered","1 tsp rose water"],"instructions":["Boil milk in a heavy pan. Add rice paste while stirring to prevent lumps.","Add crumbled paneer. Stir well.","Cook on medium heat, stirring frequently, for 25 minutes until thick.","Add sugar, saffron, and cardamom. Cook 5 more minutes.","Add rose water and most of the pistachios.","Serve warm or chilled, garnished with remaining pistachios."],"prepTime":15,"cookTime":35,"servings":6,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-paneer-kheer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paneer%20Kheer%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.844Z"},{"id":167,"title":"Vermicelli Kheer","description":"Seviyan kheer — thin roasted vermicelli cooked in whole milk with saffron and cardamom. Made at Eid and throughout the year.","ingredients":["1 cup thin vermicelli (seviyan)","1 litre full-fat milk","½ cup sugar","2 tbsp ghee","½ tsp cardamom powder","A generous pinch of saffron","¼ cup raisins","¼ cup cashews and almonds","1 tsp rose water"],"instructions":["Fry cashews and raisins in ghee until golden. Set aside.","In the same ghee, fry vermicelli on medium heat until golden.","Add milk and bring to a boil. Reduce heat and cook for 15 minutes, stirring often.","Add sugar, saffron, and cardamom. Cook 5 more minutes.","Add rose water and fried nuts.","Serve warm or chilled."],"prepTime":5,"cookTime":25,"servings":6,"cuisineType":"Pan-Indian","dietaryTags":[],"category":"dessert","imageUrl":"/stock-images/recipe-vermicelli-kheer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Seviyan%20Kheer%20Vermicelli%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.846Z"},{"id":168,"title":"Mango Kheer","description":"Chilled summer rice pudding with Alphonso mango pulp — fragrant with cardamom and saffron, naturally sweetened.","ingredients":["¼ cup basmati rice","1 litre full-fat milk","½ cup sugar (adjust)","1 cup ripe mango pulp","½ tsp cardamom powder","A pinch of saffron","Mango pieces for garnish"],"instructions":["Cook rice in milk on medium-low heat, stirring often, for 35 minutes until thick.","Add sugar, saffron, and cardamom. Stir for 10 more minutes.","Cool completely.","Fold in mango pulp gently.","Refrigerate 2 hours.","Serve chilled garnished with fresh mango pieces."],"prepTime":5,"cookTime":50,"servings":6,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-mango-kheer.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mango%20Kheer%20Aam%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.849Z"},{"id":169,"title":"Aam Papad","description":"Sun-dried mango leather — raw mango pulp mixed with sugar and dried into tangy sweet sheets. Childhood nostalgia in every bite.","ingredients":["2 cups raw mango pulp","1 cup sugar","½ tsp black salt","½ tsp cumin powder","¼ tsp chilli powder (optional)"],"instructions":["Cook mango pulp with sugar on low heat, stirring until sugar dissolves and mixture thickens slightly.","Add black salt, cumin, and chilli if using. Mix.","Grease a flat baking tray or plate.","Pour a thin layer of mango mixture onto the tray.","Sun dry for 2–3 days in direct sunlight, or dry in oven at 70°C for 3–4 hours.","When completely dry and slightly leather-like, peel off the sheet.","Cut into strips and roll up. Store in airtight container."],"prepTime":20,"cookTime":10,"servings":20,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-aam-papad.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aam%20Papad%20Mango%20Leather%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.852Z"},{"id":170,"title":"Poha Ladoo","description":"Quick flattened rice ladoos with jaggery and coconut — a simple, wholesome sweet needing no cooking.","ingredients":["2 cups thick poha (flattened rice)","¾ cup jaggery, grated","½ cup desiccated coconut","½ tsp cardamom powder","2 tbsp ghee","2 tbsp roasted peanuts, crushed"],"instructions":["Dry roast poha in a pan for 3 minutes until crisp. Cool.","Grind poha to a coarse powder.","Warm jaggery with 1 tbsp water until it just softens.","Mix poha powder, coconut, jaggery, cardamom, ghee, and peanuts.","Shape into balls while warm. If the mixture doesn't hold, add a few drops of warm ghee.","Cool and store in airtight container."],"prepTime":15,"cookTime":5,"servings":15,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-poha-ladoo.png","youtubeUrl":"https://www.youtube.com/results?search_query=Poha%20Ladoo%20Flattened%20Rice%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.854Z"},{"id":171,"title":"Kheer Kadam","description":"Bengali novelty sweet — a rasgulla inside a khoya ball coated with tiny boondi. Sweet, spongy and layered in texture.","ingredients":["10 small rasgullas (fresh or packaged)","1 cup khoya, crumbled","¼ cup powdered sugar","½ tsp cardamom","1 cup fine boondi (unsalted)","Pistachios"],"instructions":["Mix khoya with powdered sugar and cardamom. Knead to smooth.","Squeeze out syrup from rasgullas gently.","Flatten a ball of khoya in your palm. Place one rasgulla in centre.","Wrap the khoya around the rasgulla to form a ball. Seal completely.","Roll in fine boondi until coated all around.","Press a pistachio on top.","Refrigerate 1 hour before serving."],"prepTime":20,"cookTime":0,"servings":10,"cuisineType":"Bengali","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-kheer-kadam.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kheer%20Kadam%20Bengali%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.857Z"},{"id":172,"title":"Mango Mastani","description":"Pune's legendary thick mango milkshake dessert — loaded with ice cream, dry fruits and topped with a cherry. A complete indulgence.","ingredients":["2 cups ripe Alphonso mango pulp","2 cups chilled milk","4 scoops vanilla ice cream","2 tbsp sugar","¼ cup mixed dry fruits (cashews, raisins, almonds)","2 cherries for garnish","Saffron strands"],"instructions":["Blend mango pulp, milk, sugar, and 2 scoops of ice cream until thick and creamy.","Pour into tall glasses.","Top with remaining ice cream scoops.","Scatter dry fruits and saffron strands over.","Place a cherry on top.","Serve immediately with a thick straw."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Maharashtrian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-mango-mastani.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mango%20Mastani%20Pune%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.859Z"},{"id":173,"title":"Basundi","description":"Gujarat's version of rabri — milk reduced to a creamy thick consistency with saffron, cardamom and nutmeg. Utterly indulgent.","ingredients":["2 litres full-fat milk","¾ cup sugar","½ tsp cardamom powder","A generous pinch of saffron","¼ tsp nutmeg, grated","2 tbsp pistachios and almonds, slivered"],"instructions":["Pour milk into a wide heavy pot. Bring to a boil.","Simmer on medium-high heat, stirring every few minutes, for 50–60 minutes until milk reduces to half.","Add sugar, saffron, cardamom, and nutmeg. Cook 10 more minutes.","Cool and refrigerate. Basundi thickens further as it chills.","Serve chilled, garnished with nuts.","Optionally serve with puri."],"prepTime":5,"cookTime":70,"servings":8,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-basundi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Basundi%20Gujarati%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.862Z"},{"id":174,"title":"Chikki","description":"Mixed dry fruit and nut brittle in jaggery — festive, energy-boosting and satisfying. A healthier Indian candy.","ingredients":["¼ cup cashews","¼ cup almonds","¼ cup pistachios","¼ cup raisins","1 cup jaggery","2 tbsp water","1 tsp ghee","½ tsp cardamom"],"instructions":["Lightly toast all nuts and keep warm.","Melt jaggery with water to hard crack stage.","Quickly stir in all nuts, raisins, and cardamom.","Pour onto a greased plate. Spread evenly with greased spatula.","Score immediately into pieces.","Cool completely before breaking."],"prepTime":10,"cookTime":15,"servings":20,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-chikki.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mixed%20Nut%20Chikki%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.865Z"},{"id":175,"title":"Panjiri","description":"Punjabi winter dry sweet powder eaten to warm the body — roasted wheat flour with edible gum, sugar, nuts and desi ghee.","ingredients":["2 cups whole wheat flour","½ cup ghee","½ cup powdered sugar","2 tbsp edible gum (gond), fried","¼ cup almonds, chopped","¼ cup cashews, chopped","2 tbsp dry ginger powder","1 tsp cardamom powder","1 tbsp poppy seeds"],"instructions":["Fry edible gum in ghee until it puffs up. Remove and crush.","In the same ghee, roast wheat flour on low heat for 20 minutes until golden.","Cool the roasted flour.","Mix in powdered sugar, crushed gond, nuts, dry ginger, cardamom, and poppy seeds.","Store in an airtight jar. Serve 2 tablespoons daily in winter.","Can be eaten dry or mixed with warm milk."],"prepTime":10,"cookTime":25,"servings":20,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-panjiri.png","youtubeUrl":"https://www.youtube.com/results?search_query=Panjiri%20Punjabi%20winter%20sweet%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.867Z"},{"id":176,"title":"Therattipal","description":"Tamil Nadu's reduced milk sweet — milk cooked down until it becomes a thick, crumbly, caramelised sweet with ghee.","ingredients":["2 litres full-fat milk","¾ cup sugar","3 tbsp ghee","½ tsp cardamom powder"],"instructions":["Boil milk in a wide heavy pan.","Cook on medium heat, stirring every 2–3 minutes, scraping the sides.","As milk reduces and thickens (after about 40 minutes), stir more frequently.","Add sugar and ghee. Continue cooking and stirring.","The milk will eventually become very thick and start to leave the sides — 60–70 minutes total.","Add cardamom. Remove when it resembles thick ricotta.","Cool, shape into rounds, or serve as is."],"prepTime":5,"cookTime":75,"servings":6,"cuisineType":"South Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-therattipal.png","youtubeUrl":"https://www.youtube.com/results?search_query=Therattipal%20Tamil%20sweet%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.870Z"},{"id":177,"title":"Doodh Peda","description":"Milk fudge made from scratch using condensed milk and milk powder — soft, quick and studded with pistachios.","ingredients":["1 cup condensed milk","½ cup milk powder","1 tbsp ghee","½ tsp cardamom powder","Pistachios for pressing on top"],"instructions":["Mix condensed milk, milk powder, and ghee in a heavy pan.","Cook on low heat, stirring continuously, until the mixture thickens and leaves the sides — 10–12 minutes.","Remove from heat. Add cardamom.","Cool until handleable. Shape into small round discs.","Press a pistachio sliver into the centre of each peda.","Refrigerate 30 minutes before serving."],"prepTime":5,"cookTime":15,"servings":15,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"dessert","imageUrl":"/stock-images/recipe-doodh-peda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Doodh%20Peda%20Milk%20Fudge%20indian%20sweet%20recipe","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.872Z"}]
6:34:32 PM [express] GET /api/recipes 200 in 28ms :: [{"id":178,"title":"Mango Lassi","description":"Punjab's ultimate summer drink — thick, creamy yogurt blended with Alphonso mango pulp, cardamom and a pinch of saffron.","ingredients":["1 cup ripe mango pulp (Alphonso)","1 cup full-fat yogurt","½ cup chilled milk","3 tbsp sugar","½ tsp cardamom powder","A pinch of saffron in 1 tbsp warm milk","Ice cubes"],"instructions":["Blend mango pulp, yogurt, milk, and sugar until smooth and frothy.","Add cardamom and saffron milk. Blend again briefly.","Taste and adjust sweetness.","Pour into tall chilled glasses over ice.","Garnish with a pinch of cardamom and a mango sliver."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-mango-lassi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mango%20Lassi%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.875Z"},{"id":179,"title":"Sweet Lassi","description":"Classic chilled yogurt drink — simple, thick and creamy, sweetened with sugar and rose water. Punjab's everyday cooling drink.","ingredients":["2 cups full-fat yogurt","½ cup chilled water or milk","3 tbsp sugar","½ tsp cardamom powder","1 tsp rose water","Ice cubes","A pinch of saffron and pistachios for garnish"],"instructions":["Blend yogurt, water, sugar, and cardamom until frothy.","Add rose water. Blend 10 seconds more.","Pour over ice in tall glasses.","Garnish with saffron strands and slivered pistachios."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-sweet-lassi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sweet%20Lassi%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.878Z"},{"id":180,"title":"Salty Lassi","description":"Savoury cumin-spiced buttermilk drink — the ideal accompaniment to heavy Punjabi meals, cooling and digestive.","ingredients":["2 cups yogurt","1 cup chilled water","½ tsp cumin powder, roasted","¼ tsp black salt","Salt to taste","A few mint leaves","Ice cubes"],"instructions":["Blend yogurt and water until smooth.","Add cumin powder, black salt, and regular salt.","Blend briefly.","Tear mint leaves and add. Blend 5 seconds.","Pour over ice. Garnish with a sprig of mint and a pinch of roasted cumin."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-salty-lassi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Salty%20Lassi%20Chach%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.880Z"},{"id":181,"title":"Rose Lassi","description":"Fragrant pink lassi with rose syrup, saffron and cream — a festive version of the classic, layered and eye-catching.","ingredients":["1½ cups thick yogurt","½ cup chilled milk","3 tbsp rose syrup","1 tsp saffron water","2 tbsp fresh cream","Ice cubes","Dried rose petals and pistachios for garnish"],"instructions":["Blend yogurt, milk, and 2 tbsp rose syrup until smooth.","Add saffron water. Mix.","Pour into glasses over ice.","Drizzle remaining rose syrup and cream on top.","Garnish with dried rose petals and slivered pistachios."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Punjabi","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-rose-lassi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rose%20Lassi%20recipe%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.883Z"},{"id":182,"title":"Strawberry Lassi","description":"Fresh strawberry and yogurt blended into a vibrant pink lassi — naturally sweet, slightly tart and utterly refreshing.","ingredients":["1 cup fresh strawberries","1½ cups yogurt","½ cup milk","2 tbsp sugar (adjust)","½ tsp cardamom","Ice cubes","Strawberry slices for garnish"],"instructions":["Blend strawberries until smooth.","Add yogurt, milk, sugar, and cardamom. Blend until frothy.","Taste and adjust sweetness.","Pour over ice.","Garnish with strawberry slices."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-strawberry-lassi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Strawberry%20Lassi%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.886Z"},{"id":183,"title":"Aam Panna","description":"Raw green mango summer cooler — tangy, sweet and spiced with cumin and black salt. India's favourite heat-stroke remedy.","ingredients":["2 raw green mangoes","¾ cup sugar","1 tsp roasted cumin powder","1 tsp black salt","Regular salt to taste","A few mint leaves","Cold water to dilute","Ice cubes"],"instructions":["Boil or roast raw mangoes until soft. Cool, peel and extract the pulp.","Blend pulp with sugar, cumin powder, black salt, and mint until smooth.","Strain through a sieve for a smooth concentrate.","Refrigerate the concentrate.","To serve: mix 3 tbsp concentrate with 1 cup cold water. Stir.","Serve over ice with a pinch of extra cumin on top."],"prepTime":15,"cookTime":20,"servings":6,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-aam-panna.png","youtubeUrl":"https://www.youtube.com/results?search_query=Aam%20Panna%20Raw%20Mango%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.888Z"},{"id":184,"title":"Jal Jeera","description":"Cumin-spiced tangy tamarind water — India's most refreshing street drink. Thirst-quenching, digestive and utterly distinctive.","ingredients":["1 tsp cumin seeds, roasted and ground","½ cup tamarind water (soaked tamarind)","2 tbsp fresh mint leaves","2 tbsp fresh coriander","1 tsp black salt","1 tbsp sugar","½ tsp amchur (dry mango powder)","3 cups cold water","Ice cubes"],"instructions":["Blend tamarind water with mint, coriander, cumin powder, black salt, sugar, and amchur.","Strain through fine mesh.","Mix with cold water. Taste and adjust seasoning — should be tangy, spiced and refreshing.","Refrigerate.","Serve over ice, garnished with a mint sprig.","Can be prepared as a concentrate and diluted to taste."],"prepTime":15,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-jal-jeera.png","youtubeUrl":"https://www.youtube.com/results?search_query=Jal%20Jeera%20recipe%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.890Z"},{"id":185,"title":"Thandai","description":"Holi and Shivratri's festive chilled milk drink — blended with almonds, fennel, rose petals, cardamom and cooling spices.","ingredients":["1 litre chilled full-fat milk","¼ cup almonds, soaked and peeled","2 tbsp fennel seeds, soaked","1 tbsp poppy seeds, soaked","10 black peppercorns","½ tsp cardamom powder","1 tsp rose water","3 tbsp sugar","A pinch of saffron","Dried rose petals for garnish"],"instructions":["Soak almonds, fennel seeds, and poppy seeds in water for 2 hours.","Grind soaked almonds, fennel, poppy seeds, and peppercorns to a smooth paste with little milk.","Mix paste with remaining milk. Add sugar, cardamom, saffron, and rose water.","Strain through a muslin cloth, pressing to extract all liquid.","Refrigerate at least 2 hours.","Serve chilled in glasses, garnished with rose petals and a pinch of saffron."],"prepTime":130,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-thandai.png","youtubeUrl":"https://www.youtube.com/results?search_query=Thandai%20recipe%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.893Z"},{"id":186,"title":"Chaas","description":"Digestive spiced buttermilk — thin, tangy and seasoned with curry leaves, green chilli and ginger. Gujarat's meal companion.","ingredients":["1 cup yogurt","2 cups chilled water","½ tsp roasted cumin powder","¼ tsp black salt","A few curry leaves","1 green chilli, slit","½ tsp grated ginger","Salt to taste","Fresh coriander"],"instructions":["Blend yogurt and water until completely smooth.","Add cumin powder, black salt, ginger, and regular salt. Mix.","Temper in 1 tsp oil: add curry leaves and green chilli until they splutter.","Pour tempering into the chaas. Stir.","Garnish with fresh coriander.","Serve at room temperature or chilled."],"prepTime":5,"cookTime":3,"servings":3,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-chaas.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chaas%20Masala%20Buttermilk%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.896Z"},{"id":187,"title":"Nimbu Pani","description":"The Indian lemonade — freshly squeezed lemon with sugar, black salt, cumin and mint. Simple, refreshing and universally loved.","ingredients":["4 lemons, juiced","3 tbsp sugar","½ tsp black salt","A pinch of roasted cumin powder","Mint leaves","4 cups cold water","Ice cubes"],"instructions":["Squeeze lemons. Strain the juice.","Mix sugar in 2 tbsp warm water to dissolve. Make a simple syrup.","Combine lemon juice, sugar syrup, cold water, black salt, and cumin.","Stir well. Taste and adjust lemon or sugar.","Add mint leaves and ice.","Serve immediately."],"prepTime":5,"cookTime":0,"servings":4,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-nimbu-pani.png","youtubeUrl":"https://www.youtube.com/results?search_query=Nimbu%20Pani%20Lemonade%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.898Z"},{"id":188,"title":"Kokum Sharbat","description":"Goa and Maharashtra's prized purple drink — kokum extract with sugar, cumin and mint. Deep ruby coloured and delightfully tart.","ingredients":["10 kokum pieces","3 cups water","4 tbsp sugar","½ tsp roasted cumin powder","A pinch of black salt","Fresh mint leaves","Ice cubes"],"instructions":["Soak kokum in 1 cup warm water for 30 minutes until it rehydrates and releases its colour.","Squeeze and strain the kokum liquid.","Dissolve sugar in the kokum extract.","Add cumin powder and black salt. Mix.","Dilute with remaining 2 cups cold water.","Serve over ice with fresh mint."],"prepTime":35,"cookTime":0,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-kokum-sharbat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kokum%20Sharbat%20recipe%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.901Z"},{"id":189,"title":"Rose Sharbat","description":"Chilled rose petal syrup diluted with chilled milk or water — fragrant, pink and elegant. Essential at Indian celebrations.","ingredients":["4 tbsp rose syrup (rooh afza)","2 cups chilled milk OR cold water","Ice cubes","Sabja (basil) seeds, soaked","Rose petals and pistachios for garnish"],"instructions":["Soak sabja seeds in water for 20 minutes until they bloom.","Pour rose syrup into glasses.","Add ice cubes.","Pour chilled milk over gently.","Add bloomed sabja seeds.","Garnish with rose petals and pistachios."],"prepTime":25,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-rose-sharbat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rose%20Sharbat%20Rooh%20Afza%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.904Z"},{"id":190,"title":"Bel Sharbat","description":"Wood apple (bael fruit) summer drink — this tart, earthy fruit blended with sugar and spices is India's ancient cooling drink.","ingredients":["1 ripe bael fruit","4 tbsp sugar","½ tsp cardamom powder","A pinch of black salt","1 tsp roasted cumin powder","3 cups cold water","Ice cubes","Mint for garnish"],"instructions":["Break open the bael fruit. Scoop out the pulp.","Mix pulp with 1 cup warm water and mash well.","Strain through a sieve, pressing to extract all juice.","Dissolve sugar in the strained juice.","Add cardamom, black salt, and cumin.","Dilute with remaining cold water.","Serve over ice with mint."],"prepTime":15,"cookTime":0,"servings":4,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-bel-sharbat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Bael%20Sharbat%20Wood%20Apple%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.907Z"},{"id":191,"title":"Sattu Sharbat","description":"Bihar's super-food energy drink — roasted chickpea flour (sattu) mixed with lemon, black salt and cumin. Protein-packed and cooling.","ingredients":["4 tbsp sattu (roasted chickpea flour)","1 lemon, juiced","1 tsp black salt","½ tsp cumin powder","1 tbsp jaggery or sugar","3 cups cold water","Mint and ginger for garnish"],"instructions":["Dissolve sattu in ½ cup cold water, stirring vigorously to avoid lumps.","Add lemon juice, black salt, cumin, and jaggery.","Add remaining cold water. Mix well.","Taste and adjust seasoning — should be tangy and salty.","Serve immediately with ice, mint, and grated ginger."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"East Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-sattu-sharbat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sattu%20Sharbat%20Bihar%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.909Z"},{"id":192,"title":"Khas Sharbat","description":"Vetiver (khus) root green sharbat — intensely fragrant and earth-cooling. North India's Ramadan and summer speciality.","ingredients":["4 tbsp khas (vetiver) syrup","2 cups chilled water OR milk","Ice cubes","Lemon slices","Mint leaves","Sabja seeds, soaked (optional)"],"instructions":["Soak sabja seeds in water for 20 minutes if using.","Add khas syrup to glasses.","Fill with chilled water or milk.","Add ice cubes.","Add sabja seeds.","Garnish with lemon slice and mint."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-khas-sharbat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Khas%20Vetiver%20Sharbat%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.912Z"},{"id":193,"title":"Fresh Pomegranate Juice","description":"Freshly extracted ruby pomegranate juice with a hint of black salt and lemon — packed with antioxidants and stunning to look at.","ingredients":["4 large pomegranates","1 tsp black salt","1 lemon, juiced","1 tsp sugar (optional)","Ice cubes","Mint for garnish"],"instructions":["Deseed pomegranates. Place seeds in a blender.","Blend on low speed for 30 seconds — just enough to extract juice without crushing the bitter membranes.","Strain through fine mesh immediately.","Add black salt, lemon juice, and sugar.","Pour over ice. Garnish with a few seeds and mint.","Serve immediately as pomegranate juice oxidises quickly."],"prepTime":15,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-fresh-pomegranate-juice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Fresh%20Pomegranate%20Juice%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.914Z"},{"id":194,"title":"Sugarcane Juice","description":"India's iconic street juice — freshly pressed sugarcane with ginger and lemon, a natural instant energy booster.","ingredients":["500g sugarcane pieces (or use a juicer)","1-inch ginger piece","1 lemon, juiced","A pinch of black salt","Ice cubes","Mint leaves"],"instructions":["Pass sugarcane through a sugarcane press or juicer to extract fresh juice.","Grate ginger and squeeze ginger juice into the cane juice.","Add lemon juice and black salt.","Strain through fine mesh.","Serve immediately over ice with mint.","Fresh sugarcane juice must be consumed within 15 minutes."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-sugarcane-juice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sugarcane%20Juice%20Ganna%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.917Z"},{"id":195,"title":"Carrot Ginger Juice","description":"Vibrant orange juice with a fiery ginger kick — nutrient-dense, immune-boosting and beautiful in the glass.","ingredients":["6 medium carrots, peeled","1-inch fresh ginger","1 lemon, juiced","1 tsp honey or sugar","A pinch of black pepper","Ice cubes"],"instructions":["Pass carrots and ginger through a juicer.","Add lemon juice and honey. Mix.","Add a tiny pinch of black pepper — it enhances the ginger flavour.","Strain if desired.","Serve immediately over ice."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-carrot-ginger-juice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Carrot%20Ginger%20Juice%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.919Z"},{"id":196,"title":"Beetroot Apple Juice","description":"Deep ruby red detox juice — earthy beetroot and sweet apple balanced with lemon and ginger. Stunning colour, remarkable nutrition.","ingredients":["2 medium beetroots, peeled","2 apples, cored","1-inch ginger","1 lemon, juiced","1 tsp honey","A pinch of black salt","Ice cubes"],"instructions":["Pass beetroot, apples, and ginger through a juicer.","Add lemon juice, honey, and black salt. Mix.","Taste and adjust. Apple sweetness varies.","Serve immediately over ice.","This juice is best drunk within 30 minutes for maximum nutrition."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-beetroot-apple-juice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Beetroot%20Apple%20Juice%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.921Z"},{"id":197,"title":"Watermelon Mint Juice","description":"Summer in a glass — pure watermelon juice with fresh mint, black salt and a squeeze of lemon. Simple perfection.","ingredients":["½ medium watermelon, cubed, seeds removed","10 fresh mint leaves","1 lemon, juiced","A pinch of black salt","A pinch of cumin powder","Ice cubes"],"instructions":["Blend watermelon until smooth. Strain if desired.","Add mint leaves and blend briefly.","Mix in lemon juice, black salt, and cumin.","Pour over ice.","Garnish with a mint sprig and a wedge of watermelon."],"prepTime":10,"cookTime":0,"servings":3,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-watermelon-mint-juice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Watermelon%20Mint%20Juice%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.924Z"},{"id":198,"title":"Pineapple Mint Cooler","description":"Tropical Indian cooler — fresh pineapple juice with mint, ginger and a hint of black salt. Brilliantly tart and refreshing.","ingredients":["½ pineapple, peeled and cubed","10 fresh mint leaves","1-inch ginger","1 lime, juiced","1 tbsp sugar","A pinch of black salt","Soda water (optional)","Ice cubes"],"instructions":["Juice pineapple chunks through a juicer or blend and strain.","Muddle mint leaves with ginger in a glass.","Add pineapple juice, lime juice, sugar, and black salt.","Stir or shake well.","Pour over ice. Top with soda water if desired.","Garnish with pineapple chunks and mint."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-pineapple-mint-cooler.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pineapple%20Mint%20Cooler%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.926Z"},{"id":199,"title":"Mosambi Juice","description":"Sweet lime juice — freshly squeezed mosambi (sweet lime) is India's most beloved fresh fruit juice, served at every juice stall.","ingredients":["8 mosambi (sweet lime) fruits","1 tsp black salt","½ tsp cumin powder","Ice cubes","Mint leaves"],"instructions":["Squeeze mosambi through a citrus juicer or press.","Strain to remove seeds and pulp if desired.","Add black salt and cumin powder.","Stir well.","Serve immediately over ice with mint.","Do NOT store — mosambi juice turns bitter within 15 minutes."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-mosambi-juice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mosambi%20Sweet%20Lime%20Juice%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.929Z"},{"id":200,"title":"Guava Cooler","description":"Pink guava juice with chilli, black salt and lemon — India's favourite seasonal fruit becomes a perfectly spiced drink.","ingredients":["4 ripe pink guavas","2 tbsp sugar","1 lemon, juiced","½ tsp black salt","A pinch of red chilli powder","2 cups cold water","Ice cubes","Mint"],"instructions":["Quarter guavas and blend with 1 cup water until smooth.","Strain through a fine sieve, pressing to extract all juice.","Add remaining water, sugar, lemon, black salt, and chilli powder.","Mix well. Taste and adjust.","Serve over ice with mint."],"prepTime":10,"cookTime":0,"servings":3,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-guava-cooler.png","youtubeUrl":"https://www.youtube.com/results?search_query=Guava%20Juice%20Amrud%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.932Z"},{"id":201,"title":"Litchi Mint Mocktail","description":"Fresh litchi juice with mint and lemon — delicately sweet, floral and impossibly refreshing for Indian summers.","ingredients":["20 fresh litchis, peeled and deseeded","10 mint leaves","1 lime, juiced","1 tbsp sugar","Soda water","Ice cubes","Lime rounds for garnish"],"instructions":["Blend litchis until smooth. Strain through a sieve.","Muddle mint leaves with lime juice and sugar in a glass.","Add litchi juice. Stir well.","Fill glass with ice.","Top with soda water.","Garnish with lime rounds and mint sprigs."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-litchi-mint-mocktail.png","youtubeUrl":"https://www.youtube.com/results?search_query=Litchi%20Mocktail%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.934Z"},{"id":202,"title":"Virgin Mojito Indian Style","description":"Indian-style mint mojito with green mango, lemon and ginger — a tangy-minty sparkling drink that's both cooling and exciting.","ingredients":["10 fresh mint leaves","1 green chilli, deseeded (optional)","2 lime wedges","1 tsp sugar","2 tbsp raw mango pulp or aam panna","A pinch of black salt","100ml soda water","Ice cubes"],"instructions":["Muddle mint leaves, lime wedges, chilli, and sugar in a glass until fragrant.","Add raw mango pulp and black salt. Stir.","Fill glass with crushed ice.","Pour soda water over slowly.","Stir gently with a long spoon.","Garnish with a mint sprig and lime wedge."],"prepTime":5,"cookTime":0,"servings":1,"cuisineType":"Fusion","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-virgin-mojito-indian-style.png","youtubeUrl":"https://www.youtube.com/results?search_query=Indian%20Virgin%20Mojito%20Green%20Mango%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.937Z"},{"id":203,"title":"Banana Milkshake","description":"Thick, creamy banana milkshake with cardamom — nourishing, naturally sweet and beloved by kids across India.","ingredients":["3 ripe bananas","2 cups cold full-fat milk","2 tbsp sugar (adjust)","½ tsp cardamom powder","2 scoops vanilla ice cream","Ice cubes"],"instructions":["Peel and freeze bananas for 30 minutes for an extra thick shake.","Blend bananas, milk, sugar, and cardamom until smooth.","Add ice cream and blend again briefly.","Pour into tall chilled glasses.","Garnish with banana slice and a pinch of cardamom."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-banana-milkshake.png","youtubeUrl":"https://www.youtube.com/results?search_query=Banana%20Milkshake%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.940Z"},{"id":204,"title":"Chikoo Milkshake","description":"Sapodilla (chikoo) milkshake — silky smooth, naturally caramel-sweet and deeply indulgent. A true Maharashtra childhood classic.","ingredients":["4 ripe chikoos (sapodilla), peeled and deseeded","2 cups cold full-fat milk","2 tbsp sugar","½ tsp cardamom","2 scoops vanilla ice cream","Ice cubes"],"instructions":["Remove seeds from chikoos. Blend with cold milk until completely smooth.","Add sugar, cardamom, and ice cream. Blend until frothy.","Pour into tall glasses over ice.","The natural sweetness of chikoo means you may need less sugar."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-chikoo-milkshake.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chikoo%20Milkshake%20Sapodilla%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.943Z"},{"id":205,"title":"Badam Milk","description":"Saffron-golden almond milk — soaked almonds ground with saffron-infused warm milk, chilled and served. A royal Indian drink.","ingredients":["20 almonds, soaked overnight and peeled","1 litre full-fat milk","3 tbsp sugar","½ tsp cardamom powder","A generous pinch of saffron in 2 tbsp warm milk","Slivered pistachios for garnish"],"instructions":["Grind soaked, peeled almonds to a fine paste with 2 tbsp milk.","Boil remaining milk. Add almond paste and stir well.","Add sugar, saffron milk, and cardamom.","Cook on medium heat for 10 minutes until slightly thickened.","Cool completely. Refrigerate.","Serve chilled with slivered pistachios — or serve warm on cold nights."],"prepTime":480,"cookTime":15,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-badam-milk.png","youtubeUrl":"https://www.youtube.com/results?search_query=Badam%20Milk%20Almond%20Milk%20Indian%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.945Z"},{"id":206,"title":"Haldi Doodh","description":"Golden milk — warm turmeric milk with ginger, cardamom and black pepper. India's ancient immunity booster and bedtime ritual.","ingredients":["2 cups full-fat milk","1 tsp turmeric powder","½ tsp ginger, grated or powdered","A pinch of black pepper","¼ tsp cardamom powder","1 tbsp honey or jaggery","1 tsp ghee (optional)"],"instructions":["Warm milk in a small saucepan on medium heat.","Add turmeric, ginger, cardamom, and black pepper.","Whisk gently as it heats — do not boil.","Remove from heat. Add honey or jaggery.","Add a tiny drop of ghee if desired — it enhances absorption of turmeric.","Pour into mugs and serve warm."],"prepTime":5,"cookTime":8,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-haldi-doodh.png","youtubeUrl":"https://www.youtube.com/results?search_query=Haldi%20Doodh%20Golden%20Milk%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.948Z"},{"id":207,"title":"Dry Fruit Milkshake","description":"Rich and nourishing dry fruit milkshake — almonds, cashews, dates and saffron blended with whole milk. A festive Indian treat.","ingredients":["10 almonds, soaked","8 cashews","4 medjool dates, pitted","2 tbsp raisins","2 cups cold full-fat milk","½ tsp cardamom","A pinch of saffron","1 tsp sugar (optional)","Ice cubes"],"instructions":["Soak almonds for 4 hours. Peel.","Blend almonds, cashews, dates, and raisins with ½ cup milk until smooth.","Add remaining milk, cardamom, and saffron. Blend until frothy.","Taste and add sugar only if needed — dates provide natural sweetness.","Serve over ice or warm as a nourishing drink."],"prepTime":245,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-dry-fruit-milkshake.png","youtubeUrl":"https://www.youtube.com/results?search_query=Dry%20Fruit%20Milkshake%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.950Z"},{"id":208,"title":"Cold Coffee","description":"Indian-style cold coffee — thick, frothy and sweet, blended with ice cream and cold milk. The café classic made at home.","ingredients":["2 tsp instant coffee","2 tbsp sugar","2 tbsp hot water","2 cups cold full-fat milk","2 scoops vanilla ice cream","Ice cubes","Chocolate syrup for garnish"],"instructions":["Dissolve instant coffee in hot water. Cool completely.","Blend coffee, sugar, milk, and ice cream until very frothy.","Pour over ice in tall glasses.","Drizzle chocolate syrup on top.","For extra thick: add more ice cream and less milk."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-cold-coffee.png","youtubeUrl":"https://www.youtube.com/results?search_query=Cold%20Coffee%20Indian%20style%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.953Z"},{"id":209,"title":"Shikanji","description":"Delhi's street lemonade — freshly squeezed lemon with black salt, roasted cumin and optional dried ginger. Quick, cheap and perfect.","ingredients":["4 lemons, juiced","4 tbsp sugar","½ tsp black salt","½ tsp cumin powder, roasted","¼ tsp dry ginger powder","4 cups cold water","Ice cubes","Lemon slices for garnish"],"instructions":["Make sugar syrup by dissolving sugar in 2 tbsp hot water. Cool.","Mix lemon juice with cold water.","Add sugar syrup, black salt, cumin powder, and dry ginger.","Mix well. Taste and adjust seasoning.","Pour over ice.","Garnish with lemon slices."],"prepTime":5,"cookTime":0,"servings":4,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-shikanji.png","youtubeUrl":"https://www.youtube.com/results?search_query=Shikanji%20Delhi%20Lemonade%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.956Z"},{"id":210,"title":"Kiwi Mint Mocktail","description":"Vibrant green kiwi and mint cooler — tangy, sweet and utterly refreshing with a fizzy finish.","ingredients":["4 ripe kiwis, peeled","10 mint leaves","1 lime, juiced","2 tbsp sugar","Soda water","Ice cubes","Kiwi slices for garnish"],"instructions":["Blend kiwis until smooth. Strain if desired.","Muddle mint leaves with sugar and lime juice in a jug.","Add kiwi juice. Stir well.","Pour into glasses over ice.","Top with soda water.","Garnish with kiwi slices and mint."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Fusion","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-kiwi-mint-mocktail.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kiwi%20Mint%20Mocktail%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.958Z"},{"id":211,"title":"Strawberry Lemonade","description":"Summer's most loved cooler — freshly muddled strawberries with lemon, sugar and chilled water. Naturally vibrant pink.","ingredients":["1 cup fresh strawberries","4 lemons, juiced","4 tbsp sugar","4 cups cold water","Ice cubes","Strawberry slices and mint for garnish"],"instructions":["Blend strawberries until smooth. Strain.","Make sugar syrup with sugar and 2 tbsp hot water.","Mix strawberry juice, lemon juice, sugar syrup, and cold water.","Taste and adjust — more lemon for tartness, more sugar for sweetness.","Pour over ice.","Garnish with strawberry slices and mint."],"prepTime":10,"cookTime":0,"servings":4,"cuisineType":"Fusion","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-strawberry-lemonade.png","youtubeUrl":"https://www.youtube.com/results?search_query=Strawberry%20Lemonade%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.961Z"},{"id":212,"title":"Mixed Fruit Punch","description":"Festive fruit punch — mango, orange, pineapple and lemon juices with a dash of rose water and ginger. Party in a glass.","ingredients":["1 cup mango juice","1 cup orange juice","1 cup pineapple juice","2 lemons, juiced","1 tsp rose water","½-inch ginger, grated","2 tbsp sugar","Soda water","Ice cubes","Mixed fruit and mint for garnish"],"instructions":["Mix all fruit juices together.","Add lemon juice, rose water, ginger juice, and sugar.","Taste and adjust sweetness.","Refrigerate for 1 hour.","Serve over ice, topped with soda water.","Garnish with fresh fruit and mint."],"prepTime":15,"cookTime":0,"servings":6,"cuisineType":"Fusion","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-mixed-fruit-punch.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mixed%20Fruit%20Punch%20Indian%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.964Z"},{"id":213,"title":"Tamarind Soda","description":"Imli soda — sweet-sour tamarind concentrate with spices topped with soda water. Street food in a glass.","ingredients":["4 tbsp tamarind paste","4 tbsp sugar","1 tsp black salt","½ tsp cumin powder","A pinch of red chilli powder","Cold soda water","Ice cubes","Mint for garnish"],"instructions":["Mix tamarind paste with sugar, black salt, cumin, and chilli powder.","Add 2 tbsp warm water to dissolve. Mix to smooth concentrate.","Taste — it should be tangy, sweet and spiced.","Place 2 tbsp concentrate in each glass.","Add ice cubes.","Top with cold soda water. Garnish with mint."],"prepTime":5,"cookTime":0,"servings":4,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-tamarind-soda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tamarind%20Soda%20Imli%20Drink%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.966Z"},{"id":214,"title":"Coconut Lemonade","description":"Refreshing coconut water with fresh lemon juice, mint and a pinch of pink Himalayan salt. Naturally electrolyte-rich.","ingredients":["2 cups fresh coconut water","2 lemons, juiced","2 tbsp honey or sugar","10 mint leaves","A pinch of Himalayan pink salt","Ice cubes","Coconut pieces for garnish"],"instructions":["Combine fresh coconut water and lemon juice.","Add honey and salt. Stir until dissolved.","Muddle mint leaves and add.","Pour over ice.","Garnish with coconut pieces and mint.","Best served immediately as coconut water loses freshness quickly."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-coconut-lemonade.png","youtubeUrl":"https://www.youtube.com/results?search_query=Coconut%20Lemonade%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.968Z"},{"id":215,"title":"Ginger Lemon Fizz","description":"Fiery Indian ginger beer-style drink — fresh ginger syrup with lemon and soda. Warming and cooling at the same time.","ingredients":["2-inch fresh ginger, juiced or grated","2 lemons, juiced","3 tbsp sugar","A pinch of black salt","Cold soda water","Ice cubes","Lemon slices and candied ginger for garnish"],"instructions":["Make ginger syrup: simmer sugar with ½ cup water and ginger slices for 5 minutes. Cool and strain.","Mix ginger syrup with lemon juice and black salt.","Pour into glasses over ice.","Top generously with soda water.","Garnish with lemon slices and candied ginger."],"prepTime":5,"cookTime":5,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-ginger-lemon-fizz.png","youtubeUrl":"https://www.youtube.com/results?search_query=Ginger%20Lemon%20Fizz%20Mocktail%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.971Z"},{"id":216,"title":"Cucumber Cooler","description":"Clean, refreshing cucumber and mint juice with lemon and black salt — the lightest, most cooling summer drink.","ingredients":["2 cucumbers, peeled and roughly chopped","10 mint leaves","1 lemon, juiced","1 green chilli (optional)","1 tsp sugar","½ tsp black salt","Cold water","Ice cubes"],"instructions":["Blend cucumber with mint, lemon juice, chilli, sugar, and black salt.","Add a little cold water to help blend.","Strain through fine mesh.","Adjust water to desired consistency.","Serve over ice."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-cucumber-cooler.png","youtubeUrl":"https://www.youtube.com/results?search_query=Cucumber%20Cooler%20Drink%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.973Z"},{"id":217,"title":"Rooh Afza Milk","description":"The timeless Indian summer drink — chilled rose-scented syrup stirred into full-fat milk with sabja seeds. Nostalgia in every sip.","ingredients":["4 tbsp Rooh Afza syrup","2 cups chilled full-fat milk","2 tbsp sabja (basil) seeds, soaked","Ice cubes","Rose petals for garnish"],"instructions":["Soak sabja seeds in water for 20 minutes until fully bloomed.","Pour Rooh Afza into tall glasses.","Add ice cubes.","Pour chilled milk over gently — the beautiful pink and white layers will form.","Add bloomed sabja seeds.","Garnish with rose petals. Stir before drinking."],"prepTime":25,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-rooh-afza-milk.png","youtubeUrl":"https://www.youtube.com/results?search_query=Rooh%20Afza%20Milk%20Drink%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.976Z"},{"id":218,"title":"Spinach Apple Detox Juice","description":"Vibrant green health juice — baby spinach, green apple, cucumber and lemon blended together. An Indian wellness staple.","ingredients":["2 cups baby spinach","2 green apples, cored","1 cucumber","1 lemon, juiced","1-inch ginger","1 tsp honey","Ice cubes"],"instructions":["Pass spinach, apple, cucumber, and ginger through a juicer.","Add lemon juice and honey. Mix.","Serve immediately over ice — green juices lose nutrition quickly.","Can also be blended (with water) and strained for a smoother version."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Fusion","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-spinach-apple-detox-juice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Spinach%20Apple%20Detox%20Juice%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.978Z"},{"id":219,"title":"Kokum Juice","description":"Goan-style fresh kokum juice — just kokum, water, sugar and salt. Cooling, blood pressure-balancing and deeply tart.","ingredients":["15 kokum pieces","3 cups warm water","3 tbsp sugar","½ tsp black salt","½ tsp cumin powder","Ice cubes","Fresh coriander"],"instructions":["Soak kokum in warm water for 45 minutes until it softens completely and releases its juice.","Squeeze and strain the deep purple juice thoroughly.","Dissolve sugar in the juice. Add black salt and cumin.","Taste — should be deeply tart, slightly sweet, and pleasantly salty.","Dilute with a little cold water if too concentrated.","Serve over ice with fresh coriander."],"prepTime":50,"cookTime":0,"servings":3,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-kokum-juice.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kokum%20Juice%20Sol%20Kadhi%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.980Z"},{"id":220,"title":"Masala Chaas","description":"Full-flavoured spiced buttermilk with tempered mustard seeds, ginger, and curry leaves — a full-bodied digestive drink.","ingredients":["1½ cups yogurt","2 cups cold water","1 tsp ginger, grated","½ tsp cumin powder","¼ tsp black salt","A few curry leaves","½ tsp mustard seeds","1 green chilli","1 tsp oil","Fresh coriander","Salt to taste"],"instructions":["Blend yogurt and water until smooth.","Add ginger, cumin, black salt, and regular salt. Mix.","Heat oil in a small pan. Add mustard seeds until they pop.","Add curry leaves and green chilli. Fry 30 seconds.","Pour tempering over the chaas. Stir.","Garnish with fresh coriander. Serve chilled."],"prepTime":5,"cookTime":3,"servings":3,"cuisineType":"Gujarati","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-masala-chaas.png","youtubeUrl":"https://www.youtube.com/results?search_query=Masala%20Chaas%20Buttermilk%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.983Z"},{"id":221,"title":"Kesar Badam Shake","description":"Royal saffron and almond milkshake with rose water and cardamom — thick, golden and luxurious. Festival drink at its finest.","ingredients":["15 almonds, soaked and peeled","A generous pinch of saffron in 2 tbsp warm milk","2 cups full-fat cold milk","3 tbsp sugar","½ tsp cardamom","1 tsp rose water","2 scoops vanilla ice cream","Slivered almonds and pistachios for garnish"],"instructions":["Blend soaked almonds with 2 tbsp milk to a smooth paste.","Add cold milk, saffron milk, sugar, cardamom, and rose water. Blend until frothy.","Add ice cream and blend again briefly.","Pour into chilled glasses.","Garnish with slivered almonds, pistachios and a saffron strand."],"prepTime":245,"cookTime":0,"servings":2,"cuisineType":"North Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-kesar-badam-shake.png","youtubeUrl":"https://www.youtube.com/results?search_query=Kesar%20Badam%20Shake%20Saffron%20Almond%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.986Z"},{"id":222,"title":"Jaljeera Soda","description":"Classic jal jeera concentrate lifted with sparkling soda — tangy, spiced, minty and wonderfully effervescent.","ingredients":["2 tbsp jaljeera powder (or homemade concentrate)","2 tbsp tamarind water","1 tsp black salt","1 tsp sugar","Lemon juice","Cold soda water","Ice cubes","Mint and boondi for garnish"],"instructions":["Mix jaljeera powder (or concentrate) with tamarind water, black salt, sugar, and lemon juice.","Taste and adjust — should be intensely spiced.","Place 2 tbsp of concentrate in each glass.","Add ice.","Top with cold soda water.","Garnish with mint, a few boondi, and a lemon wedge."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"North Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-jaljeera-soda.png","youtubeUrl":"https://www.youtube.com/results?search_query=Jaljeera%20Soda%20Mocktail%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.988Z"},{"id":223,"title":"Mango Ginger Lassi","description":"Spiced mango lassi with a warming ginger kick — the perfect balance of cooling and warming for year-round enjoyment.","ingredients":["1 cup mango pulp","1 cup yogurt","½ cup milk","1-inch ginger, juiced","2 tbsp sugar","½ tsp cardamom","Ice cubes","Mango pieces and candied ginger for garnish"],"instructions":["Blend mango pulp, yogurt, milk, sugar, ginger juice, and cardamom until smooth.","Taste — mango sweetness varies. Adjust sugar accordingly.","Pour over ice.","Garnish with mango pieces and ginger."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"Pan-Indian","dietaryTags":["Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-mango-ginger-lassi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Mango%20Ginger%20Lassi%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.991Z"},{"id":224,"title":"Paan Sharbat","description":"Refreshing betel leaf sharbat with fennel, gulkand and mint — India's most distinctive post-meal palate cleanser turned cooling drink.","ingredients":["5 fresh betel (paan) leaves","2 tbsp gulkand (rose petal jam)","1 tbsp fennel seeds, soaked","A pinch of cardamom","2 tbsp sugar","2 cups cold water","Ice cubes","Rose petals and fennel for garnish"],"instructions":["Soak fennel seeds in water for 30 minutes.","Blend paan leaves, gulkand, soaked fennel seeds, cardamom, and sugar with a little water.","Strain through fine mesh.","Mix with remaining cold water. Taste and adjust.","Serve over ice.","Garnish with rose petals and a few fennel seeds."],"prepTime":35,"cookTime":0,"servings":3,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-paan-sharbat.png","youtubeUrl":"https://www.youtube.com/results?search_query=Paan%20Sharbat%20Betel%20Leaf%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.994Z"},{"id":225,"title":"Grape Mint Cooler","description":"Fresh grape juice muddled with mint, lime and chilled soda — deeply purple, sweet-tart and utterly elegant.","ingredients":["2 cups fresh black grapes","10 mint leaves","1 lime, juiced","2 tbsp sugar","Soda water","Ice cubes","Grape clusters and mint for garnish"],"instructions":["Blend grapes until smooth. Strain through a sieve.","Muddle mint with lime juice and sugar.","Mix grape juice with mint mixture.","Pour over ice in glasses.","Top with soda water.","Garnish with grape clusters and mint."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"Fusion","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-grape-mint-cooler.png","youtubeUrl":"https://www.youtube.com/results?search_query=Grape%20Mint%20Cooler%20Mocktail%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.996Z"},{"id":226,"title":"Sol Kadhi","description":"Goa and Konkan's iconic pink coconut milk and kokum digestive drink — velvety, gently tart and spiced with garlic and cumin.","ingredients":["10 kokum pieces","1 cup thick coconut milk","2 cups water","1 garlic clove, crushed","½ tsp cumin powder","Green chilli, slit","Fresh coriander","Salt to taste"],"instructions":["Soak kokum in 1 cup warm water for 30 minutes. Squeeze and strain.","Mix kokum water with coconut milk and remaining water.","Add crushed garlic, cumin, green chilli, and salt.","Whisk until the colour turns a beautiful pink from the kokum.","Refrigerate 30 minutes.","Serve cold, garnished with fresh coriander. Do not heat."],"prepTime":35,"cookTime":0,"servings":4,"cuisineType":"Maharashtrian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-sol-kadhi.png","youtubeUrl":"https://www.youtube.com/results?search_query=Sol%20Kadhi%20Goan%20Kokum%20Coconut%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:56.999Z"},{"id":227,"title":"Turmeric Ginger Lemonade","description":"Sunshine in a glass — fresh turmeric, ginger and lemon with honey and black pepper. The ultimate Indian wellness drink.","ingredients":["1-inch fresh turmeric, juiced (or ½ tsp powder)","1-inch ginger, juiced","3 lemons, juiced","2 tbsp honey","A pinch of black pepper","3 cups cold water","Ice cubes","Lemon wheels and turmeric for garnish"],"instructions":["Juice fresh turmeric and ginger if available.","Mix turmeric juice, ginger juice, lemon juice, honey, and black pepper.","Add cold water. Stir vigorously.","Taste and adjust sweetness with honey.","Pour over ice.","Garnish with lemon wheels and a tiny pinch of turmeric powder."],"prepTime":10,"cookTime":0,"servings":3,"cuisineType":"Pan-Indian","dietaryTags":["Vegan","Gluten-Free"],"category":"mocktail","imageUrl":"/stock-images/recipe-turmeric-ginger-lemonade.png","youtubeUrl":"https://www.youtube.com/results?search_query=Turmeric%20Ginger%20Lemonade%20indian%20recipe%20homemade","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-11T01:34:57.002Z"}]













































