6:30:14 PM [express] GET /api/recipes 200 in 94ms :: [{"id":312,"title":"Cottage Cheese & Hemp Bowl","description":"A quick, protein-packed no-cook bowl of creamy cottage cheese layered with nutty hemp hearts and cool cucumber — ready in 2 minutes and delivering 30g+ protein.","ingredients":["1 cup cottage cheese","3 tbsp hemp hearts","½ cup cucumber, sliced","Pinch of black pepper","Pinch of chilli flakes (optional)","Fresh dill or chives to garnish"],"instructions":["Spoon cottage cheese into a bowl.","Layer cucumber slices on top.","Sprinkle hemp hearts evenly over the bowl.","Season with black pepper and chilli flakes.","Garnish with fresh herbs and serve immediately."],"prepTime":2,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-cottage-cheese-hemp-bowl.png","youtubeUrl":"https://www.youtube.com/results?search_query=Cottage%20Cheese%20Hemp%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.864Z"},{"id":313,"title":"Greek Yogurt Whey Mix","description":"Thick non-fat Greek yogurt blended with a scoop of vanilla whey protein and topped with walnuts — a creamy, high-protein snack or breakfast with minimal effort.","ingredients":["1 cup non-fat Greek yogurt","½ scoop vanilla whey protein powder","2 tbsp walnuts, roughly chopped","1 tsp honey (optional)","A pinch of cinnamon"],"instructions":["Spoon Greek yogurt into a bowl.","Stir in vanilla whey protein until smooth.","Top with walnuts and a pinch of cinnamon.","Drizzle with honey if desired.","Serve immediately."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-greek-yogurt-whey-mix.png","youtubeUrl":"https://www.youtube.com/results?search_query=Greek%20Yogurt%20Protein%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.897Z"},{"id":314,"title":"Savory Tofu Toast","description":"Slices of pressed extra-firm tofu piled on high-protein bread with creamy avocado and a shower of nutritional yeast — a satisfying no-cook open sandwich.","ingredients":["3 slices extra-firm tofu, pressed and sliced","2 slices high-protein bread","½ avocado, mashed","2 tbsp nutritional yeast","1 tsp lemon juice","Salt, pepper and chilli flakes","Microgreens to garnish"],"instructions":["Toast the bread if desired (or serve as is for fully no-cook).","Spread mashed avocado on the bread. Season with lemon, salt and pepper.","Lay tofu slices on top.","Shower generously with nutritional yeast and chilli flakes.","Garnish with microgreens and serve."],"prepTime":5,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-savory-tofu-toast.png","youtubeUrl":"https://www.youtube.com/results?search_query=Savory%20Tofu%20Toast%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.901Z"},{"id":315,"title":"Peanut Butter Greek Yogurt Dip","description":"Greek yogurt swirled with peanut butter creates a thick, protein-rich dip that pairs perfectly with apple slices or celery sticks for a nourishing snack.","ingredients":["1 cup Greek yogurt","1 tbsp natural peanut butter","1 tsp honey","½ tsp cinnamon","Apple slices or celery sticks to serve"],"instructions":["Combine Greek yogurt, peanut butter, honey and cinnamon in a small bowl.","Stir until fully incorporated and creamy.","Serve immediately with apple slices or celery sticks for dipping."],"prepTime":3,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-peanut-butter-greek-yogurt-dip.png","youtubeUrl":"https://www.youtube.com/results?search_query=Peanut%20Butter%20Yogurt%20Dip%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.904Z"},{"id":316,"title":"Tofu Egg Salad","description":"Crumbled firm tofu mimics the texture of egg salad, mixed with tangy Greek yogurt instead of mayo, mustard and turmeric for colour — a brilliant vegan protein lunch.","ingredients":["200g firm tofu, pressed and crumbled","3 tbsp Greek yogurt","1 tsp Dijon mustard","½ tsp turmeric","1 tbsp spring onions, sliced","Salt and pepper","Paprika to garnish","Bread or crackers to serve"],"instructions":["Crumble pressed tofu into a bowl with your hands to create a chunky texture.","Add Greek yogurt, mustard, turmeric, spring onions, salt and pepper.","Mix until well combined. Taste and adjust seasoning.","Garnish with paprika and serve on bread, crackers or lettuce cups."],"prepTime":10,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-tofu-egg-salad.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tofu%20Egg%20Salad%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.907Z"},{"id":317,"title":"Ricotta & Almond Plate","description":"Velvety ricotta topped with slivered almonds and a delicate drizzle of honey — a simple, elegant Italian-inspired protein plate.","ingredients":["½ cup ricotta cheese","2 tbsp slivered almonds","1 tsp honey","A pinch of sea salt","Fresh thyme or lemon zest to garnish","Crackers or crostini to serve"],"instructions":["Spoon ricotta onto a small serving plate and spread slightly.","Scatter slivered almonds over the top.","Drizzle with honey and a tiny pinch of sea salt.","Garnish with fresh thyme or a little lemon zest.","Serve with crackers or crostini."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-ricotta-almond-plate.png","youtubeUrl":"https://www.youtube.com/results?search_query=Ricotta%20Almond%20Plate%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.911Z"},{"id":318,"title":"Paneer Salad (Raw)","description":"Cubes of fresh paneer tossed with chaat masala, lemon juice and raw sprouts — a quick Indian-inspired high-protein salad that needs zero cooking.","ingredients":["200g fresh paneer, cubed","1 cup mixed sprouts (moong, chickpea)","½ red onion, finely sliced","1 tomato, diced","1 green chilli, finely chopped (optional)","1 tsp chaat masala","Juice of 1 lemon","Fresh coriander and mint"],"instructions":["Combine paneer cubes, sprouts, red onion, tomato and green chilli in a bowl.","Sprinkle chaat masala and squeeze lemon juice over the top.","Toss gently so paneer doesn't break.","Garnish with coriander and mint. Serve immediately."],"prepTime":8,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-paneer-salad-raw.png","youtubeUrl":"https://www.youtube.com/results?search_query=Raw%20Paneer%20Salad%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.916Z"},{"id":319,"title":"Chickpea Tuna Salad","description":"Smashed chickpeas mixed with Greek yogurt, capers and optional seaweed flakes create an addictive plant-based tuna-style filling for wraps or toast.","ingredients":["1 can chickpeas, drained and rinsed","3 tbsp Greek yogurt","1 tbsp capers","1 tbsp seaweed flakes (optional, for a sea flavour)","1 tsp Dijon mustard","1 tsp lemon juice","Salt and pepper","High-protein wrap or bread to serve"],"instructions":["Drain and rinse chickpeas. Place in a bowl and smash roughly with a fork — keep some texture.","Add Greek yogurt, capers, seaweed flakes, mustard and lemon juice.","Mix well. Season with salt and pepper.","Serve inside a wrap, on toast or over salad greens."],"prepTime":8,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-chickpea-tuna-salad.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chickpea%20Tuna%20Salad%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.921Z"},{"id":320,"title":"Lentil & Feta Bowl","description":"Ready-to-eat canned lentils with crumbled feta, olives and a lemon dressing — a protein-and-fibre powerhouse lunch that requires no cooking whatsoever.","ingredients":["1 can brown or green lentils, drained and rinsed","60g feta cheese, crumbled","¼ cup Kalamata olives, halved","½ cucumber, diced","1 tbsp olive oil","1 tbsp lemon juice","1 tsp dried oregano","Salt and pepper","Fresh parsley"],"instructions":["Rinse lentils and place in a bowl.","Add olives, cucumber and crumbled feta.","Drizzle with olive oil and lemon juice. Sprinkle oregano, salt and pepper.","Toss gently. Garnish with parsley and serve."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-lentil-feta-bowl.png","youtubeUrl":"https://www.youtube.com/results?search_query=Lentil%20Feta%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.925Z"},{"id":321,"title":"Three-Bean Salad","description":"Kidney beans, black beans and chickpeas tossed in a bright lime-cumin dressing — a classic high-protein no-cook salad that keeps well in the fridge for days.","ingredients":["½ cup kidney beans, canned and rinsed","½ cup black beans, canned and rinsed","½ cup chickpeas, canned and rinsed","½ red onion, finely diced","1 capsicum, diced","Juice of 2 limes","2 tbsp olive oil","1 tsp cumin powder","1 tsp coriander powder","Salt and pepper","Fresh coriander"],"instructions":["Combine all three beans in a large bowl.","Add red onion and capsicum.","Whisk together lime juice, olive oil, cumin, coriander, salt and pepper.","Pour dressing over beans and toss well.","Garnish with coriander. Rest 10 minutes for flavours to develop before serving."],"prepTime":10,"cookTime":0,"servings":4,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-three-bean-salad.png","youtubeUrl":"https://www.youtube.com/results?search_query=Three%20Bean%20Salad%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.929Z"},{"id":322,"title":"Edamame & Hummus Wrap","description":"Thawed shelled edamame with a thick spread of hummus in a high-protein tortilla — fast, filling and easily customisable with your favourite vegetables.","ingredients":["½ cup shelled edamame, thawed","3 tbsp hummus","1 high-protein tortilla","¼ avocado, sliced","¼ cup baby spinach","¼ cup grated carrot","1 tsp lemon juice","Salt and pepper","Chilli flakes (optional)"],"instructions":["Lay the tortilla flat. Spread hummus thickly across the surface.","Layer spinach, carrot and avocado slices.","Scatter edamame evenly. Drizzle with lemon juice, salt, pepper and chilli flakes.","Roll the tortilla tightly, slice in half and serve."],"prepTime":5,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-edamame-hummus-wrap.png","youtubeUrl":"https://www.youtube.com/results?search_query=Edamame%20Hummus%20Wrap%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.934Z"},{"id":323,"title":"White Bean & Pesto Mash","description":"Cannellini beans mashed with vibrant pesto and topped with pumpkin seeds — a creamy, protein-rich spread for toast, crackers or a simple side.","ingredients":["1 can cannellini beans, drained and rinsed","2 tbsp store-bought basil pesto","2 tbsp pumpkin seeds","1 tsp lemon juice","Salt and pepper","Fresh basil to garnish","Toast or crackers to serve"],"instructions":["Drain and rinse cannellini beans. Mash with a fork to your preferred texture — smooth or chunky.","Stir in pesto and lemon juice. Season with salt and pepper.","Spoon onto a plate. Top with pumpkin seeds and fresh basil.","Serve on toast or crackers."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-white-bean-pesto-mash.png","youtubeUrl":"https://www.youtube.com/results?search_query=White%20Bean%20Pesto%20Mash%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.945Z"},{"id":324,"title":"Chia Seed Protein Pudding","description":"Chia seeds soaked overnight in creamy soy milk with a scoop of plant-based protein powder — a set-and-forget breakfast that is thick, filling and nutritious.","ingredients":["4 tbsp chia seeds","1½ cups unsweetened soy milk","1 scoop plant-based vanilla protein powder","1 tsp maple syrup","½ tsp vanilla extract","Fresh berries and granola to top"],"instructions":["Whisk together soy milk, protein powder, maple syrup and vanilla extract in a jar.","Add chia seeds and stir well. Wait 5 minutes and stir again to prevent clumping.","Cover and refrigerate overnight (or at least 4 hours).","Top with fresh berries and granola just before serving."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-chia-seed-protein-pudding.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chia%20Protein%20Pudding%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.948Z"},{"id":325,"title":"Pumpkin Seed Trail Mix","description":"A satisfying handful of dry-roasted soy nuts, pumpkin seeds and almonds — a portable, protein-dense snack delivering 15–20g protein per cup.","ingredients":["½ cup roasted soy nuts","½ cup pumpkin seeds (pepitas)","½ cup almonds","¼ cup dried cranberries or raisins","1 tsp smoked paprika (optional)","Pinch of sea salt"],"instructions":["Combine soy nuts, pumpkin seeds, almonds and dried cranberries in a bowl.","Season with smoked paprika and sea salt if desired. Toss to mix.","Portion into snack bags or a jar.","Keeps for up to 2 weeks in an airtight container."],"prepTime":3,"cookTime":0,"servings":4,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-pumpkin-seed-trail-mix.png","youtubeUrl":"https://www.youtube.com/results?search_query=Pumpkin%20Seed%20Trail%20Mix%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.952Z"},{"id":326,"title":"Overnight Oats with Soy","description":"Rolled oats soaked overnight in high-protein soy milk with almond butter and chia seeds — wake up to a creamy, ready-to-eat breakfast packed with protein and fibre.","ingredients":["½ cup rolled oats","¾ cup unsweetened soy milk","1 tbsp almond butter","1 tbsp chia seeds","1 tsp maple syrup or honey","½ tsp vanilla extract","Fresh fruit and nuts to top"],"instructions":["Combine oats, soy milk, almond butter, chia seeds, sweetener and vanilla in a jar.","Stir well to incorporate the almond butter.","Cover and refrigerate overnight or for at least 6 hours.","In the morning, stir and add a splash of soy milk if too thick.","Top with fresh fruit and nuts and serve cold."],"prepTime":5,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-overnight-oats-with-soy.png","youtubeUrl":"https://www.youtube.com/results?search_query=Overnight%20Oats%20Soy%20Milk%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.955Z"},{"id":327,"title":"Chocolate Banana Protein Shake","description":"A thick, indulgent protein shake blending chocolate protein powder, creamy soy milk and peanut butter with a ripe banana — tastes like dessert but fuels like a meal.","ingredients":["1 scoop chocolate whey or plant protein powder","1 cup soy milk","1 ripe banana","1 tbsp peanut butter","4 ice cubes","½ tsp cocoa powder (optional, for extra depth)"],"instructions":["Add all ingredients to a blender.","Blend on high for 45 seconds until completely smooth and creamy.","Pour into a glass and serve immediately.","Add more ice for a thicker, colder shake."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-chocolate-banana-protein-shake.png","youtubeUrl":"https://www.youtube.com/results?search_query=Chocolate%20Banana%20Protein%20Shake%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.958Z"},{"id":328,"title":"Berry Green Smoothie","description":"Spinach, Greek yogurt, fresh blueberries and hemp seeds blended into a vibrant, protein-rich smoothie — you won't taste the greens but you'll feel the benefits.","ingredients":["1 cup fresh spinach","¾ cup Greek yogurt","½ cup blueberries (fresh or frozen)","3 tbsp hemp seeds","½ cup water or milk","1 tsp honey","3 ice cubes"],"instructions":["Add spinach, Greek yogurt, blueberries, hemp seeds, water, honey and ice to a blender.","Blend on high for 60 seconds until completely smooth.","Pour into a glass and serve immediately.","Add more liquid for a thinner consistency."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-berry-green-smoothie.png","youtubeUrl":"https://www.youtube.com/results?search_query=Berry%20Green%20Smoothie%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.961Z"},{"id":329,"title":"Coffee Protein Frappe","description":"Cold brew coffee blended with soy milk and vanilla protein powder over ice — the ultimate protein-packed alternative to a coffee shop frappe.","ingredients":["1 cup cold brew coffee","¾ cup soy milk","1 scoop vanilla protein powder","1 cup ice","1 tsp maple syrup (optional)","Whipped cream to top (optional)"],"instructions":["Add cold brew, soy milk, protein powder, maple syrup and ice to a blender.","Blend on high for 30 seconds until frothy and smooth.","Pour into a tall glass. Top with whipped cream if desired.","Serve immediately."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-coffee-protein-frappe.png","youtubeUrl":"https://www.youtube.com/results?search_query=Coffee%20Protein%20Frappe%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.964Z"},{"id":330,"title":"Savory Oat Bran","description":"Cold-soaked oat bran stirred with creamy cottage cheese and cracked black pepper — a surprisingly savoury, extremely high-protein breakfast that requires zero heat.","ingredients":["½ cup oat bran","½ cup cold water or milk","½ cup cottage cheese","¼ tsp black pepper","Pinch of sea salt","1 tbsp chives or spring onion, sliced","Optional: a drizzle of olive oil"],"instructions":["Combine oat bran and cold water or milk in a bowl. Stir and soak 5 minutes.","The oat bran will absorb the liquid and soften without cooking.","Stir in cottage cheese, pepper and salt.","Top with chives and a drizzle of olive oil if desired. Serve immediately."],"prepTime":8,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-savory-oat-bran.png","youtubeUrl":"https://www.youtube.com/results?search_query=Savory%20Oat%20Bran%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.968Z"},{"id":331,"title":"Quinoa Salad (Pre-cooked)","description":"Ready-to-eat vacuum-sealed quinoa tossed with tomatoes, cucumber, lemon and herbs — a complete protein salad that takes under 5 minutes to assemble.","ingredients":["1 pack pre-cooked vacuum-sealed quinoa (250g)","1 tomato, diced","½ cucumber, diced","¼ red onion, finely sliced","2 tbsp olive oil","Juice of 1 lemon","1 tsp dried mint or fresh herbs","Salt and pepper","Feta cheese (optional)"],"instructions":["Empty pre-cooked quinoa into a bowl. Fluff gently with a fork.","Add tomato, cucumber and red onion.","Drizzle with olive oil and lemon juice. Season with herbs, salt and pepper.","Toss well. Crumble feta on top if using.","Serve immediately or refrigerate for later."],"prepTime":5,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-quinoa-salad-pre-cooked.png","youtubeUrl":"https://www.youtube.com/results?search_query=Quinoa%20Salad%20No%20Cook%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.971Z"},{"id":332,"title":"Seitan Deli Sandwich","description":"Pre-packaged seitan slices layered on high-protein bread with mustard, crisp lettuce and pickles — a no-cook, meaty-textured vegetarian deli sandwich.","ingredients":["4 slices pre-packaged seitan","2 slices high-protein or sprouted grain bread","1 tbsp Dijon or whole grain mustard","2 leaves romaine lettuce","2 slices tomato","4 pickle slices","Salt and pepper"],"instructions":["Lay bread slices out. Spread mustard on both slices.","Layer lettuce leaves on one slice.","Add seitan slices, tomato and pickles.","Season with salt and pepper. Close the sandwich.","Slice in half and serve."],"prepTime":5,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-seitan-deli-sandwich.png","youtubeUrl":"https://www.youtube.com/results?search_query=Seitan%20Sandwich%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.975Z"},{"id":333,"title":"Tempeh Strips & Guacamole","description":"Pre-steamed ready-to-eat tempeh strips dipped in spicy avocado guacamole — a protein and healthy-fat combo that makes for a seriously satisfying snack.","ingredients":["150g pre-steamed tempeh, sliced into strips","For guacamole: 2 ripe avocados","1 lime, juiced","1 green chilli, minced","1 small tomato, diced","¼ red onion, finely chopped","Salt","Fresh coriander"],"instructions":["Mash avocados with lime juice and salt until creamy.","Fold in green chilli, tomato, red onion and coriander.","Arrange tempeh strips on a serving plate.","Serve with the spicy guacamole for dipping."],"prepTime":8,"cookTime":0,"servings":2,"cuisineType":"High-Protein","dietaryTags":["Vegan","Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-tempeh-strips-guacamole.png","youtubeUrl":"https://www.youtube.com/results?search_query=Tempeh%20Guacamole%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.978Z"},{"id":334,"title":"Nutty Protein Balls","description":"No-bake energy balls made with raw oats, peanut butter, honey and protein powder — rolled into bites and refrigerated, they're the ultimate high-protein snack to make ahead.","ingredients":["1 cup rolled oats","½ cup natural peanut butter","3 tbsp honey or maple syrup","1 scoop protein powder (vanilla or chocolate)","2 tbsp chia seeds","2 tbsp dark chocolate chips (optional)","Pinch of salt"],"instructions":["Mix oats, peanut butter, honey, protein powder, chia seeds and salt in a bowl until a dough forms.","If too dry, add a teaspoon of water. If too wet, add more oats.","Roll heaped tablespoons of the mixture into balls.","Place on a lined tray and refrigerate for at least 30 minutes to firm up.","Store in an airtight container in the fridge for up to 1 week."],"prepTime":10,"cookTime":0,"servings":12,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-nutty-protein-balls.png","youtubeUrl":"https://www.youtube.com/results?search_query=Nutty%20Protein%20Balls%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.981Z"},{"id":335,"title":"Almond Butter & Hemp Toast","description":"Sprouted grain bread spread thick with almond butter and showered in hemp hearts — a simple, crunchy, high-protein toast requiring absolutely no cooking.","ingredients":["2 slices sprouted grain bread","2 tbsp almond butter","2 tbsp hemp hearts","½ banana, sliced (optional)","Drizzle of honey","Pinch of cinnamon"],"instructions":["Spread almond butter thickly over both slices of bread.","Sprinkle hemp hearts generously over the almond butter.","Add banana slices if using.","Drizzle with honey and a pinch of cinnamon.","Serve immediately."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Vegan","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-almond-butter-hemp-toast.png","youtubeUrl":"https://www.youtube.com/results?search_query=Almond%20Butter%20Hemp%20Toast%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.984Z"},{"id":336,"title":"Skyr Fruit Bowl","description":"Thick, tangy Icelandic Skyr — even higher in protein than Greek yogurt — layered with flaxseeds and fresh berries for a beautiful, nutrient-dense breakfast bowl.","ingredients":["200g Skyr (Icelandic yogurt)","1 tbsp ground flaxseeds","½ cup mixed berries (strawberries, blueberries, raspberries)","1 tbsp granola","1 tsp honey","A few fresh mint leaves"],"instructions":["Spoon Skyr into a bowl.","Stir in ground flaxseeds.","Arrange mixed berries on top.","Scatter granola and drizzle with honey.","Garnish with fresh mint and serve immediately."],"prepTime":3,"cookTime":0,"servings":1,"cuisineType":"High-Protein","dietaryTags":["Gluten-Free","No-Cook"],"category":"no-cook","imageUrl":"/stock-images/recipe-skyr-fruit-bowl.png","youtubeUrl":"https://www.youtube.com/results?search_query=Skyr%20Fruit%20Bowl%20recipe%20indian%20vegetarian","authorId":null,"submittedBy":null,"submittedByName":null,"submittedByImage":null,"isUserSubmitted":false,"challengeId":null,"createdAt":"2026-03-18T10:32:43.986Z"}]
